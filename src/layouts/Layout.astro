---
interface Props {
  title?: string;
  description?: string;
}
const {
  title = "All Masonry Services Inc — Chicago's Trusted Masonry Experts",
  description = "All Masonry Services Inc has been serving Chicagoland since 2008. Expert brick, stone, chimney repair, tuckpointing and more. Free inspection.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <title>{title}</title>

    <!-- WebMCP / Agentic Browsing — AI agent discoverability -->
    <link rel="mcp-manifest" href="/.well-known/mcp.json" />
    <meta name="mcp:name" content="All Masonry Services Inc" />
    <meta name="mcp:description" content="Expert masonry contractor in Chicagoland — brick, stone, chimney, tuckpointing. Free estimates. Licensed & insured." />
    <meta name="mcp:action:estimate" content="/contact#form" />
    <meta name="mcp:action:call" content="tel:+17736562107" />
    <!-- AI agent hints (Claude, ChatGPT, Gemini, Perplexity) -->
    <meta name="ai:service" content="masonry contractor" />
    <meta name="ai:location" content="Chicagoland, Illinois" />
    <meta name="ai:phone" content="+17736562107" />
    <meta name="ai:free-estimate" content="true" />

    <!-- Sequence frame-001 preload (LCP) -->
    <link rel="preload" as="image" href="/images/sequence-desktop-webp/frame-001.webp" media="(min-width: 768px)" fetchpriority="high" />
    <link rel="preload" as="image" href="/images/sequence-mobile-webp/frame-001.webp" media="(max-width: 767px)" fetchpriority="high" />

    <!-- Google Fonts: Onest (headings) + Inter (body) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Onest:wght@400;500;600;700;800&family=Inter:wght@300;400;500;600;700&display=swap" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Onest:wght@400;500;600;700;800&family=Inter:wght@300;400;500;600;700&display=swap" media="print" onload="this.media='all'" />
    <noscript>
      <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Onest:wght@400;500;600;700;800&family=Inter:wght@300;400;500;600;700&display=swap" />
    </noscript>
  </head>
  <body>
    <slot />

    <!-- GSAP + ScrollTrigger (bundled via Vite to eliminate double-loading) -->
    <script>
      import gsap from 'gsap';
      import { ScrollTrigger } from 'gsap/ScrollTrigger';

      gsap.registerPlugin(ScrollTrigger);
      gsap.defaults({ duration: 0.8, ease: 'power2.out' });
      ScrollTrigger.config({ ignoreMobileResize: true });

      // @ts-ignore
      window.__gsap = gsap;
      // @ts-ignore
      window.__ScrollTrigger = ScrollTrigger;

      requestAnimationFrame(function() {
        window.dispatchEvent(new CustomEvent('animations:ready'));
      });
    </script>

    <!-- Scroll reveal: IntersectionObserver for [data-reveal] elements -->
    <script is:inline>
    (function () {
      var io = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            entry.target.classList.add('revealed');
          } else {
            entry.target.classList.remove('revealed');
          }
        });
      }, { threshold: 0.12 });
      function attachObservers() {
        document.querySelectorAll('[data-reveal]').forEach(function (el) { io.observe(el); });
      }
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', attachObservers);
      } else {
        attachObservers();
      }
    })();
    </script>

    <!-- Service Worker: caches sequence frames in background -->
    <script is:inline>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', function() {
          navigator.serviceWorker.register('/sw.js');
        });
      }
    </script>

    <!-- Mobile Floating CTA -->
    <div class="mob-float-wrap" id="mob-float-wrap">
      <a href="/contact#form" class="mob-float-cta" aria-label="Get a Free Quote">
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/>
        </svg>
        Get Free Quote
      </a>
      <button class="mob-float-close" id="mob-float-close" aria-label="Close">
        <svg width="11" height="11" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" aria-hidden="true">
          <path d="M2 2l10 10M12 2L2 12"/>
        </svg>
      </button>
    </div>
    <button class="mob-float-tab" id="mob-float-tab" aria-label="Reopen">
      <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M15 18l-6-6 6-6"/>
      </svg>
    </button>

    <!-- Mobile Float CTA: close / reopen toggle -->
    <script is:inline>
    (function() {
      var wrap = document.getElementById('mob-float-wrap');
      var closeBtn = document.getElementById('mob-float-close');
      var tab = document.getElementById('mob-float-tab');
      if (!wrap || !closeBtn || !tab) return;
      closeBtn.addEventListener('click', function(e) {
        e.preventDefault();
        wrap.classList.add('is-hidden');
        tab.classList.add('is-visible');
      });
      tab.addEventListener('click', function() {
        wrap.classList.remove('is-hidden');
        tab.classList.remove('is-visible');
      });
    })();
    </script>

    <!-- Hash scroll: ensure #anchor navigation works after page load -->
    <script is:inline>
    window.addEventListener('load', function() {
      if (!window.location.hash) return;
      var target = document.querySelector(window.location.hash);
      if (!target) return;
      setTimeout(function() {
        target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }, 120);
    });
    </script>
  </body>
</html>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html {
    scroll-behavior: smooth;
    overflow-x: hidden;
    overscroll-behavior-x: none;
  }
  body {
    font-family: 'Inter', sans-serif;
    background: #ffffff;
    color: #4A433B;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    width: 100%;
    overflow-x: clip;
    overscroll-behavior-x: none;
  }
  h1, h2, h3, h4, h5, h6 {
    font-family: 'Onest', sans-serif;
    color: #16120F;
    line-height: 1.1;
  }
  a { color: inherit; }
  img, svg { display: block; }

  /* ── Mobile Floating CTA ── */
  .mob-float-wrap,
  .mob-float-tab {
    display: none;
  }
  @media (max-width: 768px) {
    .mob-float-wrap {
      display: flex;
      align-items: center;
      position: fixed;
      bottom: 24px;
      right: 16px;
      background: #B85C38;
      border-radius: 50px;
      box-shadow: 0 4px 20px rgba(184,92,56,0.5);
      z-index: 900;
      transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
      overflow: hidden;
    }
    .mob-float-wrap.is-hidden {
      transform: translateX(calc(100% + 20px));
    }
    .mob-float-cta {
      display: flex;
      align-items: center;
      gap: 8px;
      color: #ffffff;
      font-family: 'Onest', sans-serif;
      font-weight: 700;
      font-size: 14px;
      letter-spacing: 0.01em;
      text-decoration: none;
      padding: 14px 12px 14px 20px;
    }
    .mob-float-cta:active { opacity: 0.85; }
    .mob-float-close {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 40px;
      height: 100%;
      min-height: 48px;
      padding: 0 10px 0 4px;
      background: none;
      border: none;
      border-left: 1px solid rgba(255,255,255,0.22);
      color: rgba(255,255,255,0.85);
      cursor: pointer;
      margin-left: 2px;
    }
    .mob-float-close:active { opacity: 0.7; }
    .mob-float-tab {
      display: none;
      align-items: center;
      justify-content: center;
      position: fixed;
      bottom: 24px;
      right: 0;
      width: 28px;
      height: 48px;
      background: #B85C38;
      border-radius: 10px 0 0 10px;
      box-shadow: -2px 4px 14px rgba(184,92,56,0.45);
      border: none;
      color: #ffffff;
      cursor: pointer;
      z-index: 900;
      transition: opacity 0.2s;
    }
    .mob-float-tab.is-visible {
      display: flex;
    }
    .mob-float-tab:active { opacity: 0.8; }
  }

  /* ── Scroll reveal ── */
  [data-reveal] {
    opacity: 0;
    transform: translateY(42px);
    transition: opacity 0.85s cubic-bezier(0.22, 1, 0.36, 1),
                transform 0.85s cubic-bezier(0.22, 1, 0.36, 1);
    transition-delay: var(--rd, 0ms);
    will-change: opacity, transform;
  }
  [data-reveal].revealed {
    opacity: 1;
    transform: none;
  }
</style>
