<script is:inline>
(function () {
  function initNav() {
    var hamburger = document.getElementById('nav-hamburger');
    if (!hamburger || hamburger.dataset.init) return;
    hamburger.dataset.init = '1';
    var mobileMenu    = document.getElementById('mobile-menu');
    var mobileOverlay = document.getElementById('mobile-overlay');
    var mobileClose   = document.getElementById('mobile-close');
    var servicesBtn   = document.getElementById('services-btn');
    var servicesDrop  = document.getElementById('services-dropdown');
    var servicesItem  = document.getElementById('services-item');
    var mobileServBtn = document.getElementById('mobile-services-btn');
    var mobileAcc     = document.getElementById('mobile-accordion');
    var dropTimer;

    function openDrop()  { clearTimeout(dropTimer); servicesDrop.classList.add('open'); servicesBtn.setAttribute('aria-expanded','true'); }
    function closeDrop() { dropTimer = setTimeout(function(){ servicesDrop.classList.remove('open'); servicesBtn.setAttribute('aria-expanded','false'); }, 150); }
    servicesItem.addEventListener('mouseenter', openDrop);
    servicesItem.addEventListener('mouseleave', closeDrop);
    servicesBtn.addEventListener('click', function(){ servicesDrop.classList.contains('open') ? closeDrop() : openDrop(); });
    document.addEventListener('click', function(e){ if(!servicesItem.contains(e.target)){ servicesDrop.classList.remove('open'); servicesBtn.setAttribute('aria-expanded','false'); }});
    document.addEventListener('keydown', function(e){ if(e.key==='Escape'){ servicesDrop.classList.remove('open'); closeMobile(); }});

    function openMobile()  { mobileMenu.classList.add('open'); mobileOverlay.classList.add('open'); mobileMenu.setAttribute('aria-hidden','false'); hamburger.setAttribute('aria-expanded','true'); hamburger.classList.add('active'); document.body.style.overflow='hidden'; }
    function closeMobile() { mobileMenu.classList.remove('open'); mobileOverlay.classList.remove('open'); mobileMenu.setAttribute('aria-hidden','true'); hamburger.setAttribute('aria-expanded','false'); hamburger.classList.remove('active'); document.body.style.overflow=''; }
    hamburger.addEventListener('click', function(){ mobileMenu.classList.contains('open') ? closeMobile() : openMobile(); });
    if (mobileClose) mobileClose.addEventListener('click', closeMobile);
    if (mobileOverlay) mobileOverlay.addEventListener('click', closeMobile);
    if (mobileServBtn && mobileAcc) {
      mobileServBtn.addEventListener('click', function(){ var open = mobileAcc.classList.toggle('open'); mobileServBtn.setAttribute('aria-expanded', String(open)); });
    }
  }
  initNav();
  document.addEventListener('astro:page-load', initNav);

  // Scroll-aware navbar
  function initScroll() {
    var wrap = document.getElementById('navbar-wrap');
    if (!wrap) return;
    var heroSection = document.querySelector('.hero-section');
    function onScroll() {
      var threshold = heroSection ? heroSection.offsetHeight - 100 : 80;
      if (window.scrollY > threshold) {
        wrap.classList.add('scrolled');
        wrap.classList.remove('hero-navbar-wrap');
      } else {
        wrap.classList.remove('scrolled');
        wrap.classList.add('hero-navbar-wrap');
      }
    }
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }
  initScroll();
  document.addEventListener('astro:page-load', initScroll);
})();
</script>

<style is:global>

/* ═══════════════════════════════════════════════════
   HERO WRAPPER
   Dark ink background — padding creates the gap around
   the rounded hero card, exactly like Roofline
════════════════════════════════════════════════════ */
.hero-wrapper {
  background-color: #ffffff;
  padding: 0 12px 0 12px;
  margin-top: -72px;
  box-sizing: border-box;
}

/* ═══════════════════════════════════════════════════
   HERO SECTION — rounded card with gradient
════════════════════════════════════════════════════ */
.hero-section {
  position: relative;
  min-height: 100vh;
  border-radius: 24px 24px 32px 32px;
  overflow: visible;
  background-image: linear-gradient(150deg,
    #16120F 0%,
    #6E2A19 35%,
    #B85C38 75%,
    #B85C38 100%
  );
  /* Subtle grid texture */
  background-size: cover;
  padding-bottom: 60px;
}

/* Grid texture overlay */
.hero-section::before {
  content: "";
  position: absolute;
  inset: 0;
  border-radius: inherit;
  background-image:
    linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
  background-size: 40px 20px;
  pointer-events: none;
  z-index: 0;
}

/* ═══════════════════════════════════════════════════
   NAVBAR WRAP — centers the white pill at top of hero
════════════════════════════════════════════════════ */
.navbar-wrap {
  display: flex;
  justify-content: center;
  position: sticky;
  top: 0;
  z-index: 200;
  background: transparent;
  pointer-events: none;
}
.navbar-wrap .navbar {
  pointer-events: auto;
}
/* Hero section এ navbar-wrap background transparent হবে যাতে gradient দেখায় */
.hero-navbar-wrap {
  background: transparent !important;
}

/* ═══════════════════════════════════════════════════
   NAVBAR — white pill, normal flow (not absolute)
   border-radius: 0 0 32px 32px
   Inverted curves sit on hero gradient bg
════════════════════════════════════════════════════ */
.navbar {
  background-color: #ffffff;
  border-bottom-left-radius: 20px;
  border-bottom-right-radius: 20px;
  width: 88%;
  max-width: 1200px;
  display: flex;
  align-items: center;
  padding: 14px 32px;
  height: 72px;
  position: relative;
}

/* ─── Inverted curve LEFT ─── */
.navbar::before {
  content: "";
  position: absolute;
  left: -24px;
  top: 0;
  width: 24px;
  height: 24px;
  background-color: #ffffff;
  -webkit-mask-image: radial-gradient(circle at 0% 100%, transparent 24px, #ffffff 25px);
  mask-image: radial-gradient(circle at 0% 100%, transparent 24px, #ffffff 25px);
  pointer-events: none;
}

/* ─── Inverted curve RIGHT ─── */
.navbar::after {
  content: "";
  position: absolute;
  right: -24px;
  top: 0;
  width: 24px;
  height: 24px;
  background-color: #ffffff;
  -webkit-mask-image: radial-gradient(circle at 100% 100%, transparent 24px, #ffffff 25px);
  mask-image: radial-gradient(circle at 100% 100%, transparent 24px, #ffffff 25px);
  pointer-events: none;
}

/* Scrolled state */
.navbar-wrap.scrolled .navbar {
  box-shadow: 0 4px 24px rgba(0,0,0,0.10);
}

/* Logo */
.nav-logo { display: flex; align-items: center; text-decoration: none; flex-shrink: 0; margin-right: 32px; }
.logo-name { font-family: 'Onest', sans-serif; font-weight: 700; font-size: 17px; color: #16120F; letter-spacing: -0.01em; }
.logo-tm { font-size: 9px; font-weight: 500; vertical-align: super; margin-left: 1px; color: #6A625A; }

/* Nav Links */
.nav-links { display: flex; align-items: center; gap: 2px; list-style: none; margin: 0; padding: 0; flex: 1; }
.nav-link {
  font-family: 'Inter', sans-serif; font-weight: 500; font-size: 14px; color: #4A433B;
  text-decoration: none; padding: 8px 13px; display: flex; align-items: center; gap: 5px;
  position: relative; transition: color 200ms ease; background: none; border: none;
  cursor: pointer; white-space: nowrap; border-radius: 10px;
}
.nav-link:hover { color: #B85C38; }
.nav-link[aria-current="page"] { color: #B85C38; font-weight: 600; }
.nav-link[aria-current="page"]::after {
  content: ''; position: absolute; bottom: 2px; left: 13px; right: 13px;
  height: 2px; background: #B85C38; border-radius: 2px;
}
.dropdown-chevron { transition: transform 250ms ease; flex-shrink: 0; }
.nav-link-dropdown[aria-expanded="true"] .dropdown-chevron { transform: rotate(180deg); }

/* Right CTA */
.nav-right { display: flex; align-items: center; margin-left: auto; flex-shrink: 0; }
.nav-cta {
  display: inline-flex; align-items: center; height: 42px; padding: 0 20px;
  background: #16120F; color: #FFFFFF; font-family: 'Inter', sans-serif;
  font-weight: 600; font-size: 14px; text-decoration: none; border-radius: 14px;
  transition: background 200ms ease; white-space: nowrap;
}
.nav-cta:hover { background: #B85C38; }

/* Hamburger */
.nav-hamburger {
  display: none; flex-direction: column; gap: 5px; padding: 10px;
  background: none; border: 1.5px solid rgba(74,67,59,0.2); border-radius: 10px;
  cursor: pointer; margin-left: auto; min-width: 44px; min-height: 44px;
  align-items: center; justify-content: center;
}
.ham-line { display: block; width: 20px; height: 2px; background: #16120F; transition: transform 250ms ease, opacity 250ms ease; border-radius: 2px; }
.nav-hamburger.active .ham-line:nth-child(1) { transform: translateY(7px) rotate(45deg); }
.nav-hamburger.active .ham-line:nth-child(2) { opacity: 0; }
.nav-hamburger.active .ham-line:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

/* Dropdown */
.nav-item-dropdown { position: relative; }
.nav-dropdown {
  position: absolute; top: calc(100% + 8px); left: -16px; min-width: 620px;
  background: #FFFFFF; border: 1px solid rgba(0,0,0,0.08); border-radius: 20px;
  box-shadow: 0 8px 40px rgba(0,0,0,0.12); opacity: 0; visibility: hidden;
  transform: translateY(-8px); transition: opacity 200ms ease, transform 200ms ease, visibility 200ms ease;
  pointer-events: none; overflow: hidden; z-index: 200;
}
.nav-dropdown.open { opacity: 1; visibility: visible; transform: translateY(0); pointer-events: auto; }
.dropdown-inner { display: grid; grid-template-columns: 1fr 1fr 160px; }
.dropdown-col { padding: 18px; border-right: 1px solid rgba(0,0,0,0.06); }
.dropdown-col:last-child { border-right: none; }
.dropdown-col ul { list-style: none; margin: 0; padding: 0; }
.dropdown-col-header { font-family: 'Inter', sans-serif; font-size: 10px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: #B85C38; margin-bottom: 8px; padding-bottom: 6px; border-bottom: 1px solid rgba(184,92,56,0.15); }
.dropdown-link { display: block; font-family: 'Inter', sans-serif; font-size: 13px; color: #4A433B; text-decoration: none; padding: 5px 8px; border-radius: 8px; transition: color 150ms ease, background 150ms ease; }
.dropdown-link:hover { color: #B85C38; background: rgba(184,92,56,0.06); }
.dropdown-col-trust { background: #F5F1E8; display: flex; flex-direction: column; gap: 10px; justify-content: center; }
.trust-stat { display: flex; flex-direction: column; }
.trust-num { font-family: 'Onest', sans-serif; font-size: 24px; font-weight: 700; color: #B85C38; line-height: 1; }
.trust-label { font-family: 'Inter', sans-serif; font-size: 10px; font-weight: 500; letter-spacing: 0.06em; text-transform: uppercase; color: #6A625A; }
.trust-badges { display: flex; flex-direction: column; gap: 3px; }
.trust-badge { font-family: 'Inter', sans-serif; font-size: 11px; font-weight: 500; color: #4A433B; }
.dropdown-cta { display: block; background: #B85C38; color: #FFFFFF; font-family: 'Inter', sans-serif; font-size: 12px; font-weight: 600; text-decoration: none; padding: 10px 14px; text-align: center; border-radius: 12px; transition: background 200ms ease; }
.dropdown-cta:hover { background: #8A3A22; }

/* ═══════════════════════════════════════════════════
   HERO CONTENT
════════════════════════════════════════════════════ */
.hero-content {
  position: relative;
  z-index: 1;
  max-width: 1100px;
  margin: 0 auto;
  padding: 60px 40px 60px;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 60px;
  align-items: center;
}

.hero-left { display: flex; flex-direction: column; gap: 0; }

.hero-title {
  font-family: 'Onest', sans-serif;
  font-size: clamp(44px, 5.5vw, 76px);
  font-weight: 700;
  line-height: 1.05;
  color: #FFFFFF;
  margin: 0 0 20px;
  letter-spacing: -0.02em;
}
.hero-subtitle {
  font-family: 'Inter', sans-serif;
  font-size: 17px; font-weight: 400; line-height: 1.65;
  color: rgba(255,255,255,0.80); margin: 0 0 32px; max-width: 400px;
}
.hero-cta {
  display: inline-flex; align-items: center; height: 52px; padding: 0 28px;
  background: #000000; color: #FFFFFF; font-family: 'Inter', sans-serif;
  font-weight: 600; font-size: 16px; text-decoration: none; border-radius: 14px;
  transition: background 200ms ease; align-self: flex-start; margin-bottom: 44px;
}
.hero-cta:hover { background: #B85C38; }

.hero-card {
  background-color: rgba(255,255,255,0.10);
  border: 1px solid rgba(255,255,255,0.12);
  border-radius: 20px; padding: 20px;
  display: flex; flex-direction: column; gap: 16px; max-width: 270px;
  backdrop-filter: blur(8px);
}
.hero-card-text { font-family: 'Inter', sans-serif; font-size: 14px; font-weight: 600; color: #FFFFFF; line-height: 1.5; margin: 0; }
.hero-phone { display: flex; align-items: center; gap: 12px; text-decoration: none; color: #FFFFFF; font-family: 'Inter', sans-serif; font-size: 17px; font-weight: 600; transition: color 200ms ease; }
.hero-phone:hover { color: #D98E5F; }
.hero-phone-icon { width: 38px; height: 38px; background: rgba(255,255,255,0.15); border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }

.hero-right { display: flex; justify-content: flex-end; }
.hero-img-wrap {
  position: relative; border-radius: 20px; overflow: hidden;
  width: 100%; max-width: 500px; aspect-ratio: 5/4;
  box-shadow: 0 20px 60px rgba(0,0,0,0.40);
  background: rgba(255,255,255,0.08);
