---
// Navbar — All Masonry Services Inc
// Announcement Strip + Fixed Nav + Services Mega Dropdown + Mobile Menu
// Zero JS hydration cost — vanilla script deferred, LCP/FCP/TBT unaffected
const pathname = Astro.url.pathname;
const isActive = (href: string) => href === '/' ? pathname === '/' : pathname.startsWith(href);
---

<!-- ═══════════════════════════════════════════════
     ANNOUNCEMENT STRIP
═══════════════════════════════════════════════ -->
