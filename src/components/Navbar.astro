<!-- ═══════════════════════════════════════════════
     SCRIPT — deferred, no TBT impact
═══════════════════════════════════════════════ -->
<script is:inline>
  function initNavbar() {
    var hamburger = document.getElementById('nav-hamburger');
    if (!hamburger || hamburger.dataset.navInit) return;
    hamburger.dataset.navInit = '1';

    var navbar = document.getElementById('navbar');
    var mobileMenu = document.getElementById('mobile-menu');
    var mobileOverlay = document.getElementById('mobile-overlay');
    var mobileClose = document.getElementById('mobile-close');
    var servicesBtn = document.getElementById('services-btn');
    var servicesDropdown = document.getElementById('services-dropdown');
    var servicesItem = document.getElementById('services-item');
    var mobileServicesBtn = document.getElementById('mobile-services-btn');
    var mobileAccordion = document.getElementById('mobile-services-accordion');
    var announceStrip = document.getElementById('announce-strip');
    var announceCta = document.getElementById('announce-cta-link');

    if (!navbar || !hamburger || !mobileMenu || !servicesBtn || !servicesDropdown || !servicesItem) return;

    var STRIP_HEIGHT = 36;
    var ticking = false;
    var dropdownTimeout;

    // ── Scroll ───────────────────────────────────────
    function updateNavbar() {
      var scrolled = window.scrollY > STRIP_HEIGHT;
      navbar.classList.toggle('scrolled', scrolled);
      navbar.classList.toggle('strip-hidden', scrolled);
      if (announceStrip) announceStrip.classList.toggle('hidden', scrolled);
      if (announceCta) announceCta.setAttribute('tabindex', scrolled ? '-1' : '0');
      ticking = false;
    }

    window.addEventListener('scroll', function() {
      if (!ticking) {
        requestAnimationFrame(updateNavbar);
        ticking = true;
      }
    }, { passive: true });

    updateNavbar();

    // ── Desktop Dropdown ─────────────────────────────
    function openDropdown() {
      clearTimeout(dropdownTimeout);
      servicesDropdown.classList.add('open');
      servicesBtn.setAttribute('aria-expanded', 'true');
    }

    function closeDropdown() {
      dropdownTimeout = setTimeout(function() {
        servicesDropdown.classList.remove('open');
        servicesBtn.setAttribute('aria-expanded', 'false');
      }, 120);
    }

    servicesItem.addEventListener('mouseenter', openDropdown);
    servicesItem.addEventListener('mouseleave', closeDropdown);
    servicesBtn.addEventListener('click', function() {
      servicesDropdown.classList.contains('open') ? closeDropdown() : openDropdown();
    });

    document.addEventListener('click', function(e) {
      if (!servicesItem.contains(e.target)) {
        servicesDropdown.classList.remove('open');
        servicesBtn.setAttribute('aria-expanded', 'false');
      }
    });

    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') {
        servicesDropdown.classList.remove('open');
        servicesBtn.setAttribute('aria-expanded', 'false');
        closeMobileMenu();
      }
    });

    // ── Mobile Menu ───────────────────────────────────
    function openMobileMenu() {
      mobileMenu.style.willChange = 'transform';
      mobileMenu.classList.add('open');
      mobileOverlay.classList.add('open');
      mobileMenu.setAttribute('aria-hidden', 'false');
      hamburger.setAttribute('aria-expanded', 'true');
      hamburger.classList.add('active');
      document.body.style.overflow = 'hidden';
    }

    function closeMobileMenu() {
      mobileMenu.classList.remove('open');
      mobileOverlay.classList.remove('open');
      mobileMenu.setAttribute('aria-hidden', 'true');
      hamburger.setAttribute('aria-expanded', 'false');
      hamburger.classList.remove('active');
      document.body.style.overflow = '';
      mobileMenu.addEventListener('transitionend', function() {
        mobileMenu.style.willChange = 'auto';
      }, { once: true });
    }

    hamburger.addEventListener('click', function(e) {
      e.stopPropagation();
      mobileMenu.classList.contains('open') ? closeMobileMenu() : openMobileMenu();
    });
    if (mobileClose) mobileClose.addEventListener('click', closeMobileMenu);
    if (mobileOverlay) mobileOverlay.addEventListener('click', closeMobileMenu);

    if (mobileServicesBtn && mobileAccordion) {
      mobileServicesBtn.addEventListener('click', function() {
        var isOpen = mobileAccordion.classList.contains('open');
        mobileAccordion.classList.toggle('open', !isOpen);
        mobileServicesBtn.setAttribute('aria-expanded', String(!isOpen));
        mobileServicesBtn.classList.toggle('accordion-open', !isOpen);
      });
    }
  }

  initNavbar();

  // Re-run on every Astro ViewTransition page load (new DOM = new hamburger element = no dataset.navInit)
  document.addEventListener('astro:page-load', initNavbar);
</script>

<style>
/* ══════════════════════════════════════════
   ANNOUNCEMENT STRIP
══════════════════════════════════════════ */
.announce-strip {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 36px;
  background: #B85C38;
  z-index: 101;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 300ms ease;
}
.announce-strip.hidden {
  transform: translateY(-100%);
}
.announce-inner {
  display: flex;
  align-items: center;
  gap: 10px;
  max-width: 1280px;
  width: 100%;
  padding: 0 16px;
  justify-content: center;
}
.announce-icon {
  font-size: 11px;
  color: rgba(255,255,255,0.85);
  flex-shrink: 0;
}
.announce-text {
  font-family: 'Inter', sans-serif;
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.04em;
  color: #ffffff;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.announce-text--mobile { display: none; }
.announce-sep {
  opacity: 0.5;
  margin: 0 4px;
}
.announce-cta {
  display: none;
  font-family: 'Inter', sans-serif;
  font-size: 11px;
  font-weight: 600;
  color: #ffffff;
  text-decoration: none;
  border: 1.5px solid rgba(255,255,255,0.6);
  border-radius: 8px;
  padding: 3px 12px;
  flex-shrink: 0;
  transition: background 150ms ease;
}
.announce-cta:hover { background: rgba(255,255,255,0.15); }
.announce-cta:focus-visible { outline: 2px solid rgba(255,255,255,0.6); outline-offset: 2px; }
@media (min-width: 640px) {
  .announce-cta { display: block; }
}

/* ══════════════════════════════════════════
   NAVBAR BASE
══════════════════════════════════════════ */
.navbar {
  position: fixed;
  top: 36px; /* below announce strip */
  left: 0;
  width: 100%;
  height: 72px;
  z-index: 100;
  background: #16120F;
  box-shadow: 0 2px 16px rgba(0,0,0,0.4);
  border-bottom: 1px solid rgba(184,92,56,0.2);
  transition: transform 300ms ease, box-shadow 300ms ease, border-color 300ms ease;
  transform: translateZ(0);
}
.navbar.strip-hidden {
  transform: translateY(-36px);
}
.navbar.scrolled {
  box-shadow: 0 2px 16px rgba(0,0,0,0.16);
  border-bottom-color: rgba(184,92,56,0.3);
}
.nav-inner {
  max-width: 1280px;
  margin: 0 auto;
  height: 100%;
  padding: 0 80px;
  display: flex;
  align-items: center;
  gap: 0;
}

/* ── Logo ── */
.nav-logo {
  display: flex;
  align-items: center;
  text-decoration: none;
  flex-shrink: 0;
  margin-right: 32px;
}
.nav-logo-img {
  height: 68px;
  width: auto;
  display: block;
  margin-top: 6px;
}


/* ── Nav Links ── */
.nav-links {
  display: flex;
  align-items: center;
  gap: 4px;
  list-style: none;
  margin: 0;
  padding: 0;
  flex: 1;
}
.nav-link {
  font-family: 'Inter', sans-serif;
  font-weight: 600;
  font-size: 12px;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.85);
  text-decoration: none;
  padding: 8px 14px;
  display: flex;
  align-items: center;
  gap: 6px;
  position: relative;
  transition: color 200ms ease;
  background: none;
  border: none;
  cursor: pointer;
  height: 72px;
}
.nav-link::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 16px;
  right: 16px;
  height: 2px;
  background: #B85C38;
  transform: scaleX(0);
  transform-origin: left;
  transition: transform 200ms ease;
}
.nav-link:hover,
.nav-link:focus-visible,
.nav-link[aria-current="page"] {
  color: #B85C38;
  outline: none;
}
.nav-link:hover::after,
.nav-link:focus-visible::after,
.nav-link[aria-current="page"]::after {
  transform: scaleX(1);
}
.dropdown-chevron {
  transition: transform 250ms ease;
  flex-shrink: 0;
}
.nav-link-dropdown[aria-expanded="true"] .dropdown-chevron {
  transform: rotate(180deg);
}

/* ── Right: Phone + CTA ── */
.nav-right {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-left: auto;
  flex-shrink: 0;
}
.nav-phone {
  display: flex;
  align-items: center;
  gap: 7px;
  font-family: 'Inter', sans-serif;
  font-weight: 700;
  font-size: 13px;
  color: #B85C38;
  text-decoration: none;
  letter-spacing: 0.03em;
  transition: color 200ms ease;
  flex-shrink: 0;
}
.nav-phone:hover { color: #FFFFFF; }
.nav-phone:focus-visible {
  outline: 2px solid #B85C38;
  outline-offset: 2px;
}
.nav-cta {
  display: inline-flex;
  align-items: center;
  height: 44px;
  padding: 0 22px;
  background: #B85C38;
  color: #ffffff;
  font-family: 'Inter', sans-serif;
  font-weight: 600;
  font-size: 13px;
  text-decoration: none;
  border-radius: 14px;
  transition: background 200ms ease;
  white-space: nowrap;
  flex-shrink: 0;
}
.nav-cta:hover { background: #8A3A22; }
.nav-cta:active { background: #8A3A22; }
.nav-cta:focus-visible { outline: 2px solid #B85C38; outline-offset: 2px; }

/* ── Hamburger ── */
.nav-hamburger {
  display: none;
  flex-direction: column;
  gap: 5px;
  padding: 11px;
  background: none;
  border: 2px solid rgba(255,255,255,0.2);
  border-radius: 10px;
  cursor: pointer;
  margin-left: auto;
  min-width: 44px;
  min-height: 44px;
  align-items: center;
  justify-content: center;
}
.ham-line {
  display: block;
  width: 22px;
  height: 2px;
  background: #FFFFFF;
  transition: transform 250ms ease, opacity 250ms ease, background 250ms ease;
}
.nav-hamburger.active .ham-line:nth-child(1) {
  transform: translateY(7px) rotate(45deg);
}
.nav-hamburger.active .ham-line:nth-child(2) {
  opacity: 0;
  transform: scaleX(0);
