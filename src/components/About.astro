---
---

<section class="about-section">
  <div class="about-inner">

    <!-- LEFT: Image + Team card overlay -->
    <div class="about-left" data-reveal>
      <div class="about-img-wrap">
        <picture style="display:block;width:100%;height:100%;">
          <source media="(max-width: 768px)" srcset="/images/home-about-m.webp" type="image/webp" />
          <img
            src="/images/home-about.webp"
            alt="All Masonry Services craftsman repairing brick wall"
            class="about-img"
            loading="lazy"
          />
        </picture>

        <!-- Team card overlay -->
        <div class="about-team-card">
          <div class="about-team-top">
            <div class="about-avatars">
              <span class="about-avatar about-avatar--1"></span>
              <span class="about-avatar about-avatar--2"></span>
              <span class="about-avatar about-avatar--3"></span>
              <span class="about-avatar-count">19+</span>
            </div>
            <div class="about-badge">
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
                <path d="M9 1L11.09 6.26L17 7.27L13 11.14L14.18 17L9 14.27L3.82 17L5 11.14L1 7.27L6.91 6.26L9 1Z" fill="#B85C38" stroke="#B85C38" stroke-width="1.2" stroke-linejoin="round"/>
              </svg>
            </div>
          </div>
          <p class="about-team-label">Years serving<br>Chicagoland</p>
        </div>
      </div>
    </div>

    <!-- RIGHT: Text content -->
    <div class="about-right">

      <!-- Eyebrow -->
      <div class="about-eyebrow" data-reveal>
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <rect x="1" y="1" width="5" height="5" rx="1" fill="#B85C38"/>
          <rect x="8" y="1" width="5" height="5" rx="1" fill="#B85C38" opacity="0.4"/>
          <rect x="1" y="8" width="5" height="5" rx="1" fill="#B85C38" opacity="0.4"/>
          <rect x="8" y="8" width="5" height="5" rx="1" fill="#B85C38"/>
        </svg>
        <span>ABOUT OUR COMPANY</span>
      </div>

      <!-- Heading -->
      <h2 class="about-heading" data-reveal style="--rd:80ms">Premium Brick & Stone<br>For Custom Homes</h2>

      <!-- Description -->
      <p class="about-desc" data-reveal style="--rd:160ms">
        Masonry is more than our profession—it's our family tradition. From custom homes and luxury residences to premium brick and stone installations, our experienced in-house crew delivers every project with precision and exceptional craftsmanship.
      </p>

      <!-- Feature list -->
      <ul class="about-features" data-reveal style="--rd:240ms">
        <li class="about-feature">
          <span class="about-feature-icon">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
              <circle cx="9" cy="9" r="8" stroke="#B85C38" stroke-width="1.4"/>
              <path d="M5.5 9L7.5 11L12.5 6.5" stroke="#B85C38" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
          <span>Specialists in Custom Homes &amp; Builders</span>
        </li>
        <li class="about-feature-divider"></li>
        <li class="about-feature">
          <span class="about-feature-icon">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
              <path d="M2 4h14M2 9h14M2 14h9" stroke="#B85C38" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </span>
          <span>Family-Owned Tradition Since 2007</span>
        </li>
        <li class="about-feature-divider"></li>
        <li class="about-feature">
          <span class="about-feature-icon">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
              <path d="M9 1.5L9 4M9 14v2.5M1.5 9H4M14 9h2.5M3.6 3.6l1.8 1.8M12.6 12.6l1.8 1.8M3.6 14.4l1.8-1.8M12.6 5.4l1.8-1.8" stroke="#B85C38" stroke-width="1.4" stroke-linecap="round"/>
              <circle cx="9" cy="9" r="3" stroke="#B85C38" stroke-width="1.4"/>
            </svg>
          </span>
          <span>100% In-House Crew — No Subcontractors</span>
        </li>
      </ul>

      <!-- CTA -->
      <a href="/about" class="about-cta" data-reveal style="--rd:320ms">Learn more about us</a>

    </div>
  </div>
</section>

<style is:global>

.about-section {
  background: #ffffff;
  padding: 100px 24px;
}

.about-inner {
  max-width: 1100px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 80px;
  align-items: center;
}

/* ── LEFT ── */
.about-left { position: relative; }

.about-img-wrap {
  position: relative;
  border-radius: 20px;
  overflow: hidden;
  aspect-ratio: 4/5;
  max-width: 500px;
  background: #E8DDD5;
}

.about-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

/* Team card overlay */
.about-team-card {
  position: absolute;
  bottom: 24px;
  left: 24px;
  background: rgba(22, 18, 15, 0.82);
  backdrop-filter: blur(10px);
  border: 1px solid rgba(255,255,255,0.10);
  border-radius: 16px;
  padding: 16px 20px;
  min-width: 200px;
}

.about-team-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 10px;
}

.about-avatars {
  display: flex;
  align-items: center;
}

.about-avatar {
  width: 34px;
  height: 34px;
  border-radius: 50%;
  border: 2px solid rgba(22,18,15,0.8);
  background: #B85C38;
  display: block;
  margin-right: -10px;
  flex-shrink: 0;
}
.about-avatar--1 { background-image: url('/images/avatar-1.webp'); background-size: cover; background-position: center; z-index: 3; }
.about-avatar--2 { background-image: url('/images/avatar-2.webp'); background-size: cover; background-position: center; z-index: 2; }
.about-avatar--3 { background-image: url('/images/avatar-3.webp'); background-size: cover; background-position: center; z-index: 1; }

.about-avatar-count {
  font-family: 'Onest', sans-serif;
  font-size: 15px;
  font-weight: 700;
  color: #ffffff;
  margin-left: 18px;
}

.about-badge {
  width: 32px;
  height: 32px;
  background: rgba(184,92,56,0.15);
  border: 1px solid rgba(184,92,56,0.30);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.about-team-label {
  font-family: 'Inter', sans-serif;
  font-size: 13px;
  font-weight: 500;
  color: rgba(255,255,255,0.85);
  line-height: 1.4;
  margin: 0;
}

/* ── RIGHT ── */
.about-right {
  display: flex;
  flex-direction: column;
  gap: 0;
}

.about-eyebrow {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 20px;
}
.about-eyebrow span {
  font-family: 'Inter', sans-serif;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.10em;
  color: #B85C38;
  text-transform: uppercase;
}

.about-heading {
  font-family: 'Onest', sans-serif;
  font-size: clamp(40px, 4.5vw, 64px);
  font-weight: 700;
  line-height: 1.05;
  color: #16120F;
  letter-spacing: -0.02em;
  margin: 0 0 24px;
}

.about-desc {
  font-family: 'Inter', sans-serif;
  font-size: 16px;
  font-weight: 400;
  line-height: 1.65;
  color: #4A433B;
  margin: 0 0 36px;
  max-width: 460px;
}

/* Feature list */
.about-features {
  list-style: none;
  margin: 0 0 40px;
  padding: 0;
  display: flex;
  flex-direction: column;
}

.about-feature {
  display: flex;
  align-items: center;
  gap: 14px;
  padding: 14px 0;
  font-family: 'Inter', sans-serif;
  font-size: 15px;
  font-weight: 500;
  color: #16120F;
}

.about-feature-icon {
  width: 36px;
  height: 36px;
  background: rgba(184,92,56,0.08);
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.about-feature-divider {
  height: 1px;
  background: rgba(0,0,0,0.07);
  margin: 0;
}

/* CTA */
.about-cta {
  display: inline-flex;
  align-items: center;
  height: 52px;
  padding: 0 28px;
  background: #16120F;
  color: #ffffff;
  font-family: 'Inter', sans-serif;
  font-weight: 600;
  font-size: 15px;
  text-decoration: none;
  border-radius: 14px;
  align-self: flex-start;
  transition: background 200ms ease;
}
.about-cta:hover { background: #B85C38; }

/* ── RESPONSIVE ── */
@media (max-width: 900px) {
  .about-inner {
    grid-template-columns: 1fr;
    gap: 48px;
  }
  .about-img-wrap { max-width: 100%; aspect-ratio: 3/2; }
  .about-section { padding: 72px 20px; }
}

</style>
