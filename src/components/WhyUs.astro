---
/*
  Custom masonry clip-path shapes — designed for AMS:
  1. BRICK      — fired-brick rectangle with chamfered corners
  2. STONE ARCH — classic Roman gateway arch (bezier)
  3. CHIMNEY    — stepped silhouette, narrow flue + wider base
  4. LIMESTONE  — irregular quarried-stone polygon
  5. FIREPLACE  — fireplace/hearth opening arch (bezier)
*/

const images = [
  {
    clip: 'whu-brick',
    src:  'https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=480&h=600&fit=crop&q=80',
    alt:  'Brick facade restoration',
    label: 'Brick'
  },
  {
    clip: 'whu-arch',
    src:  'https://images.unsplash.com/photo-1600585154340-be6161a56a0c?w=480&h=600&fit=crop&q=80',
    alt:  'Natural limestone exterior',
    label: 'Stone Arch'
  },
  {
    clip: 'whu-chimney',
    src:  'https://images.unsplash.com/photo-1504307651254-35680f356dfd?w=480&h=600&fit=crop&q=80',
    alt:  'Chimney repair and rebuild',
    label: 'Chimney'
  },
  {
    clip: 'whu-limestone',
    src:  'https://images.unsplash.com/photo-1590725140246-20acdee442be?w=480&h=600&fit=crop&q=80',
    alt:  'Tuckpointing and repointing',
    label: 'Limestone'
  },
  {
    clip: 'whu-fireplace',
    src:  'https://images.unsplash.com/photo-1565008447742-97f6f38c985c?w=480&h=600&fit=crop&q=80',
    alt:  'Custom stone retaining wall',
    label: 'Fireplace'
  },
];
---

<section class="whu-section" style="background:#ffffff; padding:100px 40px; position:relative;">

  <!-- ═══════════════════════════════════════════════════════════
       HIDDEN SVG — Masonry-shaped clip-path definitions
       All paths use clipPathUnits="objectBoundingBox" (0–1 space)
  ════════════════════════════════════════════════════════════ -->
  <svg style="position:absolute;top:0;left:0;width:0;height:0;" aria-hidden="true">
    <defs>

      <!--
        BRICK SHAPE
        Standard fired-brick with 8% chamfered/cut corners.
        Recognisable octagon matching a real brick silhouette.
      -->
      <clipPath id="whu-brick" clipPathUnits="objectBoundingBox">
        <path d="
          M0.08,0
          H0.92
          L1,0.08
          V0.92
          L0.92,1
          H0.08
          L0,0.92
          V0.08
          Z
        "/>
      </clipPath>

      <!--
        STONE ARCH (Roman gateway arch)
        Straight walls + semicircular top, like a masonry arch doorway.
        Uses cubic-bezier to approximate the semicircle cleanly.
        Peak touches y=0 at x=0.5 (top-center of element).
      -->
      <clipPath id="whu-arch" clipPathUnits="objectBoundingBox">
        <path d="
          M0.06,1
          L0.06,0.38
          C0.06,0.12  0.26,0     0.5,0
          C0.74,0     0.94,0.12  0.94,0.38
          L0.94,1
          Z
        "/>
      </clipPath>

      <!--
        CHIMNEY SILHOUETTE
        Narrow rectangular flue at top (30%–70% width),
        widens at shoulder (y=0.56) to full chimney base (10%–90%).
        Immediately recognisable as a chimney front-view.
      -->
      <clipPath id="whu-chimney" clipPathUnits="objectBoundingBox">
        <path d="
          M0.30,0
          H0.70
          L0.70,0.56
          L0.90,0.56
          L0.90,1
          L0.10,1
          L0.10,0.56
          L0.30,0.56
          Z
        "/>
      </clipPath>

      <!--
        LIMESTONE SLAB
        Irregular 8-point polygon, each vertex offset slightly —
        mimics the hand-cut edges of a quarried limestone block.
        No two sides are perfectly parallel, like real stone.
      -->
      <clipPath id="whu-limestone" clipPathUnits="objectBoundingBox">
        <path d="
          M0.12,0.03
          L0.84,0
          L1,0.13
          L0.97,0.87
          L0.83,1
          L0.08,0.97
          L0,0.83
          L0.04,0.11
          Z
        "/>
      </clipPath>

      <!--
        FIREPLACE / HEARTH OPENING
        Classic fireplace arch: straight floor, curved interior arch.
        Inner bezier curves inward (concave), like a real hearth opening.
        Outer rectangle is the surround, inner cutout is the opening.
        Implemented as a simple rounded-shoulder arch (positive shape).
      -->
      <clipPath id="whu-fireplace" clipPathUnits="objectBoundingBox">
        <path d="
          M0.06,1
          L0.06,0.45
          C0.06,0.16  0.24,0.06  0.5,0.06
          C0.76,0.06  0.94,0.16  0.94,0.45
          L0.94,1
          Z
        "/>
      </clipPath>

    </defs>
  </svg>

  <div class="whu-outer-grid" style="max-width:1200px; margin:0 auto; display:grid; grid-template-columns:1fr 1fr; gap:72px; align-items:center;">

    <!-- ══ LEFT: Text content ══ -->
    <div>

      <!-- Eyebrow -->
      <div style="display:flex; align-items:center; gap:8px; margin-bottom:20px;" data-reveal>
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <rect x="1" y="1" width="5" height="5" rx="1" fill="#B85C38"/>
          <rect x="8" y="1" width="5" height="5" rx="1" fill="#B85C38" opacity="0.4"/>
          <rect x="1" y="8" width="5" height="5" rx="1" fill="#B85C38" opacity="0.4"/>
          <rect x="8" y="8" width="5" height="5" rx="1" fill="#B85C38"/>
        </svg>
        <span style="font-family:'Inter',sans-serif; font-size:11px; font-weight:700; letter-spacing:0.10em; color:#B85C38; text-transform:uppercase;">Why Choose Us</span>
      </div>

      <!-- Heading -->
      <h2 style="font-family:'Onest',sans-serif; font-size:clamp(38px,4.5vw,58px); font-weight:700; line-height:1.08; color:#16120F; letter-spacing:-0.02em; margin:0 0 22px; --rd:80ms;" data-reveal>
        Built on brick,<br>stone, and trust
      </h2>

      <!-- Description -->
      <p style="font-family:'Inter',sans-serif; font-size:16px; line-height:1.7; color:#4A433B; margin:0 0 36px; max-width:440px; --rd:160ms;" data-reveal>
        19 years of masonry across Chicagoland — from tuckpointing original brick to setting custom limestone. Every project reflects the same standard we've held since 2007.
      </p>

      <!-- Feature list -->
      <div style="display:flex; flex-direction:column; gap:0; margin-bottom:40px; --rd:240ms;" data-reveal>

        <div style="display:flex; align-items:center; gap:14px; padding:14px 0; border-bottom:1px solid rgba(0,0,0,0.07);">
          <div style="width:36px; height:36px; background:rgba(184,92,56,0.08); border-radius:10px; display:flex; align-items:center; justify-content:center; flex-shrink:0;">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
              <circle cx="9" cy="9" r="7.5" stroke="#B85C38" stroke-width="1.4"/>
              <path d="M5.5 9L7.5 11L12.5 6.5" stroke="#B85C38" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <span style="font-family:'Inter',sans-serif; font-size:15px; font-weight:500; color:#16120F;">Licensed &amp; insured in Illinois</span>
        </div>

        <div style="display:flex; align-items:center; gap:14px; padding:14px 0; border-bottom:1px solid rgba(0,0,0,0.07);">
          <div style="width:36px; height:36px; background:rgba(184,92,56,0.08); border-radius:10px; display:flex; align-items:center; justify-content:center; flex-shrink:0;">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
              <path d="M3 5h12M3 9h12M3 13h7" stroke="#B85C38" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </div>
          <span style="font-family:'Inter',sans-serif; font-size:15px; font-weight:500; color:#16120F;">Own crew only — no subcontractors</span>
        </div>

        <div style="display:flex; align-items:center; gap:14px; padding:14px 0;">
          <div style="width:36px; height:36px; background:rgba(184,92,56,0.08); border-radius:10px; display:flex; align-items:center; justify-content:center; flex-shrink:0;">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
              <path d="M9 2v1.5M9 14.5V16M3 9H1.5M16.5 9H15M4.9 4.9l-1-1M14.1 13.1l-1-1M4.9 13.1l-1 1M14.1 4.9l-1 1" stroke="#B85C38" stroke-width="1.3" stroke-linecap="round"/>
              <circle cx="9" cy="9" r="3" stroke="#B85C38" stroke-width="1.4"/>
            </svg>
          </div>
          <span style="font-family:'Inter',sans-serif; font-size:15px; font-weight:500; color:#16120F;">$0 hidden fees — written quote is final</span>
        </div>

      </div>

      <!-- Stats row -->
      <div class="whu-stats" style="display:flex; align-items:center; gap:32px; margin-bottom:36px; padding:24px 28px; background:#F0EFED; border-radius:18px; --rd:320ms;" data-reveal>
        <div>
          <p style="font-family:'Onest',sans-serif; font-size:36px; font-weight:700; color:#B85C38; margin:0; line-height:1; letter-spacing:-0.02em;">500+</p>
          <p style="font-family:'Inter',sans-serif; font-size:12px; font-weight:500; color:#6A625A; margin:4px 0 0; text-transform:uppercase; letter-spacing:0.08em;">Projects done</p>
        </div>
        <div class="whu-stats-divider" style="width:1px; height:48px; background:rgba(0,0,0,0.10);"></div>
        <div>
          <p style="font-family:'Onest',sans-serif; font-size:36px; font-weight:700; color:#B85C38; margin:0; line-height:1; letter-spacing:-0.02em;">19+</p>
          <p style="font-family:'Inter',sans-serif; font-size:12px; font-weight:500; color:#6A625A; margin:4px 0 0; text-transform:uppercase; letter-spacing:0.08em;">Years serving IL</p>
        </div>
        <div class="whu-stats-divider" style="width:1px; height:48px; background:rgba(0,0,0,0.10);"></div>
        <div>
          <p style="font-family:'Onest',sans-serif; font-size:36px; font-weight:700; color:#B85C38; margin:0; line-height:1; letter-spacing:-0.02em;">4.8★</p>
          <p style="font-family:'Inter',sans-serif; font-size:12px; font-weight:500; color:#6A625A; margin:4px 0 0; text-transform:uppercase; letter-spacing:0.08em;">Homeowner rating</p>
        </div>
      </div>

      <!-- CTA -->
      <a href="/about"
        style="display:inline-flex; align-items:center; gap:10px; background:#16120F; color:#ffffff; font-family:'Inter',sans-serif; font-size:16px; font-weight:600; padding:16px 30px; border-radius:14px; text-decoration:none; transition:background 0.2s;"
        onmouseenter="this.style.background='#B85C38'"
        onmouseleave="this.style.background='#16120F'">
        Our story
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
          <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>

    </div>

    <!-- ══ RIGHT: 2×3 Masonry-shaped image mosaic ══ -->
    <div id="whu-grid" style="display:grid; grid-template-columns:1fr 1fr; gap:14px;">

      <!--
        Row 1: BRICK + STONE ARCH
      -->
      <figure class="whu-cell" data-shape="brick"
        style="clip-path:url(#whu-brick); aspect-ratio:4/5; margin:0; cursor:pointer;"
        title="Brick facade restoration">
        <picture style="display:block;width:100%;height:100%;">
          <source media="(max-width: 768px)" srcset="/images/why-brick-m.webp" type="image/webp" />
          <img class="whu-img" src="/images/why-brick.webp" alt="Brick facade restoration"
            style="width:100%; height:100%; object-fit:cover; display:block;" loading="lazy"/>
        </picture>
      </figure>

      <figure class="whu-cell" data-shape="arch"
        style="clip-path:url(#whu-arch); aspect-ratio:4/5; margin:0; cursor:pointer;"
        title="Stone arch — masonry gateway">
        <picture style="display:block;width:100%;height:100%;">
          <source media="(max-width: 768px)" srcset="/images/why-arch-m.webp" type="image/webp" />
          <img class="whu-img" src="/images/why-arch.webp" alt="Natural limestone exterior"
            style="width:100%; height:100%; object-fit:cover; display:block;" loading="lazy"/>
        </picture>
      </figure>

      <!--
        Row 2: CHIMNEY + LIMESTONE SLAB
      -->
      <figure class="whu-cell" data-shape="chimney"
        style="clip-path:url(#whu-chimney); aspect-ratio:4/5; margin:0; cursor:pointer;"
        title="Chimney repair and rebuild">
        <picture style="display:block;width:100%;height:100%;">
          <source media="(max-width: 768px)" srcset="/images/why-chimney-m.webp" type="image/webp" />
          <img class="whu-img" src="/images/why-chimney.webp" alt="Chimney repair and rebuild"
            style="width:100%; height:100%; object-fit:cover; display:block;" loading="lazy"/>
        </picture>
      </figure>

      <figure class="whu-cell" data-shape="limestone"
        style="clip-path:url(#whu-limestone); aspect-ratio:4/5; margin:0; cursor:pointer;"
        title="Limestone and tuckpointing">
        <picture style="display:block;width:100%;height:100%;">
          <source media="(max-width: 768px)" srcset="/images/why-limestone-m.webp" type="image/webp" />
          <img class="whu-img" src="/images/why-limestone.webp" alt="Tuckpointing and repointing"
            style="width:100%; height:100%; object-fit:cover; display:block;" loading="lazy"/>
        </picture>
      </figure>

      <!--
        Row 3: FIREPLACE + dark stat card
      -->
      <figure class="whu-cell" data-shape="fireplace"
        style="clip-path:url(#whu-fireplace); aspect-ratio:4/5; margin:0; cursor:pointer;"
        title="Custom stone fireplace and hearth">
        <picture style="display:block;width:100%;height:100%;">
          <source media="(max-width: 768px)" srcset="/images/why-fireplace-m.webp" type="image/webp" />
          <img class="whu-img" src="/images/why-fireplace.webp" alt="Custom stone fireplace"
            style="width:100%; height:100%; object-fit:cover; display:block;" loading="lazy"/>
        </picture>
      </figure>

      <!-- 6th cell: dark accent card -->
      <div class="whu-stat-card"
        style="aspect-ratio:4/5; background:#16120F; border-radius:20px; display:flex; flex-direction:column; justify-content:space-between; padding:28px 24px; box-sizing:border-box;">
        <div>
          <svg width="36" height="36" viewBox="0 0 36 36" fill="none" aria-hidden="true">
            <rect x="4" y="12" width="8" height="6" rx="1" fill="#B85C38"/>
            <rect x="14" y="8"  width="8" height="10" rx="1" fill="#B85C38" opacity="0.7"/>
            <rect x="24" y="4"  width="8" height="14" rx="1" fill="#B85C38" opacity="0.4"/>
            <rect x="4" y="24"  width="28" height="2"  rx="1" fill="rgba(255,255,255,0.15)"/>
          </svg>
        </div>
        <div>
          <p style="font-family:'Onest',sans-serif; font-size:48px; font-weight:700; color:#B85C38; margin:0; line-height:1; letter-spacing:-0.03em;">A+</p>
          <p style="font-family:'Inter',sans-serif; font-size:11px; font-weight:700; color:#4A433B; margin:6px 0 8px; text-transform:uppercase; letter-spacing:0.12em;">BBB Rating</p>
          <p style="font-family:'Inter',sans-serif; font-size:13px; line-height:1.55; color:rgba(255,255,255,0.60); margin:0;">Accredited since 2009 — zero unresolved complaints.</p>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
@media (max-width: 900px) {
  .whu-section {
    padding: 72px 24px !important;
  }
  .whu-outer-grid {
    grid-template-columns: 1fr !important;
    gap: 48px !important;
  }
  .whu-outer-grid > * {
    min-width: 0;
  }
  #whu-grid {
    min-width: 0 !important;
    width: 100% !important;
  }
  .whu-cell,
  .whu-stat-card {
    min-width: 0 !important;
  }
  .whu-stat-card {
    padding: 20px 16px !important;
  }
  .whu-stat-card p:first-of-type {
    font-size: 36px !important;
  }
  .whu-stats {
    display: grid !important;
    grid-template-columns: 1fr 1fr 1fr !important;
    gap: 0 !important;
    padding: 18px 16px !important;
    text-align: center;
  }
  .whu-stats-divider {
    display: none !important;
  }
}
@media (max-width: 480px) {
  .whu-section {
    padding: 56px 16px !important;
  }
}
</style>

<script>
import gsap from 'gsap';
import { ScrollTrigger } from 'gsap/ScrollTrigger';

gsap.registerPlugin(ScrollTrigger);

// ── Initial state: all cells invisible ──────────────────────────────────────
gsap.set('.whu-cell', { opacity: 0, scale: 0.78, transformOrigin: 'center center' });
gsap.set('.whu-stat-card', { opacity: 0, y: 20 });

// ── Stagger-reveal masonry image cells on scroll ─────────────────────────────
ScrollTrigger.create({
  trigger: '#whu-grid',
  start: 'top 76%',
  once: true,
  onEnter() {
    gsap.to('.whu-cell', {
      opacity: 1,
      scale: 1,
      duration: 0.7,
      stagger: { each: 0.12, from: 'start' },
      ease: 'back.out(1.3)',
    });
    gsap.to('.whu-stat-card', {
      opacity: 1,
      y: 0,
      duration: 0.6,
      delay: 0.5,
      ease: 'power2.out',
    });
  },
});

// ── Hover: zoom IMG inside the clip-path shape (clip-path stays fixed) ───────
document.querySelectorAll<HTMLElement>('.whu-cell').forEach(cell => {
  const img = cell.querySelector<HTMLElement>('.whu-img');
  if (!img) return;

  cell.addEventListener('mouseenter', () => {
    gsap.to(img, { scale: 1.12, duration: 0.45, ease: 'power2.out', overwrite: 'auto' });
  });
  cell.addEventListener('mouseleave', () => {
    gsap.to(img, { scale: 1,    duration: 0.55, ease: 'power2.out', overwrite: 'auto' });
  });
});
</script>
