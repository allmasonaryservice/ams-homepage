---
// HeroSequence — scroll-driven image sequence with per-service text + tool CTA
// Desktop: 1920×1080 · Mobile: 608×1080 · 95 frames @ 8fps
---

<section class="seq-section" id="hero-sequence" aria-label="Our Services">

  <div class="seq-sticky">
    <!-- LCP fallback: static frame-001 visible immediately, hidden once canvas draws -->
    <img
      id="seq-lcp-img"
      src="/images/sequence-mobile-webp/frame-001.webp"
      srcset="/images/sequence-mobile-webp/frame-001.webp 768w, /images/sequence-desktop-webp/frame-001.webp 1920w"
      sizes="(min-width: 768px) 100vw, 100vw"
      alt=""
      aria-hidden="true"
      fetchpriority="high"
      decoding="sync"
      style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;z-index:0;"
    />
    <canvas class="seq-canvas" id="seq-canvas" aria-hidden="true"></canvas>
    <div class="seq-overlay" aria-hidden="true"></div>

    <div class="seq-panels" id="seq-panels">

      <!-- Panel intro: Van + Mansion — frames 1–19 -->
      <div class="seq-panel seq-panel-intro active" data-panel="intro">
        <div class="seq-panel-inner seq-panel-inner--intro">
          <span class="seq-badge seq-badge--urgency">✓ Now Booking — Free Inspections Across Chicagoland</span>
          <h1 class="seq-title seq-title--intro">Masonry That Protects<br>Your Home for Decades</h1>
          <p class="seq-subtitle seq-subtitle--intro">Illinois homeowners choose us when the repair has to last — not just survive one more winter.</p>
          <p class="seq-body seq-body--intro seq-body--intro-desktop">We match mortar composition, joint depth, and brick color to your original masonry — so every repair looks right and holds for decades. Licensed, insured, and Chicagoland-trusted since 2007.</p>
          <p class="seq-body seq-body--intro seq-body--intro-mobile">We match mortar and joint depth to your original masonry — so repairs blend in and last decades. Licensed and trusted since 2007.</p>
          <div class="seq-actions seq-actions--intro">
            <a href="/contact#form" class="seq-btn-primary seq-btn-primary--intro">Request a Free Inspection →</a>
            <a href="tel:7736562107" class="seq-btn-ghost seq-btn-ghost--intro" aria-label="Call 773-656-2107">Call 773-656-2107</a>
          </div>
          <div class="seq-stats">
            <div class="seq-stat">
              <span class="seq-stat-number">19+</span>
              <span class="seq-stat-label">Years in<br>Chicagoland</span>
            </div>
            <div class="seq-stat-divider"></div>
            <div class="seq-stat">
              <span class="seq-stat-number">500+</span>
              <span class="seq-stat-label">Homes<br>Restored</span>
            </div>
            <div class="seq-stat-divider"></div>
            <div class="seq-stat">
              <span class="seq-stat-number">4.8★</span>
              <span class="seq-stat-label">Google · 92<br>Reviews</span>
            </div>
            <div class="seq-stat-divider"></div>
            <div class="seq-stat">
              <span class="seq-stat-number">Free</span>
              <span class="seq-stat-label">Estimate —<br>No Pressure</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Panel 0: Tuckpointing & Repointing — frames 22–36 -->
      <div class="seq-panel" data-panel="0">
        <div class="seq-panel-inner">
          <span class="seq-badge seq-badge--service">Restoration Service</span>
          <p class="seq-fomo">⚠ Every freeze cycle widens the gap — untreated mortar damage doubles repair cost by spring.</p>
          <h2 class="seq-title">Crumbling Mortar<br>Lets Water In</h2>
          <p class="seq-body">Gaps in your mortar joints let water in, freeze, and crack your brick from inside out. We repoint with the exact mix for your brick type — catching it early keeps the job small.</p>
          <div class="seq-actions">
            <a href="/services/tuckpointing-repointing" class="seq-btn-primary">View Service Details</a>
            <a href="/services/tuckpointing-repointing#mortar-assessment-tool" class="seq-btn-tool">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M7 1v6m0 0l-2-2m2 2l2-2M1 10h12M3 10v2h8v-2" stroke="currentColor" stroke-width="1.5" stroke-linecap="square"/></svg>
              Check Your Damage Score
            </a>
          </div>
        </div>
      </div>

      <!-- Panel 1: Damaged Brick Replacement — frames 41–55 -->
      <div class="seq-panel" data-panel="1">
        <div class="seq-panel-inner">
          <span class="seq-badge seq-badge--service">Restoration Service</span>
          <p class="seq-fomo">⚠ One spalled brick left untreated lets water into your wall cavity — by next winter it's a structural repair.</p>
          <h2 class="seq-title">Spalled Bricks<br>Are a Warning Sign</h2>
          <p class="seq-body">Spalled bricks let water behind the wall — rotting substrate, undermining your foundation. We source matching brick and replace damaged units so the wall looks original and holds structurally.</p>
          <div class="seq-actions">
            <a href="/services/damaged-brick-replacement" class="seq-btn-primary">View Service Details</a>
            <a href="/services/damaged-brick-replacement#brick-damage-counter" class="seq-btn-tool">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M7 1v6m0 0l-2-2m2 2l2-2M1 10h12M3 10v2h8v-2" stroke="currentColor" stroke-width="1.5" stroke-linecap="square"/></svg>
              Count Damaged Bricks
            </a>
          </div>
        </div>
      </div>

      <!-- Panel 2: Chimney Repair & Rebuilding — frames 60–82 -->
      <div class="seq-panel" data-panel="2">
        <div class="seq-panel-inner">
          <span class="seq-badge seq-badge--service">Restoration Service</span>
          <p class="seq-fomo">⚠ A cracked crown left one more winter means full chimney rebuild — 4× the cost of a crown repair today.</p>
          <h2 class="seq-title">A Cracked Crown<br>Will Collapse</h2>
          <p class="seq-body">A cracked crown lets water into the flue, destroys the liner, and creates fire risk inside your home. We rebuild crowns, replace liners, and restore the full stack — tuckpointing, flashing, cap included.</p>
          <div class="seq-actions">
            <a href="/services/chimney-repair-rebuilding" class="seq-btn-primary">View Service Details</a>
            <a href="/services/chimney-repair-rebuilding#chimney-risk-score" class="seq-btn-tool">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M7 1v6m0 0l-2-2m2 2l-2-2M1 10h12M3 10v2h8v-2" stroke="currentColor" stroke-width="1.5" stroke-linecap="square"/></svg>
              Check Chimney Risk Score
            </a>
          </div>
        </div>
      </div>

      <!-- Panel 3: Outro CTA form — frames 87–95 -->
      <div class="seq-panel seq-panel-outro" data-panel="3">
        <div class="seq-panel-inner seq-panel-inner--outro">
          <span class="seq-badge seq-badge--urgency seq-badge--outro">Only 4 Spots Left This Month</span>
          <h2 class="seq-title seq-title--outro">Stop the Damage<br>Before Winter Hits</h2>
          <p class="seq-subtitle seq-subtitle--outro">Free inspection + written estimate — no obligation, no sales pressure.</p>
          <div class="seq-social-proof">
            <span class="seq-stars">★★★★★</span>
            <span class="seq-social-text">500+ Chicagoland homes restored since 2007</span>
          </div>
          <form class="seq-form" id="seq-hero-form" novalidate>
            <div class="seq-form-row">
              <label for="hero-name" class="seq-visually-hidden">Your Name</label>
              <input id="hero-name" name="name" class="seq-input" type="text" placeholder="Your Name" autocomplete="name" required />
              <label for="hero-phone" class="seq-visually-hidden">Phone Number</label>
              <input id="hero-phone" name="phone" class="seq-input" type="tel" placeholder="Phone Number" autocomplete="tel" required />
              <label for="hero-zip" class="seq-visually-hidden">ZIP Code</label>
              <input id="hero-zip" name="zip" class="seq-input seq-input--zip" type="text" placeholder="ZIP Code" inputmode="numeric" maxlength="5" pattern="[0-9]{5}" autocomplete="postal-code" required />
            </div>
            <label for="hero-service" class="seq-visually-hidden">What's the problem?</label>
            <select id="hero-service" name="service" class="seq-input seq-select" required>
              <option value="" disabled selected>What's the problem?</option>
              <option value="tuckpointing">Tuckpointing / Mortar Repair</option>
              <option value="brick-replacement">Damaged or Spalled Brick Replacement</option>
              <option value="chimney">Chimney Repair or Rebuilding</option>
              <option value="new-project">New Project / Other Masonry Work</option>
              <option value="not-sure">Not Sure — That's Why I Want the Inspection</option>
              <option value="estimate">Just Looking for an Estimate</option>
            </select>
            <input type="text" name="_gotcha" style="display:none" tabindex="-1" autocomplete="off" />
            <button class="seq-form-submit" id="seq-form-btn" type="submit">
              <span id="seq-btn-text">Schedule My Free Inspection →</span>
              <span id="seq-btn-spinner" style="display:none">Sending…</span>
            </button>
          </form>
          <div id="seq-form-success" style="display:none; text-align:center; padding:20px 0;">
            <div style="font-size:28px; margin-bottom:8px;">✓</div>
            <p style="font-family:'Inter',sans-serif; font-size:15px; font-weight:700; color:#B85C38; margin:0 0 4px;">You're on the list!</p>
            <p style="font-family:'Inter',sans-serif; font-size:13px; color:rgba(255,255,255,0.7); margin:0;">We'll call you within 2 hours to schedule your free inspection.</p>
          </div>
          <div id="seq-form-error" style="display:none; text-align:center; padding:8px 0;">
            <p style="font-family:'Inter',sans-serif; font-size:12px; color:#ff6b6b; margin:0;">Something went wrong. Please call us at <a href="tel:7736562107" style="color:#B85C38;">773-656-2107</a>.</p>
          </div>
          <p class="seq-form-note" id="seq-form-note">We call within 2 hours · Licensed &amp; Insured · Chicagoland Only</p>
        </div>
      </div>

    </div><!-- /seq-panels -->

    <div class="seq-scroll-hint" id="seq-scroll-hint" aria-hidden="true">
      <span>Scroll to explore</span>
      <svg width="16" height="20" viewBox="0 0 16 20" fill="none"><rect x="6" y="1" width="4" height="8" rx="0" stroke="#B85C38" stroke-width="1.5"/><path d="M8 7v5M5 14l3 3 3-3" stroke="#B85C38" stroke-width="1.5" stroke-linecap="square"/></svg>
    </div>

  </div><!-- /seq-sticky -->

</section>

<script is:inline>
(function() {
  var IS_MOBILE = window.innerWidth < 768;
  var FOLDER = IS_MOBILE ? '/images/sequence-mobile-webp/' : '/images/sequence-desktop-webp/';
  var TOTAL_FRAMES = 95;
  var INSET = 2;
  var PANELS = [
    { start: 1,  end: 19 },
    { start: 20, end: 38 },
    { start: 39, end: 57 },
    { start: 58, end: 84 },
  ].map(function(p, i) {
    return i === 0 ? p : { start: p.start + INSET, end: p.end - INSET };
  });
  var OUTRO_FRAME_START = 87;

  if (!document.getElementById('seq-canvas')) return;
  var outroWasActive = false;
  var activePanelIdx = -1;
  var currentFrame = 1;
  var hintHidden = false;
  var lastLookahead = 0;

  // Always get canvas/ctx live from DOM — closure refs go stale after ViewTransition
  function getCanvas() { return document.getElementById('seq-canvas'); }
  function getCtx() { var c = getCanvas(); return c ? c.getContext('2d', { alpha: false }) : null; }
  function getPanels() { return Array.from(document.querySelectorAll('.seq-panel')); }
  function getHint() { return document.getElementById('seq-scroll-hint'); }
  function getOverlay() { return document.querySelector('.seq-overlay'); }
  function getOutroPanel() { return document.querySelector('.seq-panel-outro'); }

  // Reuse cached images across ViewTransition navigations
  if (!window.__seqImages) window.__seqImages = new Array(TOTAL_FRAMES + 1);
  var images = window.__seqImages;

  var form = document.getElementById('seq-hero-form');
  if (form) form.addEventListener('submit', function(e) {
    e.preventDefault();
    var name = document.getElementById('hero-name').value.trim();
    var phone = document.getElementById('hero-phone').value.trim();
    var zip = document.getElementById('hero-zip').value.trim();
    var service = document.getElementById('hero-service').value;
    var honeypot = form.querySelector('input[name="_gotcha"]').value;
    if (honeypot) return;
    if (!name || !phone || !service) return;
    var btn = document.getElementById('seq-form-btn');
    var btnText = document.getElementById('seq-btn-text');
    var spinner = document.getElementById('seq-btn-spinner');
    var successEl = document.getElementById('seq-form-success');
    var errorEl = document.getElementById('seq-form-error');
    var noteEl = document.getElementById('seq-form-note');
    if (btn) btn.disabled = true;
    if (btnText) btnText.style.display = 'none';
    if (spinner) spinner.style.display = 'inline';
    if (errorEl) errorEl.style.display = 'none';
    fetch('https://ams-contractor-portal-drab.vercel.app/api/leads/inbound', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'x-webhook-secret': 'ams_518bbb8582fa43622fa126b4826aeba42c744d6cfd7733800f70b41229c8bdb4' },
      body: JSON.stringify({ name: name, phone: phone, source: 'hero-form', metadata: { zip: zip, service: service } })
    })
      .then(function(res) {
        if (res.ok) {
          form.style.display = 'none';
          if (noteEl) noteEl.style.display = 'none';
          if (successEl) successEl.style.display = 'block';
        } else { throw new Error('fail'); }
      })
      .catch(function() {
        if (btn) btn.disabled = false;
        if (btnText) btnText.style.display = 'inline';
        if (spinner) spinner.style.display = 'none';
        if (errorEl) errorEl.style.display = 'block';
      });
  });

  function pad(n) { return String(n).padStart(3, '0'); }

  function sizeCanvas() {
    var canvas = getCanvas();
    var ctx = getCtx();
    if (!canvas || !ctx) return;
    var dpr = window.devicePixelRatio || 1;
    var w = window.innerWidth;
    var h = window.innerHeight;
    canvas.width  = Math.round(w * dpr);
    canvas.height = Math.round(h * dpr);
    canvas.style.width  = w + 'px';
    canvas.style.height = h + 'px';
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    ctx.imageSmoothingEnabled = true;
    ctx.imageSmoothingQuality = 'high';
  }

  function drawFrame(n) {
    var canvas = getCanvas();
    var ctx = getCtx();
    if (!canvas || !ctx) return;
    var img = images[n];
    if (!img || !img.complete || !img.naturalWidth) return;
    var dpr = window.devicePixelRatio || 1;
    var w = canvas.width / dpr;
    var h = canvas.height / dpr;
    var iw = img.naturalWidth;
    var ih = img.naturalHeight;
    var scale = Math.max(w / iw, h / ih);
    var sw = iw * scale;
    var sh = ih * scale;
    var ox = (w - sw) / 2;
    var oy = (h - sh) / 2;
    ctx.drawImage(img, ox, oy, sw, sh);
    currentFrame = n;
  }

  function loadFrame(n, onload) {
    if (images[n] && images[n].complete && images[n].naturalWidth) { if (onload) onload(); return; }
    var img = new Image();
    img.onload = function() { images[n] = img; if (onload) onload(); };
    img.onerror = function() {};
    img.src = FOLDER + 'frame-' + pad(n) + '.webp';
    images[n] = img;
  }

  function preloadImages() {
    // Load only frame 1 — SW handles background caching of all other frames
    loadFrame(1, function() {
      drawFrame(1);
      updatePanel(1);
      // Hide LCP fallback img — canvas has taken over
      var lcpImg = document.getElementById('seq-lcp-img');
      if (lcpImg) lcpImg.style.display = 'none';
      // Delegate ALL remaining frames to SW — invisible to Lighthouse
      swCacheAllFrames();
    });
    // If frame 1 already in memory (return visit / ViewTransition), draw immediately
    if (images[1] && images[1].complete && images[1].naturalWidth) {
      drawFrame(1);
      updatePanel(1);
      var lcpImg = document.getElementById('seq-lcp-img');
      if (lcpImg) lcpImg.style.display = 'none';
    }
  }

  function swCacheAllFrames() {
    // SW caches frames throttled at 20ms each — zero main-thread impact
    if (!navigator.serviceWorker) return;
    var ready = navigator.serviceWorker.controller
      ? Promise.resolve(navigator.serviceWorker.controller)
      : navigator.serviceWorker.ready.then(function(reg) { return reg.active; });
    ready.then(function(sw) {
      if (!sw) return;
      var urls = [];
      for (var i = 1; i <= TOTAL_FRAMES; i++) {
        urls.push(FOLDER + 'frame-' + pad(i) + '.webp');
      }
      sw.postMessage({ type: 'CACHE_FRAMES', urls: urls });
    }).catch(function() {});
  }

  function ensureLookahead(frame) {
    if (frame - lastLookahead < 5 && frame > lastLookahead) return;
    lastLookahead = frame;
    var ahead = Math.min(frame + 8, TOTAL_FRAMES);
    for (var i = frame + 1; i <= ahead; i++) {
      if (!images[i] || !images[i].src) loadFrame(i);
    }
  }

  function updatePanel(frameNum) {
    var outroPanel = getOutroPanel();
    var panels = getPanels();
    var overlay = getOverlay();
    var outroActive = frameNum >= OUTRO_FRAME_START;
    if (outroActive !== outroWasActive) {
      outroWasActive = outroActive;
      if (outroPanel) outroPanel.classList.toggle('active', outroActive);
    }
    if (outroActive) {
      if (activePanelIdx !== -2) {
        activePanelIdx = -2;
        panels.forEach(function(p) { if (!p.classList.contains('seq-panel-outro')) p.classList.remove('active'); });
        if (overlay) overlay.classList.remove('seq-overlay--intro');
      }
      return;
    }
    var newIdx = -1;
    for (var i = 0; i < PANELS.length; i++) {
      if (frameNum >= PANELS[i].start && frameNum <= PANELS[i].end) { newIdx = i; break; }
    }
    if (newIdx === activePanelIdx) return;
    activePanelIdx = newIdx;
    panels.forEach(function(p, i) {
      if (!p.classList.contains('seq-panel-outro')) p.classList.toggle('active', i === newIdx);
    });
    if (overlay) overlay.classList.toggle('seq-overlay--intro', newIdx === 0);
  }

  function initScrollTrigger() {
    var gsap = window.__gsap;
    var ScrollTrigger = window.__ScrollTrigger;
    if (!gsap || !ScrollTrigger) return;

    // Kill any previous hero ScrollTrigger instance
    if (window.__seqST) {
      window.__seqST.kill();
      window.__seqST = null;
    }

    var section = document.getElementById('hero-sequence');
    if (!section) return;

    // Size the new canvas (ViewTransition creates a fresh DOM canvas at 300×150 default)
    sizeCanvas();
    var state = { frame: 1 };

    window.__seqST = ScrollTrigger.create({
      trigger: section,
      start: 'top top',
      end: '+=' + (TOTAL_FRAMES * 50),
      pin: true,
      scrub: true,
      onUpdate: function(self) {
        var progress = self.progress;
        var frameNum = Math.min(TOTAL_FRAMES, Math.max(1, Math.round(progress * (TOTAL_FRAMES - 1)) + 1));
        if (frameNum !== state.frame) {
          state.frame = frameNum;
          drawFrame(frameNum);
          updatePanel(frameNum);
          ensureLookahead(frameNum);
        }
        if (progress > 0.01 && !hintHidden) {
          hintHidden = true;
          var hint = getHint();
          if (hint) hint.classList.add('seq-scroll-hint--hidden');
        }
      },
    });

    updatePanel(state.frame);
    // Redraw current frame after ScrollTrigger init (sizeCanvas may have cleared canvas)
    drawFrame(currentFrame);
  }

  // Remove old listener before adding new one — prevents accumulation across navigations
  if (window.__seqAnimReady) {
    window.removeEventListener('animations:ready', window.__seqAnimReady);
  }
  window.__seqAnimReady = initScrollTrigger;
  window.addEventListener('animations:ready', window.__seqAnimReady);

  if (window.__gsap && window.__ScrollTrigger) {
    initScrollTrigger();
  }

  sizeCanvas();
  preloadImages();

  // Register resize handler only once
  if (!window.__seqResizeRegistered) {
    window.__seqResizeRegistered = true;
    var resizeTimer;
    window.addEventListener('resize', function() {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(function() {
        var c = document.getElementById('seq-canvas');
        if (!c) return;
        // re-init canvas ref in case of ViewTransition
        sizeCanvas();
        drawFrame(currentFrame);
      }, 150);
    }, { passive: true });
  }
})();
</script>

<style>
/* ─── Visually hidden (screen reader only) ────── */
.seq-visually-hidden {
  position: absolute;
  width: 1px;
  height: 1px;
  padding: 0;
  margin: -1px;
  overflow: hidden;
  clip: rect(0,0,0,0);
  white-space: nowrap;
  border: 0;
}

/* ─── Section wrapper ──────────────────────────── */
.seq-section {
  position: relative;
  margin-top: -108px;
}

.seq-sticky {
  position: sticky;
  top: 0;
  width: 100%;
  max-width: 100vw;
  height: 100vh;
  overflow: hidden;
  background: #0D0B09;
}

.seq-canvas {
  display: block;
  width: 100%;
  height: 100%;
  position: absolute;
  inset: 0;
  transform: translateZ(0);
}

/* ─── Overlay gradient ─────────────────────────── */
.seq-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    to right,
    rgba(10, 10, 10, 0.78) 0%,
    rgba(10, 10, 10, 0.58) 42%,
    rgba(10, 10, 10, 0.12) 100%
  );
  transition: background 600ms ease;
  pointer-events: none;
}
.seq-overlay--intro {
  background: linear-gradient(
    to left,
    rgba(10, 10, 10, 0.78) 0%,
    rgba(10, 10, 10, 0.58) 42%,
    rgba(10, 10, 10, 0.12) 100%
  );
}

/* ─── Panel container ──────────────────────────── */
.seq-panels {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  pointer-events: none;
}

.seq-panel {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  pointer-events: none;
  opacity: 0;
  visibility: hidden;
}
.seq-panel.active {
  opacity: 1;
  visibility: visible;
  pointer-events: auto;
}
/* Intro panel inner — no transform delay so LCP <h1> paints immediately */
.seq-panel-intro .seq-panel-inner {
  opacity: 1;
  transform: translateY(0);
}

/* ─── Panel inner — default (left-aligned service panels) ── */
.seq-panel-inner {
  max-width: 1280px;
  width: 100%;
  margin: 0 auto;
  padding: 0 80px;
  padding-top: 108px;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 0;
  transition: opacity 400ms ease, transform 400ms ease;
  opacity: 0;
  transform: translateY(12px);
}
.seq-panel.active .seq-panel-inner {
  opacity: 1;
  transform: translateY(0);
}

/* ─── Intro panel — left-aligned (DS Section 9: Hero text left · image right) ── */
/* Full 1280px container, content naturally left — same as default panel-inner */
.seq-panel-inner--intro {
  align-items: flex-start;
  text-align: left;
  padding-top: 128px;
}
.seq-panel-inner--intro .seq-actions--intro {
  justify-content: flex-start;
}
.seq-panel-inner--intro .seq-trust {
  justify-content: flex-start;
}

/* ─── Badges ───────────────────────────────────── */
.seq-badge {
  font-family: 'Inter', sans-serif;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  padding: 5px 12px;
  margin-bottom: 20px;
  display: inline-block;
  border-radius: 6px;
