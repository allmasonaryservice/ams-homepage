---
---

<section class="services-section" id="services">
  <div class="services-inner">

    <!-- Section header -->
    <div class="services-header">
      <div class="services-eyebrow" data-reveal>
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <rect x="1" y="1" width="5" height="5" rx="1" fill="#B85C38"/>
          <rect x="8" y="1" width="5" height="5" rx="1" fill="#B85C38" opacity="0.4"/>
          <rect x="1" y="8" width="5" height="5" rx="1" fill="#B85C38" opacity="0.4"/>
          <rect x="8" y="8" width="5" height="5" rx="1" fill="#B85C38"/>
        </svg>
        <span>WHAT WE DO</span>
      </div>
      <h2 class="services-heading" data-reveal style="--rd:80ms">Expert masonry services</h2>
    </div>

    <!-- Cards grid -->
    <div class="services-grid">

      <!-- Card 1 -->
      <a href="/services/tuckpointing-repointing" class="svc-card" data-reveal>
        <div class="svc-img-wrap">
          <div class="svc-img-clip">
            <picture style="display:block;width:100%;">
              <source media="(max-width: 768px)" srcset="/images/svc-tuckpointing-m.webp" type="image/webp" />
              <img src="/images/svc-tuckpointing.webp" alt="Tuckpointing & Repointing" class="svc-img" loading="lazy" />
            </picture>
          </div>
          <div class="svc-notch">
            <svg class="notch-bg" viewBox="0 0 160 40" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M0 40 C20 40 28 40 38 28 C46 18 50 4 68 4 L92 4 C110 4 114 18 122 28 C132 40 140 40 160 40 Z" fill="white"/></svg>
            <div class="svc-icon-inner"><svg width="22" height="22" viewBox="0 0 22 22" fill="none" aria-hidden="true"><path d="M4 18L10 12M10 12L8 7L15 4L18 11L13 13L10 12Z" stroke="#B85C38" stroke-width="1.6" stroke-linejoin="round" stroke-linecap="round"/><path d="M4 18L7 15" stroke="#B85C38" stroke-width="1.6" stroke-linecap="round"/></svg></div>
          </div>
        </div>
        <div class="svc-body">
          <h3 class="svc-title">Tuckpointing &amp; Repointing</h3>
          <p class="svc-desc">Failed mortar raked out and replaced with a matched composition — joints sealed tight for another 30 years.</p>
        </div>
      </a>

      <!-- Card 2 -->
      <a href="/services/damaged-brick-replacement" class="svc-card" data-reveal style="--rd:80ms">
        <div class="svc-img-wrap">
          <div class="svc-img-clip">
            <picture style="display:block;width:100%;">
              <source media="(max-width: 768px)" srcset="/images/svc-brick-repair-m.webp" type="image/webp" />
              <img src="/images/svc-brick-repair.webp" alt="Brick Repair & Replacement" class="svc-img" loading="lazy" />
            </picture>
          </div>
          <div class="svc-notch">
            <svg class="notch-bg" viewBox="0 0 160 40" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M0 40 C20 40 28 40 38 28 C46 18 50 4 68 4 L92 4 C110 4 114 18 122 28 C132 40 140 40 160 40 Z" fill="white"/></svg>
            <div class="svc-icon-inner"><svg width="22" height="22" viewBox="0 0 22 22" fill="none" aria-hidden="true"><rect x="2" y="5" width="8" height="4" rx="1" stroke="#B85C38" stroke-width="1.5"/><rect x="12" y="5" width="8" height="4" rx="1" stroke="#B85C38" stroke-width="1.5"/><rect x="6" y="11" width="10" height="4" rx="1" stroke="#B85C38" stroke-width="1.5"/><rect x="2" y="11" width="2" height="4" rx="0.5" stroke="#B85C38" stroke-width="1.5"/><rect x="18" y="11" width="2" height="4" rx="0.5" stroke="#B85C38" stroke-width="1.5"/></svg></div>
          </div>
        </div>
        <div class="svc-body">
          <h3 class="svc-title">Brick Repair &amp; Replacement</h3>
          <p class="svc-desc">Spalled, cracked, or missing bricks sourced to match and reset — preserving the original look and structural integrity.</p>
        </div>
      </a>

      <!-- Card 3 -->
      <a href="/services/chimney-repair-rebuilding" class="svc-card" data-reveal style="--rd:160ms">
        <div class="svc-img-wrap">
          <div class="svc-img-clip">
            <picture style="display:block;width:100%;">
              <source media="(max-width: 768px)" srcset="/images/svc-chimney-m.webp" type="image/webp" />
              <img src="/images/svc-chimney.webp" alt="Chimney Repair & Rebuilding" class="svc-img" loading="lazy" />
            </picture>
          </div>
          <div class="svc-notch">
            <svg class="notch-bg" viewBox="0 0 160 40" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M0 40 C20 40 28 40 38 28 C46 18 50 4 68 4 L92 4 C110 4 114 18 122 28 C132 40 140 40 160 40 Z" fill="white"/></svg>
            <div class="svc-icon-inner"><svg width="22" height="22" viewBox="0 0 22 22" fill="none" aria-hidden="true"><path d="M7 19V10H15V19" stroke="#B85C38" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M5 19H17" stroke="#B85C38" stroke-width="1.5" stroke-linecap="round"/><rect x="8" y="4" width="6" height="6" rx="0.5" stroke="#B85C38" stroke-width="1.5"/><path d="M9 4V3M11 4V2M13 4V3" stroke="#B85C38" stroke-width="1.4" stroke-linecap="round"/></svg></div>
          </div>
        </div>
        <div class="svc-body">
          <h3 class="svc-title">Chimney Repair &amp; Rebuilding</h3>
          <p class="svc-desc">Crown repair, liner restoration, flashing, and full stack rebuild — waterproofed and code-compliant.</p>
        </div>
      </a>

      <!-- Card 4 -->
      <a href="/services/brick-installation" class="svc-card" data-reveal style="--rd:240ms">
        <div class="svc-img-wrap">
          <div class="svc-img-clip">
            <picture style="display:block;width:100%;">
              <source media="(max-width: 768px)" srcset="/images/svc-stone-install-m.webp" type="image/webp" />
              <img src="/images/svc-stone-install.webp" alt="Brick & Stone Installation" class="svc-img" loading="lazy" />
            </picture>
          </div>
          <div class="svc-notch">
            <svg class="notch-bg" viewBox="0 0 160 40" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M0 40 C20 40 28 40 38 28 C46 18 50 4 68 4 L92 4 C110 4 114 18 122 28 C132 40 140 40 160 40 Z" fill="white"/></svg>
            <div class="svc-icon-inner"><svg width="22" height="22" viewBox="0 0 22 22" fill="none" aria-hidden="true"><path d="M13 4L18 9L10 17L5 12L13 4Z" stroke="#B85C38" stroke-width="1.5" stroke-linejoin="round"/><path d="M5 12L3 19L10 17" stroke="#B85C38" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M14 5L17 8" stroke="#B85C38" stroke-width="1.5" stroke-linecap="round"/></svg></div>
          </div>
        </div>
        <div class="svc-body">
          <h3 class="svc-title">Brick &amp; Stone Installation</h3>
          <p class="svc-desc">New brick walls, stone facades, and decorative veneers installed with precision for homes across Chicagoland.</p>
        </div>
      </a>

      <!-- Card 5 -->
      <a href="/services/natural-stone-limestone" class="svc-card" data-reveal style="--rd:320ms">
        <div class="svc-img-wrap">
          <div class="svc-img-clip">
            <picture style="display:block;width:100%;">
              <source media="(max-width: 768px)" srcset="/images/svc-natural-stone-m.webp" type="image/webp" />
              <img src="/images/svc-natural-stone.webp" alt="Natural Stone & Limestone" class="svc-img" loading="lazy" />
            </picture>
          </div>
          <div class="svc-notch">
            <svg class="notch-bg" viewBox="0 0 160 40" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M0 40 C20 40 28 40 38 28 C46 18 50 4 68 4 L92 4 C110 4 114 18 122 28 C132 40 140 40 160 40 Z" fill="white"/></svg>
            <div class="svc-icon-inner"><svg width="22" height="22" viewBox="0 0 22 22" fill="none" aria-hidden="true"><path d="M11 3L19 9L11 19L3 9L11 3Z" stroke="#B85C38" stroke-width="1.5" stroke-linejoin="round"/><path d="M3 9H19M7 9L11 3L15 9L11 19" stroke="#B85C38" stroke-width="1.2" stroke-linejoin="round" stroke-linecap="round" opacity="0.5"/></svg></div>
          </div>
        </div>
        <div class="svc-body">
          <h3 class="svc-title">Natural Stone &amp; Limestone</h3>
          <p class="svc-desc">Timeless natural stone and limestone installed to last decades — matched to your home's architectural style.</p>
        </div>
      </a>

      <!-- Card 6 -->
      <a href="/services/commercial-brick-stone" class="svc-card" data-reveal style="--rd:400ms">
        <div class="svc-img-wrap">
          <div class="svc-img-clip">
            <picture style="display:block;width:100%;">
              <source media="(max-width: 768px)" srcset="/images/svc-commercial-m.webp" type="image/webp" />
              <img src="/images/svc-commercial.webp" alt="Commercial Masonry" class="svc-img" loading="lazy" />
            </picture>
          </div>
          <div class="svc-notch">
            <svg class="notch-bg" viewBox="0 0 160 40" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M0 40 C20 40 28 40 38 28 C46 18 50 4 68 4 L92 4 C110 4 114 18 122 28 C132 40 140 40 160 40 Z" fill="white"/></svg>
            <div class="svc-icon-inner"><svg width="22" height="22" viewBox="0 0 22 22" fill="none" aria-hidden="true"><rect x="3" y="6" width="16" height="13" rx="1" stroke="#B85C38" stroke-width="1.5"/><path d="M3 10H19" stroke="#B85C38" stroke-width="1.2" stroke-linecap="round" opacity="0.5"/><path d="M3 14H19" stroke="#B85C38" stroke-width="1.2" stroke-linecap="round" opacity="0.5"/><path d="M8 6V3H14V6" stroke="#B85C38" stroke-width="1.5" stroke-linejoin="round"/><rect x="9" y="15" width="4" height="4" rx="0.5" stroke="#B85C38" stroke-width="1.3"/></svg></div>
          </div>
        </div>
        <div class="svc-body">
          <h3 class="svc-title">Commercial Masonry</h3>
          <p class="svc-desc">Large-scale brick, stone, and CMU block work for storefronts, office buildings, and industrial properties.</p>
        </div>
      </a>

    </div>

    <!-- Bottom CTA bar -->
    <div class="services-cta-bar" data-reveal style="--rd:80ms">
      <div class="services-cta-left">
        <svg width="28" height="28" viewBox="0 0 28 28" fill="none" aria-hidden="true">
          <circle cx="14" cy="14" r="11" stroke="rgba(255,255,255,0.6)" stroke-width="1.5"/>
          <path d="M14 8v6l4 2" stroke="white" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M6 6l2 2M22 6l-2 2M6 22l2-2M22 22l-2-2" stroke="rgba(255,255,255,0.4)" stroke-width="1.3" stroke-linecap="round"/>
        </svg>
        <span>Available 7 days a week across Chicagoland</span>
      </div>
      <a href="/contact#form" class="services-cta-btn">
        Get Free Inspection
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path d="M2.5 7H11.5M8 3.5L11.5 7L8 10.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>

  </div>
</section>

<style is:global>

.services-section {
  background: #ffffff;
  padding: 0 12px 0;
}

.services-inner {
  background: #16120F;
  border-radius: 24px;
  padding: 80px 40px;
}

/* ── HEADER ── */
.services-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  margin-bottom: 56px;
}

.services-eyebrow {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 20px;
}
.services-eyebrow span {
  font-family: 'Inter', sans-serif;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.10em;
  color: #B85C38;
  text-transform: uppercase;
}

.services-heading {
  font-family: 'Onest', sans-serif;
  font-size: clamp(36px, 4vw, 60px);
  font-weight: 700;
  line-height: 1.05;
  color: #ffffff;
  letter-spacing: -0.02em;
  margin: 0;
}

/* ── GRID ── */
.services-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24px;
  max-width: 1150px;
  margin: 0 auto;
}

/* ── CARD ── */
.svc-card {
  background: #ffffff;
  border-radius: 20px;
  overflow: visible;
  text-decoration: none;
  display: flex;
  flex-direction: column;
  transition: transform 240ms ease, box-shadow 240ms ease;
  height: 100%;
}
.svc-card:hover {
  box-shadow: 0 16px 48px rgba(0,0,0,0.40);
}

/* Image outer wrap — relative container for notch positioning */
.svc-img-wrap {
  position: relative;
  width: 100%;
  flex-shrink: 0;
  padding: 10px 10px 0;
}

/* Image clip — clips zoom, keeps notch outside */
.svc-img-clip {
  overflow: hidden;
  border-radius: 14px 14px 0 0;
  width: 100%;
}

.svc-img {
  width: 100%;
  height: 260px;
  object-fit: cover;
  display: block;
  transform: scale(1);
  transition: transform 500ms cubic-bezier(0.25, 0.46, 0.45, 0.94);
}
.svc-card:hover .svc-img {
  transform: scale(1.06);
}

/* SVG notch — sits outside img-clip, won't zoom */
.svc-notch {
  position: absolute;
  bottom: -1px;
  left: 50%;
  transform: translateX(-50%);
  z-index: 3;
  width: 160px;
  height: 40px;
  pointer-events: none;
}

.svc-notch svg.notch-bg {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.svc-icon-inner {
  position: absolute;
  top: 6px;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  align-items: center;
  justify-content: center;
}

/* Card body */
.svc-body {
  padding: 16px 20px 22px;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  flex: 1;
  background: #ffffff;
  border-radius: 0 0 20px 20px;
}

.svc-title {
  font-family: 'Onest', sans-serif;
  font-size: 16px;
  font-weight: 700;
  color: #16120F;
  margin: 0 0 6px;
  line-height: 1.2;
  letter-spacing: -0.01em;
  transition: color 200ms ease;
}
.svc-card:hover .svc-title {
  color: #B85C38;
}

.svc-desc {
  font-family: 'Inter', sans-serif;
  font-size: 13px;
  font-weight: 400;
  line-height: 1.5;
  color: #4A433B;
  margin: 0;
  max-width: 260px;
}

/* ── CTA BAR ── */
.services-cta-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  max-width: 1150px;
  margin: 48px auto 0;
  padding: 18px 24px;
  border-radius: 14px;
  background: linear-gradient(90deg, #16120F 0%, #6E2A19 40%, #B85C38 100%);
}

.services-cta-left {
  display: flex;
  align-items: center;
  gap: 14px;
  font-family: 'Inter', sans-serif;
  font-size: 16px;
  font-weight: 600;
  color: #ffffff;
}


.services-cta-btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  height: 44px;
  padding: 0 22px;
  background: #ffffff;
  color: #16120F;
  font-family: 'Inter', sans-serif;
  font-size: 15px;
  font-weight: 600;
  text-decoration: none;
  border-radius: 10px;
  white-space: nowrap;
  transition: background 200ms ease, color 200ms ease;
  flex-shrink: 0;
}
.services-cta-btn:hover {
  background: #F5F1E8;
}

.services-cta-right {
  display: flex;
  align-items: center;
  gap: 20px;
  flex-shrink: 0;
}

.services-cta-text {
  font-family: 'Inter', sans-serif;
  font-size: 15px;
  font-weight: 500;
  color: rgba(255,255,255,0.75);
  text-decoration: underline;
  text-underline-offset: 3px;
  text-decoration-color: rgba(255,255,255,0.35);
  white-space: nowrap;
  transition: color 200ms ease;
}
.services-cta-text:hover {
  color: #ffffff;
  text-decoration-color: rgba(255,255,255,0.75);
}

/* ── RESPONSIVE ── */
@media (max-width: 900px) {
  .services-grid {
    grid-template-columns: repeat(2, 1fr);
  }
  .services-section { padding: 72px 0; }
}
@media (max-width: 580px) {
  .services-grid {
    grid-template-columns: 1fr;
  }
}
@media (max-width: 640px) {
  .services-inner {
    padding: 48px 20px;
  }
  .services-cta-bar {
    flex-direction: column;
    align-items: stretch;
    gap: 12px;
  }
  .services-cta-left {
    flex-direction: column;
    align-items: flex-start;
    gap: 6px;
    font-size: 14px;
  }
  .services-cta-btn {
    width: 100%;
    justify-content: center;
  }
}

</style>
