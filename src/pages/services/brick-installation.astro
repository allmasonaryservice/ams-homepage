  <!-- ─── BEFORE / AFTER ANIMATION ─── -->
  <script is:inline>
  (function() {
    var el     = document.getElementById('sp-ba-main');
    var lineEl = document.getElementById('sp-ba-line');
    var hint   = document.getElementById('sp-ba-hint');
    if (!el || !lineEl) return;

    var before = el.querySelector('.sp-ba-before');
    if (!before) return;

    var dragging = false;

    function apply(p) {
      before.style.clipPath = 'inset(0 ' + (100 - p) + '% 0 0)';
      lineEl.style.left = p + '%';
    }

    /* Initial state: 95% before (damaged mortar dominates) */
    apply(95);

    function setX(clientX) {
      var r = el.getBoundingClientRect();
      var p = Math.max(2, Math.min(98, ((clientX - r.left) / r.width) * 100));
      apply(p);
      if (hint) hint.style.opacity = '0';
    }

    /* ── Drag (mouse) — set up immediately, no GSAP needed ── */
    el.addEventListener('mousedown', function(e) {
      dragging = true; setX(e.clientX); e.preventDefault();
    });
    document.addEventListener('mousemove', function(e) { if (dragging) setX(e.clientX); });
    document.addEventListener('mouseup',   function()  { dragging = false; });

    /* ── Touch ── */
    el.addEventListener('touchstart', function(e) {
      dragging = true; setX(e.touches[0].clientX);
    }, {passive: true});
    el.addEventListener('touchmove', function(e) {
      if (dragging) setX(e.touches[0].clientX);
    }, {passive: true});
    el.addEventListener('touchend', function() { dragging = false; });

    /* ── GSAP scroll reveal (separate — needs animations:ready) ── */
    function initReveal() {
      var gsap = window.__gsap;
      var ST   = window.__ScrollTrigger;
      if (!gsap || !ST) return;

      var handle   = document.getElementById('sp-ba-handle');
      var revealed = false;

      ST.create({
        trigger: el,
        start: 'top 74%',
        onEnter: function() {
          if (revealed) return;
          revealed = true;
          /* Sweep: AFTER image slides in from right, pushing line left 95→50 */
          var proxy = { p: 95 };
          gsap.to(proxy, {
            p: 50,
            duration: 1.9,
            ease: 'expo.inOut',
            onUpdate: function() { apply(proxy.p); },
            onComplete: function() {
              /* Left-right nudge on handle: "drag me" signal */
              if (handle) {
                gsap.fromTo(handle,
                  { x: 0 },
                  { x: -12, duration: 0.16, yoyo: true, repeat: 5,
                    ease: 'power1.inOut',
                    onComplete: function() { gsap.set(handle, { clearProps: 'x' }); }
                  }
                );
              }
            }
          });
        }
      });
    }

    if (window.__gsap && window.__ScrollTrigger) { initReveal(); }
    else { window.addEventListener('animations:ready', initReveal, { once: true }); }
  })();
  </script>

  <!-- ─── HERO ANIMATION ─── -->
  <script is:inline>
  (function() {

    /* ── BRICK MASK GENERATOR — running bond, objectBoundingBox coords ── */
    function makeBrickClip(clipId, cols, rows) {
      var clipEl = document.getElementById(clipId);
      if (!clipEl) return [];
      var bricks = [], gapX = 0.009, gapY = 0.011;
      var cW = 1 / cols, cH = 1 / rows;
      var bW = cW - gapX, bH = cH - gapY;
      for (var r = 0; r < rows; r++) {
        var odd = r % 2 === 1;
        for (var c = (odd ? -1 : 0); c < cols + (odd ? 1 : 0); c++) {
          var xRaw = c * cW + (odd ? cW * 0.5 : 0);
          var yPos = r * cH + gapY * 0.5;
          if (xRaw + bW <= 0 || xRaw >= 1) continue;
          var x = Math.max(0, xRaw);
          var w = Math.min(bW - Math.max(0, x - xRaw), 1 - x);
          if (w < 0.012) continue;
          var rect = document.createElementNS('http://www.w3.org/2000/svg', 'rect');
          rect.setAttribute('x', x);
          rect.setAttribute('y', yPos);
          rect.setAttribute('width', w);
          rect.setAttribute('height', bH);
          clipEl.appendChild(rect);
          bricks.push({ el: rect, fy: yPos, r: r, x: x });
        }
      }
      /* Sort top-left → bottom-right diagonal for stagger order */
      bricks.sort(function(a, b) { return (a.r * 0.45 + a.x) - (b.r * 0.45 + b.x); });
      return bricks;
    }

    var lgBricks = makeBrickClip('lh-clip-lg', 6, 4);
    var mdBricks = makeBrickClip('lh-clip-md', 4, 3);
    var smBricks = makeBrickClip('lh-clip-sm', 3, 3);
    makeBrickClip('lh-clip-mob', 5, 3);

    /* Apply clip-paths */
    ['lg', 'md', 'sm'].forEach(function(k) {
      var el = document.getElementById('lh-clip-wrap-' + k);
      if (el) { el.style.clipPath = 'url(#lh-clip-' + k + ')'; }
    });
    var mobClip = document.getElementById('lh-mob-clip-wrap');
    if (mobClip) { mobClip.style.clipPath = 'url(#lh-clip-mob)'; }

    /* Mortar SVG for mobile image */
    (function() {
      var svg = document.getElementById('lh-mob-mlines');
      if (!svg) return;
      svg.setAttribute('viewBox', '0 0 100 100');
      var col = 'rgba(200,169,110,0.18)', sw = '0.4';
      for (var y = 33; y < 100; y += 33) {
        var l = document.createElementNS('http://www.w3.org/2000/svg', 'line');
        l.setAttribute('x1', 0); l.setAttribute('y1', y);
        l.setAttribute('x2', 100); l.setAttribute('y2', y);
        l.setAttribute('stroke', col); l.setAttribute('stroke-width', sw);
        svg.appendChild(l);
      }
      var bW = 20;
      for (var ri = 0; ri < 3; ri++) {
        var yT = ri * 33, xOff = (ri % 2 === 1) ? bW * 0.5 : 0;
        for (var x = xOff; x <= 100; x += bW) {
          var lv = document.createElementNS('http://www.w3.org/2000/svg', 'line');
          lv.setAttribute('x1', x); lv.setAttribute('y1', yT);
          lv.setAttribute('x2', x); lv.setAttribute('y2', yT + 33);
          lv.setAttribute('stroke', col); lv.setAttribute('stroke-width', sw);
          svg.appendChild(lv);
        }
      }
    })();

    /* ── MORTAR LINE SVG — viewBox 0 0 100 100, preserveAspectRatio="none" ── */
    function buildMortarLines() {
      var svg = document.getElementById('lh-mlines');
      if (!svg) return [];
      svg.setAttribute('viewBox', '0 0 100 100');
      var lines = [], col = 'rgba(200,169,110,0.18)', sw = '0.25';
      /* Horizontal bed joints every 5 units */
      for (var y = 5; y < 100; y += 5) {
        var l = document.createElementNS('http://www.w3.org/2000/svg', 'line');
        l.setAttribute('x1', 0); l.setAttribute('y1', y);
        l.setAttribute('x2', 100); l.setAttribute('y2', y);
        l.setAttribute('stroke', col); l.setAttribute('stroke-width', sw);
        svg.appendChild(l); lines.push(l);
      }
      /* Vertical head joints — running bond pattern */
      var bW = 14;
      for (var ri = 0; ri < 20; ri++) {
        var yT = ri * 5, xOff = (ri % 2 === 1) ? bW * 0.5 : 0;
        for (var x = xOff; x <= 100; x += bW) {
          var lv = document.createElementNS('http://www.w3.org/2000/svg', 'line');
          lv.setAttribute('x1', x); lv.setAttribute('y1', yT);
          lv.setAttribute('x2', x); lv.setAttribute('y2', yT + 5);
          lv.setAttribute('stroke', col); lv.setAttribute('stroke-width', sw);
          svg.appendChild(lv); lines.push(lv);
        }
      }
      return lines;
    }
    var mortarLines = buildMortarLines();

    /* ── MOUSE PARALLAX — RAF loop, lerped at 0.08 ── */
    var heroEl = document.getElementById('sp-hero');
    var imgLg  = document.getElementById('lh-img-lg');
    var imgMd  = document.getElementById('lh-img-md');
    var imgSm  = document.getElementById('lh-img-sm');
    var mX = 0, mY = 0, cX = 0, cY = 0, rafOn = false;

    function rafTick() {
      cX += (mX - cX) * 0.08; cY += (mY - cY) * 0.08;
      if (imgLg) imgLg.style.transform = 'translate(' + (cX * 10) + 'px,' + (cY * 7) + 'px)';
      if (imgMd) imgMd.style.transform = 'translate(' + (cX * 14) + 'px,' + (cY * 10) + 'px)';
      if (imgSm) imgSm.style.transform = 'translate(' + (cX * 7)  + 'px,' + (cY * 5)  + 'px)';
      if (Math.abs(mX - cX) + Math.abs(mY - cY) > 0.001) requestAnimationFrame(rafTick);
      else rafOn = false;
    }
    if (heroEl) {
      heroEl.addEventListener('mousemove', function(e) {
        var r = heroEl.getBoundingClientRect();
        mX = ((e.clientX - r.left) / r.width  - 0.5) * 2;
        mY = ((e.clientY - r.top)  / r.height - 0.5) * 2;
        if (!rafOn) { rafOn = true; requestAnimationFrame(rafTick); }
      }, { passive: true });
    }

    /* ── GSAP SCROLL PARALLAX only — no entrance animation ── */
    function initHero() {
      var gsap = window.__gsap;
      var ST   = window.__ScrollTrigger;
      if (!gsap || !ST) return;

      var rightEl = document.getElementById('lh-right');
      var leftEl  = heroEl ? heroEl.querySelector('.lh-left') : null;

      if (rightEl && heroEl) {
        gsap.to(rightEl, {
          y: -55, ease: 'none',
          scrollTrigger: { trigger: heroEl, start: 'top top', end: 'bottom top', scrub: 0.8 }
        });
      }
      if (leftEl && heroEl) {
        gsap.to(leftEl, {
          y: -30, ease: 'none',
          scrollTrigger: { trigger: heroEl, start: 'top top', end: '55% top', scrub: 0.8 }
        });
      }

      var scrEl = document.getElementById('lh-scroll');
      if (scrEl) {
        scrEl.addEventListener('click', function() {
          var next = document.querySelector('.sp-trust');
          if (next) next.scrollIntoView({ behavior: 'smooth' });
          else window.scrollTo({ top: window.innerHeight, behavior: 'smooth' });
        });
      }
    }

    if (window.__gsap && window.__ScrollTrigger) {
      initHero();
    } else {
      window.addEventListener('animations:ready', initHero, { once: true });
    }
  })();
  </script>

  <!-- ─── PROCESS SCROLL ANIMATION ─── -->
  <script is:inline>
    (function() {
      function initProcessAnim() {
        var gsap = window.__gsap;
        var ScrollTrigger = window.__ScrollTrigger;
        if (!gsap || !ScrollTrigger) return;

        var driver   = document.getElementById('sp-prc-driver');
        var leftCol  = document.getElementById('sp-prc-left');
        var items    = Array.from(document.querySelectorAll('.sp-prc-item'));
        var nums     = Array.from(document.querySelectorAll('.sp-prc-num'));
        if (!driver || !leftCol || !items.length) return;

        var isMobile = window.innerWidth < 900;
        // Skip entrance fades on mobile — content always visible, no blank spaces
        if (isMobile) {
          items.forEach(function(item, i) {
            var stepTl = gsap.timeline({ defaults: { ease: 'none' } });
            var n = nums[i];
            stepTl
              .fromTo(n, { opacity: 0.22 }, { opacity: 1, duration: 0.5 }, 0)
              .fromTo(item, { backgroundColor: 'rgba(184,92,56,0)' }, { backgroundColor: 'rgba(184,92,56,0.06)', duration: 0.5 }, 0)
              .to(n, { opacity: 0.22, duration: 0.5 }, 0.5)
              .to(item, { backgroundColor: 'rgba(184,92,56,0)', duration: 0.5 }, 0.5);
            ScrollTrigger.create({ trigger: item, start: 'top 65%', end: 'bottom 35%', scrub: 0.4, animation: stepTl });
          });
          return;
        }

        // Desktop: left column entrance
        gsap.from(leftCol, {
          opacity: 0, x: -24,
          duration: 0.9, ease: 'power2.out',
          scrollTrigger: { trigger: driver, start: 'top 80%', once: true },
        });

        // Desktop: steps fade in
        gsap.from(items, {
          opacity: 0, y: 20, duration: 0.6, ease: 'power2.out', stagger: 0.08,
          scrollTrigger: { trigger: driver, start: 'top 70%', once: true },
        });

        // Desktop: scrub active-step highlight
        var tl  = gsap.timeline({ defaults: { ease: 'none' } });
        var seg = 1 / items.length;

        items.forEach(function(item, i) {
          var s  = i * seg;
          var fi = seg * 0.25;
          var fo = seg * 0.25;

          tl.fromTo(nums[i],  { opacity: 0.22 }, { opacity: 1,                           duration: fi }, s);
          tl.to(nums[i],                          { opacity: 0.22,                        duration: fo }, s + seg - fo);
          tl.fromTo(items[i], { backgroundColor: 'rgba(184,92,56,0)' },
                              { backgroundColor: 'rgba(184,92,56,0.06)', duration: fi }, s);
          tl.to(items[i],     { backgroundColor: 'rgba(184,92,56,0)',    duration: fo }, s + seg - fo);
        });

        ScrollTrigger.create({
          trigger: driver, start: 'top top', end: 'bottom bottom',
          scrub: 1.2, animation: tl,
        });
      }

      window.removeEventListener('animations:ready', window.__spPrcAnimReady);
      window.__spPrcAnimReady = initProcessAnim;
      window.addEventListener('animations:ready', window.__spPrcAnimReady);
    })();
  </script>

  <!-- ─── DELAY / PROBLEM ANIMATION ─── -->
  <script is:inline>
    (function() {
      function initDelayAnim() {
        var gsap = window.__gsap;
        var ScrollTrigger = window.__ScrollTrigger;
        if (!gsap || !ScrollTrigger) return;
        if (window.innerWidth <= 900) return;
        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

        var section = document.querySelector('.sp-problem');
        if (!section) return;
        var label   = section.querySelector('.sp-section-label');
        var h2      = section.querySelector('.sp-delay-h2');
        var sub     = section.querySelector('.sp-delay-sub');
        var sidebar = section.querySelector('.sp-delay-sidebar');
        var stats   = Array.from(section.querySelectorAll('.sp-delay-stat'));
        var items   = Array.from(section.querySelectorAll('.sp-delay-item'));
        var rules   = Array.from(section.querySelectorAll('.sp-delay-rule'));
        var bars    = Array.from(section.querySelectorAll('.sp-delay-chart-bar'));

        // Initial states
        gsap.set([label, h2, sub].filter(Boolean), { opacity: 0, y: 24 });
        if (sidebar) gsap.set(sidebar, { opacity: 0, x: -32 });
        gsap.set(stats, { opacity: 0, y: 16 });
        gsap.set(rules, { scaleX: 0, transformOrigin: 'left center' });
        gsap.set(items, { opacity: 0, y: 28 });
        if (bars.length) gsap.set(bars, { scaleX: 0, transformOrigin: 'left center' });

        // Header
        ScrollTrigger.create({
          trigger: section,
          start: 'top 78%',
          onEnter: function() {
            gsap.to([label, h2, sub].filter(Boolean), {
              opacity: 1, y: 0, duration: 0.65, ease: 'power2.out', stagger: 0.12, overwrite: true
            });
          },
          onLeaveBack: function() {
            gsap.set([label, h2, sub].filter(Boolean), { opacity: 0, y: 24 });
          }
        });

        // Sidebar slides in from left
        if (sidebar) {
          ScrollTrigger.create({
            trigger: '.sp-delay-cols',
            start: 'top 82%',
            onEnter: function() {
              gsap.to(sidebar, { opacity: 1, x: 0, duration: 0.7, ease: 'power2.out', overwrite: true });
              gsap.to(stats, { opacity: 1, y: 0, duration: 0.5, ease: 'power2.out', stagger: 0.12, delay: 0.3, overwrite: true });
            },
            onLeaveBack: function() {
              gsap.set(sidebar, { opacity: 0, x: -32 });
              gsap.set(stats, { opacity: 0, y: 16 });
            }
          });
        }

        // List items: rules draw, then items fade in
        items.forEach(function(item, i) {
          var prevRule = rules[i];
          ScrollTrigger.create({
            trigger: item,
            start: 'top 88%',
            onEnter: function() {
              if (prevRule) gsap.to(prevRule, { scaleX: 1, duration: 0.5, ease: 'power2.out', overwrite: true });
              gsap.to(item, { opacity: 1, y: 0, duration: 0.6, ease: 'power2.out', delay: 0.15, overwrite: true });
              if (i === 2 && bars.length) {
                gsap.to(bars, { scaleX: 1, duration: 0.5, ease: 'power2.inOut', stagger: 0.12, delay: 0.5, overwrite: true });
              }
            },
            onLeaveBack: function() {
              if (prevRule) gsap.set(prevRule, { scaleX: 0 });
              gsap.set(item, { opacity: 0, y: 28 });
              if (i === 2 && bars.length) gsap.set(bars, { scaleX: 0 });
            }
          });
        });

        // Last rule
        var lastRule = rules[rules.length - 1];
        if (lastRule) {
          ScrollTrigger.create({
            trigger: lastRule,
            start: 'top 92%',
            onEnter: function() { gsap.to(lastRule, { scaleX: 1, duration: 0.5, ease: 'power2.out', overwrite: true }); },
            onLeaveBack: function() { gsap.set(lastRule, { scaleX: 0 }); }
          });
        }
      }
      window.removeEventListener('animations:ready', window.__spProblemAnimReady);
      window.__spProblemAnimReady = initDelayAnim;
      window.addEventListener('animations:ready', window.__spProblemAnimReady);
    })();
  </script>

  <!-- ─── WHY AMS CARD ANIMATION ─── -->
  <script is:inline>
    (function() {
      function initWhyAnim() {
