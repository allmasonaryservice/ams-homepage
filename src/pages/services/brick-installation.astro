---
import Layout from '../../layouts/Layout.astro';
import { projects as allProjects } from '../../data/projects.js';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import BrickInstallationEstimator from '../../components/magnets/BrickInstallationEstimator.astro';

const siteUrl = 'https://allmasonryservices.com';
  const svcProjects = allProjects.filter(p => p.serviceSlug === 'brick-installation').slice(0, 5);
const pageUrl = `${siteUrl}/services/brick-installation`;

const faqItems = [
  {
    question: "How much does brick installation cost in Chicago?",
    answer: "Brick installation in Chicagoland typically costs $15–$35 per square foot depending on brick type, mortar complexity, and site access. A small outdoor feature or wall repair runs $2,000–$6,000. A full home exterior can range from $20,000 to $75,000+. Free on-site estimates at 773-656-2107."
  },
  {
    question: "How do I know what brick type I need?",
    answer: "Brick selection depends on your home's style, the location of the installation, and your climate exposure. AMS helps you select the right brick type and source it before any work begins — we'll walk you through options on the estimate visit."
  },
  {
    question: "How long does brick installation take?",
    answer: "Small projects (retaining walls, outdoor features, additions) typically run 1–5 days. A full exterior can take 1–3 weeks. We provide a detailed timeline at the estimate stage."
  },
  {
    question: "Can you match existing brick on my home?",
    answer: "Yes — brick matching is one of our specialties. We source bricks that match your existing in color, texture, and size, and we mortar-match to your existing joints. The goal is that you can't see where old ends and new begins."
  },
  {
    question: "What's the difference between Type N, S, and M mortar?",
    answer: "Type N is correct for most above-grade exterior walls — medium strength, flexible enough for brick movement. Type S is for below-grade or high-moisture environments. Type M is for foundations and hardscape. Using the wrong type causes premature brick failure. AMS matches every mortar mix to your specific brick and location."
  },
  {
    question: "Do you install brick for both residential and commercial projects?",
    answer: "Yes — AMS does both. For commercial brick installation, see our Commercial Brick & Stone service page. For custom home builds, see Custom Home Masonry."
  },
  {
    question: "Is AMS licensed and insured for brick installation?",
    answer: "Yes. Licensed in Illinois (License #MA-104-018887), $2.5M general liability, workers' compensation on all crew members. Proof of insurance available before work starts."
  },
  {
    question: "Do you offer free estimates for brick installation?",
    answer: "Yes — all estimates are free, on-site, and in writing. Call 773-656-2107 or fill out our contact form to schedule."
  }
];
---

<Layout
  title="Brick Installation Chicago | All Masonry Services"
  description="Professional brick installation for Chicago and Chicagoland homes and builders. New walls, facades, additions, and outdoor features. 19+ years experience. Free estimates. Call 773-656-2107."
>
  <!-- Schema: Service -->
  <script is:inline type="application/ld+json">{JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Brick Installation in Chicago & Chicagoland",
    "description": "Professional brick installation services for Chicago and Chicagoland homes and builders. New walls, facades, additions, and outdoor features. 19+ years experience, fully licensed and insured.",
    "url": pageUrl,
    "provider": { "@type": "Organization", "name": "All Masonry Services", "url": siteUrl },
    "areaServed": "Chicago, Chicagoland, IL",
    "serviceType": "Brick Installation"
  })}</script>

  <!-- Schema: HowTo -->
  <script is:inline type="application/ld+json">{JSON.stringify({
    "@context": "https://schema.org",
    "@type": "HowTo",
    "name": "How Brick Installation Works: AMS 5-Step Process",
    "description": "How professional brick installation is done on Chicago and Chicagoland homes and new construction projects.",
    "step": [
      { "@type": "HowToStep", "position": 1, "name": "Site & Substrate Assessment", "text": "We evaluate your foundation, existing substrate, and drainage conditions before a single brick is laid." },
      { "@type": "HowToStep", "position": 2, "name": "Mortar Selection & Mix", "text": "We select the correct mortar type for your brick — Type N, S, or M — based on brick density, location, and climate exposure." },
      { "@type": "HowToStep", "position": 3, "name": "Weep Holes & Flashing", "text": "Before brick is laid, we install proper flashing at the base course and weep holes at regular intervals to allow moisture to escape." },
      { "@type": "HowToStep", "position": 4, "name": "Brick Laying & Joint Tooling", "text": "We lay brick in consistent courses, checking level and plumb at every stage. Mortar joints are tooled while still workable." },
      { "@type": "HowToStep", "position": 5, "name": "Cleanup & Final Inspection", "text": "We clean mortar haze off the brick face with acid wash, sweep the area, and walk the completed work with you before closing out." }
    ]
  })}</script>

  <!-- Schema: FAQ -->
  <script is:inline type="application/ld+json">{JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqItems.map(item => ({
      "@type": "Question",
      "name": item.question,
      "acceptedAnswer": { "@type": "Answer", "text": item.answer }
    }))
  })}</script>

  <Navbar />

  <!-- ─── 1. HERO — HEAVY CLAY IMPACT ─── -->
  <section class="bi-hero" id="bi-hero" aria-label="Brick Installation hero">
    <div class="bi-hero-base" aria-hidden="true"></div>
    <div class="bi-grid" id="bi-grid" aria-hidden="true"></div>
    <div class="bi-grid-ink" aria-hidden="true"></div>
    <div class="bi-vignette" aria-hidden="true"></div>
    <div class="bi-content">
      <div class="bi-label" id="bi-label">
        <span class="bi-label-line" aria-hidden="true"></span>
        Brick Installation · Chicago &amp; Chicagoland
      </div>
      <h1 class="bi-h1">
        <div class="bi-h1-row"><span id="bi-r1">Brick Installation</span></div>
        <div class="bi-h1-row"><span id="bi-r2">in Chicago &amp; Chicagoland</span></div>
      </h1>
      <p class="bi-sub" id="bi-sub">
        New brick walls, facades, additions, and outdoor features — professionally laid with precision mortar work, matched materials, and craftsmanship that lasts for decades.
      </p>
      <div class="lh-actions bi-actions" id="bi-act">
        <a href="/contact#form" class="lh-btn bi-btn-primary">
          <span class="lh-btn-bg" aria-hidden="true"></span>
          <span class="lh-btn-label">Get a Free Estimate</span>
          <svg width="13" height="13" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <a href="tel:7736562107" class="lh-btn bi-btn-ghost">
          <span class="lh-btn-bg" aria-hidden="true"></span>
          <span class="lh-btn-label">Call 773-656-2107</span>
        </a>
      </div>
      <div class="lh-badges bi-badges" id="bi-bdg">
        <div class="lh-badge"><strong>500+</strong><span>Homes Built</span></div>
        <div class="bi-badge-sep" aria-hidden="true"></div>
        <div class="lh-badge"><strong>4.8★</strong><span>92 Google Reviews</span></div>
        <div class="bi-badge-sep" aria-hidden="true"></div>
        <div class="lh-badge"><strong>19+</strong><span>Years Experience</span></div>
      </div>
    </div>
    <div class="lh-scroll" id="bi-scroll">
      <div class="lh-scroll-mouse"><div class="lh-scroll-dot"></div></div>
      <span>Scroll</span>
    </div>
  </section>

  <script is:inline>
  (function() {
    function initBi() {
      var gsap = window.__gsap;
      if (!gsap) return;

      var gridEl  = document.getElementById('bi-grid');
      var heroEl  = document.getElementById('bi-hero');
      var labelEl = document.getElementById('bi-label');
      var r1El    = document.getElementById('bi-r1');
      var r2El    = document.getElementById('bi-r2');
      var subEl   = document.getElementById('bi-sub');
      var actEl   = document.getElementById('bi-act');
      var bdgEl   = document.getElementById('bi-bdg');

      if (!gridEl || !heroEl) return;

      /* Build brick mosaic grid — each cell shows its slice of the hero image */
      var BW = 160, BH = 58;
      var W  = window.innerWidth;
      var H  = window.innerHeight;
      var cols = Math.ceil(W / BW) + 1;
      var rows = Math.ceil(H / BH) + 1;
      var bricks = [];

      for (var r = 0; r < rows; r++) {
        var xOff = (r % 2 !== 0) ? -(BW / 2) : 0;
        for (var c = 0; c < cols; c++) {
          var bx = (c * BW) + xOff + 1;
          var by = r * BH + 1;
          var b  = document.createElement('div');
          b.style.cssText = [
            'position:absolute',
            'background-image:url(/images/bi-hero/bi-wall.webp)',
            'background-size:' + W + 'px ' + H + 'px',
            'background-position:-' + bx + 'px -' + by + 'px',
            'background-repeat:no-repeat',
            'width:' + (BW - 2) + 'px',
            'height:' + (BH - 2) + 'px',
            'left:' + bx + 'px',
            'top:' + by + 'px',
            'box-shadow:0 8px 24px rgba(0,0,0,0.85)'
          ].join(';');
          gridEl.appendChild(b);
          bricks.push(b);
        }
      }

      var isTouch = window.matchMedia('(hover: none)').matches;

      /* Brick parallax — mouse on desktop, touch on mobile */
      var quickTos = bricks.map(function(b, i) {
        return gsap.quickTo(b, 'x', {
          duration: 0.6 + (i % 8) * 0.08,
          ease: 'power2.out'
        });
      });
      var mults = bricks.map(function(b, i) {
        return 0.15 + (i % 7) * 0.06;
      });

      function shiftBricks(clientX) {
        var bounds = heroEl.getBoundingClientRect();
        var relX = ((clientX - bounds.left) / bounds.width - 0.5) * 2;
        for (var i = 0; i < bricks.length; i++) {
          quickTos[i](relX * 22 * mults[i]);
        }
      }
      function resetBricks() {
        for (var i = 0; i < bricks.length; i++) { quickTos[i](0); }
      }

      heroEl.addEventListener('mousemove', function(e) { shiftBricks(e.clientX); }, { passive: true });
      heroEl.addEventListener('mouseleave', resetBricks);
      heroEl.addEventListener('touchmove', function(e) { shiftBricks(e.touches[0].clientX); }, { passive: true });
      heroEl.addEventListener('touchend', resetBricks, { passive: true });

      /* Scroll cue */
      var scrEl = document.getElementById('bi-scroll');
      if (scrEl) {
        scrEl.addEventListener('click', function() {
          var next = document.querySelector('.sp-trust');
          if (next) next.scrollIntoView({ behavior: 'smooth' });
          else window.scrollTo({ top: window.innerHeight, behavior: 'smooth' });
        });
      }
    }
    if (window.__gsap) { initBi(); }
    else { window.addEventListener('animations:ready', initBi, { once: true }); }
  })();
  </script>

  <!-- ─── 2. TRUST BAR ─── -->
  <section class="sp-trust">
    <div class="sp-trust-inner">
      <div class="sp-trust-item">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        Licensed &amp; Insured in Illinois
      </div>
      <div class="sp-trust-sep"></div>
      <div class="sp-trust-item">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        Free On-Site Estimates
      </div>
      <div class="sp-trust-sep"></div>
      <div class="sp-trust-item">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        Mortar Matched to Your Brick
      </div>
      <div class="sp-trust-sep"></div>
      <div class="sp-trust-item">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        19+ Years in Chicagoland
      </div>
    </div>
  </section>

  <!-- ─── 3. PROBLEM / CONSEQUENCE ─── -->
  <section class="sp-problem">
    <div class="sp-delay-inner">

      <!-- Header -->
      <div class="sp-delay-hdr">
        <div class="sp-section-label">Why It Matters</div>
        <h2 class="sp-delay-h2">What Happens When You <em>Cut Corners on Brick</em></h2>
        <p class="sp-delay-sub">Brick installation looks simple. Get the mortar wrong, the base wrong, or the drainage wrong — and you're relooking at the wall in 5 years.</p>
      </div>

      <div class="sp-delay-cols">

        <!-- LEFT: dark stats sidebar -->
        <div class="sp-delay-sidebar">
          <p class="sp-delay-sidebar-label">The real cost of cutting corners</p>
          <div class="sp-delay-stats">
            <div class="sp-delay-stat">
              <span class="sp-delay-stat-val">$20k+</span>
              <span class="sp-delay-stat-desc">Average remediation cost when brick drainage is wrong from day one</span>
            </div>
            <div class="sp-delay-stat-sep"></div>
            <div class="sp-delay-stat">
              <span class="sp-delay-stat-val">9%</span>
              <span class="sp-delay-stat-desc">Water expands this much per freeze cycle inside a wall without weep holes</span>
            </div>
            <div class="sp-delay-stat-sep"></div>
            <div class="sp-delay-stat">
              <span class="sp-delay-stat-val">2–3</span>
              <span class="sp-delay-stat-desc">Seasons before foundation settling becomes visible in your brick courses</span>
            </div>
          </div>
          <a href="/contact#form" class="sp-delay-sidebar-cta">
            Get a free brick estimate
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M2.5 7H11.5M8 3.5L11.5 7L8 10.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>

        <!-- RIGHT: consequence list -->
        <div class="sp-delay-list">

          <div class="sp-delay-rule"></div>

          <div class="sp-delay-item">
            <div class="sp-delay-item-head">
              <div class="sp-delay-icon-wrap">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#B85C38" stroke-width="1.8" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              </div>
              <h3 class="sp-delay-title">Wrong Mortar Hardness → Cracks &amp; Spalling</h3>
            </div>
            <p class="sp-delay-text">Mortar too hard for your brick is the single most common installation mistake in Chicagoland. It looks fine for a few years — then freeze-thaw stress transfers to the brick face, spalling it from the inside.</p>
          </div>

          <div class="sp-delay-rule"></div>

          <div class="sp-delay-item">
            <div class="sp-delay-item-head">
              <div class="sp-delay-icon-wrap">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#B85C38" stroke-width="1.8" aria-hidden="true"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
              </div>
              <h3 class="sp-delay-title">No Drainage System → Water Buildup</h3>
            </div>
            <p class="sp-delay-text">Without weep holes and proper flashing, water collects behind the brick — saturating your wall cavity, rotting framing, and causing mold before you see any visible damage on the exterior.</p>
          </div>

          <div class="sp-delay-rule"></div>

          <div class="sp-delay-item">
            <div class="sp-delay-item-head">
              <div class="sp-delay-icon-wrap">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#B85C38" stroke-width="1.8" aria-hidden="true"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
              </div>
              <h3 class="sp-delay-title">Poor Foundation Prep → Settling &amp; Cracks</h3>
            </div>
            <p class="sp-delay-text">Brick is heavy. Lay it on an inadequately prepped base and it settles unevenly — cracking joints, shifting courses, and creating structural problems that only get worse over years.</p>
            <div class="sp-delay-chart" aria-label="Cost escalation timeline">
              <div class="sp-delay-chart-row">
                <span class="sp-delay-chart-stage">Now</span>
                <div class="sp-delay-chart-bar-wrap"><div class="sp-delay-chart-bar" style="--w:20%"></div></div>
                <span class="sp-delay-chart-cost">$</span>
                <span class="sp-delay-chart-note">Right materials</span>
              </div>
              <div class="sp-delay-chart-row">
                <span class="sp-delay-chart-stage">1–2 yrs</span>
                <div class="sp-delay-chart-bar-wrap"><div class="sp-delay-chart-bar" style="--w:42%"></div></div>
                <span class="sp-delay-chart-cost">$$</span>
                <span class="sp-delay-chart-note">Joint cracking</span>
              </div>
              <div class="sp-delay-chart-row">
                <span class="sp-delay-chart-stage">3–5 yrs</span>
                <div class="sp-delay-chart-bar-wrap"><div class="sp-delay-chart-bar" style="--w:68%"></div></div>
                <span class="sp-delay-chart-cost">$$$</span>
                <span class="sp-delay-chart-note">Brick spalling</span>
              </div>
              <div class="sp-delay-chart-row">
                <span class="sp-delay-chart-stage">5+ yrs</span>
                <div class="sp-delay-chart-bar-wrap"><div class="sp-delay-chart-bar" style="--w:100%"></div></div>
                <span class="sp-delay-chart-cost">$$$$</span>
                <span class="sp-delay-chart-note">Full redo</span>
              </div>
            </div>
          </div>

          <div class="sp-delay-rule"></div>

          <div class="sp-delay-item">
            <div class="sp-delay-item-head">
              <div class="sp-delay-icon-wrap">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#B85C38" stroke-width="1.8" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
              </div>
              <h3 class="sp-delay-title">Mismatched Materials → Visible Incompatibility</h3>
            </div>
            <p class="sp-delay-text">Mixing brick types or batches without careful matching creates obvious color and texture inconsistencies. Once the mortar cures, there's no fixing it — you're living with it or tearing it down.</p>
          </div>

          <div class="sp-delay-rule"></div>

        </div>
      </div>
    </div>
  </section>

  <!-- ─── 4. PROCESS ─── -->
  <section id="sp-prc-section" style="background:#ffffff; position:relative;">
    <div id="sp-prc-driver" style="position:relative; height:600vh;">
      <div id="sp-prc-sticky" style="position:sticky; top:0; height:100vh; display:flex; align-items:center; overflow:hidden;">
        <div class="sp-prc-grid">

          <!-- LEFT: heading + CTA -->
          <div id="sp-prc-left">
            <div style="display:flex; align-items:center; gap:8px; margin-bottom:20px;">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <rect x="1" y="1" width="5" height="5" rx="1" fill="#B85C38"/>
                <rect x="8" y="1" width="5" height="5" rx="1" fill="#B85C38" opacity="0.4"/>
                <rect x="1" y="8" width="5" height="5" rx="1" fill="#B85C38" opacity="0.4"/>
                <rect x="8" y="8" width="5" height="5" rx="1" fill="#B85C38"/>
              </svg>
              <span style="font-family:'Inter',sans-serif; font-size:11px; font-weight:700; letter-spacing:0.10em; color:#B85C38; text-transform:uppercase;">How We Work</span>
            </div>

            <h2 style="font-family:'Onest',sans-serif; font-size:clamp(36px,3.5vw,54px); font-weight:700; line-height:1.1; color:#16120F; letter-spacing:-0.02em; margin:0 0 20px;">Our Brick Installation<br>Process</h2>

            <p style="font-family:'Inter',sans-serif; font-size:16px; line-height:1.65; color:#6A625A; margin:0 0 36px;">No surprise crews. No hidden costs. You know exactly what happens at every step — and why.</p>

            <div class="sp-prc-desktop-cta">
              <a href="/contact#form"
                style="display:inline-flex; align-items:center; gap:8px; background:#B85C38; color:#fff; font-family:'Inter',sans-serif; font-size:15px; font-weight:500; padding:14px 26px; border-radius:12px; text-decoration:none; transition:background 0.2s;"
                onmouseenter="this.style.background='#8A3A22'"
                onmouseleave="this.style.background='#B85C38'">
                Get a free estimate
                <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                  <path d="M3 8h10M9 4l4 4-4 4" stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
              <p style="font-family:'Inter',sans-serif; font-size:11px; font-weight:700; letter-spacing:0.08em; color:#B85C38; text-transform:uppercase; margin:28px 0 0;">5 steps · 24 hrs to first visit</p>
            </div>
          </div>

          <!-- RIGHT: steps -->
          <div id="sp-prc-right">

            <div class="sp-prc-item" style="padding:14px 0; border-top:1px solid #E4E2DE;">
              <div style="display:flex; gap:20px; align-items:flex-start;">
                <span class="sp-prc-num" style="font-family:'Onest',sans-serif; font-size:40px; font-weight:700; color:#B85C38; opacity:0.22; line-height:1; min-width:52px; padding-top:2px; transition:opacity 0.3s;">01</span>
                <div style="flex:1;">
                  <h3 style="font-family:'Onest',sans-serif; font-size:15px; font-weight:700; color:#16120F; margin:0 0 7px; letter-spacing:0.04em; text-transform:uppercase;">Site &amp; Substrate Assessment</h3>
                  <p style="font-family:'Inter',sans-serif; font-size:13px; line-height:1.65; color:#4A433B; margin:0 0 10px;">We evaluate your foundation, existing substrate, and drainage conditions before a single brick is laid. This determines the right base preparation and drainage system.</p>
                  <div style="border-left:3px solid #B85C38; padding:8px 12px; background:rgba(184,92,56,0.05); border-radius:0 8px 8px 0;">
                    <p style="font-family:'Inter',sans-serif; font-size:12px; line-height:1.6; color:#4A433B; margin:0;"><strong style="color:#B85C38; font-weight:700;">Why it matters: </strong>Skipping this step is how brick walls end up settling, cracking, and failing within 5–10 years of installation. The base is invisible once built — so is the damage when it's wrong.</p>
                  </div>
                </div>
              </div>
            </div>

            <div class="sp-prc-item" style="padding:14px 0; border-top:1px solid #E4E2DE;">
              <div style="display:flex; gap:20px; align-items:flex-start;">
                <span class="sp-prc-num" style="font-family:'Onest',sans-serif; font-size:40px; font-weight:700; color:#B85C38; opacity:0.22; line-height:1; min-width:52px; padding-top:2px; transition:opacity 0.3s;">02</span>
                <div style="flex:1;">
                  <h3 style="font-family:'Onest',sans-serif; font-size:15px; font-weight:700; color:#16120F; margin:0 0 7px; letter-spacing:0.04em; text-transform:uppercase;">Mortar Selection &amp; Mix</h3>
                  <p style="font-family:'Inter',sans-serif; font-size:13px; line-height:1.65; color:#4A433B; margin:0 0 10px;">We select the correct mortar type for your brick — Type N, S, or M — based on the brick's density, location, and climate exposure. Every batch is mixed to consistent spec.</p>
                  <div style="border-left:3px solid #B85C38; padding:8px 12px; background:rgba(184,92,56,0.05); border-radius:0 8px 8px 0;">
                    <p style="font-family:'Inter',sans-serif; font-size:12px; line-height:1.6; color:#4A433B; margin:0;"><strong style="color:#B85C38; font-weight:700;">Why it matters: </strong>The wrong mortar hardness is the single biggest cause of premature brick failure. It's also invisible until it's too late — you won't see spalling for 3–5 years.</p>
                  </div>
                </div>
              </div>
            </div>

            <div class="sp-prc-item" style="padding:14px 0; border-top:1px solid #E4E2DE;">
              <div style="display:flex; gap:20px; align-items:flex-start;">
                <span class="sp-prc-num" style="font-family:'Onest',sans-serif; font-size:40px; font-weight:700; color:#B85C38; opacity:0.22; line-height:1; min-width:52px; padding-top:2px; transition:opacity 0.3s;">03</span>
                <div style="flex:1;">
                  <h3 style="font-family:'Onest',sans-serif; font-size:15px; font-weight:700; color:#16120F; margin:0 0 7px; letter-spacing:0.04em; text-transform:uppercase;">Weep Holes &amp; Flashing</h3>
                  <p style="font-family:'Inter',sans-serif; font-size:13px; line-height:1.65; color:#4A433B; margin:0 0 10px;">Before brick is laid, we install proper flashing at the base course and weep holes at regular intervals to allow moisture to escape the wall cavity.</p>
                  <div style="border-left:3px solid #B85C38; padding:8px 12px; background:rgba(184,92,56,0.05); border-radius:0 8px 8px 0;">
                    <p style="font-family:'Inter',sans-serif; font-size:12px; line-height:1.6; color:#4A433B; margin:0;"><strong style="color:#B85C38; font-weight:700;">Why it matters: </strong>Inspectors look for this. Builders who skip it create water damage that shows up 3–5 years later — after you've already closed on the project and the contractor is long gone.</p>
                  </div>
                </div>
              </div>
            </div>

            <div class="sp-prc-item" style="padding:14px 0; border-top:1px solid #E4E2DE;">
              <div style="display:flex; gap:20px; align-items:flex-start;">
                <span class="sp-prc-num" style="font-family:'Onest',sans-serif; font-size:40px; font-weight:700; color:#B85C38; opacity:0.22; line-height:1; min-width:52px; padding-top:2px; transition:opacity 0.3s;">04</span>
                <div style="flex:1;">
                  <h3 style="font-family:'Onest',sans-serif; font-size:15px; font-weight:700; color:#16120F; margin:0 0 7px; letter-spacing:0.04em; text-transform:uppercase;">Brick Laying &amp; Joint Tooling</h3>
                  <p style="font-family:'Inter',sans-serif; font-size:13px; line-height:1.65; color:#4A433B; margin:0 0 10px;">We lay brick in consistent courses, checking level and plumb at every stage. Mortar joints are tooled to the specified profile while still workable — not raked dry.</p>
                  <div style="border-left:3px solid #B85C38; padding:8px 12px; background:rgba(184,92,56,0.05); border-radius:0 8px 8px 0;">
                    <p style="font-family:'Inter',sans-serif; font-size:12px; line-height:1.6; color:#4A433B; margin:0;"><strong style="color:#B85C38; font-weight:700;">Why it matters: </strong>Joint tooling is what makes brick weathertight. A joint tooled properly sheds water. A joint raked too early or left untooled holds it — leading to freeze-thaw damage within seasons.</p>
                  </div>
                </div>
              </div>
            </div>

            <div class="sp-prc-item" style="padding:14px 0; border-top:1px solid #E4E2DE; border-bottom:1px solid #E4E2DE;">
              <div style="display:flex; gap:20px; align-items:flex-start;">
                <span class="sp-prc-num" style="font-family:'Onest',sans-serif; font-size:40px; font-weight:700; color:#B85C38; opacity:0.22; line-height:1; min-width:52px; padding-top:2px; transition:opacity 0.3s;">05</span>
                <div style="flex:1;">
                  <h3 style="font-family:'Onest',sans-serif; font-size:15px; font-weight:700; color:#16120F; margin:0 0 7px; letter-spacing:0.04em; text-transform:uppercase;">Cleanup &amp; Final Inspection</h3>
                  <p style="font-family:'Inter',sans-serif; font-size:13px; line-height:1.65; color:#4A433B; margin:0 0 10px;">We clean mortar haze off the brick face with appropriate acid wash, sweep the work area, and walk the completed installation with you before we close out.</p>
                  <div style="border-left:3px solid #B85C38; padding:8px 12px; background:rgba(184,92,56,0.05); border-radius:0 8px 8px 0;">
                    <p style="font-family:'Inter',sans-serif; font-size:12px; line-height:1.6; color:#4A433B; margin:0;"><strong style="color:#B85C38; font-weight:700;">Why it matters: </strong>Mortar residue left on brick permanently stains the face. The walk-through is your final check — we don't consider the job done until you do.</p>
                  </div>
                </div>
              </div>
            </div>

