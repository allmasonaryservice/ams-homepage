/* ─── 9.5. BEFORE / AFTER ─── */
.sp-ba { background: #16120F; padding: 100px 0; }
.sp-ba-inner { max-width: 1140px; margin: 0 auto; padding: 0 40px; }

/* Centered header */
.sp-ba-hdr { text-align: center; margin-bottom: 56px; }
.sp-ba-eyebrow { display: inline-flex; align-items: center; gap: 8px; margin-bottom: 20px; font-family: 'Inter', sans-serif; font-size: 11px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: #B85C38; }
.sp-ba-h2 { font-family: 'Onest', sans-serif; font-size: clamp(36px, 4vw, 56px); font-weight: 700; line-height: 1.1; letter-spacing: -0.025em; color: #ffffff; margin: 0 0 16px; }
.sp-ba-h2 em { font-style: normal; color: #ffffff; }
.sp-ba-sub { font-family: 'Inter', sans-serif; font-size: 15px; color: rgba(255,255,255,0.42); margin: 0; }

/* Slider stage */
.sp-ba-stage { width: 100%; }
.sp-ba-slider {
  position: relative; overflow: hidden;
  border-radius: 20px;
  height: clamp(360px, 52vh, 580px);
  cursor: ew-resize; user-select: none;
  box-shadow: 0 28px 90px rgba(0,0,0,0.65), 0 0 0 1px rgba(255,255,255,0.06);
}

/* Image layers */
.sp-ba-after, .sp-ba-before { position: absolute; inset: 0; }
.sp-ba-before { clip-path: inset(0 5% 0 0); }
.sp-ba-img { width: 100%; height: 100%; object-fit: cover; display: block; pointer-events: none; }

/* Glowing divider */
.sp-ba-line {
  position: absolute; top: 0; bottom: 0; left: 95%;
  width: 2px; background: rgba(255,255,255,0.96);
  transform: translateX(-50%); z-index: 10; pointer-events: none;
  box-shadow: 0 0 10px rgba(255,255,255,0.80), 0 0 36px rgba(255,255,255,0.22);
  transition: none;
}

/* Handle */
.sp-ba-handle {
  position: absolute; top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  width: 60px; height: 60px; border-radius: 50%;
  background: #ffffff;
  box-shadow: 0 4px 28px rgba(0,0,0,0.55), 0 0 0 4px rgba(255,255,255,0.15);
  display: flex; align-items: center; justify-content: center;
  pointer-events: none; will-change: transform;
}

/* Before / After pills */
.sp-ba-pill {
  position: absolute; top: 22px; z-index: 8;
  font-family: 'Inter', sans-serif; font-size: 11px; font-weight: 800;
  letter-spacing: 0.13em; text-transform: uppercase; color: #ffffff;
  background: rgba(22,18,15,0.68); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
  padding: 8px 18px; border-radius: 9px; pointer-events: none;
}
.sp-ba-pill--b { left: 22px; }
.sp-ba-pill--a { right: 22px; }

/* Bottom vignette + location */
.sp-ba-vignette {
  position: absolute; inset: 0; z-index: 6;
  background: linear-gradient(to bottom, transparent 50%, rgba(22,18,15,0.80) 100%);
  pointer-events: none;
}
.sp-ba-location {
  position: absolute; bottom: 22px; left: 50%; transform: translateX(-50%);
  z-index: 7; font-family: 'Inter', sans-serif; font-size: 12px;
  color: rgba(255,255,255,0.55); white-space: nowrap; pointer-events: none;
  letter-spacing: 0.02em;
}

/* Drag hint badge */
.sp-ba-drag-hint {
  position: absolute; bottom: 22px; right: 22px; z-index: 7;
  display: inline-flex; align-items: center; gap: 6px;
  font-family: 'Inter', sans-serif; font-size: 11px; color: rgba(255,255,255,0.50);
  pointer-events: none; opacity: 1; transition: opacity 0.4s ease;
}
.sp-ba-drag-hint.hidden { opacity: 0; }

/* Stats row */
.sp-ba-stats {
  display: flex; align-items: center; justify-content: center;
  margin-top: 52px;
  border: 1px solid rgba(255,255,255,0.08); border-radius: 18px;
  padding: 32px 48px;
}
.sp-ba-stat {
  display: flex; flex-direction: column; align-items: center;
  padding: 0 52px; text-align: center; flex: 1;
}
.sp-ba-stat strong {
  font-family: 'Onest', sans-serif; font-size: 36px; font-weight: 700;
  color: #B85C38; line-height: 1; display: block; margin-bottom: 8px;
}
.sp-ba-stat span {
  font-family: 'Inter', sans-serif; font-size: 13px; line-height: 1.5;
  color: rgba(255,255,255,0.42);
}
.sp-ba-stat-sep {
  width: 1px; height: 44px; background: rgba(255,255,255,0.10); flex-shrink: 0;
}

/* Responsive */
@media (max-width: 768px) {
  .sp-ba { padding: 72px 0; }
  .sp-ba-inner { padding: 0 20px; }
  .sp-ba-hdr { margin-bottom: 40px; }
  .sp-ba-slider { height: clamp(260px, 52vw, 400px); border-radius: 14px; }
  .sp-ba-handle { width: 50px; height: 50px; }
  .sp-ba-stats { padding: 24px 20px; flex-direction: column; gap: 0; }
  .sp-ba-stat { padding: 16px 0; }
  .sp-ba-stat-sep { width: 56px; height: 1px; }
  .sp-ba-stat strong { font-size: 28px; }
}
@media (max-width: 480px) {
  .sp-ba-hdr { margin-bottom: 28px; }
  .sp-ba-slider { height: 56vw; min-height: 220px; }
  .sp-ba-handle { width: 44px; height: 44px; }
  .sp-ba-pill { font-size: 10px; padding: 6px 13px; }
  .sp-ba-location { display: none; }
  .sp-ba-drag-hint { bottom: 14px; right: 14px; }
}

