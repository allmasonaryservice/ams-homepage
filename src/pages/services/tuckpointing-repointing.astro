  <style>
    /* ── TP HERO ── */
    .tp-hero { position: relative; width: 100%; height: 100svh; min-height: 600px; overflow: hidden; background: #16120F; display: flex; align-items: flex-end; justify-content: flex-start; }
    .tp-hero-base { position: absolute; inset: 0; background: #0D0A08; z-index: 0; }
    .tp-grid { position: absolute; inset: 0; z-index: 1; overflow: hidden; }
    .tp-grid-ink { position: absolute; inset: 0; background: #16120F; opacity: 0.55; z-index: 2; pointer-events: none; }
    .tp-vignette { display: none; }
    .tp-content { position: relative; z-index: 10; padding: 0 60px 72px 80px; pointer-events: none; max-width: 780px; margin-left: max(0px, calc((100vw - 1280px) / 2)); }
    .tp-label { display: inline-flex; align-items: center; gap: 12px; color: rgba(255,255,255,0.55); font-family: 'Inter', sans-serif; font-size: 11px; font-weight: 700; letter-spacing: 0.16em; text-transform: uppercase; margin-bottom: 20px; }
    .tp-label-line { display: block; width: 32px; height: 1px; background: currentColor; opacity: 0.7; }
    .tp-h1 { color: #FFFFFF; font-family: 'Onest', sans-serif; font-weight: 700; font-size: clamp(2.4rem, 5.5vw, 4.6rem); line-height: 1.0; letter-spacing: -0.03em; margin-bottom: 24px; }
    .tp-h1-row { display: block; overflow: hidden; padding-bottom: 0.06em; }
    .tp-h1-accent { color: #ffffff; font-style: normal; font-weight: 700; }
    .tp-sub { max-width: 520px; color: rgba(255,255,255,0.72); font-family: 'Inter', sans-serif; font-weight: 400; font-size: clamp(0.95rem, 1.4vw, 1.05rem); line-height: 1.65; margin-bottom: 28px; }
    .tp-btn-primary { background: #B85C38; color: #FFFFFF; border: none; }
    .tp-btn-primary .lh-btn-bg { background: #8A3A22; }
    .tp-btn-primary:hover { color: #FFFFFF; }
    .tp-btn-ghost { background: transparent; color: #F5F1E8; border: 1.5px solid rgba(245,241,232,0.22); }
    .tp-btn-ghost .lh-btn-bg { background: rgba(245,241,232,0.08); }
    .tp-btn-ghost:hover { color: #F5F1E8; border-color: rgba(245,241,232,0.4); }
    .tp-actions { pointer-events: auto; }
    .tp-badges .lh-badge { border-left: none; }
    .tp-badges .lh-badge strong { color: #B85C38; }
    .tp-badges .lh-badge span { color: rgba(255,255,255,0.5); }
    .tp-badge-sep { width: 1px; height: 28px; background: rgba(255,255,255,0.15); align-self: center; margin: 0 4px; }
    .tp-hero .lh-scroll { z-index: 20; }
    .tp-hero .lh-scroll-mouse { border-color: rgba(245,241,232,0.22); }
    .tp-hero .lh-scroll-dot { background: #B85C38; }
    .tp-hero .lh-scroll span { color: rgba(245,241,232,0.28); }
    @media (max-width: 900px) {
      .tp-content { padding: 0 24px 100px; margin-left: 0; }
      .tp-h1 { font-size: clamp(2.4rem, 10vw, 4rem); }
    }
    @media (max-width: 640px) {
      #tp-label, #tp-r1, #tp-r2, #tp-sub, #tp-act, #tp-bdg { opacity: 1 !important; transform: none !important; }
      .tp-h1 { font-size: clamp(2.2rem, 11vw, 3.5rem); }
    }
  </style>

  <script is:inline>
  (function () {
    function initTpHero() {
      var gsap = window.__gsap;
      if (!gsap) return;

      var gridEl  = document.getElementById('tp-grid');
      var heroEl  = document.getElementById('tp-hero');
      var labelEl = document.getElementById('tp-label');
      var r1El    = document.getElementById('tp-r1');
      var r2El    = document.getElementById('tp-r2');
      var subEl   = document.getElementById('tp-sub');
      var actEl   = document.getElementById('tp-act');
      var bdgEl   = document.getElementById('tp-bdg');
      if (!gridEl || !heroEl) return;

      gridEl.innerHTML = '';

      var BW = 160, BH = 58;
      var W  = window.innerWidth;
      var H  = window.innerHeight;
      var cols = Math.ceil(W / BW) + 1;
      var rows = Math.ceil(H / BH) + 1;
      var blocks = [];

      for (var r = 0; r < rows; r++) {
        var xOff = (r % 2 !== 0) ? -(BW / 2) : 0;
        for (var c = 0; c < cols; c++) {
          var bx = (c * BW) + xOff + 1;
          var by = r * BH + 1;
          var b  = document.createElement('div');
          b.style.cssText = [
            'position:absolute',
            'background-image:url(/images/tuckpointing-repointing/pexels/hero-desktop.webp)',
            'background-size:' + W + 'px ' + H + 'px',
            'background-position:-' + bx + 'px -' + by + 'px',
            'background-repeat:no-repeat',
            'width:'  + (BW - 2) + 'px',
            'height:' + (BH - 2) + 'px',
            'left:' + bx + 'px',
            'top:'  + by + 'px',
            'box-shadow:0 8px 24px rgba(0,0,0,0.85)'
          ].join(';');
          gridEl.appendChild(b);
          blocks.push(b);
        }
      }

      var quickTos = blocks.map(function (b, i) {
        return gsap.quickTo(b, 'x', { duration: 0.6 + (i % 8) * 0.08, ease: 'power2.out' });
      });
      var mults = blocks.map(function (b, i) { return 0.15 + (i % 7) * 0.06; });

      function shiftBlocks(clientX) {
        var bounds = heroEl.getBoundingClientRect();
        var relX = ((clientX - bounds.left) / bounds.width - 0.5) * 2;
        for (var i = 0; i < blocks.length; i++) { quickTos[i](relX * 22 * mults[i]); }
      }
      function resetBlocks() {
        for (var i = 0; i < blocks.length; i++) { quickTos[i](0); }
      }

      heroEl.addEventListener('mousemove',  function (e) { shiftBlocks(e.clientX); }, { passive: true });
      heroEl.addEventListener('mouseleave', resetBlocks);
      heroEl.addEventListener('touchmove',  function (e) { shiftBlocks(e.touches[0].clientX); }, { passive: true });
      heroEl.addEventListener('touchend',   resetBlocks, { passive: true });

      var scrEl = document.getElementById('tp-scroll');
      if (scrEl) {
        scrEl.addEventListener('click', function () {
          var next = document.querySelector('.sp-trust');
          if (next) next.scrollIntoView({ behavior: 'smooth' });
          else window.scrollTo({ top: window.innerHeight, behavior: 'smooth' });
        });
      }
    }

    if (window.__gsap) { initTpHero(); }
    else { window.addEventListener('animations:ready', initTpHero, { once: true }); }

    window.addEventListener('resize', function () {
      clearTimeout(window._tpHeroTimer);
      window._tpHeroTimer = setTimeout(initTpHero, 300);
    });
  }());
  </script>

  <!-- ─── 2. TRUST BAR ─── -->
  <section class="sp-trust">
    <div class="sp-trust-inner">
      <div class="sp-trust-item">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        Licensed &amp; Insured in Illinois
      </div>
      <div class="sp-trust-sep"></div>
      <div class="sp-trust-item">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        Free On-Site Estimates
      </div>
      <div class="sp-trust-sep"></div>
      <div class="sp-trust-item">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        Mortar Matched to Your Brick
      </div>
      <div class="sp-trust-sep"></div>
      <div class="sp-trust-item">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        19+ Years in Chicagoland
      </div>
    </div>
  </section>

  <!-- ─── 3. PROBLEM / CONSEQUENCE ─── -->
  <section class="sp-problem">
    <div class="sp-delay-inner">
      <div class="sp-delay-hdr">
        <div class="sp-section-label">Why It Matters</div>
        <h2 class="sp-delay-h2">The Threat of <em>Amateur Tuckpointing</em></h2>
        <p class="sp-delay-sub">Grinding out and replacing mortar seems simple, but in the hands of a subcontractor it becomes a disaster. Using the wrong cement ruins the structural breathability of a luxury facade, trapping moisture and permanently scarring the brick faces.</p>
      </div>
      <div class="sp-delay-cols">
        <div class="sp-delay-sidebar">
          <p class="sp-delay-sidebar-label">The AMS Preservation Method</p>
          <div class="sp-delay-stats">
            <div class="sp-delay-stat">
              <span class="sp-delay-stat-val">100%</span>
              <span class="sp-delay-stat-desc">Custom-blended mortar matching</span>
            </div>
            <div class="sp-delay-stat-sep"></div>
            <div class="sp-delay-stat">
              <span class="sp-delay-stat-val">Zero</span>
              <span class="sp-delay-stat-desc">Subcontractors touching your facade</span>
            </div>
            <div class="sp-delay-stat-sep"></div>
            <div class="sp-delay-stat">
              <span class="sp-delay-stat-val">19+</span>
              <span class="sp-delay-stat-desc">Years restoring Chicago's masonry</span>
            </div>
          </div>
          <a href="/contact#form" class="sp-delay-sidebar-cta">
            Request an evaluation
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M2.5 7H11.5M8 3.5L11.5 7L8 10.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>
        <div class="sp-delay-list">
          <div class="sp-delay-rule"></div>
          <div class="sp-delay-item">
            <div class="sp-delay-item-head">
              <div class="sp-delay-icon-wrap">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#B85C38" stroke-width="1.8" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              </div>
              <h3 class="sp-delay-title">Over-Hardened Mortar → Shattered Brick</h3>
            </div>
            <p class="sp-delay-text">Standard repairmen universally apply cheap Portland cement. On older estates, this traps moisture and forces the softer historic brick to shatter during winter freezes. We analyze and match the exact compressive strength required.</p>
          </div>
          <div class="sp-delay-rule"></div>
          <div class="sp-delay-item">
            <div class="sp-delay-item-head">
              <div class="sp-delay-icon-wrap">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#B85C38" stroke-width="1.8" aria-hidden="true"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
              </div>
              <h3 class="sp-delay-title">Sloppy Grinding → Permanent Scars</h3>
            </div>
            <p class="sp-delay-text">Rushed laborers use oversized grinders, slicing into the brick faces above and below the joint. Our master artisans utilize specialized diamond blades and hand chisels to preserve the pristine edge of your facade.</p>
          </div>
          <div class="sp-delay-rule"></div>
          <div class="sp-delay-item">
            <div class="sp-delay-item-head">
              <div class="sp-delay-icon-wrap">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#B85C38" stroke-width="1.8" aria-hidden="true"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
              </div>
              <h3 class="sp-delay-title">Smear Jobs → Institutional Ugly</h3>
            </div>
            <p class="sp-delay-text">Inexperienced subs simply wipe fresh mortar across the wall, leaving a messy white film that permanently clouds the masonry. We tool our joints cleanly and perform meticulous acid washes to restore the building's original brilliance.</p>
          </div>
          <div class="sp-delay-rule"></div>
          <div class="sp-delay-item">
            <div class="sp-delay-item-head">
              <div class="sp-delay-icon-wrap">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#B85C38" stroke-width="1.8" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
              </div>
              <h3 class="sp-delay-title">Shallow Removal → Repeated Failures</h3>
            </div>
            <p class="sp-delay-text">"Tuck and run" crews barely scratch the surface before applying new mud. This thin layer falls out within two years. We grind down a minimum of 3/4-inch to ensure the new mortar bonds permanently with the inner core.</p>
          </div>
          <div class="sp-delay-rule"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── 4. PROCESS ─── -->
  <section id="sp-prc-section" style="background:#ffffff; position:relative;">
    <div id="sp-prc-driver" style="position:relative; height:600vh;">
      <div id="sp-prc-sticky" style="position:sticky; top:0; height:100vh; display:flex; align-items:center; overflow:hidden;">
        <div class="sp-prc-grid">
          <div id="sp-prc-left">
            <div style="display:flex; align-items:center; gap:8px; margin-bottom:20px;">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <rect x="1" y="1" width="5" height="5" rx="1" fill="#B85C38"/>
                <rect x="8" y="1" width="5" height="5" rx="1" fill="#B85C38" opacity="0.4"/>
                <rect x="1" y="8" width="5" height="5" rx="1" fill="#B85C38" opacity="0.4"/>
                <rect x="8" y="8" width="5" height="5" rx="1" fill="#B85C38"/>
              </svg>
              <span style="font-family:'Inter',sans-serif; font-size:11px; font-weight:700; letter-spacing:0.10em; color:#B85C38; text-transform:uppercase;">How We Work</span>
            </div>
            <h2 style="font-family:'Onest',sans-serif; font-size:clamp(36px,3.5vw,54px); font-weight:700; line-height:1.1; color:#16120F; letter-spacing:-0.02em; margin:0 0 20px;">The Invisible<br>Restoration Protocol</h2>
            <p style="font-family:'Inter',sans-serif; font-size:16px; line-height:1.65; color:#6A625A; margin:0 0 36px;">We apply the same engineering discipline used in our custom home builds to restore the structural integrity of your aging facade.</p>
            <div class="sp-prc-desktop-cta">
              <a href="/contact#form" style="display:inline-flex; align-items:center; gap:8px; background:#B85C38; color:#fff; font-family:'Inter',sans-serif; font-size:15px; font-weight:500; padding:14px 26px; border-radius:12px; text-decoration:none; transition:background 0.2s;" onmouseenter="this.style.background='#8A3A22'" onmouseleave="this.style.background='#B85C38'">
                Schedule a diagnostic
                <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4" stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </a>
              <p style="font-family:'Inter',sans-serif; font-size:11px; font-weight:700; letter-spacing:0.08em; color:#B85C38; text-transform:uppercase; margin:28px 0 0;">5 phases · 1 standard of excellence</p>
            </div>
          </div>
          <div id="sp-prc-right">
            <div class="sp-prc-item" style="padding:14px 0; border-top:1px solid #E4E2DE;">
              <div style="display:flex; gap:20px; align-items:flex-start;">
                <span class="sp-prc-num" style="font-family:'Onest',sans-serif; font-size:40px; font-weight:700; color:#B85C38; opacity:0.22; line-height:1; min-width:52px; padding-top:2px;">01</span>
                <div style="flex:1;">
                  <h3 style="font-family:'Onest',sans-serif; font-size:15px; font-weight:700; color:#16120F; margin:0 0 7px; letter-spacing:0.04em; text-transform:uppercase;">Scientific Mortar Analysis</h3>
                  <p style="font-family:'Inter',sans-serif; font-size:13px; line-height:1.65; color:#4A433B; margin:0 0 10px;">We take samples of the original, failed mortar to determine its aggregate composition and compressive strength, formulating a custom Type O, N, or S mix that perfectly mimics the original.</p>
                  <div style="border-left:3px solid #B85C38; padding:8px 12px; background:rgba(184,92,56,0.05); border-radius:0 8px 8px 0;">
                    <p style="font-family:'Inter',sans-serif; font-size:12px; line-height:1.6; color:#4A433B; margin:0;"><strong style="color:#B85C38; font-weight:700;">Why it matters: </strong>A mismatched mortar doesn't just look bad; it causes structural spalling within a single Chicago winter.</p>
                  </div>
                </div>
              </div>
            </div>
            <div class="sp-prc-item" style="padding:14px 0; border-top:1px solid #E4E2DE;">
              <div style="display:flex; gap:20px; align-items:flex-start;">
                <span class="sp-prc-num" style="font-family:'Onest',sans-serif; font-size:40px; font-weight:700; color:#B85C38; opacity:0.22; line-height:1; min-width:52px; padding-top:2px;">02</span>
                <div style="flex:1;">
                  <h3 style="font-family:'Onest',sans-serif; font-size:15px; font-weight:700; color:#16120F; margin:0 0 7px; letter-spacing:0.04em; text-transform:uppercase;">Deep Structural Grinding</h3>
                  <p style="font-family:'Inter',sans-serif; font-size:13px; line-height:1.65; color:#4A433B; margin:0 0 10px;">Our in-house crew utilizes HEPA-filtered masonry saws to grind out the decayed joints uniformly to a minimum depth of 3/4-inch, exposing a solid base for the new mortar to grip.</p>
                  <div style="border-left:3px solid #B85C38; padding:8px 12px; background:rgba(184,92,56,0.05); border-radius:0 8px 8px 0;">
                    <p style="font-family:'Inter',sans-serif; font-size:12px; line-height:1.6; color:#4A433B; margin:0;"><strong style="color:#B85C38; font-weight:700;">Why it matters: </strong>Cutting corners here means the new mortar simply falls out. We grind deep.</p>
                  </div>
                </div>
              </div>
            </div>
            <div class="sp-prc-item" style="padding:14px 0; border-top:1px solid #E4E2DE;">
              <div style="display:flex; gap:20px; align-items:flex-start;">
                <span class="sp-prc-num" style="font-family:'Onest',sans-serif; font-size:40px; font-weight:700; color:#B85C38; opacity:0.22; line-height:1; min-width:52px; padding-top:2px;">03</span>
                <div style="flex:1;">
                  <h3 style="font-family:'Onest',sans-serif; font-size:15px; font-weight:700; color:#16120F; margin:0 0 7px; letter-spacing:0.04em; text-transform:uppercase;">Air Wash & Hydration</h3>
                  <p style="font-family:'Inter',sans-serif; font-size:13px; line-height:1.65; color:#4A433B; margin:0 0 10px;">We blast the joints with compressed air to remove all dust, then lightly hydrate the brick faces. This critical step prevents the dry brick from immediately sucking the moisture out of the new mortar.</p>
                  <div style="border-left:3px solid #B85C38; padding:8px 12px; background:rgba(184,92,56,0.05); border-radius:0 8px 8px 0;">
                    <p style="font-family:'Inter',sans-serif; font-size:12px; line-height:1.6; color:#4A433B; margin:0;"><strong style="color:#B85C38; font-weight:700;">Why it matters: </strong>Flash-drying mortar becomes brittle instantly. Proper hydration ensures a permanent cure.</p>
                  </div>
                </div>
              </div>
            </div>
            <div class="sp-prc-item" style="padding:14px 0; border-top:1px solid #E4E2DE;">
              <div style="display:flex; gap:20px; align-items:flex-start;">
                <span class="sp-prc-num" style="font-family:'Onest',sans-serif; font-size:40px; font-weight:700; color:#B85C38; opacity:0.22; line-height:1; min-width:52px; padding-top:2px;">04</span>
                <div style="flex:1;">
                  <h3 style="font-family:'Onest',sans-serif; font-size:15px; font-weight:700; color:#16120F; margin:0 0 7px; letter-spacing:0.04em; text-transform:uppercase;">Artisanal Repointing</h3>
                  <p style="font-family:'Inter',sans-serif; font-size:13px; line-height:1.65; color:#4A433B; margin:0 0 10px;">Our custom-home builders meticulously pack the custom-tinted mortar into the joints in multiple layers, striking it flush or concave to exactly match the existing architectural profile.</p>
                  <div style="border-left:3px solid #B85C38; padding:8px 12px; background:rgba(184,92,56,0.05); border-radius:0 8px 8px 0;">
                    <p style="font-family:'Inter',sans-serif; font-size:12px; line-height:1.6; color:#4A433B; margin:0;"><strong style="color:#B85C38; font-weight:700;">Why it matters: </strong>The repair must vanish. Our men are trained to replicate complex, historic joint strikes perfectly.</p>
                  </div>
                </div>
              </div>
            </div>
            <div class="sp-prc-item" style="padding:14px 0; border-top:1px solid #E4E2DE; border-bottom:1px solid #E4E2DE;">
              <div style="display:flex; gap:20px; align-items:flex-start;">
                <span class="sp-prc-num" style="font-family:'Onest',sans-serif; font-size:40px; font-weight:700; color:#B85C38; opacity:0.22; line-height:1; min-width:52px; padding-top:2px;">05</span>
                <div style="flex:1;">
                  <h3 style="font-family:'Onest',sans-serif; font-size:15px; font-weight:700; color:#16120F; margin:0 0 7px; letter-spacing:0.04em; text-transform:uppercase;">Final Acid Wash & Seal</h3>
                  <p style="font-family:'Inter',sans-serif; font-size:13px; line-height:1.65; color:#4A433B; margin:0 0 10px;">Once cured, we perform a controlled wash to remove any residual mortar haze from the brick faces, optionally applying a silane-siloxane penetrating sealer for ultimate weatherproofing.</p>
                  <div style="border-left:3px solid #B85C38; padding:8px 12px; background:rgba(184,92,56,0.05); border-radius:0 8px 8px 0;">
                    <p style="font-family:'Inter',sans-serif; font-size:12px; line-height:1.6; color:#4A433B; margin:0;"><strong style="color:#B85C38; font-weight:700;">Why it matters: </strong>We return your luxury property to a pristine, polished state without the messy white smears left by amateurs.</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

