---
import Layout from '../../layouts/Layout.astro';
  import { projects as allProjects } from '../../data/projects.js';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import MortarDamageAssessment from '../../components/magnets/MortarDamageAssessment.astro';

const siteUrl = 'https://allmasonryservices.com';
  const svcProjects = allProjects.filter(p => p.serviceSlug === 'tuckpointing-repointing').slice(0, 5);
const pageUrl = `${siteUrl}/services/tuckpointing-repointing`;

const faqItems = [
  {
    question: "How much does tuckpointing cost in Chicago?",
    answer: "Tuckpointing in Chicago typically costs $5–$25 per square foot depending on the extent of mortar damage, brick type, and accessibility. A standard chimney tuckpoint runs $300–$800. We provide free on-site estimates with no obligation — call 773-656-2107 to schedule."
  },
  {
    question: "How do I know if my home needs tuckpointing?",
    answer: "Look for crumbling or missing mortar joints, white chalky stains on brick (efflorescence), cracks wider than 1/4 inch, or mortar that crumbles when you press it. Chicago's freeze-thaw winters accelerate this damage — what looks minor in fall can become a serious water intrusion problem by spring."
  },
  {
    question: "What happens if I delay tuckpointing repairs?",
    answer: "Deteriorating mortar allows water to penetrate behind your brick. In Chicago's climate, that water freezes and expands every winter, cracking bricks from the inside. What starts as a $500 tuckpointing job can become a $5,000–$15,000 brick replacement project within 2–3 seasons of neglect."
  },
  {
    question: "How long does tuckpointing last?",
    answer: "Quality tuckpointing using correctly matched mortar lasts 20–30 years. The key is matching the mortar hardness to your brick — using a mortar that's too hard will crack the brick itself rather than flex with it. AMS matches every mortar mix to your specific brick type."
  },
  {
    question: "Can tuckpointing be done in winter in Chicago?",
    answer: "Tuckpointing requires temperatures above 40°F for mortar to cure properly. We typically work March through November in the Chicago area. If you're seeing damage now, schedule a spring appointment — we book up fast once the season starts."
  },
  {
    question: "What is the difference between tuckpointing and repointing?",
    answer: "Repointing means removing old mortar and replacing it — this is the core repair. Tuckpointing traditionally refers to a decorative technique with two-color mortar, but in the Chicago area both terms are used interchangeably to mean mortar joint repair. AMS does both structural repointing and decorative tuckpointing."
  },
  {
    question: "Is AMS licensed and insured for tuckpointing in Illinois?",
    answer: "Yes. All Masonry Services Inc is fully licensed and insured in Illinois. We carry general liability and workers' compensation insurance on every job. We're happy to provide proof of insurance before any work begins."
  },
  {
    question: "Do you offer free estimates for tuckpointing?",
    answer: "Yes — all estimates are free and come with no pressure or obligation. We assess the full scope of mortar damage, explain what needs to be done and why, and give you a written quote on the spot. Call 773-656-2107 or fill out our contact form."
  },
  {
    question: "Which mortar type does my home need — Type N, S, or M?",
    answer: "Type N (medium strength) is correct for above-grade exterior walls on most Chicago homes — flexible enough to move with brick without causing spalling. Type S is for below-grade and soil-contact work; Type M is for foundations and hardscape only. AMS matches every mortar mix to your specific brick type and location before touching your joints."
  }
];
---

<Layout
  title="Tuckpointing & Repointing Chicago | All Masonry Services"
  description="Professional tuckpointing and mortar repointing for Chicago and Chicagoland homes. 19+ years experience. Free estimates. Call 773-656-2107."
>
  <!-- Schema: Service -->
  <script is:inline type="application/ld+json">{JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Tuckpointing & Repointing in Chicago & Chicagoland",
    "description": "Professional tuckpointing and mortar repointing services for Chicago and Chicagoland homes. 19+ years experience, fully licensed and insured.",
    "url": pageUrl,
    "provider": { "@type": "Organization", "name": "All Masonry Services", "url": siteUrl },
    "areaServed": "Chicago, Chicagoland, IL",
    "serviceType": "Tuckpointing"
  })}</script>

  <!-- Schema: HowTo -->
  <script is:inline type="application/ld+json">{JSON.stringify({
    "@context": "https://schema.org",
    "@type": "HowTo",
    "name": "How Tuckpointing Works: AMS 5-Step Process",
    "description": "How professional tuckpointing and mortar repointing is done on Chicago and Chicagoland brick homes.",
    "step": [
      { "@type": "HowToStep", "position": 1, "name": "Free On-Site Assessment", "text": "We inspect your mortar joints, identify all areas of damage, and assess the depth of deterioration." },
      { "@type": "HowToStep", "position": 2, "name": "Mortar Matching", "text": "We match the new mortar to your existing joints — color, texture, and hardness." },
      { "@type": "HowToStep", "position": 3, "name": "Old Mortar Removal", "text": "We grind out deteriorated mortar to a depth of 3/4\"–1\" using angle grinders and chisels." },
      { "@type": "HowToStep", "position": 4, "name": "New Mortar Application", "text": "Fresh mortar is packed in layers — never in one shot, which causes shrinkage cracks." },
      { "@type": "HowToStep", "position": 5, "name": "Cleanup & Final Walk-Through", "text": "We clean mortar residue off the brick face, sweep the work area, and walk the job with you." }
    ]
  })}</script>

  <!-- Schema: FAQ -->
  <script is:inline type="application/ld+json">{JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqItems.map(item => ({
      "@type": "Question",
      "name": item.question,
      "acceptedAnswer": { "@type": "Answer", "text": item.answer }
    }))
  })}</script>

  <Navbar />

  <!-- ─── 1. HERO ─── -->
  <section class="tp-hero" id="tp-hero" aria-label="Tuckpointing &amp; Repointing hero">
    <div class="tp-hero-base" aria-hidden="true"></div>
    <div class="tp-grid" id="tp-grid" aria-hidden="true"></div>
    <div class="tp-grid-ink" aria-hidden="true"></div>
    <div class="tp-vignette" aria-hidden="true"></div>
    <div class="tp-content">
      <div class="tp-label" id="tp-label">
        <span class="tp-label-line" aria-hidden="true"></span>
        Tuckpointing &amp; Repointing · Chicago &amp; Chicagoland
      </div>
      <h1 class="tp-h1">
        <div class="tp-h1-row"><span id="tp-r1">Tuckpointing &amp; Repointing</span></div>
        <div class="tp-h1-row"><span id="tp-r2">in Chicago &amp; Chicagoland</span></div>
      </h1>
      <p class="tp-sub" id="tp-sub">
        We stop water infiltration before it becomes a brick replacement — with matched mortar, clean joints, and work that lasts 20–30 years.
      </p>
      <div class="lh-actions tp-actions" id="tp-act">
        <a href="/contact#form" class="lh-btn tp-btn-primary">
