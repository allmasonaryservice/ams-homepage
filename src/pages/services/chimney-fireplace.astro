      </div>
      <div class="sp-faqx-body">
        <nav class="sp-faqx-nav" id="faq-nav" aria-label="FAQ categories">
          <button class="sp-faqx-tab active" data-cat="problems" aria-selected="true"><span class="sp-faqx-tab-dot" aria-hidden="true"></span>Engineering</button>
          <button class="sp-faqx-tab" data-cat="cost" aria-selected="false"><span class="sp-faqx-tab-dot" aria-hidden="true"></span>Materials</button>
