/* Badges */
.lh-badges { display: flex; align-items: center; }
.lh-badge { display: flex; flex-direction: column; gap: 3px; padding: 0 22px; border-left: 1px solid rgba(22,18,15,0.12); }
.lh-badge:first-child { padding-left: 0; border-left: none; }
.lh-badge strong { font-family: 'Onest', sans-serif; font-size: 24px; font-weight: 800; color: #B85C38; line-height: 1; display: block; }
.lh-badge span { font-family: 'Inter', sans-serif; font-size: 9px; font-weight: 700; letter-spacing: 0.10em; text-transform: uppercase; color: #6A625A; }

/* RIGHT image grid */
.lh-right { position: relative; height: 600px; will-change: transform; }
.lh-mlines { position: absolute; inset: 0; width: 100%; height: 100%; z-index: 10; pointer-events: none; }
.lh-img { position: absolute; border-radius: 8px; overflow: hidden; will-change: transform; box-shadow: 0 4px 24px rgba(22,18,15,0.10); }
.lh-img-clip { width: 100%; height: 100%; overflow: hidden; border-radius: 8px; }
.lh-img-photo {
  width: 100%; height: 100%; object-fit: cover; display: block;
  transition: transform 0.65s cubic-bezier(0.4,0,0.2,1); will-change: transform;
}
.lh-img:hover .lh-img-photo { transform: scale(1.06); }
.lh-img--lg { top: 0; left: 0; right: 0; height: 57%; }
.lh-img--md { bottom: 0; left: 0; width: 56%; height: 39%; }
.lh-img--sm { bottom: 0; right: 0; width: 40%; height: 39%; }

/* Service label: slides up on hover */
.lh-img-label {
  position: absolute; bottom: 0; left: 0; right: 0;
  padding: 20px 16px 13px;
  background: linear-gradient(to top, rgba(22,18,15,0.82) 0%, transparent 100%);
  transform: translateY(100%); transition: transform 0.38s cubic-bezier(0.4,0,0.2,1);
  pointer-events: none;
}
.lh-img:hover .lh-img-label { transform: translateY(0); }
.lh-img-label span { font-family: 'Inter', sans-serif; font-size: 10px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: #D98E5F; }

/* Scroll cue */
.lh-scroll {
  position: absolute; bottom: 32px; left: 50%; transform: translateX(-50%);
  display: flex; flex-direction: column; align-items: center; gap: 9px;
  z-index: 3; cursor: pointer;
}
.lh-scroll-mouse { width: 21px; height: 33px; border: 1.5px solid rgba(22,18,15,0.2); border-radius: 11px; position: relative; }
.lh-scroll-dot {
  position: absolute; top: 5px; left: 50%; transform: translateX(-50%);
  width: 3px; height: 6px; background: #B85C38; border-radius: 2px;
  animation: lhScrollDot 1.9s ease-in-out infinite;
}
@keyframes lhScrollDot {
  0%  { opacity: 1; top: 5px; }
  60% { opacity: 0; top: 20px; }
  100% { opacity: 0; top: 20px; }
}
.lh-scroll span { font-family: 'Inter', sans-serif; font-size: 9px; font-weight: 700; letter-spacing: 0.17em; text-transform: uppercase; color: rgba(22,18,15,0.32); }

/* Mobile-only image — hidden on desktop */
.lh-mob-img { display: none; position: relative; }
.lh-mob-mlines { position: absolute; inset: 0; width: 100%; height: 100%; z-index: 2; pointer-events: none; }
.lh-mob-clip-wrap { width: 100%; height: 100%; overflow: hidden; border-radius: 12px; }

@media (prefers-reduced-motion: reduce) {
  .lh-p { animation: none; opacity: 0; }
  .lh-scroll-dot { animation: none; }
  .lh-h1-inner { clip-path: none !important; transform: none !important; }
  .lh-eyebrow { clip-path: none !important; }
  .lh-sub, .lh-actions, .lh-badges, .lh-h1-loc { opacity: 1 !important; transform: none !important; }
  .lh-img-clip { opacity: 1 !important; }
}

/* ─── 2. TRUST BAR ─── */
