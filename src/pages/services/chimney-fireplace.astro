.sp-why-title { font-family: 'Inter', sans-serif; font-size: 13px; font-weight: 700; color: #16120F; text-transform: uppercase; letter-spacing: 0.05em; margin: 0; }
.sp-why-body { font-family: 'Inter', sans-serif; font-size: 15px; color: #4A433B; line-height: 1.7; margin: 0; }

