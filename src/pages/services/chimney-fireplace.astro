.sp-tool-stat-sep { width: 1px; height: 36px; background: rgba(0,0,0,0.10); flex-shrink: 0; }
.sp-tool-quote { border-left: 3px solid #B85C38; margin: 0 0 36px 0; padding: 12px 20px; background: rgba(184,92,56,0.06); border-radius: 0 8px 8px 0; }
