}
.sp-delay-title {
  font-family: 'Onest', sans-serif; font-size: clamp(17px, 1.7vw, 20px);
  font-weight: 700; color: #16120F; margin: 0; line-height: 1.2;
}
.sp-delay-text {
  font-family: 'Inter', sans-serif; font-size: 14px; line-height: 1.75;
  color: #4A433B; margin: 0; max-width: 600px;
}
/* Cost chart */
.sp-delay-chart { margin-top: 24px; display: flex; flex-direction: column; gap: 12px; max-width: 500px; }
.sp-delay-chart-row { display: grid; grid-template-columns: 56px 1fr 36px 120px; align-items: center; gap: 10px; }
.sp-delay-chart-stage { font-family: 'Inter', sans-serif; font-size: 11px; font-weight: 600; color: #6A625A; text-transform: uppercase; letter-spacing: 0.05em; white-space: nowrap; }
.sp-delay-chart-bar-wrap { height: 5px; background: rgba(0,0,0,0.08); border-radius: 3px; overflow: hidden; }
.sp-delay-chart-bar { height: 100%; width: var(--w, 100%); background: #B85C38; border-radius: 3px; transform-origin: left center; }
.sp-delay-chart-cost { font-family: 'Inter', sans-serif; font-size: 11px; font-weight: 700; color: #B85C38; text-align: right; }
.sp-delay-chart-note { font-family: 'Inter', sans-serif; font-size: 11px; color: #6A625A; }
@media (max-width: 960px) {
  .sp-delay-cols { grid-template-columns: 1fr; gap: 48px; }
  .sp-delay-sidebar { position: static; }
}
@media (max-width: 640px) {
  .sp-problem { padding: 64px 0; }
  .sp-delay-inner { padding: 0 20px; }
  .sp-delay-hdr { margin-bottom: 40px; }
  .sp-delay-chart-row { grid-template-columns: 52px 1fr 30px; }
  .sp-delay-chart-note { display: none; }
}

