        </div>
        <h1 class="cfh-h1">
          <div class="cfh-h1-row"><span id="cfh-r1">Chimney &amp; Fireplace</span></div>
          <div class="cfh-h1-row"><span id="cfh-r2">in Chicago &amp; Chicagoland</span></div>
        </h1>
      </div>
      <!-- Body block: sub + actions + badges -->
      <div class="cfh-cb" id="cfh-cb">
        <p class="cfh-sub" id="cfh-sub">
          New chimney construction, fireplace masonry, and fireplace surround installation — built to code, built to last, and built to pass every inspection on the first visit.
        </p>
        <div class="lh-actions cfh-actions" id="cfh-act">
          <a href="/contact#form" class="lh-btn cfh-btn-primary">
            <span class="lh-btn-bg" aria-hidden="true"></span>
            <span class="lh-btn-label">Get a Free Estimate</span>
            <svg width="13" height="13" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <a href="tel:7736562107" class="lh-btn cfh-btn-ghost">
            <span class="lh-btn-bg" aria-hidden="true"></span>
            <span class="lh-btn-label">Call 773-656-2107</span>
          </a>
        </div>
        <div class="lh-badges cfh-badges" id="cfh-bdg">
          <div class="lh-badge"><strong>100+</strong><span>Projects Done</span></div>
          <div class="cfh-badge-sep" aria-hidden="true"></div>
          <div class="lh-badge"><strong>4.8★</strong><span>92 Google Reviews</span></div>
          <div class="cfh-badge-sep" aria-hidden="true"></div>
          <div class="lh-badge"><strong>19+</strong><span>Years Experience</span></div>
        </div>
      </div>
    </div>

    <div class="lh-scroll" id="cfh-scroll">
      <div class="lh-scroll-mouse"><div class="lh-scroll-dot"></div></div>
      <span>Scroll</span>
    </div>
  </section>

  <script is:inline>
  (function() {
    function initCfh() {
      var gsap = window.__gsap;
      if (!gsap) return;

      var container = document.getElementById('cfh-physics-container');
      if (!container) return;
      container.innerHTML = '';

      var W = 460, H = 540;
      var cols = 8, rows = 10;
      var blockW = W / cols;
      var blockH = H / rows;
      var blocks = [];

      for (var r = 0; r < rows; r++) {
        for (var c = 0; c < cols; c++) {
          var block = document.createElement('div');
          block.style.cssText = [
            'position:absolute',
            'width:' + blockW + 'px',
            'height:' + blockH + 'px',
            "background-image:url('/images/chimney-fireplace/pexels/hero-desktop.webp')",
            'background-size:' + W + 'px ' + H + 'px',
            'background-repeat:no-repeat',
            'background-position:-' + (c * blockW) + 'px -' + (r * blockH) + 'px',
            'left:' + (c * blockW) + 'px',
            'top:' + (r * blockH) + 'px'
          ].join(';');
          container.appendChild(block);
          blocks.push(block);
        }
      }

      gsap.set(blocks, { scale: 0.85, filter: 'brightness(0.9)' });

      var heroEl = document.getElementById('cfh-hero');

      var quickTos = blocks.map(function(b, i) {
        return gsap.quickTo(b, 'x', {
          duration: 0.6 + (i % 8) * 0.08,
          ease: 'power2.out'
        });
      });
      var mults = blocks.map(function(b, i) {
        return 0.15 + (i % 7) * 0.06;
      });

      function shiftBlocks(clientX) {
        var bounds = heroEl.getBoundingClientRect();
        var relX = ((clientX - bounds.left) / bounds.width - 0.5) * 2;
        for (var i = 0; i < blocks.length; i++) {
          quickTos[i](relX * 22 * mults[i]);
        }
      }
      function resetBlocks() {
        for (var i = 0; i < blocks.length; i++) { quickTos[i](0); }
      }

      heroEl.addEventListener('mousemove', function(e) { shiftBlocks(e.clientX); }, { passive: true });
      heroEl.addEventListener('mouseleave', resetBlocks);
      heroEl.addEventListener('touchmove', function(e) { shiftBlocks(e.touches[0].clientX); }, { passive: true });
      heroEl.addEventListener('touchend', resetBlocks, { passive: true });

      var scrEl = document.getElementById('cfh-scroll');
      if (scrEl) {
        scrEl.addEventListener('click', function() {
          var next = document.querySelector('.sp-trust');
          if (next) next.scrollIntoView({ behavior: 'smooth' });
          else window.scrollTo({ top: window.innerHeight, behavior: 'smooth' });
        });
      }
    }

    if (window.__gsap) { initCfh(); }
    else { window.addEventListener('animations:ready', initCfh, { once: true }); }

    window.addEventListener('resize', function() {
      clearTimeout(window._cfhTimer);
      window._cfhTimer = setTimeout(initCfh, 300);
    });
  })();
  </script>

  <!-- ─── 2. TRUST BAR ─── -->
  <section class="sp-trust">
    <div class="sp-trust-inner">
      <div class="sp-trust-item">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        Licensed &amp; Insured in Illinois
      </div>
      <div class="sp-trust-sep"></div>
      <div class="sp-trust-item">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        Free On-Site Estimates
      </div>
      <div class="sp-trust-sep"></div>
      <div class="sp-trust-item">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        Code-Compliant Installation
      </div>
      <div class="sp-trust-sep"></div>
      <div class="sp-trust-item">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        19+ Years in Chicagoland
      </div>
    </div>
  </section>

  <!-- ─── 3. PROBLEM / CONSEQUENCE ─── -->
  <section class="sp-problem">
    <div class="sp-delay-inner">
      <div class="sp-delay-hdr">
        <div class="sp-section-label">Why It Matters</div>
        <h2 class="sp-delay-h2">The Anatomy of a <em>Luxury Chimney & Fireplace</em></h2>
        <p class="sp-delay-sub">A custom fireplace isn't just a heat source; it's the architectural anchor of the home. Poor drafting, substandard masonry, and inadequate clearances can turn a centerpiece into a costly hazard.</p>
      </div>
      <div class="sp-delay-cols">
        <div class="sp-delay-sidebar">
          <p class="sp-delay-sidebar-label">The Master Builder Standard</p>
          <div class="sp-delay-stats">
            <div class="sp-delay-stat">
              <span class="sp-delay-stat-val">100%</span>
              <span class="sp-delay-stat-desc">Draft-tested architectural fireboxes</span>
            </div>
            <div class="sp-delay-stat-sep"></div>
            <div class="sp-delay-stat">
              <span class="sp-delay-stat-val">Zero</span>
              <span class="sp-delay-stat-desc">Subcontractors building your flue</span>
            </div>
            <div class="sp-delay-stat-sep"></div>
            <div class="sp-delay-stat">
              <span class="sp-delay-stat-val">19+</span>
              <span class="sp-delay-stat-desc">Years crafting Chicagoland centerpieces</span>
            </div>
          </div>
          <a href="/contact#form" class="sp-delay-sidebar-cta">
            Design your centerpiece
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M2.5 7H11.5M8 3.5L11.5 7L8 10.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>
        <div class="sp-delay-list">
          <div class="sp-delay-rule"></div>
          <div class="sp-delay-item">
            <div class="sp-delay-item-head">
              <div class="sp-delay-icon-wrap">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#B85C38" stroke-width="1.8" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              </div>
              <h3 class="sp-delay-title">Poor Draft Dynamics → Smoke Infiltration</h3>
            </div>
            <p class="sp-delay-text">Incorrect flue-to-firebox ratios push smoke back into your luxury living space. We calculate precise thermodynamic dimensions to guarantee a flawless upward draft every single fire.</p>
          </div>
          <div class="sp-delay-rule"></div>
          <div class="sp-delay-item">
            <div class="sp-delay-item-head">
              <div class="sp-delay-icon-wrap">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#B85C38" stroke-width="1.8" aria-hidden="true"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
              </div>
              <h3 class="sp-delay-title">Inferior Firebrick → Structural Cracking</h3>
            </div>
            <p class="sp-delay-text">Standard brick shatters under intense heat. We lay true refractory firebrick with specialized high-heat mortar, ensuring the core of your fireplace remains impenetrable and structurally sound.</p>
          </div>
          <div class="sp-delay-rule"></div>
          <div class="sp-delay-item">
            <div class="sp-delay-item-head">
              <div class="sp-delay-icon-wrap">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#B85C38" stroke-width="1.8" aria-hidden="true"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
              </div>
              <h3 class="sp-delay-title">Flawed Flashing → Roof Line Leaks</h3>
            </div>
            <p class="sp-delay-text">Where the chimney meets the roof is the most vulnerable point on a custom home. We install heavy-gauge custom saddle flashing that permanently diverts water away from the masonry.</p>
          </div>
          <div class="sp-delay-rule"></div>
          <div class="sp-delay-item">
            <div class="sp-delay-item-head">
              <div class="sp-delay-icon-wrap">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#B85C38" stroke-width="1.8" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
              </div>
              <h3 class="sp-delay-title">Asymmetrical Veneering → Ruined Aesthetics</h3>
            </div>
            <p class="sp-delay-text">A fireplace surround should be a work of art. Subpar masons rush the stone placement, creating awkward joints. Our artisans weave every stone symmetrically for a perfectly balanced visual impact.</p>
          </div>
          <div class="sp-delay-rule"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── 4. PROCESS ─── -->
  <section id="sp-prc-section" style="background:#ffffff; position:relative;">
    <div id="sp-prc-driver" style="position:relative; height:600vh;">
      <div id="sp-prc-sticky" style="position:sticky; top:0; height:100vh; display:flex; align-items:center; overflow:hidden;">
        <div class="sp-prc-grid">
          <div id="sp-prc-left">
            <div style="display:flex; align-items:center; gap:8px; margin-bottom:20px;">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <rect x="1" y="1" width="5" height="5" rx="1" fill="#B85C38"/>
                <rect x="8" y="1" width="5" height="5" rx="1" fill="#B85C38" opacity="0.4"/>
                <rect x="1" y="8" width="5" height="5" rx="1" fill="#B85C38" opacity="0.4"/>
                <rect x="8" y="8" width="5" height="5" rx="1" fill="#B85C38"/>
              </svg>
              <span style="font-family:'Inter',sans-serif; font-size:11px; font-weight:700; letter-spacing:0.10em; color:#B85C38; text-transform:uppercase;">How We Work</span>
            </div>
            <h2 style="font-family:'Onest',sans-serif; font-size:clamp(36px,3.5vw,54px); font-weight:700; line-height:1.1; color:#16120F; letter-spacing:-0.02em; margin:0 0 20px;">The Hearth & Stack<br>Construction Process</h2>
            <p style="font-family:'Inter',sans-serif; font-size:16px; line-height:1.65; color:#6A625A; margin:0 0 36px;">From drafting the interior firebox to capping the exterior crown, we build custom chimneys with zero margin for error.</p>
            <div class="sp-prc-desktop-cta">
              <a href="/contact#form" style="display:inline-flex; align-items:center; gap:8px; background:#B85C38; color:#fff; font-family:'Inter',sans-serif; font-size:15px; font-weight:500; padding:14px 26px; border-radius:12px; text-decoration:none; transition:background 0.2s;" onmouseenter="this.style.background='#8A3A22'" onmouseleave="this.style.background='#B85C38'">
                Discuss your blueprint
                <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4" stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </a>
              <p style="font-family:'Inter',sans-serif; font-size:11px; font-weight:700; letter-spacing:0.08em; color:#B85C38; text-transform:uppercase; margin:28px 0 0;">5 phases · Complete accountability</p>
            </div>
          </div>
          <div id="sp-prc-right">
            <div class="sp-prc-item" style="padding:14px 0; border-top:1px solid #E4E2DE;">
              <div style="display:flex; gap:20px; align-items:flex-start;">
                <span class="sp-prc-num" style="font-family:'Onest',sans-serif; font-size:40px; font-weight:700; color:#B85C38; opacity:0.22; line-height:1; min-width:52px; padding-top:2px;">01</span>
                <div style="flex:1;">
                  <h3 style="font-family:'Onest',sans-serif; font-size:15px; font-weight:700; color:#16120F; margin:0 0 7px; letter-spacing:0.04em; text-transform:uppercase;">Draft & Dimension Modeling</h3>
                  <p style="font-family:'Inter',sans-serif; font-size:13px; line-height:1.65; color:#4A433B; margin:0 0 10px;">Before any brick is laid, we calculate the exact flue-to-opening ratio, throat size, and smoke chamber angles required for the specific volume of your living room.</p>
                  <div style="border-left:3px solid #B85C38; padding:8px 12px; background:rgba(184,92,56,0.05); border-radius:0 8px 8px 0;">
                    <p style="font-family:'Inter',sans-serif; font-size:12px; line-height:1.6; color:#4A433B; margin:0;"><strong style="color:#B85C38; font-weight:700;">Critical detail: </strong>Physics drives a fireplace. Getting the math wrong at this stage guarantees a smoky, unusable room.</p>
                  </div>
                </div>
              </div>
            </div>
            <div class="sp-prc-item" style="padding:14px 0; border-top:1px solid #E4E2DE;">
              <div style="display:flex; gap:20px; align-items:flex-start;">
                <span class="sp-prc-num" style="font-family:'Onest',sans-serif; font-size:40px; font-weight:700; color:#B85C38; opacity:0.22; line-height:1; min-width:52px; padding-top:2px;">02</span>
                <div style="flex:1;">
                  <h3 style="font-family:'Onest',sans-serif; font-size:15px; font-weight:700; color:#16120F; margin:0 0 7px; letter-spacing:0.04em; text-transform:uppercase;">Firebox & Core Construction</h3>
                  <p style="font-family:'Inter',sans-serif; font-size:13px; line-height:1.65; color:#4A433B; margin:0 0 10px;">We lay the internal firebox using extreme-temperature refractory bricks and specialized heat-resistant mortar, parging the smoke chamber smooth to accelerate updraft velocity.</p>
                  <div style="border-left:3px solid #B85C38; padding:8px 12px; background:rgba(184,92,56,0.05); border-radius:0 8px 8px 0;">
                    <p style="font-family:'Inter',sans-serif; font-size:12px; line-height:1.6; color:#4A433B; margin:0;"><strong style="color:#B85C38; font-weight:700;">Critical detail: </strong>A smooth smoke chamber eliminates turbulence, pulling exhaust safely out of the home.</p>
                  </div>
                </div>
              </div>
            </div>
            <div class="sp-prc-item" style="padding:14px 0; border-top:1px solid #E4E2DE;">
              <div style="display:flex; gap:20px; align-items:flex-start;">
                <span class="sp-prc-num" style="font-family:'Onest',sans-serif; font-size:40px; font-weight:700; color:#B85C38; opacity:0.22; line-height:1; min-width:52px; padding-top:2px;">03</span>
                <div style="flex:1;">
                  <h3 style="font-family:'Onest',sans-serif; font-size:15px; font-weight:700; color:#16120F; margin:0 0 7px; letter-spacing:0.04em; text-transform:uppercase;">Flue Lining & Stack Build</h3>
