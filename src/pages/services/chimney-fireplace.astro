.sp-tool-quote  { opacity: 0; }
.sp-tool-embed  { opacity: 0; }
@media (prefers-reduced-motion: reduce) {
  .sp-tool-header, .sp-tool-social, .sp-tool-quote, .sp-tool-embed { opacity: 1; }
}
.sp-tool-h2 { font-family: 'Onest', sans-serif; font-size: clamp(28px, 3.5vw, 40px); font-weight: 700; color: #16120F; line-height: 1.2; margin: 0 0 16px 0; }
.sp-tool-h2 em { font-style: normal; color: #16120F; }
.sp-tool-sub { font-family: 'Inter', sans-serif; font-size: 16px; color: #6A625A; line-height: 1.75; margin: 0; }
.sp-tool-warning-hook {
