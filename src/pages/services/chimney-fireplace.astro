---
import Layout from '../../layouts/Layout.astro';
import { projects as allProjects } from '../../data/projects.js';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import ChimneyInspectionChecklist from '../../components/magnets/ChimneyInspectionChecklist.astro';

const siteUrl = 'https://allmasonryservices.com';
const svcProjects = allProjects.filter(p => p.serviceSlug === 'chimney-fireplace').slice(0, 5);
const pageUrl = `${siteUrl}/services/chimney-fireplace`;

const faqItems = [
  {
    question: "What is refractory mortar and why does it matter?",
    answer: "Refractory mortar is a heat-resistant mortar designed for fireplace temperatures (2,000°F+). Standard mortar fails at these temperatures — cracking joints, allowing heat to transfer to combustibles. Every AMS firebox uses refractory mortar, not standard mortar."
  },
  {
    question: "What is a chimney cricket?",
    answer: "A cricket is a small ridged structure installed behind a chimney to divert water around it rather than collecting at the chimney-roof junction. It's required by code on all chimneys over 30 inches wide. AMS installs crickets on every applicable chimney."
  },
  {
    question: "What is a chimney crown and why does it fail?",
    answer: "The crown is the concrete or mortar cap that seals the top of the chimney around the flue. Thin or flat crowns crack within 2–3 Chicago winters from freeze-thaw cycles. A proper crown is sloped, overhangs the brick face, and is cast in concrete — not mortar. AMS builds code-compliant crowns only."
  },
  {
    question: "How do I know if my chimney needs repair vs. full rebuild?",
    answer: "If deterioration is limited to mortar joints, crown, or cap — repair is typically appropriate. If the brick itself is spalling or the structure has moved, a partial or full rebuild may be necessary. AMS assesses on site and gives you an honest recommendation."
  },
  {
    question: "Do I need a permit to build or rebuild a chimney?",
    answer: "Yes — chimney construction and major repair requires a permit in most Chicagoland municipalities. AMS pulls all required permits, coordinates inspections, and maintains a clean inspection record."
  },
  {
    question: "How long does chimney construction take?",
    answer: "A new chimney construction takes 5–10 days depending on height and complexity. Chimney rebuild from the roofline takes 1–3 days. A fireplace surround installation runs 2–3 days."
  },
  {
    question: "Can you match existing brick on a chimney rebuild?",
    answer: "Yes — we source brick to match your existing chimney and exterior brick in color and texture. The goal is a rebuild that's visually indistinguishable from the original."
  },
  {
    question: "Is AMS licensed for fireplace and chimney construction?",
    answer: "Yes — licensed masonry contractor in Illinois (License #MA-104-018887), $2.5M liability, workers' comp. We pull permits and work above board on every job."
  }
];
---

<Layout
  title="Chimney & Fireplace Masonry Chicago | All Masonry Services"
  description="Professional chimney and fireplace masonry for Chicago and Chicagoland homes. New construction, rebuilds, fireplace surrounds, refractory work. 19+ years experience. Free estimates. Call 773-656-2107."
>
  <!-- Schema: Service -->
  <script is:inline type="application/ld+json">{JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Chimney & Fireplace Masonry in Chicago & Chicagoland",
    "description": "Professional chimney and fireplace masonry for Chicago and Chicagoland homes. New construction, rebuilds, fireplace surrounds, and refractory work. 19+ years experience, fully licensed and insured.",
    "url": pageUrl,
    "provider": { "@type": "Organization", "name": "All Masonry Services", "url": siteUrl },
    "areaServed": "Chicago, Chicagoland, IL",
    "serviceType": "Chimney and Fireplace Masonry"
  })}</script>

  <!-- Schema: HowTo -->
  <script is:inline type="application/ld+json">{JSON.stringify({
    "@context": "https://schema.org",
    "@type": "HowTo",
    "name": "How Chimney & Fireplace Masonry Works: AMS 5-Step Process",
    "description": "How professional chimney and fireplace masonry is done on Chicago and Chicagoland homes — from drawing review to final inspection.",
    "step": [
      { "@type": "HowToStep", "position": 1, "name": "Drawing Review & Code Check", "text": "We review your drawings against current IRC and local code — chimney height, clearances, flue sizing, and crown specifications — before any work begins." },
      { "@type": "HowToStep", "position": 2, "name": "Foundation & Footing Inspection", "text": "Chimney mass requires an engineered footing. We verify footing capacity and dimensions before constructing the chimney base." },
      { "@type": "HowToStep", "position": 3, "name": "Brick or Block Construction", "text": "We construct the chimney in planned courses — checking plumb at every lift, using correct mortar type for each application." },
      { "@type": "HowToStep", "position": 4, "name": "Crown, Cap & Flashing Installation", "text": "We pour or form a proper sloped crown, install a code-compliant cap, and flash the chimney-roof junction — including a cricket where required." },
      { "@type": "HowToStep", "position": 5, "name": "Firebox Completion & Final Inspection", "text": "We complete the firebox with refractory mortar, install damper, and conduct a final walk-through including flue visual check." }
    ]
  })}</script>

  <!-- Schema: FAQ -->
  <script is:inline type="application/ld+json">{JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqItems.map(item => ({
      "@type": "Question",
      "name": item.question,
      "acceptedAnswer": { "@type": "Answer", "text": item.answer }
    }))
  })}</script>

  <Navbar />

  <!-- ─── 1. HERO: CHIMNEY & FIREPLACE ─── -->
  <section class="cfh-hero" id="cfh-hero" aria-label="Chimney &amp; Fireplace hero">
    <div class="cfh-hero-base" aria-hidden="true"></div>

    <!-- Chimney-shaped image grid — right side -->
