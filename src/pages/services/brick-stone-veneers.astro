/* ─── 13. RELATED ─── */
.sp-related { background: #ffffff; padding: 0 12px 80px; }
.sp-related-dark {
  background: #16120F; border-radius: 24px;
  padding: 80px 40px; max-width: 1224px; margin: 0 auto;
}
.sp-related-hdr { margin-bottom: 56px; }
.sp-related-eyebrow { display: flex; align-items: center; gap: 8px; margin-bottom: 16px; }
.sp-related-eyebrow span { font-family: 'Inter',sans-serif; font-size: 11px; font-weight: 700; letter-spacing: 0.10em; color: #B85C38; text-transform: uppercase; }
.sp-related-heading { font-family: 'Onest',sans-serif; font-size: clamp(36px,4vw,54px); font-weight: 700; line-height: 1.1; letter-spacing: -0.02em; color: #ffffff; margin: 0; }
.sp-related-heading em { font-style: normal; color: #ffffff; }
/* Card grid */
.sp-rsvc-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
.sp-rsvc-card { background: #ffffff; border-radius: 20px; overflow: visible; text-decoration: none; display: flex; flex-direction: column; transition: transform 240ms ease, box-shadow 240ms ease; height: 100%; }
.sp-rsvc-card:hover { box-shadow: 0 16px 48px rgba(0,0,0,0.40); }
.sp-rsvc-img-wrap { position: relative; width: 100%; flex-shrink: 0; padding: 10px 10px 0; }
.sp-rsvc-img-clip { overflow: hidden; border-radius: 14px 14px 0 0; width: 100%; }
.sp-rsvc-img { width: 100%; height: 260px; object-fit: cover; display: block; transform: scale(1); transition: transform 500ms cubic-bezier(0.25,0.46,0.45,0.94); }
.sp-rsvc-card:hover .sp-rsvc-img { transform: scale(1.06); }
.sp-rsvc-notch { position: absolute; bottom: -1px; left: 50%; transform: translateX(-50%); z-index: 3; width: 160px; height: 40px; pointer-events: none; }
.sp-rsvc-notch-bg { position: absolute; inset: 0; width: 100%; height: 100%; }
.sp-rsvc-icon-inner { position: absolute; top: 6px; left: 50%; transform: translateX(-50%); display: flex; align-items: center; justify-content: center; }
.sp-rsvc-body { padding: 16px 20px 22px; display: flex; flex-direction: column; align-items: center; text-align: center; flex: 1; background: #ffffff; border-radius: 0 0 20px 20px; }
.sp-rsvc-title { font-family: 'Onest',sans-serif; font-size: 16px; font-weight: 700; color: #16120F; margin: 0 0 6px; line-height: 1.2; letter-spacing: -0.01em; transition: color 200ms ease; }
.sp-rsvc-card:hover .sp-rsvc-title { color: #B85C38; }
.sp-rsvc-desc { font-family: 'Inter',sans-serif; font-size: 13px; line-height: 1.5; color: #4A433B; margin: 0; max-width: 260px; }

/* ─── 14. CTA BANNER ─── */
.sp-cta-banner { background: linear-gradient(90deg, #16120F 0%, #6E2A19 40%, #B85C38 100%); padding: 80px 0; }
.sp-cta-banner-inner {
  max-width: 1200px; margin: 0 auto; padding: 0 30px;
  display: flex; align-items: center; justify-content: space-between; gap: 40px; flex-wrap: wrap;
}
.sp-cta-banner-h2 { font-family: 'Onest', sans-serif; font-size: clamp(28px, 3vw, 40px); font-weight: 700; color: #ffffff; margin: 0 0 10px 0; line-height: 1.2; }
.sp-cta-banner-sub { font-family: 'Inter', sans-serif; font-size: 16px; color: rgba(255,255,255,0.85); line-height: 1.6; margin: 0; max-width: 520px; }
.sp-cta-banner-actions { display: flex; gap: 14px; flex-wrap: wrap; flex-shrink: 0; }

/* ─── RESPONSIVE ─── */
@media (max-width: 1100px) {
  .sp-process-inner, .sp-why-inner,
  .sp-tool-inner, .sp-pricing-inner, .sp-reviews-inner,
  .sp-creds-inner, .sp-areas-inner,
