  .sp-cta-banner-inner { flex-direction: column; align-items: flex-start; }
  /* Mobile animation fix: never hide content behind opacity:0 on mobile */
  .sp-why-item { opacity: 1 !important; transform: translateY(0) !important; }
  #sp-rev-nbhd-area, .sp-rev-nbhd-card { opacity: 1 !important; transform: translateY(0) !important; }
  .sp-tool-header, .sp-tool-social, .sp-tool-quote, .sp-tool-embed { opacity: 1 !important; transform: none !important; }
}
@media (max-width: 640px) {
  .sp-process-inner, .sp-why-inner,
  .sp-tool-inner, .sp-pricing-inner, .sp-reviews-inner,
  .sp-creds-inner, .sp-areas-inner,
  .sp-cta-banner-inner { padding: 0 20px; }
  .sp-related { padding: 0 8px 48px; }
  .sp-related-dark { padding: 48px 20px; border-radius: 16px; }
  .sp-trust-inner { padding: 0 20px; }
  .lh-inner { padding: 88px 20px 60px; }
  .lh-right { height: 300px; }
  .lh-h1 { font-size: clamp(40px, 10.5vw, 60px); }
  .lh-sub { font-size: 15px; margin-bottom: 28px; }
  .lh-badge { padding: 0 14px; }
  .lh-badge strong { font-size: 20px; }
  /* Fix: guarantee card stack vertically on mobile */
  .sp-creds-guarantee { flex-direction: column; gap: 14px; padding: 20px; }
  .sp-guarantee-badge { white-space: normal; }
  /* Fix: tool section elements always visible on mobile — no GSAP opacity trap */
  .sp-tool-social, .sp-tool-quote, .sp-tool-embed { opacity: 1 !important; transform: none !important; }
  .sp-tool-stat-sep { display: none; }
  .sp-tool-social { gap: 20px; }
  .sp-process, .sp-why, .sp-tool,
  .sp-pricing, .sp-creds, .sp-areas { padding: 56px 0; }
  .sp-cta-banner { padding: 56px 0; }
  .sp-pricing-grid,
  .sp-creds-grid, .sp-rsvc-grid { grid-template-columns: 1fr; }
  .sp-step { grid-template-columns: 60px 1fr; }
  .sp-step-num { font-size: 24px; padding: 24px 0 24px 20px; }
  .sp-step-content { padding: 24px 20px 24px 0; }
  .lh-actions, .sp-cta-banner-actions { flex-direction: column; }
  .lh-btn { width: 100%; text-align: center; justify-content: center; }
  .sp-btn { width: 100%; text-align: center; }
}

/* ─── BV HERO — EXPLODED ANATOMY ─── */
.bv-hero {
  position: relative; width: 100%; height: 100svh; min-height: 600px;
  background: #16120F;
  display: grid; grid-template-columns: 1fr 1fr;
  grid-template-rows: 1fr auto auto 1fr;
  overflow: hidden;
}

/* Heading block — col 1, row 2 (spacer rows 1+4 center it) */
.bv-ct {
  grid-column: 1; grid-row: 2;
  position: relative; z-index: 10;
  display: flex; flex-direction: column; justify-content: flex-end; align-items: flex-start;
  padding: 0 40px 16px 80px; pointer-events: none;
  margin-left: max(0px, calc((100vw - 1280px) / 2));
}

/* Body block — col 1, row 3 */
.bv-cb {
  grid-column: 1; grid-row: 3;
  position: relative; z-index: 10;
  display: flex; flex-direction: column; justify-content: flex-start; align-items: flex-start;
  padding: 0 40px 0 80px; pointer-events: none;
  margin-left: max(0px, calc((100vw - 1280px) / 2));
}

/* 3D stage — RIGHT half, spans all 4 rows */
.bv-stage-wrap {
  grid-column: 2; grid-row: 1 / span 4;
  position: relative;
  display: flex; align-items: center; justify-content: flex-end;
  padding-right: 64px;
  perspective: 2200px; perspective-origin: 50% 50%;
}
.bv-stage {
  width: 310px; height: 68vh; min-height: 420px;
  transform-style: preserve-3d; flex-shrink: 0;
}
.bv-layer {
  position: absolute; inset: 0;
  transform-style: preserve-3d;
}
.bv-l1 { background: url(/images/brick-stone-veneers/bg-0-8354.webp) center/cover no-repeat; }
.bv-l2 { background: url(/images/brick-stone-veneers/bg-1-4407.webp) center/cover no-repeat; }
.bv-l3 { background: url(/images/brick-stone-veneers/bg-2-7148.webp) center/cover no-repeat; }
.bv-l4 { background: url(/images/brick-stone-veneers/pexels/hero-desktop.webp) center/cover no-repeat; }

/* Slab-thickness edge (left side now, rotated -90deg so it faces left) */
.bv-ledge {
  position: absolute; top: 0; left: -26px; width: 26px; height: 100%;
  transform-origin: right center; transform: rotateY(-90deg);
}
.bv-ledge-1 { background: url(/images/brick-stone-veneers/bg-0-8354.webp) center/cover no-repeat; filter: brightness(0.35); }
.bv-ledge-2 { background: url(/images/brick-stone-veneers/bg-1-4407.webp) center/cover no-repeat; filter: brightness(0.22); }
.bv-ledge-3 { background: url(/images/brick-stone-veneers/bg-2-7148.webp) center/cover no-repeat; filter: brightness(0.55); }
.bv-ledge-4 { background: url(/images/brick-stone-veneers/pexels/hero-desktop.webp) left/cover no-repeat; filter: brightness(0.3); }

/* Layer labels — left edge of stage-wrap (between content and stage) */
.bv-label-panel {
  position: absolute; left: 20px; top: 50%; transform: translateY(-50%);
  display: none; flex-direction: column; gap: 18px; pointer-events: none;
}
.bv-ltag { display: flex; align-items: center; gap: 8px; }
.bv-lnum {
  font-family: 'Onest', sans-serif; font-size: 11px; font-weight: 700;
  color: #B85C38; letter-spacing: 0.08em; flex-shrink: 0;
}
.bv-ltxt {
  font-family: 'Inter', sans-serif; font-size: 10px; font-weight: 700;
  letter-spacing: 0.13em; text-transform: uppercase;
  color: rgba(255,255,255,0.48); white-space: nowrap;
}

/* Eyebrow */
.bv-eyebrow {
  display: inline-flex; align-items: center; gap: 12px;
  font-family: 'Inter', sans-serif; font-size: 11px; font-weight: 700;
  letter-spacing: 0.16em; text-transform: uppercase;
  color: rgba(255,255,255,0.55); margin-bottom: 20px;
}
.bv-ey-line { display: block; width: 32px; height: 1px; background: rgba(255,255,255,0.3); flex-shrink: 0; }

/* Heading */
.bv-h1 {
  font-family: 'Onest', sans-serif; font-weight: 700;
  font-size: clamp(2.4rem, 5.5vw, 4.6rem); line-height: 1.0;
  letter-spacing: -0.03em; color: #FFFFFF; margin-bottom: 24px;
}
.bv-h1-row { display: block; overflow: hidden; padding-bottom: 0.06em; }
.bv-accent { color: #ffffff; font-style: normal; font-weight: 700; }

/* Subtitle */
.bv-sub {
  max-width: 480px; font-family: 'Inter', sans-serif;
  font-size: clamp(0.88rem, 1.2vw, 1.0rem);
  color: rgba(255,255,255,0.75); line-height: 1.7; margin-bottom: 28px;
}
.bv-actions { pointer-events: auto; margin-bottom: 24px; }

/* Ghost button — dark-bg */
.bv-btn-ghost {
  background: transparent; color: #FFFFFF;
  border: 1.5px solid rgba(255,255,255,0.35);
}
.bv-btn-ghost .lh-btn-bg { background: rgba(255,255,255,0.12); }
.bv-btn-ghost:hover { color: #FFFFFF; border-color: rgba(255,255,255,0.7); }

/* Badges — dark-bg */
.bv-badges { pointer-events: auto; }
.bv-badges .lh-badge { border-left-color: rgba(255,255,255,0.2); }
.bv-badges .lh-badge strong { color: #B85C38; }
.bv-badges .lh-badge span { color: rgba(255,255,255,0.6); }
.bv-badge-sep { width: 1px; height: 28px; background: rgba(255,255,255,0.2); align-self: center; margin: 0 4px; }

/* Scroll indicator — dark-bg */
.bv-scroll { z-index: 20; }
