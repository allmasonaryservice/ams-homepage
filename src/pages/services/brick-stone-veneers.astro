---
import Layout from '../../layouts/Layout.astro';
import { projects as allProjects } from '../../data/projects.js';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import VeneerCoverageCalculator from '../../components/magnets/VeneerCoverageCalculator.astro';

const siteUrl = 'https://allmasonryservices.com';
const svcProjects = allProjects.filter(p => p.serviceSlug === 'brick-stone-veneers').slice(0, 5);
const pageUrl = `${siteUrl}/services/brick-stone-veneers`;

const faqItems = [
  {
    question: "What's the difference between full-thickness masonry and veneer?",
    answer: "Full-thickness masonry (like a full brick wall) is structural — it carries load. Veneer is a facing material attached to a substrate — it's not structural. Veneer is lighter and faster to install, but requires a correct substrate system to last. AMS installs both."
  },
  {
    question: "Is brick veneer as durable as full brick?",
    answer: "Properly installed brick veneer — with correct waterproofing, lath, scratch coat, and movement joints — lasts as long as full brick. The failure mode for veneer is almost always the substrate system, not the brick itself."
  },
  {
    question: "Can veneer be installed on any wall?",
    answer: "Almost any wall can accept veneer with the right substrate prep. We assess each wall before recommending a veneer system — some substrates require reinforcement or additional waterproofing."
  },
  {
    question: "How thick is brick or stone veneer?",
    answer: "Thin veneer panels are typically 3/4\" to 1-1/4\" thick. Full veneer (adhered to substrate, not pinned) runs 1-1/4\" to 2\". AMS installs both thin-set and full-thickness adhered systems."
  },
  {
    question: "Do I need permits for veneer installation?",
    answer: "In most Chicagoland municipalities, veneer installation on a structure's exterior requires a permit. AMS pulls all required permits and schedules inspections — you don't have to manage that process."
  },
  {
    question: "How long does veneer installation take?",
    answer: "A feature wall or fireplace runs 1–2 days. A partial exterior takes 3–7 days. Full exterior veneer can run 1–3 weeks depending on size and pattern complexity."
  },
  {
    question: "What maintenance does brick or stone veneer require?",
    answer: "Brick veneer: inspect joints every 5–7 years, repoint any deteriorating areas, keep weep holes clear. Stone veneer: reseal every 5–7 years. Annual visual inspection is recommended in Chicago's climate."
  },
  {
    question: "Are you licensed and insured for veneer installation?",
    answer: "Yes — licensed in Illinois, $2.5M general liability, workers' comp on all crew. Proof of insurance available before work begins. We pull all required permits and schedule inspections."
  }
];
