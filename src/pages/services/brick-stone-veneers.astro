<Layout
  title="Brick & Stone Veneer Installation Chicago | All Masonry Services"
  description="Professional brick and stone veneer installation for Chicago and Chicagoland homes. Full system — barrier, lath, scratch coat, veneer, movement joints. 19+ years experience. Free estimates. Call 773-656-2107."
>
  <!-- Schema: Service -->
  <script is:inline type="application/ld+json">{JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Brick & Stone Veneer Installation in Chicago & Chicagoland",
    "description": "Professional brick and stone veneer installation for Chicago and Chicagoland homes. Full system installation — waterproofing barrier, lath, scratch coat, veneer, and movement joints. 19+ years experience, fully licensed and insured.",
    "url": pageUrl,
    "provider": { "@type": "Organization", "name": "All Masonry Services", "url": siteUrl },
    "areaServed": "Chicago, Chicagoland, IL",
    "serviceType": "Brick and Stone Veneer Installation"
  })}</script>

  <!-- Schema: HowTo -->
  <script is:inline type="application/ld+json">{JSON.stringify({
    "@context": "https://schema.org",
    "@type": "HowTo",
    "name": "How Brick & Stone Veneer Installation Works: AMS 5-Step Process",
    "description": "How professional brick and stone veneer installation is done on Chicago and Chicagoland homes — full system from substrate prep to final inspection.",
    "step": [
      { "@type": "HowToStep", "position": 1, "name": "Wall Assessment & Substrate Prep", "text": "We inspect the existing wall, assess the substrate, identify any moisture issues, and determine the correct waterproofing approach." },
      { "@type": "HowToStep", "position": 2, "name": "Waterproof Barrier & Lath Installation", "text": "We install the waterproofing membrane and attach metal lath fastened to studs — not just sheathing — for maximum adhesion." },
      { "@type": "HowToStep", "position": 3, "name": "Scratch Coat Application", "text": "We apply a consistent, properly cured scratch coat over the lath — the foundation every veneer panel bonds to." },
      { "@type": "HowToStep", "position": 4, "name": "Veneer Installation & Jointing", "text": "We set each veneer panel, tool joints while mortar is workable, and maintain consistent spacing and pattern throughout." },
      { "@type": "HowToStep", "position": 5, "name": "Movement Joints & Final Inspection", "text": "We install movement joints at corners and required intervals, then walk the entire installation with you before we leave." }
    ]
  })}</script>

  <!-- Schema: FAQ -->
  <script is:inline type="application/ld+json">{JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqItems.map(item => ({
      "@type": "Question",
      "name": item.question,
      "acceptedAnswer": { "@type": "Answer", "text": item.answer }
    }))
  })}</script>

