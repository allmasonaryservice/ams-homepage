    </div>

  </section>

  <script is:inline>
  (function() {
    function initBv() {
      var gsap = window.__gsap;
      var ST   = window.__ScrollTrigger;
      if (!gsap) return;
      if (window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

      var hero      = document.getElementById('bv-hero');
      var stage     = document.getElementById('bv-stage');
      var stageWrap = hero ? hero.querySelector('.bv-stage-wrap') : null;
      if (!hero || !stage) return;

      var layers = [
        document.getElementById('bv-l1'),
        document.getElementById('bv-l2'),
        document.getElementById('bv-l3'),
        document.getElementById('bv-l4')
      ].filter(Boolean);

      var tags = hero.querySelectorAll('.bv-ltag');

      /* ── Initial state: panels flat, content hidden ── */
      gsap.set(stage,  { rotationY: 0, x: 0 });
      gsap.set(layers, { z: 0 });
      gsap.set(tags,   { opacity: 0, x: 14 });
      /* ── 3D explosion timeline — shared by hover + scroll ── */
      var isMobile = window.innerWidth <= 900;
      var rotY  = isMobile ? -20  : -42;
      var xShift = isMobile ? '0%' : '-6%';
      var zStep  = isMobile ? 58   : 155;

      var explodeTl = gsap.timeline({ paused: true })
        .to(stage, { rotationY: rotY, x: xShift, duration: 0.75, ease: 'power3.inOut' }, 0)
        .to(layers, {
          z: function(i) { return i * zStep; },
          duration: 0.9, ease: 'expo.out', stagger: 0.08
        }, 0.1)
        .to(tags, { opacity: 1, x: 0, duration: 0.5, ease: 'power2.out', stagger: 0.08 }, 0.5);

      var isHovered  = false;
      var isScrolled = false;
      var autoPlaying = true; /* blocks hover/scroll until auto-expand finishes */

      function syncExplode() {
        if (autoPlaying) return;
        if (isHovered || isScrolled) {
          explodeTl.play();
        } else {
          explodeTl.reverse();
        }
      }

      /* ── Auto-expand on every page load (once) ── */
      explodeTl.eventCallback('onComplete', function() {
        autoPlaying = false; /* hand control to hover + scroll */
      });
      gsap.delayedCall(0.4, function() { explodeTl.play(); });

      /* ── Hover (desktop) / Tap (touch) ── */
      if (stageWrap) {
        var isTouch = ('ontouchstart' in window) || (navigator.maxTouchPoints > 0);
        if (isTouch) {
          /* Mobile: tap the stage to toggle open/close */
          stageWrap.addEventListener('click', function() {
            isHovered = !isHovered;
            syncExplode();
          });
        } else {
          stageWrap.addEventListener('mouseenter', function() { isHovered = true;  syncExplode(); });
          stageWrap.addEventListener('mouseleave', function() { isHovered = false; syncExplode(); });
        }
      }

      /* ── Scroll: open when scrolled, close when scrolled back up ── */
      if (ST) {
        gsap.registerPlugin(ST);
        ST.create({
          trigger: hero,
          start: 'top -20%',
          onEnter:     function() { isScrolled = true;  syncExplode(); },
          onLeaveBack: function() { isScrolled = false; syncExplode(); }
        });
      }

      /* ── Scroll cue click ── */
      var scrEl = document.getElementById('bv-scroll');
      if (scrEl) {
        scrEl.addEventListener('click', function() {
          var next = document.querySelector('.sp-trust');
          if (next) next.scrollIntoView({ behavior: 'smooth' });
          else window.scrollTo({ top: window.innerHeight, behavior: 'smooth' });
        });
      }
    }

    if (window.__gsap) { initBv(); }
    else { window.addEventListener('animations:ready', initBv, { once: true }); }
  })();
  </script>

  <!-- ─── 2. TRUST BAR ─── -->
  <section class="sp-trust">
    <div class="sp-trust-inner">
      <div class="sp-trust-item">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        Licensed &amp; Insured in Illinois
      </div>
      <div class="sp-trust-sep"></div>
      <div class="sp-trust-item">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        Free On-Site Estimates
      </div>
      <div class="sp-trust-sep"></div>
      <div class="sp-trust-item">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        Full System Veneer Installation
      </div>
      <div class="sp-trust-sep"></div>
      <div class="sp-trust-item">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        19+ Years in Chicagoland
      </div>
    </div>
  </section>

  <!-- ─── 3. PROBLEM / CONSEQUENCE ─── -->
  <section class="sp-problem">
    <div class="sp-delay-inner">
      <div class="sp-delay-hdr">
        <div class="sp-section-label">Why It Matters</div>
        <h2 class="sp-delay-h2">The Hidden Risks of <em>Subpar Veneer Application</em></h2>
        <p class="sp-delay-sub">Applying a veneer to a luxury home isn't just about sticking stone to a wall. It requires meticulous moisture management, perfect adhesion, and an eye for architectural flow. A poor job fails quickly.</p>
      </div>
      <div class="sp-delay-cols">
        <div class="sp-delay-sidebar">
          <p class="sp-delay-sidebar-label">The Veneer Master Standard</p>
          <div class="sp-delay-stats">
            <div class="sp-delay-stat">
              <span class="sp-delay-stat-val">100%</span>
              <span class="sp-delay-stat-desc">Directly employed veneer artisans</span>
            </div>
            <div class="sp-delay-stat-sep"></div>
            <div class="sp-delay-stat">
              <span class="sp-delay-stat-val">Zero</span>
              <span class="sp-delay-stat-desc">Reliance on third-party subcontractors</span>
            </div>
            <div class="sp-delay-stat-sep"></div>
            <div class="sp-delay-stat">
              <span class="sp-delay-stat-val">19+</span>
              <span class="sp-delay-stat-desc">Years delivering premium exteriors</span>
            </div>
          </div>
          <a href="/contact#form" class="sp-delay-sidebar-cta">
            Consult our estimators
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M2.5 7H11.5M8 3.5L11.5 7L8 10.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>
        <div class="sp-delay-list">
          <div class="sp-delay-rule"></div>
          <div class="sp-delay-item">
            <div class="sp-delay-item-head">
              <div class="sp-delay-icon-wrap">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#B85C38" stroke-width="1.8" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              </div>
              <h3 class="sp-delay-title">Adhesion Failure → Delamination</h3>
            </div>
            <p class="sp-delay-text">Incorrect scratch coats or rushed application leads to veneer pieces popping off within a few harsh winters. We guarantee a permanent bond through rigorous surface prep and premium bonding agents.</p>
          </div>
          <div class="sp-delay-rule"></div>
          <div class="sp-delay-item">
            <div class="sp-delay-item-head">
              <div class="sp-delay-icon-wrap">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#B85C38" stroke-width="1.8" aria-hidden="true"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
              </div>
              <h3 class="sp-delay-title">Trapped Moisture → Internal Rot</h3>
            </div>
            <p class="sp-delay-text">Without a proper rain screen and breathable barrier, veneer systems trap moisture against your home’s framing. Our advanced weatherproofing eliminates the risk of structural rot entirely.</p>
          </div>
          <div class="sp-delay-rule"></div>
          <div class="sp-delay-item">
            <div class="sp-delay-item-head">
              <div class="sp-delay-icon-wrap">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#B85C38" stroke-width="1.8" aria-hidden="true"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
              </div>
              <h3 class="sp-delay-title">Poor Patterning → Artificial Appearance</h3>
            </div>
            <p class="sp-delay-text">Inexperienced installers create repetitive, blocky patterns that look instantly artificial. Our artisans meticulously blend stone shapes and hues to emulate organic, natural formations perfectly.</p>
          </div>
          <div class="sp-delay-rule"></div>
          <div class="sp-delay-item">
            <div class="sp-delay-item-head">
              <div class="sp-delay-icon-wrap">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#B85C38" stroke-width="1.8" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
              </div>
              <h3 class="sp-delay-title">Joint Messiness → Degraded Value</h3>
            </div>
            <p class="sp-delay-text">Sloppy mortar joints ruin the high-end appeal of premium stone. We offer distinct, architect-approved joint styles—from dry-stack looks to overgrout—executed flawlessly across the entire facade.</p>
          </div>
          <div class="sp-delay-rule"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── 4. PROCESS ─── -->
  <section id="sp-prc-section" style="background:#ffffff; position:relative;">
    <div id="sp-prc-driver" style="position:relative; height:600vh;">
      <div id="sp-prc-sticky" style="position:sticky; top:0; height:100vh; display:flex; align-items:center; overflow:hidden;">
        <div class="sp-prc-grid">
          <div id="sp-prc-left">
            <div style="display:flex; align-items:center; gap:8px; margin-bottom:20px;">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <rect x="1" y="1" width="5" height="5" rx="1" fill="#B85C38"/>
                <rect x="8" y="1" width="5" height="5" rx="1" fill="#B85C38" opacity="0.4"/>
                <rect x="1" y="8" width="5" height="5" rx="1" fill="#B85C38" opacity="0.4"/>
                <rect x="8" y="8" width="5" height="5" rx="1" fill="#B85C38"/>
              </svg>
              <span style="font-family:'Inter',sans-serif; font-size:11px; font-weight:700; letter-spacing:0.10em; color:#B85C38; text-transform:uppercase;">How We Work</span>
            </div>
            <h2 style="font-family:'Onest',sans-serif; font-size:clamp(36px,3.5vw,54px); font-weight:700; line-height:1.1; color:#16120F; letter-spacing:-0.02em; margin:0 0 20px;">The Master Veneer<br>Application Process</h2>
            <p style="font-family:'Inter',sans-serif; font-size:16px; line-height:1.65; color:#6A625A; margin:0 0 36px;">An unyielding 5-step methodology designed specifically to give custom homes an enduring, natural stone aesthetic.</p>
            <div class="sp-prc-desktop-cta">
              <a href="/contact#form" style="display:inline-flex; align-items:center; gap:8px; background:#B85C38; color:#fff; font-family:'Inter',sans-serif; font-size:15px; font-weight:500; padding:14px 26px; border-radius:12px; text-decoration:none; transition:background 0.2s;" onmouseenter="this.style.background='#8A3A22'" onmouseleave="this.style.background='#B85C38'">
                Book an architecture review
                <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4" stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </a>
              <p style="font-family:'Inter',sans-serif; font-size:11px; font-weight:700; letter-spacing:0.08em; color:#B85C38; text-transform:uppercase; margin:28px 0 0;">Zero Subcontractors Used</p>
            </div>
          </div>
          <div id="sp-prc-right">
            <div class="sp-prc-item" style="padding:14px 0; border-top:1px solid #E4E2DE;">
              <div style="display:flex; gap:20px; align-items:flex-start;">
                <span class="sp-prc-num" style="font-family:'Onest',sans-serif; font-size:40px; font-weight:700; color:#B85C38; opacity:0.22; line-height:1; min-width:52px; padding-top:2px;">01</span>
                <div style="flex:1;">
                  <h3 style="font-family:'Onest',sans-serif; font-size:15px; font-weight:700; color:#16120F; margin:0 0 7px; letter-spacing:0.04em; text-transform:uppercase;">Substrate Readiness Check</h3>
                  <p style="font-family:'Inter',sans-serif; font-size:13px; line-height:1.65; color:#4A433B; margin:0 0 10px;">We verify that your framing, sheathing, and existing barriers can safely support the weight and moisture dynamics of a premium stone veneer.</p>
                  <div style="border-left:3px solid #B85C38; padding:8px 12px; background:rgba(184,92,56,0.05); border-radius:0 8px 8px 0;">
                    <p style="font-family:'Inter',sans-serif; font-size:12px; line-height:1.6; color:#4A433B; margin:0;"><strong style="color:#B85C38; font-weight:700;">Crucial step: </strong>Without a rock-solid foundation, the most expensive stone in the world will inevitably crack and fail.</p>
                  </div>
                </div>
              </div>
            </div>
            <div class="sp-prc-item" style="padding:14px 0; border-top:1px solid #E4E2DE;">
              <div style="display:flex; gap:20px; align-items:flex-start;">
                <span class="sp-prc-num" style="font-family:'Onest',sans-serif; font-size:40px; font-weight:700; color:#B85C38; opacity:0.22; line-height:1; min-width:52px; padding-top:2px;">02</span>
                <div style="flex:1;">
                  <h3 style="font-family:'Onest',sans-serif; font-size:15px; font-weight:700; color:#16120F; margin:0 0 7px; letter-spacing:0.04em; text-transform:uppercase;">Lath & Weatherproofing</h3>
                  <p style="font-family:'Inter',sans-serif; font-size:13px; line-height:1.65; color:#4A433B; margin:0 0 10px;">We install a dual-layer, commercial-grade moisture barrier and secure heavy-gauge metal lath to provide an unyielding grip for the scratch coat.</p>
