        </a>
      </div>
      <div class="lh-badges bv-badges" id="bv-bdg">
        <div class="lh-badge"><strong>100+</strong><span>Projects Done</span></div>
        <div class="bv-badge-sep" aria-hidden="true"></div>
        <div class="lh-badge"><strong>4.8★</strong><span>92 Google Reviews</span></div>
        <div class="bv-badge-sep" aria-hidden="true"></div>
