  <style>
    /* ── DB HERO ── */
    .db-hero { position: relative; width: 100%; height: 100svh; min-height: 600px; overflow: hidden; background: #16120F; display: flex; align-items: flex-end; justify-content: flex-start; }
    .db-hero-base { position: absolute; inset: 0; background: #0D0A08; z-index: 0; }
    .db-grid { position: absolute; inset: 0; z-index: 1; overflow: hidden; }
    .db-grid-ink { position: absolute; inset: 0; background: #16120F; opacity: 0.62; z-index: 2; pointer-events: none; }
    .db-vignette { display: none; }
    .db-content { position: relative; z-index: 10; padding: 0 60px 72px 80px; pointer-events: none; max-width: 780px; margin-left: max(0px, calc((100vw - 1280px) / 2)); }
    .db-label { display: inline-flex; align-items: center; gap: 12px; color: rgba(255,255,255,0.55); font-family: 'Inter', sans-serif; font-size: 11px; font-weight: 700; letter-spacing: 0.16em; text-transform: uppercase; margin-bottom: 20px; }
    .db-label-line { display: block; width: 32px; height: 1px; background: currentColor; opacity: 0.7; }
    .db-h1 { color: #FFFFFF; font-family: 'Onest', sans-serif; font-weight: 700; font-size: clamp(2.4rem, 5.5vw, 4.6rem); line-height: 1.0; letter-spacing: -0.03em; margin-bottom: 24px; }
    .db-h1-row { display: block; overflow: hidden; padding-bottom: 0.06em; }
    .db-h1-accent { color: #ffffff; font-style: normal; font-weight: 700; }
    .db-sub { max-width: 520px; color: rgba(255,255,255,0.72); font-family: 'Inter', sans-serif; font-weight: 400; font-size: clamp(0.95rem, 1.4vw, 1.05rem); line-height: 1.65; margin-bottom: 28px; }
    .db-btn-primary { background: #B85C38; color: #FFFFFF; border: none; }
    .db-btn-primary .lh-btn-bg { background: #8A3A22; }
    .db-btn-primary:hover { color: #FFFFFF; }
    .db-btn-ghost { background: transparent; color: #F5F1E8; border: 1.5px solid rgba(245,241,232,0.22); }
    .db-btn-ghost .lh-btn-bg { background: rgba(245,241,232,0.08); }
    .db-btn-ghost:hover { color: #F5F1E8; border-color: rgba(245,241,232,0.4); }
    .db-actions { pointer-events: auto; }
    .db-badges .lh-badge { border-left: none; }
    .db-badges .lh-badge strong { color: #B85C38; }
    .db-badges .lh-badge span { color: rgba(255,255,255,0.5); }
    .db-badge-sep { width: 1px; height: 28px; background: rgba(255,255,255,0.15); align-self: center; margin: 0 4px; }
    .db-hero .lh-scroll { z-index: 20; }
    .db-hero .lh-scroll-mouse { border-color: rgba(245,241,232,0.22); }
    .db-hero .lh-scroll-dot { background: #B85C38; }
    .db-hero .lh-scroll span { color: rgba(245,241,232,0.28); }
    @media (max-width: 900px) {
      .db-content { padding: 0 24px 100px; margin-left: 0; }
      .db-h1 { font-size: clamp(2.4rem, 10vw, 4rem); }
    }
    @media (max-width: 640px) {
      #db-label, #db-r1, #db-r2, #db-sub, #db-act, #db-bdg { opacity: 1 !important; transform: none !important; }
      .db-h1 { font-size: clamp(2.2rem, 11vw, 3.5rem); }
    }
  </style>

  <script is:inline>
  (function() {
    function initDb() {
      var gsap = window.__gsap;
      if (!gsap) return;

      var gridEl  = document.getElementById('db-grid');
      var heroEl  = document.getElementById('db-hero');
      var labelEl = document.getElementById('db-label');
      var r1El    = document.getElementById('db-r1');
      var r2El    = document.getElementById('db-r2');
      var subEl   = document.getElementById('db-sub');
      var actEl   = document.getElementById('db-act');
      var bdgEl   = document.getElementById('db-bdg');
      if (!gridEl || !heroEl) return;

      var BW = 160, BH = 58;
      var W  = window.innerWidth;
      var H  = window.innerHeight;
      var cols = Math.ceil(W / BW) + 1;
      var rows = Math.ceil(H / BH) + 1;
      var bricks = [];

      for (var r = 0; r < rows; r++) {
        var xOff = (r % 2 !== 0) ? -(BW / 2) : 0;
        for (var c = 0; c < cols; c++) {
          var bx = (c * BW) + xOff + 1;
          var by = r * BH + 1;
          var b  = document.createElement('div');
          b.style.cssText = [
            'position:absolute',
            'background-image:url(/images/damaged-brick-replacement/pexels/hero-desktop.webp)',
            'background-size:' + W + 'px ' + H + 'px',
            'background-position:-' + bx + 'px -' + by + 'px',
            'background-repeat:no-repeat',
            'width:' + (BW - 2) + 'px',
            'height:' + (BH - 2) + 'px',
            'left:' + bx + 'px',
            'top:' + by + 'px',
            'box-shadow:0 8px 24px rgba(0,0,0,0.85)'
          ].join(';');
          gridEl.appendChild(b);
          bricks.push(b);
        }
      }

      var quickTos = bricks.map(function(b, i) {
        return gsap.quickTo(b, 'x', { duration: 0.6 + (i % 8) * 0.08, ease: 'power2.out' });
      });
      var mults = bricks.map(function(b, i) { return 0.15 + (i % 7) * 0.06; });

      function shiftBricks(clientX) {
        var bounds = heroEl.getBoundingClientRect();
        var relX = ((clientX - bounds.left) / bounds.width - 0.5) * 2;
        for (var i = 0; i < bricks.length; i++) { quickTos[i](relX * 22 * mults[i]); }
      }
      function resetBricks() {
        for (var i = 0; i < bricks.length; i++) { quickTos[i](0); }
      }

      heroEl.addEventListener('mousemove', function(e) { shiftBricks(e.clientX); }, { passive: true });
      heroEl.addEventListener('mouseleave', resetBricks);
      heroEl.addEventListener('touchmove', function(e) { shiftBricks(e.touches[0].clientX); }, { passive: true });
      heroEl.addEventListener('touchend', resetBricks, { passive: true });

      var scrEl = document.getElementById('db-scroll');
      if (scrEl) {
        scrEl.addEventListener('click', function() {
          var next = document.querySelector('.sp-trust');
          if (next) next.scrollIntoView({ behavior: 'smooth' });
          else window.scrollTo({ top: window.innerHeight, behavior: 'smooth' });
        });
      }
    }
    if (window.__gsap) { initDb(); }
    else { window.addEventListener('animations:ready', initDb, { once: true }); }
  })();
  </script>

  <!-- ─── 2. TRUST BAR ─── -->
  <section class="sp-trust">
    <div class="sp-trust-inner">
      <div class="sp-trust-item">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        Licensed &amp; Insured in Illinois
      </div>
      <div class="sp-trust-sep"></div>
      <div class="sp-trust-item">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        Free On-Site Estimates
      </div>
      <div class="sp-trust-sep"></div>
      <div class="sp-trust-item">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        Precision Brick Matching
      </div>
      <div class="sp-trust-sep"></div>
      <div class="sp-trust-item">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        19+ Years in Chicagoland
      </div>
    </div>
  </section>

  <!-- ─── 3. PROBLEM / CONSEQUENCE ─── -->
  <section class="sp-problem">
    <div class="sp-delay-inner">
      <div class="sp-delay-hdr">
        <div class="sp-section-label">Why It Matters</div>
        <h2 class="sp-delay-h2">The Eyesore of <em>Mismatched Brick Repairs</em></h2>
        <p class="sp-delay-sub">Standard repairmen often grab whatever brick is cheapest at the local yard, resulting in a glaring, patchy facade that destroys your property's curb appeal. We treat brick replacement with the exact same material-sourcing rigor as a brand new custom home build.</p>
      </div>
      <div class="sp-delay-cols">
        <div class="sp-delay-sidebar">
          <p class="sp-delay-sidebar-label">The AMS Restoration Edge</p>
          <div class="sp-delay-stats">
            <div class="sp-delay-stat">
              <span class="sp-delay-stat-val">100%</span>
              <span class="sp-delay-stat-desc">Architectural color matching</span>
            </div>
            <div class="sp-delay-stat-sep"></div>
            <div class="sp-delay-stat">
              <span class="sp-delay-stat-val">Zero</span>
              <span class="sp-delay-stat-desc">Subcontractors handling your facade</span>
            </div>
            <div class="sp-delay-stat-sep"></div>
            <div class="sp-delay-stat">
              <span class="sp-delay-stat-val">19+</span>
              <span class="sp-delay-stat-desc">Years preserving Chicago's luxury homes</span>
            </div>
          </div>
          <a href="/contact#form" class="sp-delay-sidebar-cta">
            Request a facade review
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M2.5 7H11.5M8 3.5L11.5 7L8 10.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>
        <div class="sp-delay-list">
          <div class="sp-delay-rule"></div>
          <div class="sp-delay-item">
            <div class="sp-delay-item-head">
              <div class="sp-delay-icon-wrap">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#B85C38" stroke-width="1.8" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              </div>
              <h3 class="sp-delay-title">Spalling Bricks → Water Intrusion</h3>
            </div>
            <p class="sp-delay-text">When a brick face shears off, the porous interior acts like a sponge, driving moisture directly into your home's framing. We extract the damaged units completely, restoring the structural water barrier.</p>
          </div>
          <div class="sp-delay-rule"></div>
          <div class="sp-delay-item">
            <div class="sp-delay-item-head">
              <div class="sp-delay-icon-wrap">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#B85C38" stroke-width="1.8" aria-hidden="true"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
              </div>
              <h3 class="sp-delay-title">Incorrect Mortar → Accelerated Decay</h3>
            </div>
            <p class="sp-delay-text">Using modern, hard Portland cement on soft, historic brick forces the brick to crack under thermal expansion. We analyze your existing joints to mix the scientifically correct mortar ratio for a permanent fix.</p>
          </div>
          <div class="sp-delay-rule"></div>
          <div class="sp-delay-item">
            <div class="sp-delay-item-head">
              <div class="sp-delay-icon-wrap">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#B85C38" stroke-width="1.8" aria-hidden="true"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
              </div>
              <h3 class="sp-delay-title">Sloppy Sourcing → Visible Patches</h3>
            </div>
            <p class="sp-delay-text">A repair shouldn't look like a repair. Leveraging our custom-home supplier network, we aggressively source reclaimed or custom-dyed bricks so the replacement blends flawlessly with your original facade.</p>
          </div>
          <div class="sp-delay-rule"></div>
          <div class="sp-delay-item">
            <div class="sp-delay-item-head">
              <div class="sp-delay-icon-wrap">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#B85C38" stroke-width="1.8" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
              </div>
              <h3 class="sp-delay-title">Subcontracted Labor → Poor Execution</h3>
            </div>
            <p class="sp-delay-text">Many firms farm out small replacement jobs to inexperienced laborers. At AMS, the exact same master craftsmen who build our multi-million dollar custom homes execute your repairs.</p>
          </div>
          <div class="sp-delay-rule"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── 4. PROCESS ─── -->
  <section id="sp-prc-section" style="background:#ffffff; position:relative;">
    <div id="sp-prc-driver" style="position:relative; height:600vh;">
      <div id="sp-prc-sticky" style="position:sticky; top:0; height:100vh; display:flex; align-items:center; overflow:hidden;">
        <div class="sp-prc-grid">
          <div id="sp-prc-left">
            <div style="display:flex; align-items:center; gap:8px; margin-bottom:20px;">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <rect x="1" y="1" width="5" height="5" rx="1" fill="#B85C38"/>
                <rect x="8" y="1" width="5" height="5" rx="1" fill="#B85C38" opacity="0.4"/>
                <rect x="1" y="8" width="5" height="5" rx="1" fill="#B85C38" opacity="0.4"/>
                <rect x="8" y="8" width="5" height="5" rx="1" fill="#B85C38"/>
              </svg>
              <span style="font-family:'Inter',sans-serif; font-size:11px; font-weight:700; letter-spacing:0.10em; color:#B85C38; text-transform:uppercase;">How We Work</span>
            </div>
            <h2 style="font-family:'Onest',sans-serif; font-size:clamp(36px,3.5vw,54px); font-weight:700; line-height:1.1; color:#16120F; letter-spacing:-0.02em; margin:0 0 20px;">The Invisible<br>Replacement Process</h2>
            <p style="font-family:'Inter',sans-serif; font-size:16px; line-height:1.65; color:#6A625A; margin:0 0 36px;">We don't just patch walls. We surgically extract decayed masonry and blend in perfect replacements with architectural precision.</p>
            <div class="sp-prc-desktop-cta">
              <a href="/contact#form" style="display:inline-flex; align-items:center; gap:8px; background:#B85C38; color:#fff; font-family:'Inter',sans-serif; font-size:15px; font-weight:500; padding:14px 26px; border-radius:12px; text-decoration:none; transition:background 0.2s;" onmouseenter="this.style.background='#8A3A22'" onmouseleave="this.style.background='#B85C38'">
                Schedule an assessment
                <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4" stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </a>
              <p style="font-family:'Inter',sans-serif; font-size:11px; font-weight:700; letter-spacing:0.08em; color:#B85C38; text-transform:uppercase; margin:28px 0 0;">5 phases · Zero compromises</p>
            </div>
          </div>
          <div id="sp-prc-right">
            <div class="sp-prc-item" style="padding:14px 0; border-top:1px solid #E4E2DE;">
              <div style="display:flex; gap:20px; align-items:flex-start;">
                <span class="sp-prc-num" style="font-family:'Onest',sans-serif; font-size:40px; font-weight:700; color:#B85C38; opacity:0.22; line-height:1; min-width:52px; padding-top:2px;">01</span>
