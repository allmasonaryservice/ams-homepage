---
import Layout from '../../layouts/Layout.astro';
import { projects as allProjects } from '../../data/projects.js';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import BrickDamageCounter from '../../components/magnets/BrickDamageCounter.astro';

const siteUrl = 'https://allmasonryservices.com';
const svcProjects = allProjects.filter(p => p.serviceSlug === 'damaged-brick-replacement').slice(0, 5);
const pageUrl = `${siteUrl}/services/damaged-brick-replacement`;

const faqItems = [
  {
    question: "How do I know if my brick needs to be replaced or just repaired?",
    answer: "If the brick face is spalling (layers separating), cracked through more than 1/3 of its depth, or showing interior erosion — replacement is the right call. Hairline surface cracks that haven't penetrated deeply may be sealed rather than replaced. AMS assesses on site and tells you honestly which approach applies."
  },
  {
    question: "Why does my brick keep spalling?",
    answer: "In Chicago's climate, spalling is caused by water infiltration followed by freeze-thaw expansion — usually entering through deteriorated mortar joints. AMS evaluates mortar condition at the same time as brick damage and addresses both to prevent recurrence."
  },
  {
    question: "Can you match old or discontinued brick?",
    answer: "Often yes — we work with a network of brick suppliers including reclaimed brick sources that specialize in matching older Chicago-area housing stock. Some discontinued styles aren't matchable, and we'll tell you that upfront rather than install something visibly different."
  },
  {
    question: "How long does brick replacement take?",
    answer: "Minor repairs (under 10 bricks) run half a day to a day. Moderate repairs (10–50 bricks) take 1–2 days. Extensive replacement (50+ bricks) may run 3–5 days depending on sourcing and access."
  },
  {
    question: "How do you remove damaged bricks without damaging surrounding ones?",
    answer: "We use angle grinders to cut through mortar joints and chisels to carefully extract the brick — working outward from the brick center to avoid stress to adjacent units. This is slower than aggressive removal but preserves the surrounding wall."
  },
  {
    question: "Can damaged brick replacement improve my home's value?",
    answer: "Yes — visible brick damage is flagged on home inspections and creates negative first impressions. Pre-sale brick repair consistently shows a positive ROI in the Chicagoland market. Many of our clients do brick work specifically before listing."
  },
  {
    question: "Do you replace brick on commercial properties?",
    answer: "Yes — AMS does damaged brick replacement on commercial buildings as well as residential. Commercial brick replacement involves the same process but may require special access equipment and after-hours work."
  },
  {
    question: "Is AMS licensed and insured for brick replacement work?",
    answer: "Yes — licensed masonry contractor in Illinois, $2.5M general liability, workers' comp. Free estimates — call 773-656-2107 to schedule an on-site assessment."
  }
];
---

<Layout
  title="Damaged Brick Replacement Chicago | All Masonry Services"
  description="Spalled, cracked, or structurally compromised bricks replaced and matched to your existing Chicago-area facade. Precise brick matching, free estimates, 19+ years."
>
  <!-- Schema: Service -->
  <script is:inline type="application/ld+json">{JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Damaged Brick Replacement in Chicago & Chicagoland",
    "description": "Spalled, cracked, or structurally compromised bricks replaced and matched to your existing facade. 19+ years experience, fully licensed and insured.",
    "url": pageUrl,
    "provider": { "@type": "Organization", "name": "All Masonry Services", "url": siteUrl },
    "areaServed": "Chicago, Chicagoland, IL",
    "serviceType": "Damaged Brick Replacement"
  })}</script>

  <!-- Schema: HowTo -->
  <script is:inline type="application/ld+json">{JSON.stringify({
    "@context": "https://schema.org",
    "@type": "HowTo",
    "name": "How Damaged Brick Replacement Works: AMS 5-Step Process",
    "description": "How professional damaged brick replacement is done on Chicago and Chicagoland homes.",
    "step": [
      { "@type": "HowToStep", "position": 1, "name": "Damage Assessment & Brick Matching", "text": "We assess all damaged bricks, identify the extent of structural impact, and source matching bricks in color, texture, and size before any removal begins." },
      { "@type": "HowToStep", "position": 2, "name": "Controlled Removal", "text": "We remove damaged bricks with angle grinders and chisels — carefully, to avoid disturbing adjacent sound bricks or mortar joints that don't need replacement." },
      { "@type": "HowToStep", "position": 3, "name": "Substrate Inspection", "text": "Once bricks are removed, we inspect the substrate, wall cavity, and mortar bed for moisture damage or structural issues before placing replacement bricks." },
      { "@type": "HowToStep", "position": 4, "name": "Replacement Brick Setting & Mortar Matching", "text": "We set replacement bricks in correctly matched mortar — type, color, and texture — and tool joints to match the existing profile." },
      { "@type": "HowToStep", "position": 5, "name": "Cleanup & Final Walk-Through", "text": "We clean mortar residue from surrounding brick, sweep the work area, and walk the repair with you. The standard: you shouldn't be able to tell which bricks were replaced." }
    ]
  })}</script>

  <!-- Schema: FAQ -->
  <script is:inline type="application/ld+json">{JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqItems.map(item => ({
      "@type": "Question",
      "name": item.question,
      "acceptedAnswer": { "@type": "Answer", "text": item.answer }
    }))
  })}</script>

  <Navbar />

  <!-- ─── 1. HERO ─── -->
