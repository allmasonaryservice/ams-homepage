  <!-- ─── HERO ANIMATION — CUSTOM HOME MASONRY ─── -->
  <script is:inline>
  (function() {

    function initChm() {
      var gsap = window.__gsap;
      var ST   = window.__ScrollTrigger;
      if (!gsap || !ST) return;

      gsap.registerPlugin(ST);

      var keyStone = document.getElementById('chm-key-stone');
      var keyBg    = document.getElementById('chm-key-bg');
      var keyLabel = document.getElementById('chm-key-label');
      var r1       = document.getElementById('chm-r1');
      var r2       = document.getElementById('chm-r2');
      var subEl    = document.getElementById('chm-sub');
      var actEl    = document.getElementById('chm-act');
      var bdgEl    = document.getElementById('chm-bdg');

      /* Initial states set via GSAP (no inline CSS transform conflicts) */
      if (keyStone) gsap.set(keyStone, { rotation: 35, y: -20, transformOrigin: 'top center' });
      if (keyBg)    gsap.set(keyBg,    { scale: 1.1, opacity: 0.06 });
      if (keyLabel) gsap.set(keyLabel, { y: 40, opacity: 0 });

      var heroEl = document.getElementById('sp-hero');
      var tl = gsap.timeline();

      /* Keystone swings in — pendulum elastic physics */
      if (keyStone) {
        tl.to(keyStone, { rotation: 0, y: 0, duration: 2.5, ease: 'elastic.out(1, 0.4)' }, 0);
      }

      /* Background texture subtly reveals as keystone locks (ink overlay stays dark) */
      if (keyBg) {
        tl.to(keyBg, { opacity: 0.32, scale: 1, duration: 1.5, ease: 'power2.out' }, 1.0);
      }

      /* Label slides up as keystone begins to land */
      if (keyLabel) {
        tl.to(keyLabel, { y: 0, opacity: 1, duration: 0.8, ease: 'power2.out' }, 0.8);
      }

      /* Interactive pendulum — enabled after entry animation completes */
      tl.call(function() {
        if (!keyStone || !heroEl) return;
        var qRot = gsap.quickTo(keyStone, 'rotation', { duration: 1.1, ease: 'power3.out' });
        var isMouseOver = false;

        /* Mouse: cursor X → left-right pendulum swing (±12°) */
        heroEl.addEventListener('mousemove', function(e) {
          isMouseOver = true;
          var bounds = heroEl.getBoundingClientRect();
          var relX = ((e.clientX - bounds.left) / bounds.width - 0.5) * 2;
          qRot(relX * 12);
        }, { passive: true });

        heroEl.addEventListener('mouseleave', function() {
          isMouseOver = false;
          qRot(0);
        });

        /* Scroll: sine-wave swing as hero scrolls through viewport (±8°) */
        window.addEventListener('scroll', function() {
          if (isMouseOver) return;
          var scrollY = window.scrollY;
          var heroH = heroEl.offsetHeight;
          if (scrollY < heroH) {
            var norm = scrollY / heroH;
            qRot(Math.sin(norm * Math.PI * 4) * 8);
          }
        }, { passive: true });
      }, null, 2.6);

      /* Vertical parallax on keystone as page scrolls */
      if (keyStone && heroEl) {
        gsap.to(keyStone, {
          y: -60, ease: 'none',
          scrollTrigger: { trigger: heroEl, start: 'top top', end: 'bottom top', scrub: 1.5 }
        });
      }

      /* Scroll cue click */
      var scrEl = document.getElementById('lh-scroll');
      if (scrEl) {
        scrEl.addEventListener('click', function() {
          var next = document.querySelector('.sp-trust');
          if (next) next.scrollIntoView({ behavior: 'smooth' });
          else window.scrollTo({ top: window.innerHeight, behavior: 'smooth' });
        });
      }
    }

    if (window.__gsap && window.__ScrollTrigger) { initChm(); }
    else { window.addEventListener('animations:ready', initChm, { once: true }); }

  })();
  </script>

