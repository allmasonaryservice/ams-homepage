---
import Layout from '../../layouts/Layout.astro';
  import { projects as allProjects } from '../../data/projects.js';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import CustomHomeMasonryPlanner from '../../components/magnets/CustomHomeMasonryPlanner.astro';

const siteUrl = 'https://allmasonryservices.com';
  const svcProjects = allProjects.filter(p => p.serviceSlug === 'custom-home-masonry').slice(0, 5);
const pageUrl = `${siteUrl}/services/custom-home-masonry`;

const faqItems = [
  { question: "What masonry work does AMS do on custom homes?", answer: "AMS handles full-scope masonry for custom homes — exterior brick and stone facades, fireplaces, chimneys, retaining walls, limestone accents, and feature walls. We work with architects, builders, and homeowners throughout Chicagoland from design through final inspection." },
  { question: "How early in the build should I involve a masonry contractor?", answer: "Ideally at the design stage — before drawings are finalized. Material selection affects window placement, lintel sizing, foundation loads, and construction sequencing. Getting us involved early prevents costly change orders and delays once framing starts." },
  { question: "What is the difference between brick, stone, and limestone for a custom home?", answer: "Brick is the most cost-effective and weather-durable option — classic Chicago aesthetic, low maintenance. Limestone is warm, refined, and works with both modern and traditional architecture. Natural stone is a premium option requiring expert installation and careful mortar selection. We help you choose based on style, site exposure, and budget." },
  { question: "Do you work with custom home builders and GCs?", answer: "Yes — the majority of our custom home work comes through builders and general contractors. We are used to coordinating with construction schedules, providing lien waivers, and working within a builder's punch list process. We will integrate cleanly with your project team." },
  { question: "How long does exterior masonry take on a custom home?", answer: "A full exterior brick facade on a custom home typically runs 3–6 weeks depending on size and complexity. Stone and limestone work can take longer due to custom cutting and fitting. We provide a detailed schedule at the estimate stage so your builder can plan sequencing." },
  { question: "Do you pull permits for custom home masonry?", answer: "Yes. Structural masonry on new construction requires permits in most Chicagoland municipalities. We pull all required permits, schedule inspections, and maintain a clean inspection record on every job." },
  { question: "What geographic areas do you serve for custom home projects?", answer: "We work throughout Chicagoland — from Chicago proper to the North Shore, western suburbs, and surrounding communities. For large custom home projects, we have worked as far as 60 miles from the city. Call us to discuss your project location." },
  { question: "Can AMS help with both exterior masonry and interior features like fireplaces?", answer: "Yes — we are a full-scope masonry contractor. Many custom home clients have us handle everything: exterior brick, stone facade accents, fireplace surrounds, chimney construction, and outdoor masonry elements like retaining walls and patios. One contractor, one accountability line." }
];
---

<Layout
  title="Custom Home Masonry Chicago | All Masonry Services"
  description="Full-scope masonry for custom home builds in Chicagoland — brick, stone, limestone, fireplaces, chimneys. 19+ years working with builders. Free estimates. Call 773-656-2107."
>
  <!-- Schema: Service -->
  <script is:inline type="application/ld+json">{JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Custom Home Masonry in Chicago & Chicagoland",
    "description": "Full-scope custom home masonry services — brick facades, natural stone, limestone, fireplaces, chimneys, and retaining walls. 19+ years working with Chicagoland builders.",
    "url": pageUrl,
    "provider": { "@type": "Organization", "name": "All Masonry Services", "url": siteUrl },
    "areaServed": "Chicago, Chicagoland, IL",
    "serviceType": "Custom Home Masonry"
  })}</script>

  <!-- Schema: HowTo -->
  <script is:inline type="application/ld+json">{JSON.stringify({
    "@context": "https://schema.org",
    "@type": "HowTo",
    "name": "How Custom Home Masonry Works: AMS 5-Step Process",
    "description": "How AMS delivers full-scope masonry for custom home builds in Chicagoland.",
    "step": [
      { "@type": "HowToStep", "position": 1, "name": "Design Collaboration", "text": "We work directly with your architect or builder at the design stage — reviewing drawings, suggesting materials, and flagging structural or logistical issues before construction starts." },
      { "@type": "HowToStep", "position": 2, "name": "Material Selection & Sourcing", "text": "We help you select the right brick, stone, or limestone for your home's style, climate exposure, and budget. We source materials and confirm availability before the project is scheduled." },
      { "@type": "HowToStep", "position": 3, "name": "Foundation & Substrate Prep", "text": "Every masonry installation starts with the foundation. We verify structural capacity, install weep holes and flashing, and prep substrates to code — work that's invisible but load-bearing." },
      { "@type": "HowToStep", "position": 4, "name": "Full Masonry Installation", "text": "Our crew installs the full scope — brick walls, stone facades, fireplaces, chimneys, retaining walls — according to approved drawings, with daily progress photos shared with your builder." },
      { "@type": "HowToStep", "position": 5, "name": "Final Inspection & Walk-Through", "text": "We complete a joint inspection with your builder before any final payments are released. Every item on the punch list is resolved. No open items, no arguments." }
    ]
  })}</script>

  <!-- Schema: FAQ -->
  <script is:inline type="application/ld+json">{JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqItems.map(item => ({
      "@type": "Question",
      "name": item.question,
      "acceptedAnswer": { "@type": "Answer", "text": item.answer }
    }))
  })}</script>

  <Navbar />

  <!-- ─── 1. HERO — KEYSTONE PENDULUM ─── -->
  <section class="chm-hero" id="sp-hero" aria-label="Custom Home Masonry hero">

    <!-- Background: AMS ink dark base with subtle stone texture -->
    <div class="chm-key-bg" id="chm-key-bg" style="background-image: url('/images/chm-hero/chm-main.webp');" aria-hidden="true"></div>
    <div class="chm-key-bg-ink" aria-hidden="true"></div>

    <!-- The keystone pendulum mask (different image for contrast) -->
    <div class="chm-key-wrap" aria-hidden="true">
      <div class="chm-key-stone" id="chm-key-stone" style="background-image: url('/images/chm-hero/chm-finish.webp');">
        <div class="chm-key-overlay"></div>
        <div class="chm-key-border"></div>
      </div>
    </div>

    <!-- Bottom gradient so text is always readable -->
    <div class="chm-key-vignette" aria-hidden="true"></div>

    <!-- Content pinned to bottom -->
    <div class="chm-key-content">

      <div class="chm-key-label" id="chm-key-label">
        <span class="chm-key-label-line" aria-hidden="true"></span>
        Custom Home Masonry · Chicago &amp; Chicagoland
      </div>

      <h1 class="chm-h1">
        <div class="chm-h1-row"><span id="chm-r1">Custom Home Masonry</span></div>
        <div class="chm-h1-row"><span id="chm-r2">in Chicago &amp; Chicagoland</span></div>
      </h1>

      <p class="chm-sub" id="chm-sub">
        Brick facades, natural stone accents, limestone details, fireplaces, chimneys — full-scope masonry for custom home builds, delivered on schedule and built to code.
      </p>

      <div class="lh-actions" id="chm-act">
        <a href="/contact#form" class="lh-btn chm-btn-primary">
          <span class="lh-btn-bg" aria-hidden="true"></span>
          <span class="lh-btn-label">Get a Free Estimate</span>
          <svg width="13" height="13" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <a href="tel:7736562107" class="lh-btn chm-btn-ghost">
          <span class="lh-btn-bg" aria-hidden="true"></span>
          <span class="lh-btn-label">Call 773-656-2107</span>
        </a>
      </div>

      <div class="lh-badges chm-badges" id="chm-bdg">
        <div class="lh-badge">
          <strong>500+</strong>
          <span>Homes Completed</span>
        </div>
        <div class="lh-badge-sep chm-badge-sep" aria-hidden="true"></div>
        <div class="lh-badge">
          <strong>4.8★</strong>
          <span>92 Google Reviews</span>
        </div>
        <div class="lh-badge-sep chm-badge-sep" aria-hidden="true"></div>
        <div class="lh-badge">
          <strong>19+</strong>
          <span>Years Experience</span>
        </div>
      </div>

    </div>

    <!-- Scroll cue -->
    <div class="lh-scroll" id="lh-scroll">
      <div class="lh-scroll-mouse"><div class="lh-scroll-dot"></div></div>
      <span>Scroll</span>
    </div>

  </section>

  <!-- ─── 2. TRUST BAR ─── -->
  <section class="sp-trust">
    <div class="sp-trust-inner">
      <div class="sp-trust-item">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        Licensed &amp; Insured in Illinois
      </div>
      <div class="sp-trust-sep"></div>
      <div class="sp-trust-item">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        Free On-Site Estimates
      </div>
      <div class="sp-trust-sep"></div>
      <div class="sp-trust-item">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        Builder &amp; GC Coordination
      </div>
      <div class="sp-trust-sep"></div>
      <div class="sp-trust-item">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        19+ Years in Chicagoland
      </div>
    </div>
  </section>

  <!-- ─── 3. PROBLEM / CONSEQUENCE ─── -->
  <section class="sp-problem">
    <div class="sp-delay-inner">

      <!-- Header -->
      <div class="sp-delay-hdr">
        <div class="sp-section-label">Why It Matters</div>
        <h2 class="sp-delay-h2">What Goes Wrong When You <em>Hire the Wrong Mason</em></h2>
        <p class="sp-delay-sub">Custom home masonry mistakes are expensive — they're often invisible for years, then impossible to fix without opening walls. Here's what hiring the wrong mason costs you.</p>
      </div>

      <div class="sp-delay-cols">

        <!-- LEFT: dark stats sidebar -->
        <div class="sp-delay-sidebar">
          <p class="sp-delay-sidebar-label">The real cost of waiting</p>
          <div class="sp-delay-stats">
            <div class="sp-delay-stat">
              <span class="sp-delay-stat-val">$25k+</span>
              <span class="sp-delay-stat-desc">Typical cost overrun when wrong mason is hired for custom home masonry</span>
            </div>
            <div class="sp-delay-stat-sep"></div>
            <div class="sp-delay-stat">
              <span class="sp-delay-stat-val">5+ yrs</span>
              <span class="sp-delay-stat-desc">Before hidden masonry defects surface and become costly to fix</span>
            </div>
            <div class="sp-delay-stat-sep"></div>
            <div class="sp-delay-stat">
              <span class="sp-delay-stat-val">1st visit</span>
              <span class="sp-delay-stat-desc">AMS passes every municipal inspection on the first visit</span>
            </div>
          </div>
          <a href="/contact#form" class="sp-delay-sidebar-cta">
            Get a free project estimate
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M2.5 7H11.5M8 3.5L11.5 7L8 10.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>

        <!-- RIGHT: consequence list -->
        <div class="sp-delay-list">

          <div class="sp-delay-rule"></div>

          <div class="sp-delay-item">
            <div class="sp-delay-item-head">
              <div class="sp-delay-icon-wrap">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#B85C38" stroke-width="1.8" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              </div>
              <h3 class="sp-delay-title">Wrong Mortar = Cracked Brick</h3>
            </div>
            <p class="sp-delay-text">Using mortar that's too hard for your brick is the single most common mistake in new construction masonry. It looks fine for a few years — then bricks start spalling from freeze-thaw stress.</p>
          </div>

          <div class="sp-delay-rule"></div>

          <div class="sp-delay-item">
            <div class="sp-delay-item-head">
              <div class="sp-delay-icon-wrap">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#B85C38" stroke-width="1.8" aria-hidden="true"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
              </div>
              <h3 class="sp-delay-title">Missing Flashing Causes Leaks</h3>
            </div>
            <p class="sp-delay-text">Flashing, weep holes, and drainage mats are code requirements for a reason. Skip them — or install them incorrectly — and water infiltrates your wall cavity, rotting framing from the inside out.</p>
          </div>

          <div class="sp-delay-rule"></div>

          <div class="sp-delay-item">
            <div class="sp-delay-item-head">
              <div class="sp-delay-icon-wrap">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#B85C38" stroke-width="1.8" aria-hidden="true"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
              </div>
              <h3 class="sp-delay-title">Failed Inspections Cost Money</h3>
            </div>
            <p class="sp-delay-text">Masonry work that doesn’t meet code gets flagged at inspection — delaying your close date, frustrating your builder, and costing you in carrying costs and rework. We pass every inspection on the first visit.</p>
            <div class="sp-delay-chart" aria-label="Cost escalation timeline">
              <div class="sp-delay-chart-row">
                <span class="sp-delay-chart-stage">Now</span>
                <div class="sp-delay-chart-bar-wrap"><div class="sp-delay-chart-bar" style="--w:20%"></div></div>
                <span class="sp-delay-chart-cost">$</span>
                <span class="sp-delay-chart-note">Planning</span>
              </div>
              <div class="sp-delay-chart-row">
                <span class="sp-delay-chart-stage">1–2 yrs</span>
                <div class="sp-delay-chart-bar-wrap"><div class="sp-delay-chart-bar" style="--w:42%"></div></div>
                <span class="sp-delay-chart-cost">$$</span>
                <span class="sp-delay-chart-note">Joint failure</span>
              </div>
              <div class="sp-delay-chart-row">
                <span class="sp-delay-chart-stage">3–4 yrs</span>
                <div class="sp-delay-chart-bar-wrap"><div class="sp-delay-chart-bar" style="--w:68%"></div></div>
                <span class="sp-delay-chart-cost">$$$</span>
                <span class="sp-delay-chart-note">Brick spalling</span>
              </div>
              <div class="sp-delay-chart-row">
                <span class="sp-delay-chart-stage">5+ yrs</span>
                <div class="sp-delay-chart-bar-wrap"><div class="sp-delay-chart-bar" style="--w:100%"></div></div>
                <span class="sp-delay-chart-cost">$$$$</span>
                <span class="sp-delay-chart-note">Structural</span>
              </div>
            </div>
          </div>

          <div class="sp-delay-rule"></div>

          <div class="sp-delay-item">
            <div class="sp-delay-item-head">
              <div class="sp-delay-icon-wrap">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#B85C38" stroke-width="1.8" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
              </div>
              <h3 class="sp-delay-title">Subs Who Miss Schedule</h3>
            </div>
            <p class="sp-delay-text">Masonry is on the critical path. A crew that doesn’t show when promised pushes framing, roofing, windows — everything. We commit to a schedule in writing and show up as agreed, every time.</p>
          </div>

          <div class="sp-delay-rule"></div>

        </div>
      </div>
    </div>
  </section>

  <!-- ─── 4. PROCESS ─── -->
  <section id="sp-prc-section" style="background:#ffffff; position:relative;">
    <div id="sp-prc-driver" style="position:relative; height:600vh;">
      <div id="sp-prc-sticky" style="position:sticky; top:0; height:100vh; display:flex; align-items:center; overflow:hidden;">
        <div class="sp-prc-grid">

          <!-- LEFT: heading + CTA -->
          <div id="sp-prc-left">
            <div style="display:flex; align-items:center; gap:8px; margin-bottom:20px;">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <rect x="1" y="1" width="5" height="5" rx="1" fill="#B85C38"/>
                <rect x="8" y="1" width="5" height="5" rx="1" fill="#B85C38" opacity="0.4"/>
                <rect x="1" y="8" width="5" height="5" rx="1" fill="#B85C38" opacity="0.4"/>
                <rect x="8" y="8" width="5" height="5" rx="1" fill="#B85C38"/>
              </svg>
              <span style="font-family:'Inter',sans-serif; font-size:11px; font-weight:700; letter-spacing:0.10em; color:#B85C38; text-transform:uppercase;">How We Work</span>
            </div>

            <h2 style="font-family:'Onest',sans-serif; font-size:clamp(36px,3.5vw,54px); font-weight:700; line-height:1.1; color:#16120F; letter-spacing:-0.02em; margin:0 0 20px;">Our Custom Home Masonry<br>Process</h2>

            <p style="font-family:'Inter',sans-serif; font-size:16px; line-height:1.65; color:#6A625A; margin:0 0 36px;">From design collaboration to final walk-through — every step is documented, on schedule, and built to pass inspection.</p>

            <div class="sp-prc-desktop-cta">
              <a href="/contact#form"
                style="display:inline-flex; align-items:center; gap:8px; background:#B85C38; color:#fff; font-family:'Inter',sans-serif; font-size:15px; font-weight:500; padding:14px 26px; border-radius:12px; text-decoration:none; transition:background 0.2s;"
                onmouseenter="this.style.background='#8A3A22'"
                onmouseleave="this.style.background='#B85C38'">
                Get a free estimate
                <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                  <path d="M3 8h10M9 4l4 4-4 4" stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
              <p style="font-family:'Inter',sans-serif; font-size:11px; font-weight:700; letter-spacing:0.08em; color:#B85C38; text-transform:uppercase; margin:28px 0 0;">5 steps · 24 hrs to first visit</p>
            </div>
          </div>

          <!-- RIGHT: steps -->
          <div id="sp-prc-right">

            <div class="sp-prc-item" style="padding:14px 0; border-top:1px solid #E4E2DE;">
              <div style="display:flex; gap:20px; align-items:flex-start;">
                <span class="sp-prc-num" style="font-family:'Onest',sans-serif; font-size:40px; font-weight:700; color:#B85C38; opacity:0.22; line-height:1; min-width:52px; padding-top:2px; transition:opacity 0.3s;">01</span>
                <div style="flex:1;">
                  <h3 style="font-family:'Onest',sans-serif; font-size:15px; font-weight:700; color:#16120F; margin:0 0 7px; letter-spacing:0.04em; text-transform:uppercase;">Design Collaboration</h3>
                  <p style="font-family:'Inter',sans-serif; font-size:13px; line-height:1.65; color:#4A433B; margin:0 0 10px;">We work directly with your architect or builder at the design stage — reviewing drawings, suggesting materials, and flagging structural or logistical issues before construction starts.</p>
                  <div style="border-left:3px solid #B85C38; padding:8px 12px; background:rgba(184,92,56,0.05); border-radius:0 8px 8px 0;">
                    <p style="font-family:'Inter',sans-serif; font-size:12px; line-height:1.6; color:#4A433B; margin:0;"><strong style="color:#B85C38; font-weight:700;">Why it matters: </strong>Material choices made at the drawing stage are nearly free to change. Material choices made after framing starts cost thousands in change orders and delays.</p>
                  </div>
                </div>
              </div>
            </div>

            <div class="sp-prc-item" style="padding:14px 0; border-top:1px solid #E4E2DE;">
              <div style="display:flex; gap:20px; align-items:flex-start;">
                <span class="sp-prc-num" style="font-family:'Onest',sans-serif; font-size:40px; font-weight:700; color:#B85C38; opacity:0.22; line-height:1; min-width:52px; padding-top:2px; transition:opacity 0.3s;">02</span>
                <div style="flex:1;">
                  <h3 style="font-family:'Onest',sans-serif; font-size:15px; font-weight:700; color:#16120F; margin:0 0 7px; letter-spacing:0.04em; text-transform:uppercase;">Material Selection &amp; Sourcing</h3>
                  <p style="font-family:'Inter',sans-serif; font-size:13px; line-height:1.65; color:#4A433B; margin:0 0 10px;">We help you select the right brick, stone, or limestone for your home's style, climate exposure, and budget — then source and confirm material availability before the project is scheduled.</p>
                  <div style="border-left:3px solid #B85C38; padding:8px 12px; background:rgba(184,92,56,0.05); border-radius:0 8px 8px 0;">
                    <p style="font-family:'Inter',sans-serif; font-size:12px; line-height:1.6; color:#4A433B; margin:0;"><strong style="color:#B85C38; font-weight:700;">Why it matters: </strong>Some materials have 8–12 week lead times. Finding this out after you've framed the house delays your entire project. We identify it upfront.</p>
                  </div>
                </div>
              </div>
            </div>

            <div class="sp-prc-item" style="padding:14px 0; border-top:1px solid #E4E2DE;">
              <div style="display:flex; gap:20px; align-items:flex-start;">
                <span class="sp-prc-num" style="font-family:'Onest',sans-serif; font-size:40px; font-weight:700; color:#B85C38; opacity:0.22; line-height:1; min-width:52px; padding-top:2px; transition:opacity 0.3s;">03</span>
                <div style="flex:1;">
                  <h3 style="font-family:'Onest',sans-serif; font-size:15px; font-weight:700; color:#16120F; margin:0 0 7px; letter-spacing:0.04em; text-transform:uppercase;">Foundation &amp; Substrate Prep</h3>
                  <p style="font-family:'Inter',sans-serif; font-size:13px; line-height:1.65; color:#4A433B; margin:0 0 10px;">Every masonry installation starts with the substrate. We verify structural capacity, install weep holes and flashing, and prep to code — work that's invisible once done but load-bearing.</p>
                  <div style="border-left:3px solid #B85C38; padding:8px 12px; background:rgba(184,92,56,0.05); border-radius:0 8px 8px 0;">
                    <p style="font-family:'Inter',sans-serif; font-size:12px; line-height:1.6; color:#4A433B; margin:0;"><strong style="color:#B85C38; font-weight:700;">Why it matters: </strong>Inspectors check flashing and weep hole installation before they check anything visible. Get this wrong and you're opening the wall after close.</p>
                  </div>
                </div>
              </div>
            </div>

            <div class="sp-prc-item" style="padding:14px 0; border-top:1px solid #E4E2DE;">
              <div style="display:flex; gap:20px; align-items:flex-start;">
                <span class="sp-prc-num" style="font-family:'Onest',sans-serif; font-size:40px; font-weight:700; color:#B85C38; opacity:0.22; line-height:1; min-width:52px; padding-top:2px; transition:opacity 0.3s;">04</span>
                <div style="flex:1;">
