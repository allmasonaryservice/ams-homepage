---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { projects as allProjects } from '../data/projects.js';

const siteUrl = 'https://allmasonryservices.com';
const svcProjects = allProjects.slice(0, 5);

const serviceAreas = [
  'Chicago', 'Evanston', 'Wilmette', 'Winnetka', 'Glencoe', 'Naperville',
  'Burr Ridge', 'Oak Park', 'Hinsdale', 'Highland Park', 'Northbrook',
  'Skokie', 'Lake Forest', 'Glenview', 'Western Springs', 'Park Ridge',
  'Elmhurst', 'La Grange', 'Kenilworth'
];

const faqItems = [
  {
    q: 'How fast can you come out for an estimate?',
    a: 'We typically schedule a free on-site estimate within 24–48 hours of your call. For urgent structural or water-intrusion issues, we prioritize same-day or next-day visits when possible.'
  },
  {
    q: 'Is the estimate really free?',
    a: 'Yes — every on-site estimate is free with no obligation. We assess every visible problem, explain what we find, and give you a written estimate before any work begins.'
  },
  {
    q: 'What areas do you serve?',
    a: 'We serve Chicago, the North Shore, and the western suburbs — 19+ cities across Chicagoland. If you are not sure whether we cover your area, just call and ask.'
  },
  {
    q: 'Do you charge for travel or consultation?',
    a: 'No. There are no travel fees, no consultation fees, and no hidden charges. The written estimate is your final price.'
  }
];
---

<Layout
  title="Contact All Masonry Services — Free Estimates Across Chicagoland | 773-656-2107"
  description="Contact All Masonry Services for a free on-site masonry estimate in Chicago and Chicagoland. Call 773-656-2107 or request a quote online. Licensed, insured, family-owned since 2007."
>
  <!-- Schema: ContactPage / LocalBusiness -->
  <script is:inline type="application/ld+json">{JSON.stringify({
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": "All Masonry Services",
    "url": siteUrl + "/contact",
    "telephone": "+1-773-656-2107",
    "areaServed": "Chicago, Chicagoland, IL",
    "priceRange": "$$",
    "address": { "@type": "PostalAddress", "addressRegion": "IL", "addressCountry": "US", "addressLocality": "Chicago" }
  })}</script>

  <Navbar />

  <!-- ─── 1. HERO — CHIMNEY-SHAPE IMAGE ANIMATION (image swapped to contact-masonry) ─── -->
  <section class="cth-hero" id="cth-hero" aria-label="Contact All Masonry Services hero">
    <div class="cth-hero-base" aria-hidden="true"></div>

    <!-- Chimney-shaped image grid — right side -->
    <div class="cth-chimney-wrap" aria-hidden="true">
      <div id="cth-image-container" class="cth-chimney-shape">
        <div id="cth-physics-container"></div>
      </div>
    </div>

    <!-- Left vignette for text contrast -->
    <div class="cth-vignette" aria-hidden="true"></div>

    <!-- Text content — bottom left -->
    <div class="cth-content">
      <!-- Heading block: label + h1 -->
      <div class="cth-ct" id="cth-ct">
        <div class="cth-label" id="cth-label">
          <span class="cth-label-line" aria-hidden="true"></span>
          Get In Touch · Chicago &amp; Chicagoland
        </div>
        <h1 class="cth-h1">
          <div class="cth-h1-row"><span id="cth-r1">Let's Talk About</span></div>
          <div class="cth-h1-row"><span id="cth-r2">Your Masonry Project</span></div>
        </h1>
      </div>
      <!-- Body block: sub + actions + badges -->
      <div class="cth-cb" id="cth-cb">
        <p class="cth-sub" id="cth-sub">
          Free on-site estimates across Chicagoland. Tell us what you need — we'll assess every visible problem and give you an honest, written estimate before any work begins.
        </p>
        <div class="cth-actions" id="cth-act">
          <a href="#form" class="cth-btn cth-btn-primary">
            <span class="cth-btn-bg" aria-hidden="true"></span>
            <span class="cth-btn-label">Request a Free Estimate</span>
            <svg width="13" height="13" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <a href="tel:7736562107" class="cth-btn cth-btn-ghost">
            <span class="cth-btn-bg" aria-hidden="true"></span>
            <span class="cth-btn-label">Call 773-656-2107</span>
          </a>
        </div>
        <div class="cth-badges" id="cth-bdg">
          <div class="cth-badge"><strong>24hr</strong><span>Estimate Response</span></div>
          <div class="cth-badge-sep" aria-hidden="true"></div>
          <div class="cth-badge"><strong>4.8★</strong><span>92 Google Reviews</span></div>
          <div class="cth-badge-sep" aria-hidden="true"></div>
          <div class="cth-badge"><strong>$0</strong><span>Hidden Fees</span></div>
        </div>
      </div>
    </div>

    <div class="cth-scroll" id="cth-scroll">
      <div class="cth-scroll-mouse"><div class="cth-scroll-dot"></div></div>
      <span>Scroll</span>
    </div>
  </section>

  <script is:inline>
  (function() {
    function initCth() {
      var gsap = window.__gsap;
      if (!gsap) return;
      var container = document.getElementById('cth-physics-container');
      if (!container) return;
      container.innerHTML = '';

      var W = 460, H = 540;
      var cols = 8, rows = 10;
      var blockW = W / cols;
      var blockH = H / rows;
      var blocks = [];

      for (var r = 0; r < rows; r++) {
        for (var c = 0; c < cols; c++) {
          var block = document.createElement('div');
          block.style.cssText = [
            'position:absolute',
            'width:' + blockW + 'px',
            'height:' + blockH + 'px',
            "background-image:url('/images/contact-masonry.webp')",
            'background-size:' + W + 'px ' + H + 'px',
            'background-repeat:no-repeat',
            'background-position:-' + (c * blockW) + 'px -' + (r * blockH) + 'px',
            'left:' + (c * blockW) + 'px',
            'top:' + (r * blockH) + 'px'
          ].join(';');
          container.appendChild(block);
          blocks.push(block);
        }
      }

      gsap.set(blocks, { scale: 0.85, filter: 'brightness(0.9)' });

      var heroEl = document.getElementById('cth-hero');

      var quickTos = blocks.map(function(b, i) {
        return gsap.quickTo(b, 'x', { duration: 0.6 + (i % 8) * 0.08, ease: 'power2.out' });
      });
      var mults = blocks.map(function(b, i) { return 0.15 + (i % 7) * 0.06; });

      function shiftBlocks(clientX) {
        var bounds = heroEl.getBoundingClientRect();
        var relX = ((clientX - bounds.left) / bounds.width - 0.5) * 2;
        for (var i = 0; i < blocks.length; i++) { quickTos[i](relX * 22 * mults[i]); }
      }
      function resetBlocks() { for (var i = 0; i < blocks.length; i++) { quickTos[i](0); } }

      heroEl.addEventListener('mousemove', function(e) { shiftBlocks(e.clientX); }, { passive: true });
      heroEl.addEventListener('mouseleave', resetBlocks);
      heroEl.addEventListener('touchmove', function(e) { shiftBlocks(e.touches[0].clientX); }, { passive: true });
      heroEl.addEventListener('touchend', resetBlocks, { passive: true });

      var scrEl = document.getElementById('cth-scroll');
      if (scrEl) {
        scrEl.addEventListener('click', function() {
          var next = document.querySelector('.cth-methods');
          if (next) next.scrollIntoView({ behavior: 'smooth' });
          else window.scrollTo({ top: window.innerHeight, behavior: 'smooth' });
        });
      }

      // Hero text entrance
      var tl = gsap.timeline({ defaults: { ease: 'power3.out' } });
      tl.fromTo('#cth-label', { opacity: 0, y: 16 }, { opacity: 1, y: 0, duration: 0.6 }, 0.1)
        .fromTo('#cth-r1',    { yPercent: 110 },      { yPercent: 0, duration: 0.75 },    0.25)
        .fromTo('#cth-r2',    { yPercent: 110 },      { yPercent: 0, duration: 0.75 },    0.38)
        .fromTo('#cth-sub',   { opacity: 0, y: 14 }, { opacity: 1, y: 0, duration: 0.6 }, 0.55)
        .fromTo('#cth-act',   { opacity: 0, y: 12 }, { opacity: 1, y: 0, duration: 0.5 }, 0.70)
        .fromTo('#cth-bdg',   { opacity: 0, y: 10 }, { opacity: 1, y: 0, duration: 0.5 }, 0.82)
        .fromTo('#cth-scroll',{ opacity: 0 },         { opacity: 1, duration: 0.5 },      1.0);
    }

    if (window.__gsap) { initCth(); }
    else { window.addEventListener('animations:ready', initCth, { once: true }); }

    window.addEventListener('resize', function() {
      clearTimeout(window._cthTimer);
      window._cthTimer = setTimeout(initCth, 300);
    });
  })();
  </script>

  <!-- ─── 2. CONTACT METHODS ─── -->
  <section class="cth-methods">
    <div class="cth-methods-inner">

      <a href="tel:7736562107" class="cth-method" data-reveal>
        <div class="cth-method-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#B85C38" stroke-width="1.7" aria-hidden="true">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/>
          </svg>
        </div>
        <span class="cth-method-label">Call Us</span>
        <span class="cth-method-val">773-656-2107</span>
        <span class="cth-method-note">7 days a week</span>
      </a>

      <a href="mailto:info@allmasonryservices.com" class="cth-method" data-reveal style="--rd:80ms">
        <div class="cth-method-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#B85C38" stroke-width="1.7" aria-hidden="true">
            <rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-10 5L2 7"/>
          </svg>
        </div>
        <span class="cth-method-label">Email Us</span>
        <span class="cth-method-val">info@allmasonryservices.com</span>
        <span class="cth-method-note">Reply within 1 business day</span>
      </a>

      <div class="cth-method cth-method--static" data-reveal style="--rd:160ms">
        <div class="cth-method-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#B85C38" stroke-width="1.7" aria-hidden="true">
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>
          </svg>
        </div>
        <span class="cth-method-label">Service Area</span>
        <span class="cth-method-val">Chicago &amp; Chicagoland</span>
        <span class="cth-method-note">19+ cities served</span>
      </div>

      <div class="cth-method cth-method--static" data-reveal style="--rd:240ms">
        <div class="cth-method-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#B85C38" stroke-width="1.7" aria-hidden="true">
            <circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/>
          </svg>
        </div>
        <span class="cth-method-label">Hours</span>
        <span class="cth-method-val">Mon–Sun · 7am–7pm</span>
        <span class="cth-method-note">Emergency calls anytime</span>
      </div>

    </div>
  </section>

  <!-- ─── 3. MAIN FORM + INFO ─── -->
  <section class="cth-form-section" id="form">
    <div class="cth-form-grid">

      <!-- LEFT: info column -->
      <div class="cth-form-info" data-reveal>
        <div class="cth-eyebrow">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <rect x="1" y="1" width="5" height="5" rx="1" fill="#B85C38"/>
            <rect x="8" y="1" width="5" height="5" rx="1" fill="#B85C38" opacity="0.4"/>
            <rect x="1" y="8" width="5" height="5" rx="1" fill="#B85C38" opacity="0.4"/>
            <rect x="8" y="8" width="5" height="5" rx="1" fill="#B85C38"/>
          </svg>
          <span>Free Inspection</span>
        </div>
        <h2 class="cth-form-h2">Request Your<br>Written Estimate</h2>
        <p class="cth-form-lead">
          No obligation. We assess every visible problem and give you a written estimate before any work begins — and the number we quote is the number you pay.
        </p>

        <ul class="cth-form-bullets">
          <li>
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true"><circle cx="9" cy="9" r="8" stroke="#B85C38" stroke-width="1.4"/><path d="M5.5 9L7.5 11L12.5 6.5" stroke="#B85C38" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Free on-site estimate within 24–48 hours
          </li>
          <li>
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true"><circle cx="9" cy="9" r="8" stroke="#B85C38" stroke-width="1.4"/><path d="M5.5 9L7.5 11L12.5 6.5" stroke="#B85C38" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Licensed &amp; insured in Illinois
          </li>
          <li>
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true"><circle cx="9" cy="9" r="8" stroke="#B85C38" stroke-width="1.4"/><path d="M5.5 9L7.5 11L12.5 6.5" stroke="#B85C38" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Own crew — no subcontractors
          </li>
          <li>
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true"><circle cx="9" cy="9" r="8" stroke="#B85C38" stroke-width="1.4"/><path d="M5.5 9L7.5 11L12.5 6.5" stroke="#B85C38" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Written estimate = your final price
          </li>
        </ul>

        <div class="cth-form-call">
          <span class="cth-form-call-label">Prefer to talk now?</span>
          <a href="tel:7736562107" class="cth-form-call-num">773-656-2107</a>
        </div>
      </div>

      <!-- RIGHT: form card -->
      <div class="cth-card">
        <form class="cth-form" id="cth-form" novalidate>
          <div class="cth-row">
            <div class="cth-field">
              <label class="cth-flabel" for="cth-name">Full name <span class="cth-req">*</span></label>
              <input class="cth-input" type="text" id="cth-name" name="fullName" placeholder="John Carter" required autocomplete="name"/>
            </div>
            <div class="cth-field">
              <label class="cth-flabel" for="cth-phone">Phone number</label>
              <input class="cth-input" type="tel" id="cth-phone" name="phone" placeholder="(555) 247-8901" autocomplete="tel"/>
            </div>
          </div>
          <div class="cth-row">
            <div class="cth-field">
              <label class="cth-flabel" for="cth-email">Email address <span class="cth-req">*</span></label>
              <input class="cth-input" type="email" id="cth-email" name="email" placeholder="john@example.com" required autocomplete="email"/>
            </div>
            <div class="cth-field">
              <label class="cth-flabel" for="cth-service">Service type</label>
              <div class="cth-select-wrap">
                <select class="cth-select" id="cth-service" name="service">
                  <option value="" disabled selected>Select a service</option>
                  <option value="tuckpointing">Tuckpointing &amp; Repointing</option>
                  <option value="brick-installation">Brick Installation</option>
                  <option value="brick-replacement">Damaged Brick Replacement</option>
                  <option value="chimney-repair">Chimney Repair &amp; Rebuilding</option>
                  <option value="chimney-fireplace">Chimney &amp; Fireplace Masonry</option>
                  <option value="natural-stone">Natural Stone &amp; Limestone</option>
                  <option value="veneers">Brick &amp; Stone Veneers</option>
                  <option value="cmu-block">CMU Block Installation</option>
                  <option value="commercial">Commercial Masonry</option>
                  <option value="custom-home">Custom Home Masonry</option>
                  <option value="other">Other / Not Sure</option>
                </select>
              </div>
            </div>
          </div>
          <div class="cth-field">
            <label class="cth-flabel" for="cth-city">City / Town</label>
            <input class="cth-input" type="text" id="cth-city" name="city" placeholder="e.g. Evanston, Naperville" autocomplete="address-level2"/>
          </div>
          <div class="cth-field">
            <label class="cth-flabel" for="cth-message">Message</label>
            <textarea class="cth-textarea" id="cth-message" name="message"
              placeholder="Briefly describe your masonry needs — wall, chimney, steps, facade, etc."></textarea>
          </div>
          <button class="cth-submit" type="submit">
            <span class="cth-submit-text">Schedule Free Inspection →</span>
            <span class="cth-submit-spinner" aria-hidden="true"></span>
          </button>
          <p class="cth-form-disclaimer">By submitting, you agree to be contacted about your estimate. We never share your information.</p>
        </form>

        <div class="cth-success" id="cth-success" hidden>
          <svg width="44" height="44" viewBox="0 0 44 44" fill="none" aria-hidden="true">
            <circle cx="22" cy="22" r="22" fill="#B85C38"/>
            <path d="M13 22l7 7 11-11" stroke="#fff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <p class="cth-success-title">Request Received!</p>
          <p class="cth-success-body">We'll reach out within one business day to schedule your free inspection. Thank you.</p>
        </div>
      </div>

    </div>
  </section>

  <!-- ─── 4. PROCESS ─── -->
  <section id="sp-prc-section" style="background:#F5F5F5; position:relative;">
    <div id="sp-prc-driver" style="position:relative; height:600vh;">
      <div id="sp-prc-sticky" style="position:sticky; top:0; height:100vh; display:flex; align-items:center; overflow:hidden;">
        <div class="sp-prc-grid">

          <!-- LEFT: heading + CTA -->
          <div id="sp-prc-left">
            <div style="display:flex; align-items:center; gap:8px; margin-bottom:20px;">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <rect x="1" y="1" width="5" height="5" rx="1" fill="#B85C38"/>
                <rect x="8" y="1" width="5" height="5" rx="1" fill="#B85C38" opacity="0.4"/>
                <rect x="1" y="8" width="5" height="5" rx="1" fill="#B85C38" opacity="0.4"/>
                <rect x="8" y="8" width="5" height="5" rx="1" fill="#B85C38"/>
              </svg>
              <span style="font-family:'Inter',sans-serif; font-size:11px; font-weight:700; letter-spacing:0.10em; color:#B85C38; text-transform:uppercase;">How We Work</span>
            </div>

            <h2 style="font-family:'Onest',sans-serif; font-size:clamp(36px,3.5vw,54px); font-weight:700; line-height:1.1; color:#16120F; letter-spacing:-0.02em; margin:0 0 20px;">How We Work With You</h2>

            <p style="font-family:'Inter',sans-serif; font-size:16px; line-height:1.65; color:#6A625A; margin:0 0 36px;">From your first call to the final walk-through — every step is documented, on schedule, and built to pass inspection. Here's exactly how an AMS project runs.</p>

            <div class="sp-prc-desktop-cta">
              <a href="#form"
                style="display:inline-flex; align-items:center; gap:8px; background:#B85C38; color:#fff; font-family:'Inter',sans-serif; font-size:15px; font-weight:500; padding:14px 26px; border-radius:12px; text-decoration:none; transition:background 0.2s;"
                onmouseenter="this.style.background='#8A3A22'"
                onmouseleave="this.style.background='#B85C38'">
                Get a free estimate
                <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                  <path d="M3 8h10M9 4l4 4-4 4" stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
              <p style="font-family:'Inter',sans-serif; font-size:11px; font-weight:700; letter-spacing:0.08em; color:#B85C38; text-transform:uppercase; margin:28px 0 0;">5 steps · 24 hrs to first visit</p>
            </div>
          </div>

          <!-- RIGHT: steps -->
          <div id="sp-prc-right">

            <div class="sp-prc-item" style="padding:14px 0; border-top:1px solid #E4E2DE;">
              <div style="display:flex; gap:20px; align-items:flex-start;">
                <span class="sp-prc-num" style="font-family:'Onest',sans-serif; font-size:40px; font-weight:700; color:#B85C38; opacity:0.22; line-height:1; min-width:52px; padding-top:2px; transition:opacity 0.3s;">01</span>
                <div style="flex:1;">
                  <h3 style="font-family:'Onest',sans-serif; font-size:15px; font-weight:700; color:#16120F; margin:0 0 7px; letter-spacing:0.04em; text-transform:uppercase;">Free On-Site Estimate</h3>
                  <p style="font-family:'Inter',sans-serif; font-size:13px; line-height:1.65; color:#4A433B; margin:0 0 10px;">We come to you, assess the work in person, and hand you a written estimate with scope, materials, and timeline. No charge, no pressure to book.</p>
                  <div style="border-left:3px solid #B85C38; padding:8px 12px; background:rgba(184,92,56,0.05); border-radius:0 8px 8px 0;">
                    <p style="font-family:'Inter',sans-serif; font-size:12px; line-height:1.6; color:#4A433B; margin:0;"><strong style="color:#B85C38; font-weight:700;">Why it matters: </strong>A real number requires real eyes on the masonry. Phone quotes are guesses — our on-site estimate is the price you can actually plan around.</p>
                  </div>
                </div>
              </div>
            </div>

            <div class="sp-prc-item" style="padding:14px 0; border-top:1px solid #E4E2DE;">
              <div style="display:flex; gap:20px; align-items:flex-start;">
                <span class="sp-prc-num" style="font-family:'Onest',sans-serif; font-size:40px; font-weight:700; color:#B85C38; opacity:0.22; line-height:1; min-width:52px; padding-top:2px; transition:opacity 0.3s;">02</span>
                <div style="flex:1;">
                  <h3 style="font-family:'Onest',sans-serif; font-size:15px; font-weight:700; color:#16120F; margin:0 0 7px; letter-spacing:0.04em; text-transform:uppercase;">Material Matching &amp; Selection</h3>
                  <p style="font-family:'Inter',sans-serif; font-size:13px; line-height:1.65; color:#4A433B; margin:0 0 10px;">We match mortar composition, color, and joint profile to your existing masonry — or help you choose new brick, stone, or limestone that suits your home and Chicago's climate.</p>
                  <div style="border-left:3px solid #B85C38; padding:8px 12px; background:rgba(184,92,56,0.05); border-radius:0 8px 8px 0;">
