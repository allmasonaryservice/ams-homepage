}

/* ── CTA BANNER ──────────────────────────────────────────────────────── */
.sp-cta-banner { background: linear-gradient(90deg, #16120F 0%, #6E2A19 40%, #B85C38 100%); padding: 80px 0; }
.sp-cta-banner-inner { max-width: 1200px; margin: 0 auto; padding: 0 30px; display: flex; align-items: center; justify-content: space-between; gap: 40px; flex-wrap: wrap; }
.sp-cta-banner-text {}
.sp-cta-banner-h2 { font-family: 'Onest', sans-serif; font-size: clamp(28px, 3vw, 40px); font-weight: 700; color: #ffffff; margin: 0 0 10px; line-height: 1.2; }
.sp-cta-banner-sub { font-family: 'Inter', sans-serif; font-size: 16px; color: rgba(255,255,255,0.85); line-height: 1.6; margin: 0; max-width: 520px; }
.sp-cta-banner-actions { display: flex; gap: 14px; flex-wrap: wrap; flex-shrink: 0; }
.sp-btn { display: inline-flex; align-items: center; justify-content: center; font-family: 'Inter', sans-serif; font-size: 15px; font-weight: 600; text-decoration: none; padding: 14px 28px; border-radius: 12px; transition: background 200ms ease, color 200ms ease, border-color 200ms ease; cursor: pointer; }
.sp-btn--accent { background: #B85C38; color: #ffffff; border: 2px solid #B85C38; }
.sp-btn--accent:hover { background: #8A3A22; border-color: #8A3A22; }
.sp-btn--ghost-light { background: transparent; color: #ffffff; border: 2px solid rgba(255,255,255,0.45); }
.sp-btn--ghost-light:hover { background: rgba(255,255,255,0.12); border-color: rgba(255,255,255,0.7); }
@media (max-width: 900px) {
  .sp-cta-banner-inner { flex-direction: column; align-items: flex-start; }
  .sp-cta-banner { padding: 60px 0; }
}
@media (max-width: 640px) {
  .sp-cta-banner-inner { padding: 0 20px; }
  .sp-cta-banner-actions { flex-direction: column; width: 100%; }
  .sp-btn { width: 100%; }
}
</style>

<script>
import gsap from 'gsap';
import { ScrollTrigger } from 'gsap/ScrollTrigger';

gsap.registerPlugin(ScrollTrigger);

// ── Hero text entrance (CMU style) ───────────────────
const tl = gsap.timeline({ defaults: { ease: 'power3.out' } });
tl.fromTo('#pix-ey',    { opacity: 0, y: 16 }, { opacity: 1, y: 0, duration: 0.6 }, 0.1)
  .fromTo('#pix-r1',    { yPercent: 110 },      { yPercent: 0, duration: 0.75 },    0.25)
  .fromTo('#pix-r2',    { yPercent: 110 },      { yPercent: 0, duration: 0.75 },    0.38)
  .fromTo('#pix-sub',   { opacity: 0, y: 14 }, { opacity: 1, y: 0, duration: 0.6 }, 0.55)
  .fromTo('#pix-stats', { opacity: 0, y: 12 }, { opacity: 1, y: 0, duration: 0.5 }, 0.70);

// ── Mosaic tile animation (same as CMU hero, different image) ──
(function initMosaic() {
  const gridEl = document.getElementById('pix-mosaic') as HTMLElement;
  const heroEl = document.getElementById('pix-hero-section') as HTMLElement;
  if (!gridEl || !heroEl) return;

  gridEl.innerHTML = '';

  const BW = 160, BH = 58;
  const W  = window.innerWidth;
  const H  = window.innerHeight;
  const cols = Math.ceil(W / BW) + 1;
  const rows = Math.ceil(H / BH) + 1;
  const blocks: HTMLElement[] = [];

  for (let r = 0; r < rows; r++) {
    const xOff = (r % 2 !== 0) ? -(BW / 2) : 0;
    for (let c = 0; c < cols; c++) {
      const bx = (c * BW) + xOff + 1;
      const by = r * BH + 1;
      const b  = document.createElement('div');
      b.style.cssText = [
        'position:absolute',
        'background-image:url(/images/proj-winnetka-brick-installation-hero.webp)',
        'background-size:' + W + 'px ' + H + 'px',
        'background-position:-' + bx + 'px -' + by + 'px',
        'background-repeat:no-repeat',
        'width:'  + (BW - 2) + 'px',
        'height:' + (BH - 2) + 'px',
        'left:'   + bx + 'px',
        'top:'    + by + 'px',
        'box-shadow:0 8px 24px rgba(0,0,0,0.85)',
      ].join(';');
      gridEl.appendChild(b);
      blocks.push(b);
    }
  }

  const quickTos = blocks.map((b, i) =>
    gsap.quickTo(b, 'x', { duration: 0.6 + (i % 8) * 0.08, ease: 'power2.out' })
  );
  const mults = blocks.map((_, i) => 0.15 + (i % 7) * 0.06);

  function shift(clientX: number) {
    const bounds = heroEl.getBoundingClientRect();
    const relX = ((clientX - bounds.left) / bounds.width - 0.5) * 2;
    blocks.forEach((_, i) => quickTos[i](relX * 22 * mults[i]));
  }
  function reset() { blocks.forEach((_, i) => quickTos[i](0)); }

  heroEl.addEventListener('mousemove',  (e: MouseEvent)      => shift(e.clientX),           { passive: true });
  heroEl.addEventListener('mouseleave', reset);
  heroEl.addEventListener('touchmove',  (e: TouchEvent)      => shift(e.touches[0].clientX), { passive: true });
  heroEl.addEventListener('touchend',   reset, { passive: true });

  window.addEventListener('resize', () => {
    clearTimeout((window as any)._pixMosaicTimer);
    (window as any)._pixMosaicTimer = setTimeout(initMosaic, 300);
  }, { once: false });
})();

// ── Pagination + Filter ──────────────────────────────
const PER_PAGE   = 12;
let currentFilter = 'all';
let currentPage   = 1;

const cards      = Array.from(document.querySelectorAll('.pix-card')) as HTMLElement[];
const gridEl     = document.getElementById('pix-grid') as HTMLElement;
const emptyState = document.getElementById('pix-empty') as HTMLElement;
const pagEl      = document.getElementById('pix-pag') as HTMLElement;
const filterBtns = Array.from(document.querySelectorAll('.pix-fb')) as HTMLElement[];
const sectionEl  = document.querySelector('.pix-section') as HTMLElement;

function getFiltered(): HTMLElement[] {
  return cards.filter(c => currentFilter === 'all' || c.dataset.service === currentFilter);
}

function renderPagination(total: number) {
  if (total <= 1) { pagEl.style.display = 'none'; return; }
  pagEl.style.display = 'flex';

  const prev = currentPage > 1;
  const next = currentPage < total;
  let html = '';

  html += `<button class="pix-pg-btn${prev ? '' : ' disabled'}" data-page="${currentPage - 1}">
    <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M10 4l-4 4 4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
  </button>`;

  for (let p = 1; p <= total; p++) {
    const near = p >= currentPage - 1 && p <= currentPage + 1;
    if (p === 1 || p === total || near) {
      html += `<button class="pix-pg-btn${p === currentPage ? ' active' : ''}" data-page="${p}">${p}</button>`;
    } else if (p === currentPage - 2 || p === currentPage + 2) {
      html += `<span class="pix-pg-dots">…</span>`;
    }
  }

  html += `<button class="pix-pg-btn${next ? '' : ' disabled'}" data-page="${currentPage + 1}">
    <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M6 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
  </button>`;

  pagEl.innerHTML = html;

  pagEl.querySelectorAll<HTMLButtonElement>('.pix-pg-btn:not(.disabled)').forEach(b => {
    b.addEventListener('click', () => {
      currentPage = parseInt(b.dataset.page!);
      showPage(true);
      const top = sectionEl.getBoundingClientRect().top + window.scrollY - 56;
      window.scrollTo({ top, behavior: 'smooth' });
    });
  });
}

function showPage(animate: boolean) {
  const filtered = getFiltered();
  const total = Math.ceil(filtered.length / PER_PAGE);
  currentPage = Math.min(Math.max(1, currentPage), total || 1);
  const start = (currentPage - 1) * PER_PAGE;
  const pageCards = filtered.slice(start, start + PER_PAGE);

  cards.forEach(c => {
    gsap.killTweensOf(c);
    c.style.display = 'none';
  });

  if (pageCards.length === 0) {
    emptyState.style.display = 'block';
    pagEl.style.display = 'none';
    return;
  }
  emptyState.style.display = 'none';
  pageCards.forEach(c => { c.style.display = ''; });

  if (animate) {
    gsap.fromTo(pageCards,
      { opacity: 0, y: 24 },
      { opacity: 1, y: 0, duration: 0.42, stagger: 0.045, ease: 'power2.out' }
    );
  }

  renderPagination(total);
}

// Init: set display before ScrollTrigger
showPage(false);

// Initial card entrance (only visible first-page cards)
ScrollTrigger.batch(cards.filter(c => c.style.display !== 'none'), {
  onEnter: (els) => {
    gsap.fromTo(els,
      { opacity: 0, y: 36 },
      { opacity: 1, y: 0, duration: 0.55, stagger: 0.07, ease: 'power2.out', overwrite: 'auto' }
    );
  },
  once: true,
  start: 'top 92%',
  interval: 0.08,
});

// Filter buttons
filterBtns.forEach(btn => {
  btn.addEventListener('click', () => {
    filterBtns.forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    currentFilter = (btn as HTMLElement).dataset.filter!;
    currentPage = 1;
    showPage(true);
  });
});
</script>
