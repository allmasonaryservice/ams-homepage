---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import { projects } from '../../data/projects.js';

// Build service filter list
const svcMap: Record<string, { name: string; count: number }> = {};
for (const p of projects) {
  if (!svcMap[p.serviceSlug]) svcMap[p.serviceSlug] = { name: p.serviceType, count: 0 };
  svcMap[p.serviceSlug].count++;
}
const services = Object.entries(svcMap).map(([slug, d]) => ({ slug, name: d.name, count: d.count }));
---

<Layout
  title="Projects | All Masonry Services"
  description={`Browse ${projects.length} completed masonry projects — brick, stone, chimney, tuckpointing, and more across Chicagoland.`}
>
  <Navbar />

  <!-- ── HERO ─────────────────────────────────────────── -->
  <section class="pix-hero" id="pix-hero-section">
    <div class="pix-mosaic" id="pix-mosaic" aria-hidden="true"></div>
    <div class="pix-mosaic-ink" aria-hidden="true"></div>
    <div class="pix-hero-content">

      <div class="pix-eyebrow" id="pix-ey">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <rect x="1" y="1" width="5" height="5" rx="1" fill="#B85C38"/>
          <rect x="8" y="1" width="5" height="5" rx="1" fill="#B85C38" opacity="0.4"/>
          <rect x="1" y="8" width="5" height="5" rx="1" fill="#B85C38" opacity="0.4"/>
          <rect x="8" y="8" width="5" height="5" rx="1" fill="#B85C38"/>
        </svg>
        <span>Our Work</span>
      </div>

      <h1 class="pix-h1">
        <div class="pix-h1-row"><span id="pix-r1">Masonry Projects</span></div>
        <div class="pix-h1-row"><span id="pix-r2">Across Chicagoland</span></div>
      </h1>

      <p class="pix-sub" id="pix-sub">
        {projects.length} completed projects — brick, stone, chimney, tuckpointing, and more across the North Shore, western suburbs, and Chicago.
      </p>

      <div class="pix-stats" id="pix-stats">
        <div class="pix-stat">
          <span class="pix-stat-num">{projects.length}</span>
          <span class="pix-stat-lbl">Projects</span>
        </div>
        <div class="pix-stat-div"></div>
        <div class="pix-stat">
          <span class="pix-stat-num">{services.length}</span>
          <span class="pix-stat-lbl">Services</span>
        </div>
        <div class="pix-stat-div"></div>
        <div class="pix-stat">
          <span class="pix-stat-num">19</span>
          <span class="pix-stat-lbl">Cities</span>
        </div>
        <div class="pix-stat-div"></div>
        <div class="pix-stat">
          <span class="pix-stat-num">19 yrs</span>
          <span class="pix-stat-lbl">Experience</span>
        </div>
      </div>

    </div>
  </section>

  <!-- ── FILTER BAR ─────────────────────────────────── -->
  <div class="pix-filter-wrap" id="pix-filters">
    <div class="pix-filter-inner">
      <button class="pix-fb active" data-filter="all">All</button>
      {services.map(s => (
        <button class="pix-fb" data-filter={s.slug}>{s.name}</button>
      ))}
    </div>
  </div>

  <!-- ── CARD GRID ──────────────────────────────────── -->
  <section class="pix-section">
    <div class="pix-grid" id="pix-grid">
      {projects.map((p, i) => (
        <a
          href={`/projects/${p.slug}`}
          class="pix-card"
          data-service={p.serviceSlug}
          data-i={i}
        >
          <!-- Image -->
          <div class="pix-card-img-wrap">
            <div class="pix-card-img-clip">
              <picture style="display:block;width:100%;height:100%;">
                <source media="(max-width: 768px)" srcset={p.heroImageSm} type="image/webp" />
                <img
                  src={p.heroImage}
                  alt={p.serviceType + ' in ' + p.city}
                  class="pix-card-img"
                  loading={i < 9 ? 'eager' : 'lazy'}
                />
              </picture>
            </div>
            <span class="pix-card-year">{p.year}</span>
          </div>

          <!-- Body -->
          <div class="pix-card-body">
            <span class="pix-card-svc">{p.serviceType}</span>
            <h3 class="pix-card-title">{p.title}</h3>
            <div class="pix-card-foot">
              <span class="pix-card-loc">
                <svg width="9" height="11" viewBox="0 0 9 11" fill="none" aria-hidden="true">
                  <path d="M4.5 0C2.01 0 0 1.96 0 4.37 0 7.65 4.5 11 4.5 11S9 7.65 9 4.37C9 1.96 6.99 0 4.5 0zm0 5.94a1.57 1.57 0 1 1 0-3.14 1.57 1.57 0 0 1 0 3.14z" fill="#B85C38"/>
                </svg>
                {p.city}, IL
              </span>
              <span class="pix-card-cta">View →</span>
            </div>
          </div>
        </a>
      ))}
    </div>

    <!-- No results state (hidden by default) -->
    <div class="pix-empty" id="pix-empty" style="display:none;">
      <p>No projects found for this filter.</p>
    </div>

    <!-- Pagination -->
    <div class="pix-pag" id="pix-pag"></div>
  </section>

  <!-- ── REVIEWS ─────────────────────────────────── -->
  <section id="sp-rev-section" style="background:#ffffff; position:relative; overflow-x:clip;">
    <div id="sp-rev-driver" style="position:relative; height:300vh;">
      <div style="position:sticky; top:0; height:100vh; display:flex; align-items:center; overflow:hidden;">
        <div class="sp-rev-grid">

          <!-- LEFT: heading + rating + neighbourhood cards -->
          <div class="sp-rev-left">
            <div style="display:flex; align-items:center; gap:8px; margin-bottom:16px;">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <rect x="1" y="1" width="5" height="5" rx="1" fill="#B85C38"/>
                <rect x="8" y="1" width="5" height="5" rx="1" fill="#B85C38" opacity="0.4"/>
                <rect x="1" y="8" width="5" height="5" rx="1" fill="#B85C38" opacity="0.4"/>
                <rect x="8" y="8" width="5" height="5" rx="1" fill="#B85C38"/>
              </svg>
              <span style="font-family:'Inter',sans-serif; font-size:11px; font-weight:700; letter-spacing:0.10em; color:#B85C38; text-transform:uppercase;">What Homeowners Say</span>
            </div>
            <h2 style="font-family:'Onest',sans-serif; font-size:clamp(40px,4.5vw,60px); font-weight:700; line-height:1.1; color:#16120F; letter-spacing:-0.02em; margin:0 0 28px;">
              Real Reviews from<br><em style="font-style:normal;">Chicagoland Clients</em>
            </h2>
            <div style="margin-bottom:40px;">
              <p style="font-family:'Onest',sans-serif; font-size:48px; font-weight:700; color:#16120F; margin:0 0 8px; line-height:1;">4.8</p>
              <div style="display:flex; gap:4px; margin-bottom:6px;">
                {[1,2,3,4,5].map(() => (
                  <svg width="18" height="18" viewBox="0 0 14 14" fill="#B85C38"><path d="M7 1l1.6 3.2 3.5.5-2.55 2.48.6 3.52L7 9.1 3.85 10.7l.6-3.52L2 4.7l3.5-.5L7 1z"/></svg>
                ))}
              </div>
              <p style="font-family:'Inter',sans-serif; font-size:14px; color:#6A625A; margin:0;">92 verified Chicagoland homeowners</p>
            </div>
            <div id="sp-rev-nbhd-area" style="opacity:0; transform:translateY(16px);">
              <div style="display:flex; align-items:center; gap:8px; margin-bottom:12px;">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                  <rect x="1" y="1" width="5" height="5" rx="1" fill="#B85C38"/>
                  <rect x="8" y="1" width="5" height="5" rx="1" fill="#B85C38" opacity="0.4"/>
                  <rect x="1" y="8" width="5" height="5" rx="1" fill="#B85C38" opacity="0.4"/>
                  <rect x="8" y="8" width="5" height="5" rx="1" fill="#B85C38"/>
                </svg>
                <span style="font-family:'Inter',sans-serif; font-size:11px; font-weight:700; letter-spacing:0.10em; text-transform:uppercase; color:#B85C38;">Trusted across Chicagoland</span>
              </div>
              <div style="display:flex; gap:10px;">
                <div class="sp-rev-nbhd-card" style="flex:1; border-radius:14px; padding:18px 14px 14px; background:#FCFAF4; border:1px solid #E4E2DE; box-shadow:0 4px 24px rgba(22,18,15,0.07); box-sizing:border-box; opacity:0; transform:translateY(16px); display:flex; flex-direction:column; justify-content:space-between;">
                  <div>
                    <div style="margin-bottom:10px;"><span style="font-family:'Inter',sans-serif; font-size:10px; font-weight:700; letter-spacing:0.10em; text-transform:uppercase; color:#B85C38;">North Shore</span></div>
                    <div style="display:flex; gap:4px; flex-wrap:wrap; margin-bottom:12px;">
                      <span style="font-family:'Inter',sans-serif; font-size:9px; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; color:#B85C38; border:1px solid rgba(184,92,56,0.30); border-radius:4px; padding:2px 7px;">Winnetka</span>
                      <span style="font-family:'Inter',sans-serif; font-size:9px; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; color:#B85C38; border:1px solid rgba(184,92,56,0.30); border-radius:4px; padding:2px 7px;">Evanston</span>
                    </div>
                    <p style="font-family:'Inter',sans-serif; font-size:12px; line-height:1.55; color:#4A433B; margin:0; font-style:italic;">"AMS was meticulous with our brick work. They showed up every day as promised, cleaned up after each session, and delivered exactly what was quoted."</p>
                  </div>
                  <div style="display:flex; align-items:center; gap:8px; margin-top:14px; padding-top:12px; border-top:1px solid #E4E2DE;">
                    <div style="width:28px; height:28px; border-radius:50%; background:#E8E4DC; overflow:hidden; flex-shrink:0;"><svg width="28" height="28" viewBox="0 0 28 28" fill="none"><circle cx="14" cy="11" r="6" fill="#C4BDB5"/><ellipse cx="14" cy="24" rx="9" ry="6" fill="#C4BDB5"/></svg></div>
                    <div>
                      <p style="font-family:'Onest',sans-serif; font-size:12px; font-weight:700; color:#16120F; margin:0 0 1px;">Sarah M.</p>
                      <p style="font-family:'Inter',sans-serif; font-size:10px; color:#6A625A; margin:0;">Winnetka, IL</p>
                    </div>
                  </div>
                </div>
                <div class="sp-rev-nbhd-card" style="flex:1; border-radius:14px; padding:18px 14px 14px; background:#FCFAF4; border:1px solid #E4E2DE; box-shadow:0 4px 24px rgba(22,18,15,0.07); box-sizing:border-box; opacity:0; transform:translateY(16px); display:flex; flex-direction:column; justify-content:space-between;">
                  <div>
                    <div style="margin-bottom:10px;"><span style="font-family:'Inter',sans-serif; font-size:10px; font-weight:700; letter-spacing:0.10em; text-transform:uppercase; color:#B85C38;">Western Suburbs</span></div>
                    <div style="display:flex; gap:4px; flex-wrap:wrap; margin-bottom:12px;">
                      <span style="font-family:'Inter',sans-serif; font-size:9px; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; color:#B85C38; border:1px solid rgba(184,92,56,0.30); border-radius:4px; padding:2px 7px;">Hinsdale</span>
                      <span style="font-family:'Inter',sans-serif; font-size:9px; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; color:#B85C38; border:1px solid rgba(184,92,56,0.30); border-radius:4px; padding:2px 7px;">Oak Brook</span>
                    </div>
                    <p style="font-family:'Inter',sans-serif; font-size:12px; line-height:1.55; color:#4A433B; margin:0; font-style:italic;">"Three bids, one clear choice. AMS was the only masonry contractor who gave us a written schedule — and kept it."</p>
                  </div>
                  <div style="display:flex; align-items:center; gap:8px; margin-top:14px; padding-top:12px; border-top:1px solid #E4E2DE;">
                    <div style="width:28px; height:28px; border-radius:50%; background:#E8E4DC; overflow:hidden; flex-shrink:0;"><svg width="28" height="28" viewBox="0 0 28 28" fill="none"><circle cx="14" cy="11" r="6" fill="#C4BDB5"/><ellipse cx="14" cy="24" rx="9" ry="6" fill="#C4BDB5"/></svg></div>
                    <div>
                      <p style="font-family:'Onest',sans-serif; font-size:12px; font-weight:700; color:#16120F; margin:0 0 1px;">David L.</p>
                      <p style="font-family:'Inter',sans-serif; font-size:10px; color:#6A625A; margin:0;">Hinsdale, IL</p>
                    </div>
                  </div>
                </div>
                <div class="sp-rev-nbhd-card" style="flex:1; border-radius:14px; padding:18px 14px 14px; background:#FCFAF4; border:1px solid #E4E2DE; box-shadow:0 4px 24px rgba(22,18,15,0.07); box-sizing:border-box; opacity:0; transform:translateY(16px); display:flex; flex-direction:column; justify-content:space-between;">
                  <div>
                    <div style="margin-bottom:10px;"><span style="font-family:'Inter',sans-serif; font-size:10px; font-weight:700; letter-spacing:0.10em; text-transform:uppercase; color:#B85C38;">DuPage Corridor</span></div>
                    <div style="display:flex; gap:4px; flex-wrap:wrap; margin-bottom:12px;">
                      <span style="font-family:'Inter',sans-serif; font-size:9px; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; color:#B85C38; border:1px solid rgba(184,92,56,0.30); border-radius:4px; padding:2px 7px;">Naperville</span>
                      <span style="font-family:'Inter',sans-serif; font-size:9px; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; color:#B85C38; border:1px solid rgba(184,92,56,0.30); border-radius:4px; padding:2px 7px;">Wheaton</span>
                    </div>
                    <p style="font-family:'Inter',sans-serif; font-size:12px; line-height:1.55; color:#4A433B; margin:0; font-style:italic;">"Used AMS for our chimney rebuild and tuckpointing. Passed every inspection first visit. Professional from start to finish."</p>
                  </div>
                  <div style="display:flex; align-items:center; gap:8px; margin-top:14px; padding-top:12px; border-top:1px solid #E4E2DE;">
                    <div style="width:28px; height:28px; border-radius:50%; background:#E8E4DC; overflow:hidden; flex-shrink:0;"><svg width="28" height="28" viewBox="0 0 28 28" fill="none"><circle cx="14" cy="11" r="6" fill="#C4BDB5"/><ellipse cx="14" cy="24" rx="9" ry="6" fill="#C4BDB5"/></svg></div>
                    <div>
                      <p style="font-family:'Onest',sans-serif; font-size:12px; font-weight:700; color:#16120F; margin:0 0 1px;">Christine H.</p>
                      <p style="font-family:'Inter',sans-serif; font-size:10px; color:#6A625A; margin:0;">Naperville, IL</p>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- RIGHT: stacked review cards -->
          <div style="display:flex; align-items:center; justify-content:center;">
            <div id="sp-rev-stack" style="position:relative; width:340px; height:400px;">

              <div class="sp-rev-card" style="position:absolute; inset:0; border-radius:20px; padding:36px 32px 30px; display:flex; flex-direction:column; align-items:center; justify-content:space-between; background:#F0EFED; border:1px solid #E4E2DE; box-shadow:0 4px 40px rgba(22,18,15,0.07); will-change:transform; backface-visibility:hidden; box-sizing:border-box; text-align:center;">
                <div style="display:flex; flex-direction:column; align-items:center; gap:18px; flex:1;">
                  <div style="display:flex; gap:4px;">{[1,2,3,4,5].map(() => (<svg width="17" height="17" viewBox="0 0 14 14" fill="#B85C38"><path d="M7 1l1.6 3.2 3.5.5-2.55 2.48.6 3.52L7 9.1 3.85 10.7l.6-3.52L2 4.7l3.5-.5L7 1z"/></svg>))}</div>
                  <p style="font-family:'Inter',sans-serif; font-size:16px; line-height:1.5; color:#4A433B; margin:0;">"AMS was the only masonry sub on our build that actually showed up when they said they would. The brick work on our Hinsdale custom home is perfect — every inspector commented on the quality."</p>
                </div>
                <div style="display:flex; align-items:center; gap:12px; margin-top:24px; width:100%; justify-content:flex-start;">
                  <div style="width:42px; height:42px; border-radius:50%; background:#E8E4DC; overflow:hidden; flex-shrink:0;"><svg width="42" height="42" viewBox="0 0 42 42" fill="none"><circle cx="21" cy="17" r="9" fill="#C4BDB5"/><ellipse cx="21" cy="36" rx="14" ry="10" fill="#C4BDB5"/></svg></div>
                  <div style="text-align:left;">
                    <p style="font-family:'Onest',sans-serif; font-size:15px; font-weight:700; color:#16120F; margin:0 0 2px;">James T.</p>
                    <p style="font-family:'Inter',sans-serif; font-size:13px; color:#6A625A; margin:0;">Hinsdale, IL</p>
                  </div>
                </div>
              </div>

              <div class="sp-rev-card" style="position:absolute; inset:0; border-radius:20px; padding:36px 32px 30px; display:flex; flex-direction:column; align-items:center; justify-content:space-between; background:#F0EFED; border:1px solid #E4E2DE; box-shadow:0 4px 40px rgba(22,18,15,0.07); will-change:transform; backface-visibility:hidden; box-sizing:border-box; text-align:center;">
                <div style="display:flex; flex-direction:column; align-items:center; gap:18px; flex:1;">
                  <div style="display:flex; gap:4px;">{[1,2,3,4,5].map(() => (<svg width="17" height="17" viewBox="0 0 14 14" fill="#B85C38"><path d="M7 1l1.6 3.2 3.5.5-2.55 2.48.6 3.52L7 9.1 3.85 10.7l.6-3.52L2 4.7l3.5-.5L7 1z"/></svg>))}</div>
                  <p style="font-family:'Inter',sans-serif; font-size:16px; line-height:1.5; color:#4A433B; margin:0;">"We used AMS for our full limestone facade, fireplace, and chimney. They coordinated directly with our GC, sent progress photos daily, and finished three days ahead of schedule. Outstanding."</p>
                </div>
                <div style="display:flex; align-items:center; gap:12px; margin-top:24px; width:100%; justify-content:flex-start;">
                  <div style="width:42px; height:42px; border-radius:50%; background:#E8E4DC; overflow:hidden; flex-shrink:0;"><svg width="42" height="42" viewBox="0 0 42 42" fill="none"><circle cx="21" cy="17" r="9" fill="#C4BDB5"/><ellipse cx="21" cy="36" rx="14" ry="10" fill="#C4BDB5"/></svg></div>
                  <div style="text-align:left;">
                    <p style="font-family:'Onest',sans-serif; font-size:15px; font-weight:700; color:#16120F; margin:0 0 2px;">Patricia &amp; David K.</p>
                    <p style="font-family:'Inter',sans-serif; font-size:13px; color:#6A625A; margin:0;">Winnetka, IL</p>
                  </div>
                </div>
              </div>

              <div class="sp-rev-card" style="position:absolute; inset:0; border-radius:20px; padding:36px 32px 30px; display:flex; flex-direction:column; align-items:center; justify-content:space-between; background:#F0EFED; border:1px solid #E4E2DE; box-shadow:0 4px 40px rgba(22,18,15,0.07); will-change:transform; backface-visibility:hidden; box-sizing:border-box; text-align:center;">
                <div style="display:flex; flex-direction:column; align-items:center; gap:18px; flex:1;">
                  <div style="display:flex; gap:4px;">{[1,2,3,4,5].map(() => (<svg width="17" height="17" viewBox="0 0 14 14" fill="#B85C38"><path d="M7 1l1.6 3.2 3.5.5-2.55 2.48.6 3.52L7 9.1 3.85 10.7l.6-3.52L2 4.7l3.5-.5L7 1z"/></svg>))}</div>
                  <p style="font-family:'Inter',sans-serif; font-size:16px; line-height:1.5; color:#4A433B; margin:0;">"I'm a builder and I've used AMS on four custom homes. They're the only masonry crew I trust to stay on schedule without me having to babysit. The quality is consistent every time."</p>
                </div>
                <div style="display:flex; align-items:center; gap:12px; margin-top:24px; width:100%; justify-content:flex-start;">
                  <div style="width:42px; height:42px; border-radius:50%; background:#E8E4DC; overflow:hidden; flex-shrink:0;"><svg width="42" height="42" viewBox="0 0 42 42" fill="none"><circle cx="21" cy="17" r="9" fill="#C4BDB5"/><ellipse cx="21" cy="36" rx="14" ry="10" fill="#C4BDB5"/></svg></div>
                  <div style="text-align:left;">
                    <p style="font-family:'Onest',sans-serif; font-size:15px; font-weight:700; color:#16120F; margin:0 0 2px;">Robert S., General Contractor</p>
                    <p style="font-family:'Inter',sans-serif; font-size:13px; color:#6A625A; margin:0;">Chicagoland</p>
                  </div>
                </div>
              </div>

              <div class="sp-rev-card" style="position:absolute; inset:0; border-radius:20px; padding:36px 32px 30px; display:flex; flex-direction:column; align-items:center; justify-content:space-between; background:#F0EFED; border:1px solid #E4E2DE; box-shadow:0 4px 40px rgba(22,18,15,0.07); will-change:transform; backface-visibility:hidden; box-sizing:border-box; text-align:center;">
                <div style="display:flex; flex-direction:column; align-items:center; gap:18px; flex:1;">
                  <div style="display:flex; gap:4px;">{[1,2,3,4,5].map(() => (<svg width="17" height="17" viewBox="0 0 14 14" fill="#B85C38"><path d="M7 1l1.6 3.2 3.5.5-2.55 2.48.6 3.52L7 9.1 3.85 10.7l.6-3.52L2 4.7l3.5-.5L7 1z"/></svg>))}</div>
                  <p style="font-family:'Inter',sans-serif; font-size:16px; line-height:1.5; color:#4A433B; margin:0;">"AMS's written estimate was the most detailed we've ever received. Every material, every elevation priced out separately. No surprises — the final bill matched the estimate exactly."</p>
                </div>
                <div style="display:flex; align-items:center; gap:12px; margin-top:24px; width:100%; justify-content:flex-start;">
                  <div style="width:42px; height:42px; border-radius:50%; background:#E8E4DC; overflow:hidden; flex-shrink:0;"><svg width="42" height="42" viewBox="0 0 42 42" fill="none"><circle cx="21" cy="17" r="9" fill="#C4BDB5"/><ellipse cx="21" cy="36" rx="14" ry="10" fill="#C4BDB5"/></svg></div>
                  <div style="text-align:left;">
                    <p style="font-family:'Onest',sans-serif; font-size:15px; font-weight:700; color:#16120F; margin:0 0 2px;">Michael B.</p>
                    <p style="font-family:'Inter',sans-serif; font-size:13px; color:#6A625A; margin:0;">Naperville, IL</p>
                  </div>
