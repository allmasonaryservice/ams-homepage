  .pp-related-grid { grid-template-columns: 1fr; gap: 12px; }
  .sp-cta-inner { flex-direction: column; align-items: flex-start; }
}

@media (max-width: 640px) {
  .pp-prob { padding: 72px 0; }
  .pp-proc { padding: 72px 0; }
  .pp-val { padding: 72px 0; }
  .pp-faq { padding: 72px 0; }
  .pp-related { padding: 72px 0; }
  .sp-cta-banner { padding: 60px 20px; }
  .pp-proc-card { padding: 28px 24px; }
  .sp-trust-inner { gap: 12px; }
  .sp-trust-sep { display: none; }
}

</style>

<!-- ═══════════════════════════════════════════════
     BEFORE / AFTER SLIDER + GALLERY NAV
══════════════════════════════════════════════════ -->
<script is:inline>
(function () {

  /* ─── Single before/after drag slider ─── */
  function initBaSlider(slider) {
    var before = slider.querySelector('.pp-ba-before');
    var divider = slider.querySelector('.pp-ba-div');
    if (!before || !divider) return;

    var dragging = false;

    function setPos(clientX) {
      var rect = slider.getBoundingClientRect();
      var pct = Math.max(2, Math.min(98, (clientX - rect.left) / rect.width * 100));
      divider.style.left = pct + '%';
      before.style.clipPath = 'inset(0 ' + (100 - pct) + '% 0 0)';
    }

    /* Mouse */
    divider.addEventListener('mousedown', function (e) {
      dragging = true;
      e.preventDefault();
    });
    slider.addEventListener('mousemove', function (e) {
      if (dragging) setPos(e.clientX);
    });
    document.addEventListener('mouseup', function () { dragging = false; });

    /* Touch */
    divider.addEventListener('touchstart', function (e) {
      dragging = true;
      e.preventDefault();
    }, { passive: false });
    slider.addEventListener('touchmove', function (e) {
      if (dragging) { setPos(e.touches[0].clientX); e.preventDefault(); }
    }, { passive: false });
    document.addEventListener('touchend', function () { dragging = false; });

    /* Keyboard: arrow keys adjust slider 5% per press */
    slider.setAttribute('tabindex', '0');
    slider.addEventListener('keydown', function (e) {
      var rect = slider.getBoundingClientRect();
      var cur = divider.offsetLeft / slider.offsetWidth * 100;
      if (e.key === 'ArrowLeft')  { e.preventDefault(); setPos(rect.left + (cur - 5) / 100 * rect.width); }
      if (e.key === 'ArrowRight') { e.preventDefault(); setPos(rect.left + (cur + 5) / 100 * rect.width); }
    });

    /* Initial state already set via CSS class */
  }

  /* ─── Gallery slideshow ─── */
  function initGallery() {
    var stage   = document.querySelector('.pp-gallery-stage');
    if (!stage) return;

    var pairs   = Array.from(stage.querySelectorAll('.pp-ba-pair'));
    var dots    = Array.from(stage.querySelectorAll('.pp-gallery-dot'));
    var prevBtn = stage.querySelector('.pp-gallery-btn--prev');
    var nextBtn = stage.querySelector('.pp-gallery-btn--next');
    var current = 0;

    /* Init all sliders */
    pairs.forEach(function (pair) {
      var slider = pair.querySelector('.pp-ba-slider');
      if (slider) initBaSlider(slider);
    });

    /* Navigate to pair index */
    function goTo(idx) {
      pairs[current].classList.remove('pp-ba-pair--active');
      dots[current].classList.remove('pp-gallery-dot--active');
      dots[current].setAttribute('aria-selected', 'false');

      current = ((idx % pairs.length) + pairs.length) % pairs.length;

      pairs[current].classList.add('pp-ba-pair--active');
      dots[current].classList.add('pp-gallery-dot--active');
      dots[current].setAttribute('aria-selected', 'true');

      /* Reset slider to 50% */
      var slider = pairs[current].querySelector('.pp-ba-slider');
      if (slider) {
        var before  = slider.querySelector('.pp-ba-before');
        var divider = slider.querySelector('.pp-ba-div');
        if (before)  before.style.clipPath = 'inset(0 50% 0 0)';
        if (divider) divider.style.left = '50%';
      }
    }

    if (prevBtn) prevBtn.addEventListener('click', function () { goTo(current - 1); });
    if (nextBtn) nextBtn.addEventListener('click', function () { goTo(current + 1); });
    dots.forEach(function (dot, i) {
      dot.addEventListener('click', function () { goTo(i); });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initGallery);
  } else {
    initGallery();
  }
  document.addEventListener('astro:page-load', initGallery);
})();
</script>

<!-- ═══════════════════════════════════════════════
     FAQ ACCORDION
══════════════════════════════════════════════════ -->
<script is:inline>
(function () {
  function initFaq() {
    var items = document.querySelectorAll('.pp-faq-item');
    items.forEach(function (item) {
      var btn = item.querySelector('.pp-faq-q');
      var ans = item.querySelector('.pp-faq-a');
      if (!btn || !ans) return;
      btn.addEventListener('click', function () {
        var open = btn.getAttribute('aria-expanded') === 'true';
        // close all
        items.forEach(function (other) {
          var ob = other.querySelector('.pp-faq-q');
          var oa = other.querySelector('.pp-faq-a');
          if (ob && oa) { ob.setAttribute('aria-expanded', 'false'); oa.hidden = true; }
        });
        if (!open) { btn.setAttribute('aria-expanded', 'true'); ans.hidden = false; }
      });
    });
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initFaq);
  } else {
    initFaq();
  }
  document.addEventListener('astro:page-load', initFaq);
})();
</script>

<!-- ═══════════════════════════════════════════════
     GSAP SCROLL ANIMATIONS
══════════════════════════════════════════════════ -->
<script is:inline>
(function () {

  function initPpAnim() {
    var gsap = window.__gsap;
    var ScrollTrigger = window.__ScrollTrigger;
    if (!gsap || !ScrollTrigger) return;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    /* ── PROBLEM SECTION ── */
    var probSection = document.querySelector('.pp-prob');
    if (probSection) {
      var probLabel = probSection.querySelector('.pp-section-label');
      var probH2 = probSection.querySelector('.pp-prob-h2');
      var probSub = probSection.querySelector('.pp-prob-sub');
      var probSidebar = probSection.querySelector('.pp-prob-sidebar');
      var probItems = Array.from(probSection.querySelectorAll('.pp-prob-item'));
      var probRules = Array.from(probSection.querySelectorAll('.pp-prob-rule'));

      gsap.set([probLabel, probH2, probSub].filter(Boolean), { opacity: 0, y: 24 });
      if (probSidebar) gsap.set(probSidebar, { opacity: 0, x: -32 });
      gsap.set(probRules, { scaleX: 0, transformOrigin: 'left center' });
      gsap.set(probItems, { opacity: 0, y: 24 });

      ScrollTrigger.create({
        trigger: probSection,
        start: 'top 78%',
        onEnter: function () {
          gsap.to([probLabel, probH2, probSub].filter(Boolean), {
            opacity: 1, y: 0, duration: 0.65, ease: 'power2.out', stagger: 0.12, overwrite: true
          });
        },
        onLeaveBack: function () {
          gsap.set([probLabel, probH2, probSub].filter(Boolean), { opacity: 0, y: 24 });
        }
      });

      if (probSidebar) {
        ScrollTrigger.create({
          trigger: '.pp-prob-cols',
          start: 'top 82%',
          onEnter: function () {
            gsap.to(probSidebar, { opacity: 1, x: 0, duration: 0.7, ease: 'power2.out', overwrite: true });
          },
          onLeaveBack: function () { gsap.set(probSidebar, { opacity: 0, x: -32 }); }
        });
      }

      probItems.forEach(function (item, i) {
        var prevRule = probRules[i];
        ScrollTrigger.create({
          trigger: item,
          start: 'top 88%',
          onEnter: function () {
            if (prevRule) gsap.to(prevRule, { scaleX: 1, duration: 0.5, ease: 'power2.out', overwrite: true });
            gsap.to(item, { opacity: 1, y: 0, duration: 0.6, ease: 'power2.out', delay: 0.12, overwrite: true });
          },
          onLeaveBack: function () {
            if (prevRule) gsap.set(prevRule, { scaleX: 0 });
            gsap.set(item, { opacity: 0, y: 24 });
          }
        });
      });

      var lastProbRule = probRules[probRules.length - 1];
      if (lastProbRule) {
        ScrollTrigger.create({
          trigger: lastProbRule,
          start: 'top 92%',
          onEnter: function () { gsap.to(lastProbRule, { scaleX: 1, duration: 0.5, ease: 'power2.out', overwrite: true }); },
          onLeaveBack: function () { gsap.set(lastProbRule, { scaleX: 0 }); }
        });
      }
    }

    /* ── PROCESS CARDS ── */
    var procSection = document.querySelector('.pp-proc');
    if (procSection) {
      var procLabel = procSection.querySelector('.pp-section-label');
      var procH2 = procSection.querySelector('.pp-proc-h2');
      var procSub = procSection.querySelector('.pp-proc-sub');
      var procCards = Array.from(procSection.querySelectorAll('.pp-proc-card'));

      gsap.set([procLabel, procH2, procSub].filter(Boolean), { opacity: 0, y: 24 });
      gsap.set(procCards, { opacity: 0, y: 32 });

      ScrollTrigger.create({
        trigger: procSection,
        start: 'top 78%',
        onEnter: function () {
          gsap.to([procLabel, procH2, procSub].filter(Boolean), {
            opacity: 1, y: 0, duration: 0.6, ease: 'power2.out', stagger: 0.1, overwrite: true
          });
          gsap.to(procCards, {
            opacity: 1, y: 0, duration: 0.65, ease: 'power2.out', stagger: 0.1, delay: 0.2, overwrite: true
          });
        },
        onLeaveBack: function () {
          gsap.set([procLabel, procH2, procSub].filter(Boolean), { opacity: 0, y: 24 });
          gsap.set(procCards, { opacity: 0, y: 32 });
        }
      });
    }

    /* ── VALUE PROP ── */
    var valSection = document.querySelector('.pp-val');
    if (valSection) {
      var valEls = Array.from(valSection.querySelectorAll('.pp-section-label, .pp-val-h2, .pp-val-body, .pp-val-badge'));
      gsap.set(valEls, { opacity: 0, y: 20 });
      ScrollTrigger.create({
        trigger: valSection,
        start: 'top 78%',
        onEnter: function () {
          gsap.to(valEls, { opacity: 1, y: 0, duration: 0.6, ease: 'power2.out', stagger: 0.08, overwrite: true });
        },
        onLeaveBack: function () { gsap.set(valEls, { opacity: 0, y: 20 }); }
      });
    }

    /* ── FAQ ── */
    var faqSection = document.querySelector('.pp-faq');
    if (faqSection) {
      var faqHdrEls = Array.from(faqSection.querySelectorAll('.pp-section-label, .pp-faq-h2'));
      var faqItems = Array.from(faqSection.querySelectorAll('.pp-faq-item'));
      gsap.set([...faqHdrEls, ...faqItems], { opacity: 0, y: 20 });
      ScrollTrigger.create({
        trigger: faqSection,
        start: 'top 78%',
        onEnter: function () {
          gsap.to([...faqHdrEls, ...faqItems], {
            opacity: 1, y: 0, duration: 0.6, ease: 'power2.out', stagger: 0.08, overwrite: true
          });
        },
        onLeaveBack: function () { gsap.set([...faqHdrEls, ...faqItems], { opacity: 0, y: 20 }); }
      });
    }

    /* ── RELATED CARDS ── */
    var relatedCards = Array.from(document.querySelectorAll('.pp-related-card'));
    if (relatedCards.length) {
      gsap.set(relatedCards, { opacity: 0, y: 28 });
      ScrollTrigger.create({
        trigger: '.pp-related',
        start: 'top 78%',
        onEnter: function () {
          gsap.to(relatedCards, {
            opacity: 1, y: 0, duration: 0.6, ease: 'power2.out', stagger: 0.07, overwrite: true
          });
        },
        onLeaveBack: function () { gsap.set(relatedCards, { opacity: 0, y: 28 }); }
      });
    }
  }

  window.__ppAnimReady = initPpAnim;
  window.addEventListener('animations:ready', window.__ppAnimReady);
  document.addEventListener('astro:page-load', initPpAnim);
})();
</script>
