/* ── HERO ── */
.pp-hero {
  position: relative;
  background: #0F0D0C;
  overflow: hidden;
  padding: 140px 0 90px;
}
.pp-hero-bg {
  position: absolute;
  inset: 0;
  background-image: var(--pp-hero-img);
  background-size: cover;
  background-position: center;
  z-index: 0;
  transform: scale(1.04);
}
@media (max-width: 767px) {
  .pp-hero-bg { background-image: var(--pp-hero-img-sm, var(--pp-hero-img)); }
}
.pp-hero-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    105deg,
    rgba(15,13,12,0.92) 0%,
    rgba(15,13,12,0.78) 55%,
    rgba(15,13,12,0.55) 100%
  );
  z-index: 1;
}
.pp-hero-grain {
  position: absolute;
  inset: 0;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
  background-size: 200px;
  pointer-events: none;
  z-index: 2;
}
.pp-hero-inner {
  position: relative;
  z-index: 3;
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 30px;
  display: grid;
  grid-template-columns: 1fr 400px;
  gap: 60px;
  align-items: start;
}
.pp-hero-label {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-family: 'Inter', sans-serif;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: #B85C38;
  margin-bottom: 24px;
}
.pp-hero-label::before {
  content: '';
  display: block;
  width: 28px;
  height: 2px;
  background: #B85C38;
  flex-shrink: 0;
}
.pp-hero-label-sep { color: rgba(184,92,56,0.45); }
.pp-h1 {
  font-family: 'Onest', sans-serif;
  font-size: clamp(38px, 4.4vw, 68px);
  font-weight: 800;
  line-height: 1.08;
  letter-spacing: -0.03em;
  margin: 0 0 28px;
  color: #ffffff;
  max-width: 640px;
}
.pp-hero-sub {
  font-family: 'Inter', sans-serif;
  font-size: 17px;
  line-height: 1.65;
  color: rgba(255,255,255,0.62);
  margin: 0 0 32px;
  max-width: 520px;
}
.pp-hero-meta {
  display: flex;
  align-items: center;
  gap: 10px;
  flex-wrap: wrap;
  margin-bottom: 40px;
}
.pp-meta-item {
  display: flex;
  align-items: center;
  gap: 5px;
  font-family: 'Inter', sans-serif;
  font-size: 13px;
  color: rgba(255,255,255,0.45);
}
.pp-meta-item svg { color: rgba(255,255,255,0.3); flex-shrink: 0; }
.pp-meta-dot { color: rgba(255,255,255,0.2); font-size: 13px; }
.pp-hero-actions { display: flex; gap: 14px; flex-wrap: wrap; }
.pp-btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-family: 'Inter', sans-serif;
  font-size: 14px;
  font-weight: 600;
  border-radius: 10px;
  padding: 13px 22px;
  text-decoration: none;
  transition: background 200ms ease, color 200ms ease, border-color 200ms ease;
}
.pp-btn--primary {
  background: #B85C38;
  color: #ffffff;
  border: 1.5px solid #B85C38;
}
.pp-btn--primary:hover { background: #8A3A22; border-color: #8A3A22; }
.pp-btn--ghost {
  background: transparent;
  color: rgba(255,255,255,0.82);
  border: 1.5px solid rgba(255,255,255,0.2);
}
.pp-btn--ghost:hover { border-color: rgba(255,255,255,0.45); color: #ffffff; }

/* snapshot card */
.pp-snapshot {
  background: #16120F;
  border: 1px solid rgba(255,255,255,0.07);
  border-radius: 16px;
  padding: 28px;
}
.pp-snapshot-eyebrow {
  font-family: 'Inter', sans-serif;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.10em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.35);
  margin: 0 0 20px;
}
.pp-snapshot-stats {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1px;
