@media (max-width: 1024px) {
  .pp-hero-inner { grid-template-columns: 1fr; gap: 40px; }
  .pp-hero-right { display: none; }
  .pp-val-inner { grid-template-columns: 1fr; gap: 40px; }
}

@media (max-width: 900px) {
  .pp-hero { padding: 110px 0 60px; }
  .pp-prob-hdr { margin-bottom: 40px; }
  .pp-prob-cols { grid-template-columns: 1fr; gap: 40px; }
  .pp-prob-sidebar { position: static; }
