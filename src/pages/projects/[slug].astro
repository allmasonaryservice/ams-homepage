  flex-direction: column;
  gap: 4px;
}
.pp-snapshot-val {
  font-family: 'Onest', sans-serif;
  font-size: 18px;
  font-weight: 700;
  color: #B85C38;
  line-height: 1.1;
}
.pp-snapshot-key {
  font-family: 'Inter', sans-serif;
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.3);
}
.pp-snapshot-divider {
  height: 1px;
  background: rgba(255,255,255,0.07);
  margin-bottom: 20px;
}
.pp-snapshot-rows { display: flex; flex-direction: column; margin-bottom: 20px; }
.pp-snapshot-row {
  display: flex;
  justify-content: space-between;
  gap: 12px;
  padding: 10px 0;
  border-bottom: 1px solid rgba(255,255,255,0.05);
  align-items: baseline;
}
.pp-snapshot-row:last-child { border-bottom: none; }
.pp-snapshot-row-key {
  font-family: 'Inter', sans-serif;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.09em;
  text-transform: uppercase;
