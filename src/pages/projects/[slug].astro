---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import { projects } from '../../data/projects.js';

export function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project: p } = Astro.props;
---

<Layout
  title={`${p.title} — ${p.serviceType} | All Masonry Services Inc`}
  description={p.heroSub}
>
  <Navbar />

  <!-- ─────────────────────────────────────────
       HERO
  ───────────────────────────────────────── -->
  <section class="pp-hero" style={[
    p.heroImage   ? `--pp-hero-img: url('${p.heroImage}')`     : '',
    p.heroImageSm ? `--pp-hero-img-sm: url('${p.heroImageSm}')` : '',
  ].filter(Boolean).join('; ')}>
    {p.heroImage && <div class="pp-hero-bg"></div>}
    <div class="pp-hero-overlay"></div>
    <div class="pp-hero-grain"></div>
    <div class="pp-hero-inner">

      <div class="pp-hero-left">
        <div class="pp-hero-label">{p.serviceType}</div>

        <h1 class="pp-h1">{p.title}</h1>

        <p class="pp-hero-sub">{p.heroSub}</p>

        <div class="pp-hero-meta">
          <span class="pp-meta-item">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M12 22s-8-4.5-8-11.8A8 8 0 0 1 12 2a8 8 0 0 1 8 8.2c0 7.3-8 11.8-8 11.8z"/>
              <circle cx="12" cy="10" r="3"/>
            </svg>
            {p.location}
          </span>
          <span class="pp-meta-dot" aria-hidden="true">·</span>
          <span class="pp-meta-item">{p.county}</span>
          <span class="pp-meta-dot" aria-hidden="true">·</span>
          <span class="pp-meta-item">Completed {p.year}</span>
        </div>

        <div class="pp-hero-actions">
          <a href="/contact#form" class="pp-btn pp-btn--primary">
            Get a Free Estimate
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
          <a href="tel:7736562107" class="pp-btn pp-btn--ghost">773-656-2107</a>
        </div>
      </div>

      <div class="pp-hero-right">
        <div class="pp-snapshot">
          <p class="pp-snapshot-eyebrow">Project Details</p>
          <div class="pp-snapshot-stats">
            <div class="pp-snapshot-stat">
              <span class="pp-snapshot-val">{p.sqft}</span>
              <span class="pp-snapshot-key">Sq Ft</span>
            </div>
            <div class="pp-snapshot-stat">
              <span class="pp-snapshot-val">{p.duration}</span>
              <span class="pp-snapshot-key">Duration</span>
            </div>
            <div class="pp-snapshot-stat">
              <span class="pp-snapshot-val">{p.year}</span>
              <span class="pp-snapshot-key">Completed</span>
            </div>
            <div class="pp-snapshot-stat">
              <span class="pp-snapshot-val">{p.warranty}</span>
              <span class="pp-snapshot-key">Warranty</span>
            </div>
          </div>
          <div class="pp-snapshot-divider"></div>
          <div class="pp-snapshot-rows">
            <div class="pp-snapshot-row">
              <span class="pp-snapshot-row-key">Materials</span>
              <span class="pp-snapshot-row-val">{p.materials}</span>
            </div>
            <div class="pp-snapshot-row">
              <span class="pp-snapshot-row-key">Cost Range</span>
              <span class="pp-snapshot-row-val">{p.costRange}</span>
            </div>
            <div class="pp-snapshot-row">
              <span class="pp-snapshot-row-key">Location</span>
              <span class="pp-snapshot-row-val">{p.location}</span>
            </div>
            <div class="pp-snapshot-row">
              <span class="pp-snapshot-row-key">County</span>
              <span class="pp-snapshot-row-val">{p.county}</span>
            </div>
          </div>
          <a href="/contact#form" class="pp-snapshot-cta">
            Request a Free Estimate
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        </div>
      </div>

    </div>
  </section>

  <!-- ─────────────────────────────────────────
       TRUST BAR
  ───────────────────────────────────────── -->
  <div class="sp-trust" role="list" aria-label="Trust indicators">
    <div class="sp-trust-inner">
      <span class="sp-trust-item" role="listitem">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#B85C38" stroke-width="2.2" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
        Licensed &amp; Insured
      </span>
      <span class="sp-trust-sep" aria-hidden="true"></span>
      <span class="sp-trust-item" role="listitem">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#B85C38" stroke-width="2.2" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
        Free Estimates
      </span>
      <span class="sp-trust-sep" aria-hidden="true"></span>
      <span class="sp-trust-item" role="listitem">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#B85C38" stroke-width="2.2" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
        Serving Chicagoland Since 2007
      </span>
      <span class="sp-trust-sep" aria-hidden="true"></span>
      <span class="sp-trust-item" role="listitem">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#B85C38" stroke-width="2.2" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
        Mortar-Match Guarantee
      </span>
    </div>
  </div>

  <!-- ─────────────────────────────────────────
       BEFORE / AFTER GALLERY
  ───────────────────────────────────────── -->
  <section class="pp-gallery">
    <div class="pp-gallery-inner">

      <div class="pp-gallery-hdr">
        <div class="pp-section-label">Project Gallery</div>
        <h2 class="pp-gallery-h2">Before &amp; After</h2>
        <p class="pp-gallery-sub">Drag the handle to compare. Use arrows to browse all {p.gallery.length} project photos.</p>
      </div>

      <div class="pp-gallery-stage">

        {p.gallery.map((pair, i) => (
          <div class={`pp-ba-pair${i === 0 ? ' pp-ba-pair--active' : ''}`} data-pair={i}>
            <div class="pp-ba-slider" data-ba>

              <!-- AFTER (base layer — always visible) -->
              <div class="pp-ba-layer pp-ba-after">
                <img
                  src={pair.after}
                  srcset={pair.afterSm ? `${pair.afterSm} 768w, ${pair.after} 1200w` : undefined}
                  sizes={pair.afterSm ? "(max-width: 767px) 100vw, 1200px" : undefined}
                  alt={`After: ${pair.caption}`}
                  loading={i === 0 ? 'eager' : 'lazy'}
                  draggable="false"
                />
                <span class="pp-ba-tag pp-ba-tag--after">After</span>
              </div>

              <!-- BEFORE (clipped — clip-path controlled by JS) -->
              <div class="pp-ba-layer pp-ba-before">
                <img
                  src={pair.before}
                  srcset={pair.beforeSm ? `${pair.beforeSm} 768w, ${pair.before} 1200w` : undefined}
                  sizes={pair.beforeSm ? "(max-width: 767px) 100vw, 1200px" : undefined}
                  alt={`Before: ${pair.caption}`}
                  loading={i === 0 ? 'eager' : 'lazy'}
                  draggable="false"
                />
                <span class="pp-ba-tag pp-ba-tag--before">Before</span>
              </div>

              <!-- DIVIDER -->
              <div class="pp-ba-div" aria-hidden="true">
                <div class="pp-ba-handle">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                    <path d="M8 5l-5 7 5 7M16 5l5 7-5 7"/>
                  </svg>
                </div>
              </div>

            </div>
            <p class="pp-ba-caption">{i + 1}/{p.gallery.length} — {pair.caption}</p>
          </div>
        ))}

        <!-- NAVIGATION -->
        <div class="pp-gallery-nav">
          <button class="pp-gallery-btn pp-gallery-btn--prev" aria-label="Previous photo">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <path d="M15 18l-6-6 6-6"/>
            </svg>
          </button>
          <div class="pp-gallery-dots" role="tablist" aria-label="Gallery navigation">
            {p.gallery.map((_, i) => (
              <button
                class={`pp-gallery-dot${i === 0 ? ' pp-gallery-dot--active' : ''}`}
                role="tab"
                aria-label={`Photo ${i + 1}`}
                aria-selected={i === 0 ? 'true' : 'false'}
                data-dot={i}
              ></button>
            ))}
          </div>
          <button class="pp-gallery-btn pp-gallery-btn--next" aria-label="Next photo">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <path d="M9 18l6-6-6-6"/>
            </svg>
          </button>
        </div>

      </div>
    </div>
  </section>

  <!-- ─────────────────────────────────────────
       PROBLEM SECTION
  ───────────────────────────────────────── -->
  <section class="pp-prob">
    <div class="pp-prob-inner">
      <div class="pp-prob-hdr">
        <div class="pp-section-label">The Problem</div>
        <h2 class="pp-prob-h2">{p.problem.heading}</h2>
        <p class="pp-prob-sub">{p.problem.intro}</p>
      </div>

      <div class="pp-prob-cols">
        <aside class="pp-prob-sidebar" aria-label="Project specifics">
          <p class="pp-prob-sidebar-label">Project Specifics</p>
          <div class="pp-prob-rows">
            <div class="pp-prob-row">
              <span class="pp-prob-row-key">Service</span>
              <span class="pp-prob-row-val">{p.serviceType}</span>
            </div>
            <div class="pp-prob-row">
              <span class="pp-prob-row-key">Location</span>
              <span class="pp-prob-row-val">{p.location}</span>
            </div>
            <div class="pp-prob-row">
              <span class="pp-prob-row-key">Sq Footage</span>
              <span class="pp-prob-row-val">{p.sqft} sq ft</span>
            </div>
            <div class="pp-prob-row">
              <span class="pp-prob-row-key">Duration</span>
              <span class="pp-prob-row-val">{p.duration}</span>
            </div>
            <div class="pp-prob-row">
              <span class="pp-prob-row-key">Materials</span>
              <span class="pp-prob-row-val">{p.materials}</span>
            </div>
            <div class="pp-prob-row">
              <span class="pp-prob-row-key">Cost Range</span>
              <span class="pp-prob-row-val">{p.costRange}</span>
            </div>
            <div class="pp-prob-row">
              <span class="pp-prob-row-key">Warranty</span>
              <span class="pp-prob-row-val pp-prob-row-val--yes">{p.warranty}</span>
            </div>
            <div class="pp-prob-row">
              <span class="pp-prob-row-key">Free Estimate</span>
              <span class="pp-prob-row-val pp-prob-row-val--yes">Yes</span>
            </div>
          </div>
          <a href="/contact#form" class="pp-prob-sidebar-cta">
            Get a Free Estimate
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        </aside>

        <div class="pp-prob-list">
          <div class="pp-prob-rule"></div>
          {p.problem.bullets.map((bullet, i) => (
            <div class="pp-prob-item">
              <div class="pp-prob-item-head">
                <div class="pp-prob-num">{String(i + 1).padStart(2, '0')}</div>
                <p class="pp-prob-text">{bullet}</p>
              </div>
            </div>
            <div class="pp-prob-rule"></div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ─────────────────────────────────────────
       PROCESS — HOW WE FIXED IT
  ───────────────────────────────────────── -->
  <section class="pp-proc">
    <div class="pp-proc-inner">
      <div class="pp-proc-hdr">
        <div class="pp-section-label">How We Fixed It</div>
        <h2 class="pp-proc-h2">Our {p.serviceType} Process</h2>
        <p class="pp-proc-sub">Every project follows the same disciplined sequence — no shortcuts, no hand-offs, same crew start to finish.</p>
      </div>

      <div class="pp-proc-grid">
        {p.process.map((step) => (
          <div class="pp-proc-card">
            <div class="pp-proc-card-num">0{step.step}</div>
            <h3 class="pp-proc-card-title">{step.title}</h3>
            <p class="pp-proc-card-body">{step.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─────────────────────────────────────────
       VALUE PROPOSITION
  ───────────────────────────────────────── -->
  <section class="pp-val">
    <div class="pp-val-inner">
      <div class="pp-val-left">
        <div class="pp-section-label">The Result</div>
        <h2 class="pp-val-h2">{p.valueProp.heading}</h2>
      </div>
      <div class="pp-val-right">
        <p class="pp-val-body">{p.valueProp.body}</p>
        <div class="pp-val-badges">
          <div class="pp-val-badge">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#B85C38" stroke-width="2" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            <span>Mortar-Match Guarantee</span>
          </div>
          <div class="pp-val-badge">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#B85C38" stroke-width="2" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            <span>Same Crew, Start to Finish</span>
          </div>
          <div class="pp-val-badge">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#B85C38" stroke-width="2" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            <span>Written Estimate Before Work Begins</span>
          </div>
          <div class="pp-val-badge">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#B85C38" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
            <span>19+ Years of Local Expertise</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─────────────────────────────────────────
       FAQ
  ───────────────────────────────────────── -->
  <section class="pp-faq">
    <div class="pp-faq-inner">
      <div class="pp-faq-hdr">
        <div class="pp-section-label">Questions About This Project</div>
        <h2 class="pp-faq-h2">Common Questions About This Project</h2>
      </div>

      <div class="pp-faq-list" role="list">
        {p.faq.map((item, i) => (
          <div class="pp-faq-item" role="listitem">
            <button
              class="pp-faq-q"
              aria-expanded="false"
              aria-controls={`pp-faq-ans-${i}`}
            >
              <span>{item.q}</span>
              <svg class="pp-faq-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <polyline points="6 9 12 15 18 9"/>
              </svg>
            </button>
            <div class="pp-faq-a" id={`pp-faq-ans-${i}`} hidden>
              <p>{item.a}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─────────────────────────────────────────
       RELATED PROJECTS
  ───────────────────────────────────────── -->
  <section class="pp-related">
    <div class="pp-related-inner">

      <div class="pp-related-block">
        <h2 class="pp-related-h2">Other Projects Near {p.city}</h2>
        <div class="pp-related-grid">
          {p.relatedByCity.map((rel) => (
            <a href={`/projects/${rel.slug}`} class="pp-related-card">
              <div class="pp-related-card-tag">{rel.service}</div>
              <h3 class="pp-related-card-title">{rel.title}</h3>
              <div class="pp-related-card-city">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path d="M12 22s-8-4.5-8-11.8A8 8 0 0 1 12 2a8 8 0 0 1 8 8.2c0 7.3-8 11.8-8 11.8z"/>
                  <circle cx="12" cy="10" r="3"/>
                </svg>
                {rel.city}
              </div>
              <div class="pp-related-card-arrow">
                View Project
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true">
                  <path d="M5 12h14M12 5l7 7-7 7"/>
                </svg>
              </div>
            </a>
          ))}
        </div>
      </div>

      <div class="pp-related-block">
        <h2 class="pp-related-h2">More {p.serviceType} Projects</h2>
        <div class="pp-related-grid">
          {p.relatedByService.map((rel) => (
            <a href={`/projects/${rel.slug}`} class="pp-related-card">
              <div class="pp-related-card-tag">{rel.service}</div>
              <h3 class="pp-related-card-title">{rel.title}</h3>
              <div class="pp-related-card-city">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path d="M12 22s-8-4.5-8-11.8A8 8 0 0 1 12 2a8 8 0 0 1 8 8.2c0 7.3-8 11.8-8 11.8z"/>
                  <circle cx="12" cy="10" r="3"/>
                </svg>
                {rel.city}
              </div>
              <div class="pp-related-card-arrow">
                View Project
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true">
                  <path d="M5 12h14M12 5l7 7-7 7"/>
                </svg>
              </div>
            </a>
          ))}
        </div>
      </div>

    </div>
  </section>

  <!-- ─────────────────────────────────────────
       CTA BANNER
  ───────────────────────────────────────── -->
  <section class="sp-cta-banner" aria-label="Call to action">
    <div class="sp-cta-inner">
      <div class="sp-cta-text">
        <h2 class="sp-cta-h2">Need {p.serviceType} Done Right?</h2>
        <p class="sp-cta-sub">See what AMS can do for your home — schedule your free on-site estimate and get a written quote within 48 hours.</p>
      </div>
      <div class="sp-cta-actions">
        <a href="/contact#form" class="sp-cta-btn sp-cta-btn--primary">
          Request Free Estimate
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
        <a href="tel:7736562107" class="sp-cta-btn sp-cta-btn--ghost">773-656-2107</a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<!-- ═══════════════════════════════════════════════
     STYLES
══════════════════════════════════════════════════ -->
<style>

/* ── GALLERY / BEFORE-AFTER ── */
.pp-gallery {
  background: #F5F5F5;
  padding: 100px 0;
}
.pp-gallery-inner {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 30px;
}
.pp-gallery-hdr {
  max-width: 640px;
  margin-bottom: 48px;
}
.pp-gallery-h2 {
  font-family: 'Onest', sans-serif;
  font-size: clamp(32px, 3.6vw, 52px);
  font-weight: 700;
  line-height: 1.1;
  letter-spacing: -0.025em;
  color: #16120F;
  margin: 0 0 14px;
}
.pp-gallery-sub {
  font-family: 'Inter', sans-serif;
  font-size: 15px;
  line-height: 1.65;
  color: #6A625A;
  margin: 0;
}
.pp-gallery-stage {
  position: relative;
}
.pp-ba-pair {
  position: absolute;
  inset: 0;
  opacity: 0;
  pointer-events: none;
  transition: opacity 380ms ease;
}
.pp-ba-pair--active {
  position: relative;
  opacity: 1;
  pointer-events: auto;
}
.pp-ba-slider {
  position: relative;
  width: 100%;
  aspect-ratio: 16 / 9;
  border-radius: 16px;
  overflow: hidden;
  cursor: col-resize;
  user-select: none;
  background: #16120F;
}
.pp-ba-layer {
  position: absolute;
  inset: 0;
}
.pp-ba-layer img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  pointer-events: none;
  user-select: none;
  -webkit-user-drag: none;
}
.pp-ba-before {
  clip-path: inset(0 50% 0 0);
  z-index: 2;
}
.pp-ba-after {
  z-index: 1;
}
.pp-ba-tag {
  position: absolute;
  top: 16px;
  font-family: 'Inter', sans-serif;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.10em;
  text-transform: uppercase;
  padding: 5px 10px;
  border-radius: 6px;
  pointer-events: none;
}
.pp-ba-tag--before {
  left: 16px;
  background: rgba(22,18,15,0.75);
  color: rgba(255,255,255,0.9);
}
.pp-ba-tag--after {
  right: 16px;
  background: rgba(184,92,56,0.9);
  color: #ffffff;
}
.pp-ba-div {
  position: absolute;
  top: 0;
  bottom: 0;
  left: 50%;
  width: 2px;
  background: #ffffff;
  z-index: 10;
  transform: translateX(-50%);
  pointer-events: none;
}
.pp-ba-handle {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 46px;
  height: 46px;
  border-radius: 50%;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2px 16px rgba(0,0,0,0.35);
  color: #16120F;
  pointer-events: all;
  cursor: col-resize;
  transition: box-shadow 150ms ease;
}
.pp-ba-handle:hover { box-shadow: 0 4px 24px rgba(0,0,0,0.45); }
.pp-ba-caption {
  font-family: 'Inter', sans-serif;
  font-size: 13px;
  color: #6A625A;
  margin: 14px 0 0;
  line-height: 1.5;
}
.pp-gallery-nav {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20px;
  margin-top: 28px;
}
.pp-gallery-btn {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  border: 1.5px solid #D4CFC9;
