/* ── FAQ ── */
.pp-faq {
  background: #F5F5F5;
  padding: 100px 0;
}
.pp-faq-inner {
  max-width: 800px;
  margin: 0 auto;
  padding: 0 30px;
}
.pp-faq-hdr { margin-bottom: 48px; }
.pp-faq-h2 {
  font-family: 'Onest', sans-serif;
  font-size: clamp(28px, 3vw, 42px);
