---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { projects as allProjects } from '../data/projects.js';

const svcProjects = allProjects.slice(0, 5);
---

<Layout
  title="About All Masonry Services — Chicago's Trusted Masonry Experts Since 2007"
  description="Family-owned masonry company serving Chicagoland since 2007. Licensed, insured, own crew only. Brick, stone, chimney, tuckpointing, and more across 19+ cities. Free on-site estimates. Call 773-656-2107."
>
  <Navbar />

  <!-- ─── 1. HERO — KEYSTONE LOCK (same animation as Natural Stone, different image) ─── -->
  <section class="ab-hero" id="ab-hero" aria-label="About All Masonry Services hero">
    <div class="ab-hero-base" aria-hidden="true"></div>
    <div class="ab-arch" aria-hidden="true">
      <div class="ab-arch-left" id="ab-arch-left">
        <div class="ab-arch-img ab-img-left"></div>
        <div class="ab-arch-overlay"></div>
      </div>
      <div class="ab-arch-right" id="ab-arch-right">
        <div class="ab-arch-img ab-img-right"></div>
        <div class="ab-arch-overlay"></div>
      </div>
      <div class="ab-arch-keystone" id="ab-arch-keystone">
        <div class="ab-arch-img ab-img-key"></div>
      </div>
    </div>
    <div class="ab-vignette" aria-hidden="true"></div>

    <div class="ab-content">
      <div class="ab-label" id="ab-label">
        <span class="ab-label-line" aria-hidden="true"></span>
        All Masonry Services · Chicago &amp; Chicagoland · Est. 2007
      </div>
      <h1 class="ab-h1">
        <div class="ab-h1-row"><span id="ab-r1">Built on Craft.</span></div>
        <div class="ab-h1-row"><span id="ab-r2">Backed by 19 Years.</span></div>
      </h1>
      <p class="ab-sub" id="ab-sub">
        Family-owned since 2007. Own crew, no subcontractors. Serving Chicagoland homeowners who expect the repair to last — not just survive one more winter.
      </p>
      <div class="ab-actions" id="ab-act">
        <a href="/contact#form" class="ab-btn-primary">
          <span class="ab-btn-bg" aria-hidden="true"></span>
          <span>Get a Free Estimate</span>
          <svg width="13" height="13" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <a href="tel:7736562107" class="ab-btn-ghost">
          <span class="ab-btn-bg" aria-hidden="true"></span>
          <span>Call 773-656-2107</span>
        </a>
      </div>
      <div class="ab-badges" id="ab-bdg">
        <div class="ab-badge"><strong>500+</strong><span>Projects Done</span></div>
        <div class="ab-badge-sep" aria-hidden="true"></div>
        <div class="ab-badge"><strong>4.8★</strong><span>92 Google Reviews</span></div>
        <div class="ab-badge-sep" aria-hidden="true"></div>
        <div class="ab-badge"><strong>19+</strong><span>Years Experience</span></div>
      </div>
    </div>

    <div class="ab-scroll" id="ab-scroll">
      <div class="ab-scroll-mouse"><div class="ab-scroll-dot"></div></div>
      <span>Scroll</span>
    </div>
  </section>

  <script is:inline>
  (function() {
    function initAbHero() {
      var gsap = window.__gsap;
      if (!gsap) return;
      var heroEl = document.getElementById('ab-hero');
      if (!heroEl) return;
      var imgs = heroEl.querySelectorAll('.ab-arch-img');
      var mouseYNorm = 0;
      var scrollProg = 0;
      function applyParallax() {
        var pct = 50 + (mouseYNorm * 12) + (scrollProg * 10);
        pct = Math.max(25, Math.min(75, pct));
        gsap.to(imgs, { backgroundPositionY: pct + '%', duration: 0.9, ease: 'power2.out', overwrite: 'auto' });
      }
      heroEl.addEventListener('mousemove', function(e) {
        var b = heroEl.getBoundingClientRect();
        mouseYNorm = ((e.clientY - b.top) / b.height - 0.5) * 2;
        applyParallax();
      }, { passive: true });
      heroEl.addEventListener('mouseleave', function() { mouseYNorm = 0; applyParallax(); });
      heroEl.addEventListener('touchmove', function(e) {
        var b = heroEl.getBoundingClientRect();
        mouseYNorm = ((e.touches[0].clientY - b.top) / b.height - 0.5) * 2;
        applyParallax();
      }, { passive: true });
      heroEl.addEventListener('touchend', function() { mouseYNorm = 0; applyParallax(); }, { passive: true });
      window.addEventListener('scroll', function() {
        scrollProg = Math.min(window.scrollY / window.innerHeight, 1);
        applyParallax();
      }, { passive: true });
      var scrEl = document.getElementById('ab-scroll');
      if (scrEl) {
        scrEl.addEventListener('click', function() {
          var next = document.querySelector('.ab-story');
          if (next) next.scrollIntoView({ behavior: 'smooth' });
          else window.scrollTo({ top: window.innerHeight, behavior: 'smooth' });
        });
      }
    }
    if (window.__gsap) { initAbHero(); }
    else { window.addEventListener('animations:ready', initAbHero, { once: true }); }
  })();
  </script>

  <!-- ─── 2. OUR STORY ─── -->
  <section class="ab-story">
    <div class="ab-story-inner">

      <!-- LEFT: image -->
      <div class="ab-story-img-wrap" data-reveal>
        <picture style="display:block;width:100%;height:100%;">
          <source media="(max-width: 768px)" srcset="/images/about-story-m.webp" type="image/webp" />
          <img src="/images/about-story.webp" alt="All Masonry Services craftsman at work" class="ab-story-img" loading="lazy" />
        </picture>
        <div class="ab-story-badge">
          <span class="ab-story-badge-num">2007</span>
          <span class="ab-story-badge-lbl">Year Founded</span>
        </div>
      </div>

      <!-- RIGHT: text -->
      <div class="ab-story-text">
        <div class="ab-eyebrow" data-reveal>
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <rect x="1" y="1" width="5" height="5" rx="1" fill="#B85C38"/>
            <rect x="8" y="1" width="5" height="5" rx="1" fill="#B85C38" opacity="0.4"/>
            <rect x="1" y="8" width="5" height="5" rx="1" fill="#B85C38" opacity="0.4"/>
            <rect x="8" y="8" width="5" height="5" rx="1" fill="#B85C38"/>
          </svg>
          <span>Our Story</span>
        </div>
        <h2 class="ab-story-h2" data-reveal style="--rd:60ms">A Family Business Built<br>on Doing It Right</h2>
        <p class="ab-story-p" data-reveal style="--rd:120ms">
          All Masonry Services was founded in 2007 with a single commitment: do the job right the first time, or don't take it. Over 19 years, that principle has guided every tuckpointing joint, every stone installation, and every chimney rebuild we've touched across Chicagoland.
        </p>
        <p class="ab-story-p" data-reveal style="--rd:160ms">
          We're not a franchise, not a referral network, and not a company that subs out your project to whoever is available. When you call AMS, you deal with the owners — and the same crew that shows up for the estimate is the crew that does the work.
        </p>
        <p class="ab-story-p" data-reveal style="--rd:200ms">
          We've served homeowners in Chicago, the North Shore, western suburbs, and beyond — matching mortar composition, joint depth, and material to original masonry so the repair lasts decades, not seasons.
        </p>
        <div class="ab-story-ctas" data-reveal style="--rd:260ms">
          <a href="/contact#form" class="ab-story-btn-primary">Get a Free Estimate</a>
          <a href="/projects" class="ab-story-btn-ghost">See Our Work</a>
        </div>
      </div>

    </div>
  </section>

  <!-- ─── 3. PROBLEM / CONSEQUENCE ─── -->
  <section class="sp-problem">
    <div class="sp-delay-inner">

      <!-- Header -->
      <div class="sp-delay-hdr">
        <div class="sp-section-label">Why It Matters</div>
        <h2 class="sp-delay-h2">What Goes Wrong When You <em>Hire the Wrong Mason</em></h2>
        <p class="sp-delay-sub">Masonry mistakes are expensive — they're often invisible for years, then impossible to fix without opening walls. After 19 years across Chicagoland, here's what hiring the wrong mason really costs you.</p>
      </div>

      <div class="sp-delay-cols">

        <!-- LEFT: dark stats sidebar -->
        <div class="sp-delay-sidebar">
          <p class="sp-delay-sidebar-label">The real cost of waiting</p>
          <div class="sp-delay-stats">
            <div class="sp-delay-stat">
              <span class="sp-delay-stat-val">$25k+</span>
              <span class="sp-delay-stat-desc">Typical cost overrun when the wrong mason is hired</span>
            </div>
            <div class="sp-delay-stat-sep"></div>
            <div class="sp-delay-stat">
              <span class="sp-delay-stat-val">5+ yrs</span>
              <span class="sp-delay-stat-desc">Before hidden masonry defects surface and become costly to fix</span>
            </div>
            <div class="sp-delay-stat-sep"></div>
            <div class="sp-delay-stat">
              <span class="sp-delay-stat-val">1st visit</span>
              <span class="sp-delay-stat-desc">AMS passes every municipal inspection on the first visit</span>
            </div>
          </div>
          <a href="/contact#form" class="sp-delay-sidebar-cta">
            Get a free project estimate
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M2.5 7H11.5M8 3.5L11.5 7L8 10.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>

        <!-- RIGHT: consequence list -->
        <div class="sp-delay-list">

          <div class="sp-delay-rule"></div>

          <div class="sp-delay-item">
            <div class="sp-delay-item-head">
              <div class="sp-delay-icon-wrap">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#B85C38" stroke-width="1.8" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              </div>
              <h3 class="sp-delay-title">Wrong Mortar = Cracked Brick</h3>
            </div>
            <p class="sp-delay-text">Using mortar that's too hard for your brick is the single most common mistake in new construction masonry. It looks fine for a few years — then bricks start spalling from freeze-thaw stress.</p>
          </div>

          <div class="sp-delay-rule"></div>

          <div class="sp-delay-item">
            <div class="sp-delay-item-head">
              <div class="sp-delay-icon-wrap">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#B85C38" stroke-width="1.8" aria-hidden="true"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
              </div>
              <h3 class="sp-delay-title">Missing Flashing Causes Leaks</h3>
            </div>
            <p class="sp-delay-text">Flashing, weep holes, and drainage mats are code requirements for a reason. Skip them — or install them incorrectly — and water infiltrates your wall cavity, rotting framing from the inside out.</p>
          </div>

          <div class="sp-delay-rule"></div>

          <div class="sp-delay-item">
            <div class="sp-delay-item-head">
              <div class="sp-delay-icon-wrap">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#B85C38" stroke-width="1.8" aria-hidden="true"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
              </div>
              <h3 class="sp-delay-title">Failed Inspections Cost Money</h3>
            </div>
            <p class="sp-delay-text">Masonry work that doesn’t meet code gets flagged at inspection — delaying your close date, frustrating your builder, and costing you in carrying costs and rework. We pass every inspection on the first visit.</p>
            <div class="sp-delay-chart" aria-label="Cost escalation timeline">
              <div class="sp-delay-chart-row">
                <span class="sp-delay-chart-stage">Now</span>
                <div class="sp-delay-chart-bar-wrap"><div class="sp-delay-chart-bar" style="--w:20%"></div></div>
                <span class="sp-delay-chart-cost">$</span>
                <span class="sp-delay-chart-note">Planning</span>
              </div>
              <div class="sp-delay-chart-row">
                <span class="sp-delay-chart-stage">1–2 yrs</span>
                <div class="sp-delay-chart-bar-wrap"><div class="sp-delay-chart-bar" style="--w:42%"></div></div>
                <span class="sp-delay-chart-cost">$$</span>
                <span class="sp-delay-chart-note">Joint failure</span>
              </div>
              <div class="sp-delay-chart-row">
                <span class="sp-delay-chart-stage">3–4 yrs</span>
                <div class="sp-delay-chart-bar-wrap"><div class="sp-delay-chart-bar" style="--w:68%"></div></div>
                <span class="sp-delay-chart-cost">$$$</span>
                <span class="sp-delay-chart-note">Brick spalling</span>
              </div>
              <div class="sp-delay-chart-row">
                <span class="sp-delay-chart-stage">5+ yrs</span>
                <div class="sp-delay-chart-bar-wrap"><div class="sp-delay-chart-bar" style="--w:100%"></div></div>
                <span class="sp-delay-chart-cost">$$$$</span>
                <span class="sp-delay-chart-note">Structural</span>
              </div>
            </div>
          </div>

          <div class="sp-delay-rule"></div>

          <div class="sp-delay-item">
            <div class="sp-delay-item-head">
              <div class="sp-delay-icon-wrap">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#B85C38" stroke-width="1.8" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
              </div>
              <h3 class="sp-delay-title">Subs Who Miss Schedule</h3>
            </div>
            <p class="sp-delay-text">Masonry is on the critical path. A crew that doesn’t show when promised pushes framing, roofing, windows — everything. We commit to a schedule in writing and show up as agreed, every time.</p>
          </div>

          <div class="sp-delay-rule"></div>

        </div>
      </div>
    </div>
  </section>

  <!-- ─── PROCESS (ported sp-prc) ─── -->
  <section id="sp-prc-section" style="background:#ffffff; position:relative;">
    <div id="sp-prc-driver" style="position:relative; height:600vh;">
      <div id="sp-prc-sticky" style="position:sticky; top:0; height:100vh; display:flex; align-items:center; overflow:hidden;">
        <div class="sp-prc-grid">

          <!-- LEFT: heading + CTA -->
          <div id="sp-prc-left">
            <div style="display:flex; align-items:center; gap:8px; margin-bottom:20px;">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <rect x="1" y="1" width="5" height="5" rx="1" fill="#B85C38"/>
                <rect x="8" y="1" width="5" height="5" rx="1" fill="#B85C38" opacity="0.4"/>
                <rect x="1" y="8" width="5" height="5" rx="1" fill="#B85C38" opacity="0.4"/>
                <rect x="8" y="8" width="5" height="5" rx="1" fill="#B85C38"/>
              </svg>
              <span style="font-family:'Inter',sans-serif; font-size:11px; font-weight:700; letter-spacing:0.10em; color:#B85C38; text-transform:uppercase;">How We Work</span>
            </div>

            <h2 style="font-family:'Onest',sans-serif; font-size:clamp(36px,3.5vw,54px); font-weight:700; line-height:1.1; color:#16120F; letter-spacing:-0.02em; margin:0 0 20px;">How We Work With You</h2>

            <p style="font-family:'Inter',sans-serif; font-size:16px; line-height:1.65; color:#6A625A; margin:0 0 36px;">From your first call to the final walk-through — every step is documented, on schedule, and built to pass inspection. Here's exactly how an AMS project runs.</p>

            <div class="sp-prc-desktop-cta">
              <a href="/contact#form"
                style="display:inline-flex; align-items:center; gap:8px; background:#B85C38; color:#fff; font-family:'Inter',sans-serif; font-size:15px; font-weight:500; padding:14px 26px; border-radius:12px; text-decoration:none; transition:background 0.2s;"
                onmouseenter="this.style.background='#8A3A22'"
                onmouseleave="this.style.background='#B85C38'">
                Get a free estimate
                <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                  <path d="M3 8h10M9 4l4 4-4 4" stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
              <p style="font-family:'Inter',sans-serif; font-size:11px; font-weight:700; letter-spacing:0.08em; color:#B85C38; text-transform:uppercase; margin:28px 0 0;">5 steps · 24 hrs to first visit</p>
            </div>
          </div>

          <!-- RIGHT: steps -->
          <div id="sp-prc-right">

            <div class="sp-prc-item" style="padding:14px 0; border-top:1px solid #E4E2DE;">
              <div style="display:flex; gap:20px; align-items:flex-start;">
                <span class="sp-prc-num" style="font-family:'Onest',sans-serif; font-size:40px; font-weight:700; color:#B85C38; opacity:0.22; line-height:1; min-width:52px; padding-top:2px; transition:opacity 0.3s;">01</span>
                <div style="flex:1;">
                  <h3 style="font-family:'Onest',sans-serif; font-size:15px; font-weight:700; color:#16120F; margin:0 0 7px; letter-spacing:0.04em; text-transform:uppercase;">Free On-Site Estimate</h3>
                  <p style="font-family:'Inter',sans-serif; font-size:13px; line-height:1.65; color:#4A433B; margin:0 0 10px;">We come to you, assess the work in person, and hand you a written estimate with scope, materials, and timeline. No charge, no pressure to book.</p>
                  <div style="border-left:3px solid #B85C38; padding:8px 12px; background:rgba(184,92,56,0.05); border-radius:0 8px 8px 0;">
                    <p style="font-family:'Inter',sans-serif; font-size:12px; line-height:1.6; color:#4A433B; margin:0;"><strong style="color:#B85C38; font-weight:700;">Why it matters: </strong>A real number requires real eyes on the masonry. Phone quotes are guesses — our on-site estimate is the price you can actually plan around.</p>
                  </div>
                </div>
              </div>
            </div>

            <div class="sp-prc-item" style="padding:14px 0; border-top:1px solid #E4E2DE;">
              <div style="display:flex; gap:20px; align-items:flex-start;">
                <span class="sp-prc-num" style="font-family:'Onest',sans-serif; font-size:40px; font-weight:700; color:#B85C38; opacity:0.22; line-height:1; min-width:52px; padding-top:2px; transition:opacity 0.3s;">02</span>
                <div style="flex:1;">
                  <h3 style="font-family:'Onest',sans-serif; font-size:15px; font-weight:700; color:#16120F; margin:0 0 7px; letter-spacing:0.04em; text-transform:uppercase;">Material Matching &amp; Selection</h3>
                  <p style="font-family:'Inter',sans-serif; font-size:13px; line-height:1.65; color:#4A433B; margin:0 0 10px;">We match mortar composition, color, and joint profile to your existing masonry — or help you choose new brick, stone, or limestone that suits your home and Chicago's climate.</p>
                  <div style="border-left:3px solid #B85C38; padding:8px 12px; background:rgba(184,92,56,0.05); border-radius:0 8px 8px 0;">
                    <p style="font-family:'Inter',sans-serif; font-size:12px; line-height:1.6; color:#4A433B; margin:0;"><strong style="color:#B85C38; font-weight:700;">Why it matters: </strong>Mortar that's too hard cracks your brick within a few winters. Matching it correctly is the difference between a repair that lasts decades and one that fails in years.</p>
                  </div>
                </div>
              </div>
            </div>

            <div class="sp-prc-item" style="padding:14px 0; border-top:1px solid #E4E2DE;">
              <div style="display:flex; gap:20px; align-items:flex-start;">
                <span class="sp-prc-num" style="font-family:'Onest',sans-serif; font-size:40px; font-weight:700; color:#B85C38; opacity:0.22; line-height:1; min-width:52px; padding-top:2px; transition:opacity 0.3s;">03</span>
                <div style="flex:1;">
                  <h3 style="font-family:'Onest',sans-serif; font-size:15px; font-weight:700; color:#16120F; margin:0 0 7px; letter-spacing:0.04em; text-transform:uppercase;">Written Schedule &amp; Site Prep</h3>
                  <p style="font-family:'Inter',sans-serif; font-size:13px; line-height:1.65; color:#4A433B; margin:0 0 10px;">Before we start, you get a start date in writing. We protect your property, set up cleanly, and pull any permits the job requires.</p>
                  <div style="border-left:3px solid #B85C38; padding:8px 12px; background:rgba(184,92,56,0.05); border-radius:0 8px 8px 0;">
                    <p style="font-family:'Inter',sans-serif; font-size:12px; line-height:1.6; color:#4A433B; margin:0;"><strong style="color:#B85C38; font-weight:700;">Why it matters: </strong>A crew that won't commit to a date in writing is a crew that will leave you waiting. We show up when we say we will.</p>
                  </div>
                </div>
              </div>
            </div>

            <div class="sp-prc-item" style="padding:14px 0; border-top:1px solid #E4E2DE;">
              <div style="display:flex; gap:20px; align-items:flex-start;">
                <span class="sp-prc-num" style="font-family:'Onest',sans-serif; font-size:40px; font-weight:700; color:#B85C38; opacity:0.22; line-height:1; min-width:52px; padding-top:2px; transition:opacity 0.3s;">04</span>
                <div style="flex:1;">
                  <h3 style="font-family:'Onest',sans-serif; font-size:15px; font-weight:700; color:#16120F; margin:0 0 7px; letter-spacing:0.04em; text-transform:uppercase;">The Work — Done Right</h3>
                  <p style="font-family:'Inter',sans-serif; font-size:13px; line-height:1.65; color:#4A433B; margin:0 0 10px;">The same crew that estimated your job does the work — no subcontractors. Daily cleanup, daily progress, and we never cut corners to save time.</p>
                  <div style="border-left:3px solid #B85C38; padding:8px 12px; background:rgba(184,92,56,0.05); border-radius:0 8px 8px 0;">
                    <p style="font-family:'Inter',sans-serif; font-size:12px; line-height:1.6; color:#4A433B; margin:0;"><strong style="color:#B85C38; font-weight:700;">Why it matters: </strong>Most masonry failures trace back to rushed work and revolving crews. One accountable crew, doing it properly, is why our work passes inspection the first time.</p>
                  </div>
                </div>
              </div>
            </div>

            <div class="sp-prc-item" style="padding:14px 0; border-top:1px solid #E4E2DE; border-bottom:1px solid #E4E2DE;">
              <div style="display:flex; gap:20px; align-items:flex-start;">
                <span class="sp-prc-num" style="font-family:'Onest',sans-serif; font-size:40px; font-weight:700; color:#B85C38; opacity:0.22; line-height:1; min-width:52px; padding-top:2px; transition:opacity 0.3s;">05</span>
                <div style="flex:1;">
                  <h3 style="font-family:'Onest',sans-serif; font-size:15px; font-weight:700; color:#16120F; margin:0 0 7px; letter-spacing:0.04em; text-transform:uppercase;">Final Walk-Through</h3>
                  <p style="font-family:'Inter',sans-serif; font-size:13px; line-height:1.65; color:#4A433B; margin:0 0 10px;">We walk the finished work with you before any final payment. Every punch-list item is resolved before we close out.</p>
