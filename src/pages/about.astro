            );
          },
          onLeaveBack: function() {
            gsap.set(card, { opacity: 0, y: yFrom });
          }
        });
      });
    }
    window.removeEventListener('animations:ready', window.__spWhyAnimReady);
    window.__spWhyAnimReady = initWhyAnim;
    window.addEventListener('animations:ready', window.__spWhyAnimReady);
  })();
</script>

<!-- ─── PROJECTS POLAROID ANIMATION (ported verbatim) ─── -->
<script is:inline>
  (function() {
    function initProjAnim() {
      var gsap = window.__gsap;
      var ScrollTrigger = window.__ScrollTrigger;
      if (!gsap || !ScrollTrigger) return;

      var driver = document.getElementById('sp-proj-driver');
      var cards  = gsap.utils.toArray('.sp-proj-polaroid');
      var N      = cards.length;
      if (!driver || !N) return;

      var FAN_ROTATIONS = [-24, -12, 0, 12, 24];

      gsap.set(cards, {
        transformOrigin: '50% 100%',
        rotation: 0,
        scale: 1,
        zIndex: function(i) { return i + 1; }
      });

      var tl = gsap.timeline({ defaults: { ease: 'power2.out' } });
      cards.forEach(function(card, i) {
        tl.to(card, { rotation: FAN_ROTATIONS[i], duration: 1 }, 0);
      });

      ScrollTrigger.create({
        trigger: driver,
        start:   'top top',
        end:     'bottom bottom',
        scrub:   0.6,
        animation: tl
      });

      var SHADOW_DEFAULT = '0 8px 40px rgba(22,18,15,0.13), 0 2px 8px rgba(22,18,15,0.06)';
      var SHADOW_HOVER   = '0 20px 60px rgba(22,18,15,0.22), 0 6px 16px rgba(22,18,15,0.10)';
      var SHADOW_ACTIVE  = '0 28px 80px rgba(22,18,15,0.26), 0 8px 20px rgba(22,18,15,0.12)';

      var activeCard = null;

      cards.forEach(function(card, i) {
        var title = card.querySelector('.sp-proj-label');
        var img   = card.querySelector('.sp-proj-img');

        card.addEventListener('mouseenter', function() {
          if (card === activeCard) return;
          card.style.boxShadow = SHADOW_HOVER;
          card.style.zIndex    = String(N + 5);
          if (title) title.style.color   = '#B85C38';
          if (img)   img.style.transform = 'scale(1.06)';
          gsap.to(card, { y: -28, duration: 0.25, ease: 'power2.out', overwrite: 'auto' });
        });

        card.addEventListener('mouseleave', function() {
          if (card === activeCard) return;
          card.style.boxShadow = SHADOW_DEFAULT;
          card.style.zIndex    = String(i + 1);
          if (title) title.style.color   = '#16120F';
          if (img)   img.style.transform = 'scale(1)';
          gsap.to(card, { y: 0, duration: 0.3, ease: 'power2.out', overwrite: 'auto' });
        });

        card.addEventListener('click', function() {
          if (card === activeCard) {
            activeCard = null;
            card.style.boxShadow = SHADOW_DEFAULT;
            card.style.zIndex    = String(i + 1);
            gsap.to(card, { y: 0, duration: 0.3, ease: 'power2.out', overwrite: 'auto' });
            return;
          }
          if (activeCard) {
            var prevI = parseInt(activeCard.dataset.i || '0');
            activeCard.style.boxShadow = SHADOW_DEFAULT;
            activeCard.style.zIndex    = String(prevI + 1);
            gsap.to(activeCard, { y: 0, duration: 0.25, ease: 'power2.out', overwrite: 'auto' });
          }
          activeCard = card;
          card.style.zIndex    = String(N + 10);
          card.style.boxShadow = SHADOW_ACTIVE;
          gsap.to(card, { y: -48, duration: 0.35, ease: 'back.out(1.6)', overwrite: 'auto' });
        });
      });
    }

    window.removeEventListener('animations:ready', window.__spProjAnimReady);
    window.__spProjAnimReady = initProjAnim;
    window.addEventListener('animations:ready', window.__spProjAnimReady);
  })();
</script>

<!-- ─── REVIEWS ANIMATION (ported verbatim) ─── -->
<script is:inline>
  (function() {
    function initRevAnim() {
      var gsap = window.__gsap;
      var ScrollTrigger = window.__ScrollTrigger;
      if (!gsap || !ScrollTrigger) return;
      if (window.innerWidth <= 900) return;

      var driver     = document.getElementById('sp-rev-driver');
      var nbhdArea   = document.getElementById('sp-rev-nbhd-area');
      var tCards     = gsap.utils.toArray('.sp-rev-card');
      var nbhdCards  = gsap.utils.toArray('.sp-rev-nbhd-card');
      var N = tCards.length;

      if (!driver || !N) return;

      var ROTATIONS = [12, 20, 28, 34, 38];
      var SCALES    = [1, 0.97, 0.94, 0.91, 0.88];

      tCards.forEach(function(card, i) {
        gsap.set(card, {
          zIndex:          N - i,
          rotation:        ROTATIONS[i] || 0,
          scale:           SCALES[i]    || 0.85,
          transformOrigin: 'center center'
        });
      });

      gsap.set(nbhdArea,  { opacity: 0, y: 16 });
      gsap.set(nbhdCards, { opacity: 0, y: 16 });

      // Card deck scroll animation
      var tl = gsap.timeline();
      for (var i = 0; i < N - 1; i++) {
        var s = i / (N - 1);
        var e = (i + 1) / (N - 1);
        var d = e - s;
        tl.to(tCards[i], { yPercent: -110, opacity: 0, duration: d, ease: 'power2.in' }, s);
        for (var j = i + 1; j < N; j++) {
          var newPos = j - (i + 1);
          tl.to(tCards[j], {
            rotation: ROTATIONS[newPos] || 0,
            scale:    SCALES[newPos]    || 0.85,
            duration: d, ease: 'power2.out'
          }, s);
        }
      }

      ScrollTrigger.create({
        trigger:   driver,
        start:     'top top',
        end:       'bottom bottom',
        scrub:     1.2,
        animation: tl
      });

      // Neighbourhood cards reveal at 60% scroll
      ScrollTrigger.create({
        trigger: driver,
        start:   '60% bottom',
        end:     '80% bottom',
        scrub:   1,
        onEnter: function() {
          gsap.to(nbhdArea,  { opacity: 1, y: 0, duration: 0.6, ease: 'power2.out' });
          gsap.to(nbhdCards, { opacity: 1, y: 0, duration: 0.5, ease: 'power2.out', stagger: 0.12, delay: 0.15 });
        },
        onLeaveBack: function() {
          gsap.to(nbhdArea,  { opacity: 0, y: 16, duration: 0.35 });
          gsap.to(nbhdCards, { opacity: 0, y: 16, duration: 0.25 });
        }
      });
    }

    window.removeEventListener('animations:ready', window.__spRevAnimReady);
    window.__spRevAnimReady = initRevAnim;
    window.addEventListener('animations:ready', window.__spRevAnimReady);
  })();
</script>

<!-- ─── PROCESS SCROLL ANIMATION (ported verbatim) ─── -->
<script is:inline>
    (function() {
      function initProcessAnim() {
        var gsap = window.__gsap;
        var ScrollTrigger = window.__ScrollTrigger;
        if (!gsap || !ScrollTrigger) return;

        var driver   = document.getElementById('sp-prc-driver');
        var leftCol  = document.getElementById('sp-prc-left');
        var items    = Array.from(document.querySelectorAll('.sp-prc-item'));
        var nums     = Array.from(document.querySelectorAll('.sp-prc-num'));
        if (!driver || !leftCol || !items.length) return;

        var isMobile = window.innerWidth < 900;
        // Skip entrance fades on mobile — content always visible, no blank spaces
        if (isMobile) {
          items.forEach(function(item, i) {
            var stepTl = gsap.timeline({ defaults: { ease: 'none' } });
            var n = nums[i];
            stepTl
              .fromTo(n, { opacity: 0.22 }, { opacity: 1, duration: 0.5 }, 0)
              .fromTo(item, { backgroundColor: 'rgba(184,92,56,0)' }, { backgroundColor: 'rgba(184,92,56,0.06)', duration: 0.5 }, 0)
              .to(n, { opacity: 0.22, duration: 0.5 }, 0.5)
              .to(item, { backgroundColor: 'rgba(184,92,56,0)', duration: 0.5 }, 0.5);
            ScrollTrigger.create({ trigger: item, start: 'top 65%', end: 'bottom 35%', scrub: 0.4, animation: stepTl });
          });
          return;
        }

        // Desktop: left column entrance
        gsap.from(leftCol, {
          opacity: 0, x: -24,
          duration: 0.9, ease: 'power2.out',
          scrollTrigger: { trigger: driver, start: 'top 80%', once: true },
        });

        // Desktop: steps fade in
        gsap.from(items, {
          opacity: 0, y: 20, duration: 0.6, ease: 'power2.out', stagger: 0.08,
          scrollTrigger: { trigger: driver, start: 'top 70%', once: true },
        });

        // Desktop: scrub active-step highlight
        var tl  = gsap.timeline({ defaults: { ease: 'none' } });
        var seg = 1 / items.length;

        items.forEach(function(item, i) {
          var s  = i * seg;
          var fi = seg * 0.25;
          var fo = seg * 0.25;

          tl.fromTo(nums[i],  { opacity: 0.22 }, { opacity: 1,                           duration: fi }, s);
          tl.to(nums[i],                          { opacity: 0.22,                        duration: fo }, s + seg - fo);
          tl.fromTo(items[i], { backgroundColor: 'rgba(184,92,56,0)' },
                              { backgroundColor: 'rgba(184,92,56,0.06)', duration: fi }, s);
          tl.to(items[i],     { backgroundColor: 'rgba(184,92,56,0)',    duration: fo }, s + seg - fo);
        });

        ScrollTrigger.create({
          trigger: driver, start: 'top top', end: 'bottom bottom',
          scrub: 1.2, animation: tl,
        });
      }

      window.removeEventListener('animations:ready', window.__spPrcAnimReady);
      window.__spPrcAnimReady = initProcessAnim;
      window.addEventListener('animations:ready', window.__spPrcAnimReady);
    })();
</script>

<!-- ─── FAQ ACCORDION + TABS + SCROLL ANIM (ported verbatim) ─── -->
<script is:inline>
  (function () {

    function openItem(item) {
      var body  = item.querySelector('.sp-faqx-a');
      var inner = item.querySelector('.sp-faqx-a-inner');
      var btn   = item.querySelector('.sp-faqx-q');
      item.classList.add('open');
      btn.setAttribute('aria-expanded', 'true');
      body.setAttribute('aria-hidden', 'false');
      var gsap = window.__gsap;
      if (gsap) {
        gsap.killTweensOf(body);
        gsap.fromTo(body, { height: 0, overflow: 'hidden' }, {
          height: inner.scrollHeight, duration: 0.38, ease: 'power3.out',
          onComplete: function () { body.style.height = 'auto'; body.style.overflow = ''; }
        });
      } else { body.style.height = inner.scrollHeight + 'px'; }
    }

    function closeItem(item) {
      var body = item.querySelector('.sp-faqx-a');
      var btn  = item.querySelector('.sp-faqx-q');
      item.classList.remove('open');
      btn.setAttribute('aria-expanded', 'false');
      body.setAttribute('aria-hidden', 'true');
      var gsap = window.__gsap;
      if (gsap) {
        gsap.killTweensOf(body);
        gsap.to(body, { height: body.offsetHeight, duration: 0,
          onComplete: function () { gsap.to(body, { height: 0, duration: 0.28, ease: 'power3.in', overflow: 'hidden' }); }
        });
      } else { body.style.height = '0'; }
    }

    function initAccordion() {
      var items = document.querySelectorAll('.sp-faqx-item');
      items.forEach(function (item) {
        var btn = item.querySelector('.sp-faqx-q');
        if (!btn || btn.dataset.faqInit) return;
        btn.dataset.faqInit = '1';
        var body = item.querySelector('.sp-faqx-a');
        if (!item.classList.contains('open')) body.style.height = '0';
        btn.addEventListener('click', function () {
          var isOpen = item.classList.contains('open');
          var panel  = item.closest('.sp-faqx-panel');
          panel.querySelectorAll('.sp-faqx-item.open').forEach(function (o) {
            if (o !== item) closeItem(o);
          });
          if (isOpen) { closeItem(item); } else { openItem(item); }
        });
      });
    }

    function initTabs() {
      var tabs = document.querySelectorAll('.sp-faqx-tab');
      if (!tabs.length || tabs[0].dataset.tabInit) return;
      tabs[0].dataset.tabInit = '1';
      tabs.forEach(function (tab) {
        tab.addEventListener('click', function () {
          var cat = tab.dataset.cat;
          tabs.forEach(function (t) { t.classList.remove('active'); t.setAttribute('aria-selected', 'false'); });
          tab.classList.add('active'); tab.setAttribute('aria-selected', 'true');
          document.querySelectorAll('.sp-faqx-panel').forEach(function (p) { p.classList.remove('active'); });
          var activePanel = document.querySelector('.sp-faqx-panel[data-cat="' + cat + '"]');
          if (activePanel) {
            activePanel.classList.add('active');
            var gsap = window.__gsap;
            if (gsap) {
              gsap.fromTo(activePanel.querySelectorAll('.sp-faqx-item'),
                { opacity: 0, y: 12 },
                { opacity: 1, y: 0, duration: 0.4, ease: 'power2.out', stagger: 0.06 }
              );
            }
          }
        });
      });
    }

    function initScrollAnims() {
      var gsap = window.__gsap;
      var ST   = window.__ScrollTrigger;
      if (!gsap || !ST) return;
      if (window.innerWidth <= 900) return;
      var section = document.getElementById('faq-section');
      if (!section || section.dataset.faqAnimDone) return;
      section.dataset.faqAnimDone = '1';
      var defaults = { ease: 'power3.out', duration: 0.7 };
      gsap.from('#faq-header .sp-faqx-eyebrow', { ...defaults, y: 24, opacity: 0, scrollTrigger: { trigger: '#faq-header', start: 'top 82%', once: true } });
      gsap.from('#faq-header .sp-faqx-heading',  { ...defaults, y: 32, opacity: 0, delay: 0.1, scrollTrigger: { trigger: '#faq-header', start: 'top 82%', once: true } });
      gsap.from('#faq-header .sp-faqx-desc',     { ...defaults, y: 20, opacity: 0, delay: 0.2, scrollTrigger: { trigger: '#faq-header', start: 'top 82%', once: true } });
      gsap.from('#faq-nav .sp-faqx-tab', { x: -24, opacity: 0, duration: 0.5, ease: 'power2.out', stagger: 0.08, scrollTrigger: { trigger: '#faq-nav', start: 'top 85%', once: true } });
      var initItems = document.querySelectorAll('.sp-faqx-panel.active .sp-faqx-item');
      gsap.from(initItems, { y: 16, opacity: 0, duration: 0.45, ease: 'power2.out', stagger: 0.07, scrollTrigger: { trigger: '#faq-panels', start: 'top 85%', once: true } });
      gsap.from('#faq-footer', { y: 20, opacity: 0, duration: 0.6, ease: 'power2.out', scrollTrigger: { trigger: '#faq-footer', start: 'top 90%', once: true } });
    }

    function init() { initAccordion(); initTabs(); initScrollAnims(); }

    if (document.readyState === 'loading') { document.addEventListener('DOMContentLoaded', init); } else { init(); }
    if (window.__gsap && window.__ScrollTrigger) { initScrollAnims(); } else { window.addEventListener('animations:ready', initScrollAnims); }

  })();
</script>
