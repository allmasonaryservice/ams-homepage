<script is:inline>
  (function() {
    function initHeroAnim() {
      var gsap = window.__gsap;
      if (!gsap) return;
      var label  = document.getElementById('sa-label');
      var r1     = document.getElementById('sa-r1');
      var r2     = document.getElementById('sa-r2');
