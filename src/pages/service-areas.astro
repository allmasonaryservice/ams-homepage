<!-- ─── SERVICE AREA MAP ─── -->
<script is:inline>
(function () {
  var REGION_COLORS = {
    'North Shore':      '#B85C38',
    'Western Suburbs':  '#6E4C3B',
    'DuPage County':    '#9B7B6A',
    'City of Chicago':  '#16120F',
  };

  var CITIES = [
    { name: 'Winnetka',          lat: 42.1078, lng: -87.7359, region: 'North Shore',      slug: 'winnetka' },
    { name: 'Wilmette',          lat: 42.0720, lng: -87.7276, region: 'North Shore',      slug: 'wilmette' },
    { name: 'Kenilworth',        lat: 42.0867, lng: -87.7148, region: 'North Shore',      slug: 'kenilworth' },
    { name: 'Glencoe',           lat: 42.1353, lng: -87.7587, region: 'North Shore',      slug: 'glencoe' },
    { name: 'Evanston',          lat: 42.0450, lng: -87.6877, region: 'North Shore',      slug: 'evanston' },
    { name: 'Highland Park',     lat: 42.1817, lng: -87.8003, region: 'North Shore',      slug: 'highland-park' },
    { name: 'Northbrook',        lat: 42.1264, lng: -87.8264, region: 'North Shore',      slug: 'northbrook' },
    { name: 'Hinsdale',          lat: 41.8003, lng: -87.9298, region: 'Western Suburbs',  slug: 'hinsdale' },
    { name: 'Oak Brook',         lat: 41.8328, lng: -87.9482, region: 'Western Suburbs',  slug: 'oak-brook' },
    { name: 'Elmhurst',          lat: 41.8997, lng: -87.9403, region: 'Western Suburbs',  slug: 'elmhurst' },
    { name: 'Western Springs',   lat: 41.8136, lng: -87.9009, region: 'Western Suburbs',  slug: 'western-springs' },
    { name: 'La Grange',         lat: 41.8069, lng: -87.8698, region: 'Western Suburbs',  slug: 'la-grange' },
    { name: 'Burr Ridge',        lat: 41.7492, lng: -87.9187, region: 'Western Suburbs',  slug: 'burr-ridge' },
    { name: 'Naperville',        lat: 41.7508, lng: -88.1535, region: 'DuPage County',    slug: 'naperville' },
    { name: 'Downers Grove',     lat: 41.8081, lng: -88.0111, region: 'DuPage County',    slug: 'downers-grove' },
    { name: 'Clarendon Hills',   lat: 41.7975, lng: -87.9576, region: 'DuPage County',    slug: 'clarendon-hills' },
    { name: 'Willowbrook',       lat: 41.7653, lng: -87.9428, region: 'DuPage County',    slug: 'willowbrook' },
    { name: 'Wheaton',           lat: 41.8661, lng: -88.1070, region: 'DuPage County',    slug: 'wheaton' },
    { name: 'Chicago',           lat: 41.8781, lng: -87.6298, region: 'City of Chicago',  slug: 'chicago' },
  ];

  function initSapMap() {
    if (typeof L === 'undefined') return;
    var el = document.getElementById('sap-map');
    if (!el) return;
    if (el.dataset.sapInit) {
      el.dataset.sapInit = '';
      try { el._sapMap && el._sapMap.remove(); } catch (e) {}
    }
    el.dataset.sapInit = '1';

    var map = L.map(el, {
      center: [41.97, -87.87],
      zoom: 10,
      scrollWheelZoom: false,
      zoomControl: true,
    });
    el._sapMap = map;

    L.tileLayer(
      'https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png',
      { attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> &copy; <a href="https://carto.com/attributions">CARTO</a>', subdomains: 'abcd', maxZoom: 19 }
    ).addTo(map);

    CITIES.forEach(function (c) {
      var color = REGION_COLORS[c.region] || '#B85C38';
      var dotIcon = L.divIcon({
        className: '',
        html: '<div style="width:11px;height:11px;background:' + color + ';border:2.5px solid #ffffff;border-radius:50%;box-shadow:0 1px 6px rgba(0,0,0,0.35);"></div>',
        iconSize: [11, 11], iconAnchor: [5, 5], popupAnchor: [0, -10],
      });
      var m = L.marker([c.lat, c.lng], { icon: dotIcon, title: c.name + ' Service Area', alt: c.name })
        .bindPopup(
          '<div style="font-family:Inter,sans-serif;min-width:130px;">' +
          '<strong style="font-size:13px;color:#16120F;">' + c.name + ', IL</strong><br>' +
          '<span style="font-size:11px;color:' + color + ';font-weight:600;">' + c.region + '</span><br>' +
          '<a href="/locations/' + c.slug + '" style="font-size:11px;color:#B85C38;text-decoration:none;font-weight:600;">View page →</a>' +
          '</div>'
        )
        .addTo(map);
      if (m._icon) m._icon.setAttribute('aria-label', c.name + ' Service Area');
    });
  }

  function triggerInit() {
    if (window.requestIdleCallback) {
      requestIdleCallback(initSapMap);
    } else {
      setTimeout(initSapMap, 500);
    }
  }

  if (document.readyState === 'complete') {
    triggerInit();
  } else {
    window.addEventListener('load', triggerInit);
  }
  document.addEventListener('astro:page-load', triggerInit);
})();
</script>

