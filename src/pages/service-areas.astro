---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { projects as allProjects } from '../data/projects.js';
import { cities } from '../data/cities.js';

const siteUrl = 'https://allmasonryservices.com';
const svcProjects = allProjects.slice(0, 5);


const faqItems = [
  {
    q: 'What cities do you serve in Chicagoland?',
    a: 'We serve 19 cities across four regions — the North Shore, western suburbs, DuPage County, and the City of Chicago. See the full directory on this page. If your city isn\'t listed, call us — we occasionally take projects in adjacent areas.'
  },
  {
    q: 'Do you charge a travel or consultation fee?',
    a: 'No. Every on-site estimate is completely free — no travel fee, no consultation charge, no obligation. The written estimate we give you is the only price commitment, and it doesn\'t change.'
  },
  {
    q: 'How soon can you come out for an estimate?',
    a: 'Typically within 24–48 hours of your call or online request. For urgent situations — active water infiltration, structural concerns, or an imminent sale — we prioritize same-day or next-day visits when possible.'
  },
  {
    q: 'Do you serve all Chicago neighborhoods?',
    a: 'Yes. We work throughout Chicago — North Side, South Side, West Side, and the lakefront. Lincoln Park, Bucktown, Logan Square, Hyde Park, Pilsen, Bridgeport — we\'ve completed projects in every major Chicago community area.'
  },
  {
    q: 'Can you match original brick and mortar in older homes?',
    a: 'Yes — brick and mortar matching is one of our specialties. We sample your existing material, source the closest replacement, and calibrate mortar hardness to your brick age. This is especially critical for pre-1940 construction, where too-hard mortar causes permanent brick spalling.'
  },
  {
    q: 'Is AMS licensed in all of these areas?',
    a: 'Yes. Illinois masonry license #MA-104-018887 covers all Chicagoland municipalities. We carry $2.5M general liability and workers\' compensation on every crew member. Proof of insurance is provided before any work begins — on every job, no exceptions.'
  },
];
---

<Layout
  title="Service Areas — Masonry Contractor Across Chicagoland | All Masonry Services"
  description="All Masonry Services serves 19 cities across Chicagoland — North Shore, western suburbs, DuPage County, and Chicago. Brick, stone, chimney, tuckpointing. Free estimates. Call 773-656-2107."
>
  <script is:inline type="application/ld+json">{JSON.stringify({
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": "All Masonry Services",
    "url": siteUrl + "/service-areas",
    "telephone": "+1-773-656-2107",
    "areaServed": cities.map(c => ({ "@type": "City", "name": c.name + ", IL" })),
    "priceRange": "$$",
    "address": { "@type": "PostalAddress", "addressRegion": "IL", "addressCountry": "US", "addressLocality": "Chicago" }
  })}</script>

  <Navbar />

  <!-- ─── 1. HERO ─── -->
  <section class="sa-hero" id="sa-hero" aria-label="Service Areas hero">
    <div class="sa-hero-bg" aria-hidden="true"></div>
    <div class="sa-hero-overlay" aria-hidden="true"></div>

    <div class="sa-hero-content">
      <div class="sa-hero-label" id="sa-label">
        <span class="sa-label-line" aria-hidden="true"></span>
        Masonry Contractor · Chicago &amp; Chicagoland · Est. 2007
      </div>

      <h1 class="sa-h1">
        <div class="sa-h1-row"><span id="sa-r1">Masonry Across</span></div>
        <div class="sa-h1-row"><span id="sa-r2">Chicagoland</span></div>
      </h1>

      <p class="sa-sub" id="sa-sub">
        High-quality brick and stone construction across Chicagoland. From custom homes to commercial buildings, our in-house crew delivers premium masonry built to last.
      </p>

      <div class="sa-actions" id="sa-act">
        <a href="/contact#form" class="sa-btn sa-btn--primary">
          Get a Free Estimate
          <svg width="13" height="13" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <a href="tel:7736562107" class="sa-btn sa-btn--ghost">Call 773-656-2107</a>
      </div>

      <div class="sa-badges" id="sa-bdg">
        <div class="sa-badge"><strong>19</strong><span>Cities Served</span></div>
        <div class="sa-badge-sep" aria-hidden="true"></div>
        <div class="sa-badge"><strong>100+</strong><span>Projects Done</span></div>
        <div class="sa-badge-sep" aria-hidden="true"></div>
        <div class="sa-badge"><strong>4.8★</strong><span>92 Reviews</span></div>
      </div>
    </div>

    <div class="sa-scroll" id="sa-scroll">
      <div class="sa-scroll-mouse"><div class="sa-scroll-dot"></div></div>
      <span>Scroll</span>
    </div>
  </section>

  <!-- ─── 2. TRUST BAR ─── -->
  <section class="sp-trust">
    <div class="sp-trust-inner">
      <div class="sp-trust-item">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        Licensed &amp; Insured in Illinois
      </div>
      <div class="sp-trust-sep"></div>
      <div class="sp-trust-item">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        Free On-Site Estimates
      </div>
      <div class="sp-trust-sep"></div>
      <div class="sp-trust-item">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        Own Crew — No Subcontractors
      </div>
      <div class="sp-trust-sep"></div>
      <div class="sp-trust-item">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        19+ Years in Chicagoland
      </div>
    </div>
  </section>

  <!-- ─── 3. ZONE OVERVIEW ─── -->
  <section class="sa-zones">
    <div class="sa-zones-inner">

      <div class="sa-zones-header" data-reveal>
        <div class="sa-eyebrow">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <rect x="1" y="1" width="5" height="5" rx="1" fill="#B85C38"/>
            <rect x="8" y="1" width="5" height="5" rx="1" fill="#B85C38" opacity="0.4"/>
            <rect x="1" y="8" width="5" height="5" rx="1" fill="#B85C38" opacity="0.4"/>
            <rect x="8" y="8" width="5" height="5" rx="1" fill="#B85C38"/>
          </svg>
          <span>19 Cities · 4 Regions</span>
        </div>
        <h2 class="sa-zones-h2">Serving Chicagoland<br><em>From the North Shore to DuPage</em></h2>
        <p class="sa-zones-sub">Family-owned since 2007 — we've built a reputation across every corner of Chicagoland. Find your area below.</p>
      </div>

      <!-- MAP full-width -->
      <div class="sap-map-wrap" data-reveal style="--rd:80ms">
        <div id="sap-map" role="img" aria-label="Map showing All Masonry Services coverage across Chicagoland"></div>
      </div>

      <!-- REGION PILL GRID -->
      <div class="sap-regions" data-reveal style="--rd:140ms">

        <div class="sap-region-col">
          <div class="sap-region-head" style="--rc:#B85C38">
            <span class="sap-region-dot"></span>
            North Shore
            <span class="sap-region-count">7</span>
          </div>
          {cities.filter(c => c.region === 'North Shore').map(c => (
            <a href={`/locations/${c.slug}`} class="sap-city-pill">{c.name}</a>
          ))}
        </div>

        <div class="sap-region-col">
          <div class="sap-region-head" style="--rc:#B85C38">
            <span class="sap-region-dot"></span>
            Western Suburbs
            <span class="sap-region-count">6</span>
          </div>
          {cities.filter(c => c.region === 'Western Suburbs').map(c => (
            <a href={`/locations/${c.slug}`} class="sap-city-pill">{c.name}</a>
          ))}
        </div>

        <div class="sap-region-col">
          <div class="sap-region-head" style="--rc:#B85C38">
            <span class="sap-region-dot"></span>
            DuPage County
            <span class="sap-region-count">5</span>
          </div>
          {cities.filter(c => c.region === 'DuPage County').map(c => (
            <a href={`/locations/${c.slug}`} class="sap-city-pill">{c.name}</a>
          ))}
        </div>

        <div class="sap-region-col">
          <div class="sap-region-head" style="--rc:#B85C38">
            <span class="sap-region-dot"></span>
            City of Chicago
            <span class="sap-region-count">1</span>
          </div>
          {cities.filter(c => c.region === 'City of Chicago').map(c => (
            <a href={`/locations/${c.slug}`} class="sap-city-pill">{c.name}</a>
          ))}
          <a href="/contact#form" class="sap-area-cta">Not in the list? Ask us →</a>
        </div>

      </div>

    </div>
  </section>

  <!-- Leaflet CSS (Async) -->
  <link rel="preload" as="style" href="https://cdn.jsdelivr.net/npm/leaflet@1.9.4/dist/leaflet.css" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/leaflet@1.9.4/dist/leaflet.css" media="print" onload="this.media='all'" />
  <noscript><link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/leaflet@1.9.4/dist/leaflet.css" /></noscript>

  <!-- ─── 4. CITY DIRECTORY ─── -->
  <section class="sa-dir" id="sa-dir">
    <div class="sa-dir-inner">

      <div class="sa-dir-header" data-reveal>
        <div class="sa-eyebrow">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <rect x="1" y="1" width="5" height="5" rx="1" fill="#B85C38"/>
            <rect x="8" y="1" width="5" height="5" rx="1" fill="#B85C38" opacity="0.4"/>
            <rect x="1" y="8" width="5" height="5" rx="1" fill="#B85C38" opacity="0.4"/>
            <rect x="8" y="8" width="5" height="5" rx="1" fill="#B85C38"/>
          </svg>
          <span>Where We Work</span>
        </div>
        <h2 class="sa-dir-h2">All 19 Service Areas<br><em>Across Chicagoland</em></h2>
      </div>

      <!-- Filter tabs -->
      <div class="sa-dir-tabs" id="sa-dir-tabs">
        <button class="sa-dir-tab active" data-filter="All" onclick="setFilter('All')">All Cities</button>
        <button class="sa-dir-tab" data-filter="North Shore" onclick="setFilter('North Shore')">North Shore</button>
        <button class="sa-dir-tab" data-filter="Western Suburbs" onclick="setFilter('Western Suburbs')">Western Suburbs</button>
        <button class="sa-dir-tab" data-filter="DuPage County" onclick="setFilter('DuPage County')">DuPage County</button>
        <button class="sa-dir-tab" data-filter="City of Chicago" onclick="setFilter('City of Chicago')">Chicago</button>
      </div>

      <!-- City cards grid -->
      <div class="sa-dir-grid" id="sa-dir-grid">
        {cities.map(city => (
          <a
            href={`/locations/${city.slug}`}
            class="sa-city-card"
            data-region={city.region}
          >
            <div class="sa-city-card-top">
              <span class="sa-city-region">{city.region}</span>
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <path d="M2.5 7H11.5M8 3.5L11.5 7L8 10.5" stroke="#B85C38" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <h3 class="sa-city-name">{city.name}</h3>
            <span class="sa-city-county">{city.county}</span>
            <div class="sa-city-bottom">
              <span class="sa-city-cta">View Page</span>
            </div>
          </a>
        ))}
      </div>

      <p class="sa-dir-note" data-reveal>Don't see your city?
        <a href="/contact#form">Call us at 773-656-2107</a> — we serve adjacent areas and take select projects outside our listed zones.
      </p>

    </div>
  </section>

  <!-- ─── 5. OUR MASONRY SERVICES ─── -->
  <section class="absvc">
    <div class="absvc-inner">
      <div class="absvc-eyebrow" data-reveal>
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <rect x="1" y="1" width="5" height="5" rx="1" fill="#B85C38"/>
          <rect x="8" y="1" width="5" height="5" rx="1" fill="#B85C38" opacity="0.4"/>
          <rect x="1" y="8" width="5" height="5" rx="1" fill="#B85C38" opacity="0.4"/>
          <rect x="8" y="8" width="5" height="5" rx="1" fill="#B85C38"/>
        </svg>
        <span>Our Masonry Services</span>
      </div>
      <h2 class="absvc-h2" data-reveal style="--rd:60ms">All 11 Services <em>— One Trusted Crew</em></h2>
      <p class="absvc-sub" data-reveal style="--rd:120ms">From large-scale commercial brickwork to custom residential stone facades. Every project is handled by our skilled in-house crew, ensuring top-tier craftsmanship and lasting quality.</p>

      <div class="absvc-grid" data-reveal style="--rd:180ms">
        <a href="/services/tuckpointing-repointing" class="absvc-cell">
          <span class="absvc-cell-num" aria-hidden="true">01</span>
          <span class="absvc-cell-name">Tuckpointing &amp; Repointing</span>
          <span class="absvc-cell-arrow" aria-hidden="true"><svg width="15" height="15" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
        </a>
        <a href="/services/brick-installation" class="absvc-cell">
          <span class="absvc-cell-num" aria-hidden="true">02</span>
          <span class="absvc-cell-name">Brick Installation</span>
          <span class="absvc-cell-arrow" aria-hidden="true"><svg width="15" height="15" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
        </a>
        <a href="/services/damaged-brick-replacement" class="absvc-cell">
          <span class="absvc-cell-num" aria-hidden="true">03</span>
          <span class="absvc-cell-name">Damaged Brick Replacement</span>
          <span class="absvc-cell-arrow" aria-hidden="true"><svg width="15" height="15" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
        </a>
        <a href="/services/chimney-repair-rebuilding" class="absvc-cell">
          <span class="absvc-cell-num" aria-hidden="true">04</span>
          <span class="absvc-cell-name">Chimney Repair &amp; Rebuilding</span>
          <span class="absvc-cell-arrow" aria-hidden="true"><svg width="15" height="15" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
        </a>
        <a href="/services/chimney-fireplace" class="absvc-cell">
          <span class="absvc-cell-num" aria-hidden="true">05</span>
          <span class="absvc-cell-name">Chimney &amp; Fireplace Masonry</span>
          <span class="absvc-cell-arrow" aria-hidden="true"><svg width="15" height="15" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
        </a>
        <a href="/services/natural-stone-limestone" class="absvc-cell">
          <span class="absvc-cell-num" aria-hidden="true">06</span>
          <span class="absvc-cell-name">Natural Stone &amp; Limestone</span>
          <span class="absvc-cell-arrow" aria-hidden="true"><svg width="15" height="15" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
        </a>
        <a href="/services/brick-stone-veneers" class="absvc-cell">
          <span class="absvc-cell-num" aria-hidden="true">07</span>
          <span class="absvc-cell-name">Brick &amp; Stone Veneers</span>
          <span class="absvc-cell-arrow" aria-hidden="true"><svg width="15" height="15" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
        </a>
        <a href="/services/cmu-block-installation" class="absvc-cell">
          <span class="absvc-cell-num" aria-hidden="true">08</span>
          <span class="absvc-cell-name">CMU Block Installation</span>
          <span class="absvc-cell-arrow" aria-hidden="true"><svg width="15" height="15" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
        </a>
        <a href="/services/commercial-brick-stone" class="absvc-cell">
          <span class="absvc-cell-num" aria-hidden="true">09</span>
          <span class="absvc-cell-name">Commercial Brick &amp; Stone</span>
          <span class="absvc-cell-arrow" aria-hidden="true"><svg width="15" height="15" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
        </a>
        <a href="/services/commercial-masonry-veneers" class="absvc-cell">
          <span class="absvc-cell-num" aria-hidden="true">10</span>
          <span class="absvc-cell-name">Commercial Masonry Veneers</span>
          <span class="absvc-cell-arrow" aria-hidden="true"><svg width="15" height="15" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
        </a>
        <a href="/services/custom-home-masonry" class="absvc-cell">
          <span class="absvc-cell-num" aria-hidden="true">11</span>
          <span class="absvc-cell-name">Custom Home Masonry</span>
          <span class="absvc-cell-arrow" aria-hidden="true"><svg width="15" height="15" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
        </a>
        <div class="absvc-cell absvc-cell--empty" aria-hidden="true"></div>
      </div>

      <div class="absvc-foot" data-reveal>
        <a href="/contact#form" class="absvc-foot-cta">Get a free estimate</a>
      </div>
    </div>
  </section>

  <!-- ─── 6. PROCESS ─── -->
  <section id="sp-prc-section" style="background:#ffffff; position:relative;">
    <div id="sp-prc-driver" style="position:relative; height:600vh;">
      <div id="sp-prc-sticky" style="position:sticky; top:0; height:100vh; display:flex; align-items:center; overflow:hidden;">
        <div class="sp-prc-grid">

          <!-- LEFT: heading + CTA -->
          <div id="sp-prc-left">
            <div style="display:flex; align-items:center; gap:8px; margin-bottom:20px;">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <rect x="1" y="1" width="5" height="5" rx="1" fill="#B85C38"/>
                <rect x="8" y="1" width="5" height="5" rx="1" fill="#B85C38" opacity="0.4"/>
                <rect x="1" y="8" width="5" height="5" rx="1" fill="#B85C38" opacity="0.4"/>
                <rect x="8" y="8" width="5" height="5" rx="1" fill="#B85C38"/>
              </svg>
              <span style="font-family:'Inter',sans-serif; font-size:11px; font-weight:700; letter-spacing:0.10em; color:#B85C38; text-transform:uppercase;">How We Work</span>
            </div>

            <h2 style="font-family:'Onest',sans-serif; font-size:clamp(36px,3.5vw,54px); font-weight:700; line-height:1.1; color:#16120F; letter-spacing:-0.02em; margin:0 0 20px;">How We Serve<br>Your Neighborhood</h2>

            <p style="font-family:'Inter',sans-serif; font-size:16px; line-height:1.65; color:#6A625A; margin:0 0 36px;">From your first call to final walk-through — every step is transparent, on schedule, and built to last through Chicago winters.</p>

            <div class="sp-prc-desktop-cta">
              <a href="/contact#form"
                style="display:inline-flex; align-items:center; gap:8px; background:#B85C38; color:#fff; font-family:'Inter',sans-serif; font-size:15px; font-weight:500; padding:14px 26px; border-radius:12px; text-decoration:none; transition:background 0.2s;"
                onmouseenter="this.style.background='#8A3A22'"
                onmouseleave="this.style.background='#B85C38'">
                Get a free estimate
                <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                  <path d="M3 8h10M9 4l4 4-4 4" stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
              <p style="font-family:'Inter',sans-serif; font-size:11px; font-weight:700; letter-spacing:0.08em; color:#B85C38; text-transform:uppercase; margin:28px 0 0;">5 steps · 24 hrs to first visit</p>
            </div>
          </div>

          <!-- RIGHT: steps -->
          <div id="sp-prc-right">

            <div class="sp-prc-item" style="padding:14px 0; border-top:1px solid #E4E2DE;">
              <div style="display:flex; gap:20px; align-items:flex-start;">
                <span class="sp-prc-num" style="font-family:'Onest',sans-serif; font-size:40px; font-weight:700; color:#B85C38; opacity:0.22; line-height:1; min-width:52px; padding-top:2px; transition:opacity 0.3s;">01</span>
                <div style="flex:1;">
                  <h3 style="font-family:'Onest',sans-serif; font-size:15px; font-weight:700; color:#16120F; margin:0 0 7px; letter-spacing:0.04em; text-transform:uppercase;">Call or Request Online</h3>
                  <p style="font-family:'Inter',sans-serif; font-size:13px; line-height:1.65; color:#4A433B; margin:0 0 10px;">Reach us by phone (773-656-2107) or our contact form. We'll schedule your free on-site estimate within 24–48 hours — same day or next day for urgent issues.</p>
                  <div style="border-left:3px solid #B85C38; padding:8px 12px; background:rgba(184,92,56,0.05); border-radius:0 8px 8px 0;">
                    <p style="font-family:'Inter',sans-serif; font-size:12px; line-height:1.6; color:#4A433B; margin:0;"><strong style="color:#B85C38; font-weight:700;">Why it matters: </strong>Every week of delayed tuckpointing accelerates mortar erosion. Getting the estimate done fast — for free — costs you nothing and saves you more every season you wait.</p>
                  </div>
                </div>
              </div>
