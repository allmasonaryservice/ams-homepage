}
.faqp-eyebrow {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 14px;
  font-family: 'Inter', sans-serif;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.4);
  margin-bottom: 28px;
  opacity: 0;
  transform: translateY(12px);
}
.faqp-ey-line {
  width: 36px;
  height: 1px;
  background: rgba(184,92,56,0.55);
  display: block;
}
.faqp-h1 {
  font-family: 'Onest', sans-serif;
  font-size: clamp(44px, 6vw, 76px);
  font-weight: 800;
  color: #FFFFFF;
  line-height: 1.05;
  letter-spacing: -0.03em;
  margin-bottom: 22px;
  opacity: 0;
  transform: translateY(18px);
}
.faqp-h1-accent {
  color: #B85C38;
}
.faqp-hero-sub {
  font-family: 'Inter', sans-serif;
  font-size: 17px;
  line-height: 1.6;
  color: rgba(255,255,255,0.5);
  max-width: 520px;
  margin: 0 auto 40px;
  opacity: 0;
  transform: translateY(12px);
}
.faqp-search-wrap {
  position: relative;
  max-width: 520px;
  margin: 0 auto;
