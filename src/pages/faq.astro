  flex-wrap: wrap;
}
.faqp-cta-btn-primary {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: #B85C38;
  color: #FFFFFF;
  font-family: 'Inter', sans-serif;
  font-size: 14px;
  font-weight: 700;
  letter-spacing: 0.01em;
  padding: 14px 28px;
  border-radius: 50px;
  text-decoration: none;
  transition: background 0.2s, transform 0.15s;
}
.faqp-cta-btn-primary:hover { background: #A04E2E; transform: translateY(-1px); }
.faqp-cta-btn-ghost {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: rgba(255,255,255,0.07);
  color: rgba(255,255,255,0.8);
  font-family: 'Inter', sans-serif;
  font-size: 14px;
  font-weight: 600;
  padding: 14px 28px;
  border-radius: 50px;
  border: 1px solid rgba(255,255,255,0.14);
  text-decoration: none;
  transition: background 0.2s, color 0.2s;
}
.faqp-cta-btn-ghost:hover { background: rgba(255,255,255,0.11); color: #FFFFFF; }

/* ── Mobile tabs (replaces sidebar at ≤900px) ── */
@media (max-width: 900px) {
  .faqp-hero { padding: 96px 0 72px; }
  .faqp-hero-inner { padding: 0 24px; }
  .faqp-body { padding-bottom: 40px; }
  .faqp-main {
    grid-template-columns: 1fr;
    padding: 0;
  }
  .faqp-sidebar {
    position: static;
    height: auto;
    overflow-x: auto;
    overflow-y: hidden;
    flex-direction: row;
    padding: 16px 20px;
    gap: 8px;
    border-right: none;
    border-bottom: 1px solid rgba(22,18,15,0.08);
    scrollbar-width: none;
    background: #FFFFFF;
  }
  .faqp-cat {
    white-space: nowrap;
    padding: 8px 14px;
    border-radius: 50px;
    border: 1px solid rgba(22,18,15,0.10);
    font-size: 13px;
    flex-shrink: 0;
  }
  .faqp-cat.active {
    background: #16120F;
    color: #FFFFFF;
    border-color: #16120F;
  }
  .faqp-cat-dot { display: none; }
  .faqp-panels { padding: 32px 20px; }
  .faqp-panel-title { font-size: 22px; }
  .faqp-loc-inner { padding: 0 20px; }
  .faqp-city-grid { grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); }
  .faqp-loc-panel { padding: 24px 20px; }
  .faqp-sr-inner { padding: 40px 20px; }
}

@media (max-width: 640px) {
  .faqp-hero { padding: 80px 0 60px; }
  .faqp-search { font-size: 14px; padding: 14px 40px 14px 44px; }
  .faqp-cta { padding: 72px 24px; }
  .faqp-loc { padding: 72px 0; }
  .faqp-city-grid { grid-template-columns: repeat(2, 1fr); }
}
</style>

<script is:inline>
(function () {
  /* ── Hero entrance animation ── */
  function animateHero() {
    var els = [
      document.getElementById('faqp-eyebrow'),
      document.getElementById('faqp-h1'),
      document.getElementById('faqp-sub'),
      document.getElementById('faqp-search-wrap'),
    ];
    els.forEach(function (el, i) {
      if (!el) return;
      el.style.transition = 'opacity 0.55s ease ' + (i * 0.10) + 's, transform 0.55s ease ' + (i * 0.10) + 's';
      el.style.opacity = '1';
      el.style.transform = 'translateY(0)';
    });
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', function () { setTimeout(animateHero, 80); });
  } else {
    setTimeout(animateHero, 80);
  }

  /* ── Category tab switching ── */
  var cats = document.querySelectorAll('.faqp-cat');
  var panels = document.querySelectorAll('.faqp-panel');

  cats.forEach(function (btn) {
    btn.addEventListener('click', function () {
      var target = btn.dataset.cat;
      cats.forEach(function (b) {
        b.classList.toggle('active', b.dataset.cat === target);
        b.setAttribute('aria-selected', b.dataset.cat === target ? 'true' : 'false');
      });
      panels.forEach(function (p) {
        p.classList.toggle('active', p.dataset.cat === target);
      });
      // On mobile, scroll sidebar to keep active tab in view
      if (window.innerWidth <= 900) {
        btn.scrollIntoView({ inline: 'center', behavior: 'smooth', block: 'nearest' });
      }
    });
  });

  /* ── Accordion ── */
  function bindAccordion(container) {
    var items = container.querySelectorAll('.faqp-item');
    items.forEach(function (item) {
      var btn = item.querySelector('.faqp-q');
      if (!btn) return;
      btn.addEventListener('click', function () {
        var isOpen = item.classList.contains('open');
        // Close all sibling items
        items.forEach(function (i) {
          i.classList.remove('open');
          var q = i.querySelector('.faqp-q');
          if (q) q.setAttribute('aria-expanded', 'false');
          var a = i.querySelector('.faqp-a');
          if (a) a.setAttribute('aria-hidden', 'true');
        });
        // Open clicked unless it was already open
        if (!isOpen) {
          item.classList.add('open');
          btn.setAttribute('aria-expanded', 'true');
          var ans = item.querySelector('.faqp-a');
          if (ans) ans.setAttribute('aria-hidden', 'false');
        }
      });
    });
  }

  // Main accordion
  document.querySelectorAll('.faqp-panel').forEach(function (panel) {
    bindAccordion(panel);
  });

  /* ── Location panels ── */
  var cityBtns = document.querySelectorAll('.faqp-city-btn');
  var locPanels = document.querySelectorAll('.faqp-loc-panel');

  cityBtns.forEach(function (btn) {
    btn.addEventListener('click', function () {
      var city = btn.dataset.city;
      var panel = document.getElementById('faqp-loc-' + city);
      if (!panel) return;

      var isOpen = !panel.hidden;
      if (isOpen) {
        // Close this panel
        panel.hidden = true;
        btn.classList.remove('active');
        btn.setAttribute('aria-expanded', 'false');
      } else {
        // Close all other panels
        locPanels.forEach(function (p) { p.hidden = true; });
        cityBtns.forEach(function (b) {
          b.classList.remove('active');
          b.setAttribute('aria-expanded', 'false');
        });
        // Open this panel
        panel.hidden = false;
        btn.classList.add('active');
        btn.setAttribute('aria-expanded', 'true');
        // Bind accordion inside
        bindAccordion(panel);
        // Smooth scroll to panel
        setTimeout(function () {
          panel.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        }, 50);
      }
    });
  });

  // Location close buttons
  document.querySelectorAll('.faqp-loc-close').forEach(function (closeBtn) {
    closeBtn.addEventListener('click', function () {
      var city = closeBtn.dataset.city;
      var panel = document.getElementById('faqp-loc-' + city);
      if (panel) panel.hidden = true;
      var cityBtn = document.querySelector('.faqp-city-btn[data-city="' + city + '"]');
      if (cityBtn) {
        cityBtn.classList.remove('active');
        cityBtn.setAttribute('aria-expanded', 'false');
      }
    });
  });

  /* ── Search ── */
  var searchInput = document.getElementById('faqp-search');
  var searchClear = document.getElementById('faqp-search-clear');
  var searchResults = document.getElementById('faqp-search-results');
  var srInner = document.getElementById('faqp-sr-inner');
  var faqMain = document.getElementById('faqp-main');

  // Build flat index from all FAQ items
  var allItems = [];
  document.querySelectorAll('.faqp-panel .faqp-item').forEach(function (item) {
    var qEl = item.querySelector('.faqp-q-text');
    var aEl = item.querySelector('.faqp-a-inner');
    var cat = item.dataset.cat;
    if (qEl && aEl) {
      allItems.push({ q: qEl.textContent.trim(), a: aEl.textContent.trim(), cat: cat, el: item });
    }
  });

  function getCatLabel(catId) {
    var btn = document.querySelector('.faqp-cat[data-cat="' + catId + '"]');
    return btn ? btn.textContent.replace(/\d+$/, '').trim() : catId;
  }

  function doSearch(query) {
    var q = query.trim().toLowerCase();
    if (!q) {
      searchResults.hidden = true;
      faqMain.style.display = '';
      searchClear.hidden = true;
      return;
    }
    searchClear.hidden = false;
    faqMain.style.display = 'none';
    searchResults.hidden = false;

    var matches = allItems.filter(function (item) {
      return item.q.toLowerCase().includes(q) || item.a.toLowerCase().includes(q);
    });

    if (!matches.length) {
      srInner.innerHTML = '<p class="faqp-sr-empty">No questions found for "<strong>' + escHtml(query) + '</strong>". Try different keywords.</p>';
      return;
    }

    // Group by category
    var grouped = {};
    matches.forEach(function (m) {
      if (!grouped[m.cat]) grouped[m.cat] = [];
      grouped[m.cat].push(m);
    });

    var html = '<p class="faqp-sr-heading">' + matches.length + ' result' + (matches.length !== 1 ? 's' : '') + ' for "' + escHtml(query) + '"</p>';
    Object.keys(grouped).forEach(function (cat) {
      html += '<p class="faqp-sr-cat">' + escHtml(getCatLabel(cat)) + '</p>';
      grouped[cat].forEach(function (m) {
        html += '<div class="faqp-item" style="border-bottom:1px solid rgba(22,18,15,0.07);">' +
          '<button class="faqp-q" aria-expanded="false">' +
          '<span class="faqp-q-text">' + highlight(escHtml(m.q), q) + '</span>' +
          '<span class="faqp-q-icon" aria-hidden="true"><svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path class="faqp-plus-h" d="M4 10h12" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/><path class="faqp-plus-v" d="M10 4v12" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg></span>' +
          '</button>' +
          '<div class="faqp-a" aria-hidden="true"><div class="faqp-a-inner">' + highlight(escHtml(m.a), q) + '</div></div>' +
          '</div>';
      });
    });

    srInner.innerHTML = html;
    bindAccordion(srInner);
  }

  function escHtml(str) {
    return str.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  function highlight(text, query) {
    var re = new RegExp('(' + query.replace(/[.*+?^${}()|[\]\\]/g,'\\$&') + ')', 'gi');
    return text.replace(re, '<mark style="background:rgba(184,92,56,0.2);color:#16120F;border-radius:3px;padding:0 2px;">$1</mark>');
  }

  if (searchInput) {
    searchInput.addEventListener('input', function () { doSearch(this.value); });
  }
  if (searchClear) {
    searchClear.addEventListener('click', function () {
      searchInput.value = '';
      doSearch('');
      searchInput.focus();
    });
  }

  /* ── Scroll reveal for location cards ── */
  if ('IntersectionObserver' in window) {
    var locHead = document.querySelector('.faqp-loc-head');
    var cityBtnsList = document.querySelectorAll('.faqp-city-btn');

    if (locHead) {
      locHead.style.opacity = '0';
      locHead.style.transform = 'translateY(20px)';
      locHead.style.transition = 'opacity 0.5s ease, transform 0.5s ease';
    }
    cityBtnsList.forEach(function (btn, i) {
      btn.style.opacity = '0';
      btn.style.transform = 'translateY(12px)';
      btn.style.transition = 'opacity 0.4s ease ' + (i * 0.03) + 's, transform 0.4s ease ' + (i * 0.03) + 's, background 0.18s, border-color 0.18s, color 0.18s';
    });

    var revealObs = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (!entry.isIntersecting) return;
        entry.target.style.opacity = '1';
        entry.target.style.transform = 'translateY(0)';
        revealObs.unobserve(entry.target);
      });
    }, { threshold: 0.15 });

    if (locHead) revealObs.observe(locHead);
    cityBtnsList.forEach(function (btn) { revealObs.observe(btn); });
  }
})();
</script>
