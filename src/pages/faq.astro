<Layout
  title="Masonry FAQ — All Your Questions Answered | All Masonry Services"
  description="Every question about brick repair, tuckpointing, chimney work, stone masonry, and more — answered by All Masonry Services, Chicago's trusted masonry contractor since 2007."
>
  <Navbar />

  <!-- ── Hero ── -->
  <section class="faqp-hero" aria-label="FAQ hero">
    <div class="faqp-hero-inner">
      <div class="faqp-eyebrow" id="faqp-eyebrow">
        <span class="faqp-ey-line" aria-hidden="true"></span>
        Frequently Asked Questions
      </div>
      <h1 class="faqp-h1" id="faqp-h1">
        All Your Masonry<br>
        Questions, <span class="faqp-h1-accent">Answered.</span>
      </h1>
      <p class="faqp-hero-sub" id="faqp-sub">
        20 categories. 60+ questions. Everything homeowners ask before calling a masonry contractor.
      </p>
      <div class="faqp-search-wrap" id="faqp-search-wrap">
        <svg class="faqp-search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
        </svg>
        <input
          class="faqp-search"
          id="faqp-search"
          type="search"
          placeholder="Search questions…"
          autocomplete="off"
          aria-label="Search FAQ"
        />
        <button class="faqp-search-clear" id="faqp-search-clear" aria-label="Clear search" hidden>
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M2 2l10 10M12 2L2 12"/>
          </svg>
        </button>
      </div>
    </div>
  </section>

  <!-- ── FAQ Body ── -->
  <section class="faqp-body" id="faqp-body">

    <!-- Search results overlay -->
    <div class="faqp-search-results" id="faqp-search-results" aria-live="polite" hidden>
      <div class="faqp-sr-inner" id="faqp-sr-inner"></div>
    </div>

    <!-- Main FAQ: sidebar + panel -->
    <div class="faqp-main" id="faqp-main">

      <!-- Left: category nav -->
      <nav class="faqp-sidebar" id="faqp-sidebar" aria-label="FAQ categories" role="tablist">
        {categories.map((cat, i) => (
          <button
            class={`faqp-cat${i === 0 ? ' active' : ''}`}
            data-cat={cat.id}
            role="tab"
            aria-selected={i === 0 ? 'true' : 'false'}
          >
            <span class="faqp-cat-dot" aria-hidden="true"></span>
            {cat.label}
            <span class="faqp-cat-count">{cat.faqs.length}</span>
          </button>
        ))}
      </nav>

      <!-- Right: accordion panels -->
      <div class="faqp-panels" id="faqp-panels">
        {categories.map((cat, ci) => (
          <div
            class={`faqp-panel${ci === 0 ? ' active' : ''}`}
            data-cat={cat.id}
            role="tabpanel"
          >
            <div class="faqp-panel-head">
              <h2 class="faqp-panel-title">{cat.label}</h2>
              <span class="faqp-panel-count">{cat.faqs.length} questions</span>
            </div>
            {cat.faqs.map((faq, fi) => (
              <div class="faqp-item" role="listitem" data-q={faq.q.toLowerCase()} data-cat={cat.id}>
                <button class="faqp-q" aria-expanded="false">
                  <span class="faqp-q-text">{faq.q}</span>
                  <span class="faqp-q-icon" aria-hidden="true">
                    <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
                      <path class="faqp-plus-h" d="M4 10h12" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                      <path class="faqp-plus-v" d="M10 4v12" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                    </svg>
                  </span>
                </button>
                <div class="faqp-a" aria-hidden="true">
                  <div class="faqp-a-inner">{faq.a}</div>
                </div>
              </div>
            ))}
          </div>
        ))}
      </div>

    </div>
  </section>

  <!-- ── Location FAQs ── -->
  <section class="faqp-loc" id="faqp-loc" aria-label="FAQ by location">
    <div class="faqp-loc-inner">
      <div class="faqp-loc-head">
        <div class="faqp-loc-eyebrow">By Location</div>
        <h2 class="faqp-loc-h2">Serving 19 Chicagoland Communities</h2>
        <p class="faqp-loc-sub">Questions specific to your area — historic districts, terrain, local building codes, and common project types.</p>
      </div>

      <div class="faqp-city-grid" id="faqp-city-grid">
        {locations.map((loc) => (
          <button
            class="faqp-city-btn"
            data-city={loc.slug}
            aria-expanded="false"
          >
            {loc.city}
            <svg class="faqp-city-arrow" width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
              <path d="M3 5l3 3 3-3" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        ))}
      </div>

      <!-- Location FAQ expanded panels -->
      {locations.map((loc) => (
        <div class="faqp-loc-panel" id={`faqp-loc-${loc.slug}`} data-city={loc.slug} hidden>
          <div class="faqp-loc-panel-head">
            <h3 class="faqp-loc-panel-city">{loc.city}</h3>
            <button class="faqp-loc-close" data-city={loc.slug} aria-label={`Close ${loc.city} FAQ`}>
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8">
                <path d="M2 2l12 12M14 2L2 14"/>
              </svg>
            </button>
          </div>
          {loc.faqs.map((faq) => (
            <div class="faqp-loc-item">
              <button class="faqp-q faqp-loc-q" aria-expanded="false">
                <span class="faqp-q-text">{faq.q}</span>
                <span class="faqp-q-icon" aria-hidden="true">
                  <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
                    <path class="faqp-plus-h" d="M4 10h12" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                    <path class="faqp-plus-v" d="M10 4v12" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                  </svg>
                </span>
              </button>
              <div class="faqp-a faqp-loc-a" aria-hidden="true">
                <div class="faqp-a-inner">{faq.a}</div>
              </div>
            </div>
          ))}
        </div>
      ))}

    </div>
  </section>

  <!-- ── CTA ── -->
  <section class="faqp-cta" aria-label="Contact CTA">
    <div class="faqp-cta-inner">
      <div class="faqp-cta-eyebrow">Still Have Questions?</div>
      <h2 class="faqp-cta-h2">Get a Free On-Site Assessment</h2>
      <p class="faqp-cta-sub">We assess all visible masonry and provide a written report with photos and a line-item estimate. No obligation, no sales pressure.</p>
      <div class="faqp-cta-actions">
        <a href="/contact#form" class="faqp-cta-btn-primary">
          Schedule Free Estimate
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <a href="tel:7736562107" class="faqp-cta-btn-ghost">Call 773-656-2107</a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<style>
/* ── Global Reset ── */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

/* ── Hero ── */
.faqp-hero {
  background: #16120F;
  padding: 120px 0 100px;
  position: relative;
  overflow: hidden;
}
.faqp-hero::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse 60% 50% at 80% 50%, rgba(184,92,56,0.07) 0%, transparent 70%),
    radial-gradient(ellipse 40% 60% at 20% 30%, rgba(184,92,56,0.04) 0%, transparent 60%);
  pointer-events: none;
}
.faqp-hero-inner {
  max-width: 780px;
  margin: 0 auto;
  padding: 0 40px;
