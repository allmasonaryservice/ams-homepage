---
import Layout from '../layouts/Layout.astro';
import DynamicCityMask from '../components/DynamicCityMask.astro';

const cities = [
  "Winnetka", "Wilmette", "Kenilworth", "Glencoe", "Evanston",
  "Highland Park", "Northbrook", "Hinsdale", "Oak Brook",
  "Elmhurst", "Western Springs", "Naperville", "Downers Grove",
  "La Grange", "Burr Ridge", "Clarendon Hills", "Willowbrook",
  "Wheaton", "Chicago"
];
---

<Layout title="19 City Masking Demo | AMS">
  <section style="background:#050505; min-height:100vh; padding:80px 40px;">

    <div style="text-align:center; margin-bottom:80px;">
      <span style="display:inline-block; padding:4px 16px; background:rgba(184,92,56,0.1); border:1px solid rgba(184,92,56,0.3); color:#B85C38; font-family:'Inter',sans-serif; font-size:11px; font-weight:700; letter-spacing:0.3em; text-transform:uppercase; border-radius:4px; margin-bottom:16px;">
        SERVICE AREAS
      </span>
      <h1 style="font-family:'Onest',sans-serif; color:#ffffff; font-size:clamp(48px,6vw,72px); font-weight:700; letter-spacing:-0.02em; margin:0 0 16px;">19 Locations</h1>
      <p style="font-family:'Inter',sans-serif; color:rgba(255,255,255,0.5); font-size:15px; max-width:560px; margin:0 auto;">City boundary shapes masked over masonry imagery — each outline represents an AMS service area.</p>
    </div>

    <div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(320px, 1fr)); gap:60px; max-width:1400px; margin:0 auto;">
      {cities.map((city) => (
        <div style="display:flex; flex-direction:column; align-items:center; gap:16px;">
          <DynamicCityMask city={city} size={320} />
          <div style="text-align:center;">
            <p style="font-family:'Onest',sans-serif; color:rgba(255,255,255,0.9); font-size:22px; font-weight:700; letter-spacing:0.05em; text-transform:uppercase; margin:0 0 4px;">{city}</p>
            <p style="font-family:'Inter',sans-serif; color:#B85C38; font-size:11px; font-weight:700; letter-spacing:0.2em; text-transform:uppercase; margin:0;">Illinois</p>
          </div>
        </div>
      ))}
    </div>

  </section>
</Layout>
