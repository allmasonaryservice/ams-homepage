---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import DynamicCityMask from '../../components/DynamicCityMask.astro';
import Testimonials from '../../components/Testimonials.astro';
import Projects from '../../components/Projects.astro';

const toSlug = (name: string) => name.toLowerCase().replace(/\s+/g, '-');
const allCityNames = ["Winnetka","Wilmette","Kenilworth","Glencoe","Evanston","Highland Park","Northbrook","Hinsdale","Oak Brook","Elmhurst","Western Springs","Naperville","Downers Grove","La Grange","Burr Ridge","Clarendon Hills","Willowbrook","Wheaton","Chicago"];

const city = {
  "slug": "wilmette",
  "name": "Wilmette",
  "county": "Cook County",
  "region": "North Shore",
  "metaTitle": "Custom Masonry Construction Wilmette IL | Builders & Contractors",
  "metaDesc": "Specializing in new custom home masonry, brick, stone, and structural block construction in Wilmette, IL. In-house crew, no subcontractors.",
  "heroSub": "Building legacies in brick and stone. We execute complex blueprints with meticulous craftsmanship, ensuring structural integrity that lasts generations.",
  "heroReview": {
    "quote": "We are custom home builders and AMS is our go-to masonry partner. They never cut corners on flashing or structural block work.",
    "author": "Michael T.",
    "location": "Wilmette, IL"
  },
  "problem": "Building a luxury home requires precision. Using unverified subcontractors often leads to out-of-plumb walls and mismatched veneers. Once the mortar cures, the only way to fix it is a total, expensive demolition.",
  "faqItems": [
    {
      "question": "How do you coordinate with our General Contractor?",
      "answer": "We work directly with your GC to ensure seamless scheduling, site safety, and perfect integration with framing and other critical trades."
    },
    {
      "question": "Do you install natural stone and limestone?",
      "answer": "Yes, we specialize in high-end natural stone veneers, custom limestone detailing, and premium brick installations for luxury estates."
    },
    {
      "question": "Do you use subcontractors for large masonry projects?",
      "answer": "Never. All our work is performed by our highly trained, in-house master masons to guarantee flawless construction quality."
    },
    {
      "question": "Do you also do masonry restoration?",
      "answer": "While we are primarily builders, we also provide expert restoration for historic and high-value properties requiring structural rebuilding."
    },
    {
      "question": "Can you read and execute complex architectural blueprints?",
      "answer": "Absolutely. We routinely build intricate arches, custom stone facades, and load-bearing CMU structures exactly to architectural specifications."
    }
  ],
  "nearbyAreas": [
    "Evanston",
    "Highland Park",
    "Wheaton",
    "Naperville",
    "Glencoe"
  ],
  "details": {
    "areas": "Central Wilmette, Linden Square, Mallinckrodt Park area",
    "zipCodes": "60091"
  }
};
const cityIndex = 1;
const siteUrl = 'https://allmasonryservices.com';
const pageUrl = `${siteUrl}/locations/${city.slug}`;



const services = [
  { name: 'Brick Installation',       href: '/services/brick-installation',         icon: 'M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z' },
  { name: 'Tuckpointing & Repointing',href: '/services/tuckpointing-repointing',    icon: 'M14.5 10c-.83 0-1.5-.67-1.5-1.5v-5c0-.83.67-1.5 1.5-1.5s1.5.67 1.5 1.5v5c0 .83-.67 1.5-1.5 1.5z M20.5 10H19V8.5c0-.83.67-1.5 1.5-1.5s1.5.67 1.5 1.5-.67 1.5-1.5 1.5z M9.5 14c.83 0 1.5.67 1.5 1.5v5c0 .83-.67 1.5-1.5 1.5S8 21.33 8 20.5v-5c0-.83.67-1.5 1.5-1.5z M3.5 14H5v1.5c0 .83-.67 1.5-1.5 1.5S2 16.33 2 15.5 2.67 14 3.5 14z M14 14.5c0-.83.67-1.5 1.5-1.5h5c.83 0 1.5.67 1.5 1.5s-.67 1.5-1.5 1.5h-5c-.83 0-1.5-.67-1.5-1.5z M3 9.5C3 8.67 3.67 8 4.5 8h5c.83 0 1.5.67 1.5 1.5S10.33 11 9.5 11h-5C3.67 11 3 10.33 3 9.5z' },
  { name: 'Chimney Repair',            href: '/services/chimney-repair-rebuilding',  icon: 'M5 22V12l7-7 7 7v10M9 22V12h6v10' },
  { name: 'Chimney & Fireplace',       href: '/services/chimney-fireplace',          icon: 'M18 8h1a4 4 0 0 1 0 8h-1 M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z M6 1v3 M10 1v3 M14 1v3' },
  { name: 'CMU Block',                 href: '/services/cmu-block-installation',     icon: 'M2 20h20M4 20V6l8-4 8 4v14' },
  { name: 'Commercial Brick & Stone',  href: '/services/commercial-brick-stone',     icon: 'M3 21h18M3 7v1a3 3 0 0 0 6 0V7m0 1a3 3 0 0 0 6 0V7m0 1a3 3 0 0 0 6 0V7H3l2-4h14l2 4' },
  { name: 'Brick & Stone Veneers',     href: '/services/brick-stone-veneers',        icon: 'M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5' },
  { name: 'Custom Home Masonry',       href: '/services/custom-home-masonry',        icon: 'M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2zM9 22V12h6v10' },
  { name: 'Commercial Veneers',        href: '/services/commercial-masonry-veneers', icon: 'M6 2v20M18 2v20M2 12h20M2 7h4m12 0h4M2 17h4m12 0h4' },
  { name: 'Damaged Brick Replacement', href: '/services/damaged-brick-replacement',  icon: 'M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z' },
  { name: 'Natural Stone & Limestone', href: '/services/natural-stone-limestone',    icon: 'M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z' },
];
---

<Layout
  title={city.metaTitle}
  description={city.metaDesc}
>
  <!-- LocalBusiness Schema -->
  <script is:inline type="application/ld+json">{JSON.stringify({
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": "All Masonry Services",
    "url": siteUrl,
    "telephone": "+17736562107",
    "address": { "@type": "PostalAddress", "addressLocality": city.name, "addressRegion": "IL", "addressCountry": "US" },
    "areaServed": city.name + ", IL",
    "description": city.metaDesc,
    "priceRange": "$$",
    "aggregateRating": { "@type": "AggregateRating", "ratingValue": "4.8", "reviewCount": "92" }
  })}</script>

  <!-- FAQ Schema -->
  <script is:inline type="application/ld+json">{JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": city.faqItems.map(item => ({
      "@type": "Question",
      "name": item.question,
      "acceptedAnswer": { "@type": "Answer", "text": item.answer }
    }))
  })}</script>

  <Navbar />

  <!-- ─── 1. HERO ─── -->
  <section class="cp-hero" aria-label={`Masonry services in ${city.name}, IL`}>
    <div class="cp-hero-bg" aria-hidden="true"></div>
    <div class="cp-hero-grain" aria-hidden="true"></div>

    <div class="cp-hero-inner">
      <!-- LEFT: text -->
      <div class="cp-hero-left" id="cp-hero-left">
        <div class="cp-hero-label" id="cp-label">
          <span class="cp-label-line" aria-hidden="true"></span>
          All Masonry Services · {city.name}, IL
        </div>

        <h1 class="cp-h1" id="cp-h1">
          <span class="cp-h1-row"><span class="cp-h1-inner" id="cp-r1">Luxury Home Masonry</span></span>
          <span class="cp-h1-row cp-h1-row--city"><span class="cp-h1-inner cp-h1-city" id="cp-r2">in {city.name}</span></span>
        </h1>

        <p class="cp-sub" id="cp-sub">{city.heroSub}</p>

        <div class="cp-actions" id="cp-act">
          <a href="/contact#form" class="cp-btn cp-btn--primary">
            <span class="cp-btn-bg" aria-hidden="true"></span>
            <span class="cp-btn-label">Get a Free Estimate</span>
            <svg width="13" height="13" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <a href="tel:7736562107" class="cp-btn cp-btn--ghost">
            <span class="cp-btn-bg" aria-hidden="true"></span>
            <span class="cp-btn-label">Call 773-656-2107</span>
          </a>
        </div>

        <div class="cp-badges" id="cp-bdg">
          <div class="cp-badge"><strong>500+</strong><span>Homes Served</span></div>
          <div class="cp-badge-sep" aria-hidden="true"></div>
          <div class="cp-badge"><strong>4.8★</strong><span>92 Reviews</span></div>
          <div class="cp-badge-sep" aria-hidden="true"></div>
          <div class="cp-badge"><strong>19+</strong><span>Years Experience</span></div>
        </div>
      </div>

      <!-- RIGHT: city shape mask -->
      <div class="cp-hero-right" id="cp-hero-right" aria-hidden="true">
        <DynamicCityMask city={city.name} size={520} />
      </div>
    </div>

    <!-- scroll cue -->
    <div class="cp-scroll" id="cp-scroll">
      <div class="cp-scroll-mouse"><div class="cp-scroll-dot"></div></div>
      <span>Scroll</span>
    </div>
  </section>

  <script is:inline>
  (function() {
    function initCpHero() {
      var gsap = window.__gsap;
      if (!gsap) return;
      var label = document.getElementById('cp-label');
      var r1    = document.getElementById('cp-r1');
      var r2    = document.getElementById('cp-r2');
      var sub   = document.getElementById('cp-sub');
      var act   = document.getElementById('cp-act');
      var bdg   = document.getElementById('cp-bdg');
      var right = document.getElementById('cp-hero-right');
      if (!r1) return;
      var tl = gsap.timeline({ defaults: { ease: 'power3.out' } });
      tl.from(label, { opacity: 0, y: 14, duration: 0.6 }, 0)
        .from(r1,    { yPercent: 110, duration: 0.75 }, 0.1)
        .from(r2,    { yPercent: 110, duration: 0.75 }, 0.18)
        .from(sub,   { opacity: 0, y: 16, duration: 0.7 }, 0.45)
        .from(act,   { opacity: 0, y: 14, duration: 0.6 }, 0.6)
        .from(bdg,   { opacity: 0, y: 10, duration: 0.5 }, 0.72)
        .from(right, { opacity: 0, x: 40, duration: 1.0, ease: 'power2.out' }, 0.2);
    }
    if (window.__gsap) { initCpHero(); }
    else { window.addEventListener('animations:ready', initCpHero, { once: true }); }

    var scroll = document.getElementById('cp-scroll');
    if (scroll) {
      scroll.addEventListener('click', function() {
        var next = document.querySelector('.sp-trust');
        if (next) next.scrollIntoView({ behavior: 'smooth' });
        else window.scrollTo({ top: window.innerHeight, behavior: 'smooth' });
      });
    }
  })();
  </script>

  <!-- ─── 2. TRUST BAR ─── -->
  <section class="sp-trust">
    <div class="sp-trust-inner">
      <div class="sp-trust-item">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        Licensed &amp; Insured in Illinois
      </div>
      <div class="sp-trust-sep"></div>
      <div class="sp-trust-item">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        Free On-Site Estimates
      </div>
      <div class="sp-trust-sep"></div>
      <div class="sp-trust-item">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        Workers' Comp Covered
      </div>
      <div class="sp-trust-sep"></div>
      <div class="sp-trust-item">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        Structural Integrity Guaranteed
      </div>
    </div>
  </section>

  <!-- ─── 2b. LOCAL CONTEXT ─── -->
  <section class="cp-ctx">
    <div class="cp-ctx-inner">

      <!-- Header -->
      <div class="cp-ctx-hdr">
        <div class="cp-section-label">{city.name} Masonry</div>
        <h2 class="cp-ctx-h2">Building Custom Masonry<br>in Wilmette</h2>
        <p class="cp-ctx-sub">Constructing luxury homes requires an elite understanding of structural engineering, premium materials, and flawless architectural execution. We partner with top builders to construct masterworks.</p>
      </div>

      <div class="cp-ctx-cols">

        <!-- LEFT: dark Service Details sidebar -->
        <aside class="cp-ctx-sidebar" aria-label="Service details">
          <p class="cp-ctx-sidebar-label">Service Details</p>
          <div class="cp-ctx-rows">
            <div class="cp-ctx-row">
              <span class="cp-ctx-row-key">Areas Served</span>
              <span class="cp-ctx-row-val">{city.details.areas}</span>
            </div>
            <div class="cp-ctx-row">
              <span class="cp-ctx-row-key">Zip Codes</span>
              <span class="cp-ctx-row-val">{city.details.zipCodes}</span>
            </div>
            <div class="cp-ctx-row">
              <span class="cp-ctx-row-key">County</span>
              <span class="cp-ctx-row-val">{city.county}</span>
            </div>
            <div class="cp-ctx-row">
              <span class="cp-ctx-row-key">Hours</span>
              <span class="cp-ctx-row-val">Mon–Sat 7am–6pm</span>
            </div>
            <div class="cp-ctx-row">
              <span class="cp-ctx-row-key">Free Estimate</span>
              <span class="cp-ctx-row-val cp-ctx-row-val--yes">Yes</span>
            </div>
            <div class="cp-ctx-row">
              <span class="cp-ctx-row-key">Licensed &amp; Insured</span>
              <span class="cp-ctx-row-val cp-ctx-row-val--yes">Yes</span>
            </div>
            <div class="cp-ctx-row">
              <span class="cp-ctx-row-key">Phone</span>
              <span class="cp-ctx-row-val"><a href="tel:7736562107" class="cp-ctx-phone">773-656-2107</a></span>
            </div>
          </div>
          <a href="/contact#form" class="cp-ctx-sidebar-cta">
            Get a free {city.name} estimate
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M2.5 7H11.5M8 3.5L11.5 7L8 10.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </aside>

        <!-- RIGHT: content items -->
        <div class="cp-ctx-list">

          <div class="cp-ctx-rule"></div>

          <div class="cp-ctx-item">
            <div class="cp-ctx-item-head">
              <div class="cp-ctx-icon-wrap">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#B85C38" stroke-width="1.8" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              </div>
              <h3 class="cp-ctx-title">Elite Construction in Wilmette</h3>
            </div>
            <p class="cp-ctx-text">{city.heroSub}</p>
          </div>

          <div class="cp-ctx-rule"></div>

          <div class="cp-ctx-item">
            <div class="cp-ctx-item-head">
              <div class="cp-ctx-icon-wrap">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#B85C38" stroke-width="1.8" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
              </div>
              <h3 class="cp-ctx-title">The Risk of Unqualified Crews</h3>
            </div>
            <p class="cp-ctx-text">{city.problem}</p>
          </div>

          <div class="cp-ctx-rule"></div>

        </div>

      </div>
    </div>
  </section>

  <script is:inline>
  (function() {
    function initCtxAnim() {
      var gsap = window.__gsap;
      var ScrollTrigger = window.__ScrollTrigger;
      if (!gsap || !ScrollTrigger) return;
      if (window.innerWidth <= 900) return;
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
      var section = document.querySelector('.cp-ctx');
      if (!section) return;
      var label   = section.querySelector('.cp-section-label');
      var h2      = section.querySelector('.cp-ctx-h2');
      var sub     = section.querySelector('.cp-ctx-sub');
      var sidebar = section.querySelector('.cp-ctx-sidebar');
      var items   = Array.from(section.querySelectorAll('.cp-ctx-item'));
      var rules   = Array.from(section.querySelectorAll('.cp-ctx-rule'));

      gsap.set([label, h2, sub].filter(Boolean), { opacity: 0, y: 24 });
      if (sidebar) gsap.set(sidebar, { opacity: 0, x: -32 });
      gsap.set(rules, { scaleX: 0, transformOrigin: 'left center' });
      gsap.set(items, { opacity: 0, y: 28 });

      ScrollTrigger.create({
        trigger: section,
        start: 'top 78%',
        onEnter: function() {
          gsap.to([label, h2, sub].filter(Boolean), { opacity: 1, y: 0, duration: 0.65, ease: 'power2.out', stagger: 0.12, overwrite: true });
        },
        onLeaveBack: function() {
          gsap.set([label, h2, sub].filter(Boolean), { opacity: 0, y: 24 });
        }
      });

      if (sidebar) {
        ScrollTrigger.create({
          trigger: '.cp-ctx-cols',
          start: 'top 82%',
          onEnter: function() {
            gsap.to(sidebar, { opacity: 1, x: 0, duration: 0.7, ease: 'power2.out', overwrite: true });
          },
          onLeaveBack: function() {
            gsap.set(sidebar, { opacity: 0, x: -32 });
          }
        });
      }

      items.forEach(function(item, i) {
        var prevRule = rules[i];
        ScrollTrigger.create({
          trigger: item,
          start: 'top 88%',
          onEnter: function() {
            if (prevRule) gsap.to(prevRule, { scaleX: 1, duration: 0.5, ease: 'power2.out', overwrite: true });
            gsap.to(item, { opacity: 1, y: 0, duration: 0.6, ease: 'power2.out', delay: 0.15, overwrite: true });
          },
          onLeaveBack: function() {
            if (prevRule) gsap.set(prevRule, { scaleX: 0 });
            gsap.set(item, { opacity: 0, y: 28 });
          }
        });
      });

      var lastRule = rules[rules.length - 1];
      if (lastRule) {
        ScrollTrigger.create({
          trigger: lastRule,
          start: 'top 92%',
          onEnter: function() { gsap.to(lastRule, { scaleX: 1, duration: 0.5, ease: 'power2.out', overwrite: true }); },
          onLeaveBack: function() { gsap.set(lastRule, { scaleX: 0 }); }
        });
      }
    }
    window.__cpCtxAnimReady = initCtxAnim;
    window.addEventListener('animations:ready', window.__cpCtxAnimReady);
    document.addEventListener('astro:page-load', initCtxAnim);
  })();
  </script>

  <!-- ─── 3. SERVICES IN [CITY] ─── -->
  <section class="cp-svc">
    <div class="cp-svc-inner">
      <div class="cp-section-label">What We Do in {city.name}</div>
      <h2 class="cp-section-h2">
        All Masonry Services<br>
        <em>Available in {city.name}, IL</em>
      </h2>
      <p class="cp-svc-sub">Our expertise lies in construction. We build grand chimneys, luxurious fireplaces, and flawless brick exteriors. We control the quality by keeping every artisan in-house—no handoffs, no middle-men.</p>

      <div class="cp-svc-grid">
        {services.map(svc => (
          <a href={svc.href} class="cp-svc-card">
            <div class="cp-svc-icon" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#B85C38" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d={svc.icon} />
              </svg>
            </div>
            <span class="cp-svc-name">{svc.name}</span>
            <svg class="cp-svc-arrow" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M2 7h10M8 3l4 4-4 4" stroke="#B85C38" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── 4. HOW WE WORK ─── -->
  <section id="sp-prc-section" style="background:#ffffff; position:relative;">
    <div id="sp-prc-driver" style="position:relative; height:600vh;">
      <div id="sp-prc-sticky" style="position:sticky; top:0; height:100vh; display:flex; align-items:center; overflow:hidden;">
        <div class="sp-prc-grid">

          <div id="sp-prc-left">
            <div style="display:flex; align-items:center; gap:8px; margin-bottom:20px;">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <rect x="1" y="1" width="5" height="5" rx="1" fill="#B85C38"/>
                <rect x="8" y="1" width="5" height="5" rx="1" fill="#B85C38" opacity="0.4"/>
                <rect x="1" y="8" width="5" height="5" rx="1" fill="#B85C38" opacity="0.4"/>
                <rect x="8" y="8" width="5" height="5" rx="1" fill="#B85C38"/>
              </svg>
              <span style="font-family:'Inter',sans-serif; font-size:11px; font-weight:700; letter-spacing:0.10em; color:#B85C38; text-transform:uppercase;">How We Work</span>
            </div>
            <h2 style="font-family:'Onest',sans-serif; font-size:clamp(36px,3.5vw,54px); font-weight:700; line-height:1.1; color:#16120F; letter-spacing:-0.02em; margin:0 0 20px;">Our Process in<br>{city.name}</h2>
            <p style="font-family:'Inter',sans-serif; font-size:16px; line-height:1.65; color:#6A625A; margin:0 0 36px;">No surprise crews. No hidden costs. You know exactly what happens at every step — and why.</p>
            <div class="sp-prc-desktop-cta">
              <a href="/contact#form"
                style="display:inline-flex; align-items:center; gap:8px; background:#B85C38; color:#fff; font-family:'Inter',sans-serif; font-size:15px; font-weight:500; padding:14px 26px; border-radius:12px; text-decoration:none; transition:background 0.2s;"
                onmouseenter="this.style.background='#8A3A22'"
                onmouseleave="this.style.background='#B85C38'">
                Get a free estimate
                <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                  <path d="M3 8h10M9 4l4 4-4 4" stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
